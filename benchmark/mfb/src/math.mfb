' Math-group benchmarks (math:: package). Split from main.mfb.
'
' Two kinds of coverage live here:
'   1. The individual libm-severed Float kernels (sin, cos, ... sqrt) — one row
'      each, the historical benchmark surface.
'   2. Consolidated "coverage" rows that exercise every remaining math:: member
'      across every relevant numeric type (Integer, Float, Fixed) plus the array
'      (SIMD) overloads, so the whole package surface is compiled and executed.
IMPORT io
IMPORT math
IMPORT collections
IMPORT datetime

' ===========================================================================
' GROUP: math (individual libm-severed Float kernels; 2000 x 1000 calls each)
' ===========================================================================

FUNC test_sin(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Float = 0.0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Float = 0.0
    FOR rep = 0 TO 1999
      MUT x AS Float = 0.001
      FOR i = 0 TO 999
        acc = acc + math::sin(x)
        x = x + 0.0015
      NEXT
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("sin = " & toString(checksum, toByte(6)))
  RETURN collections::append(tests, makeResult("math", "sin", times))
END FUNC

