' ===========================================================================
' GROUP: math coverage — every remaining member across each relevant type.
' ===========================================================================

' Float: abs, floor, ceil, round, min, max, clamp (the non-transcendental
' members not already covered by the kernels above).
FUNC test_math_float(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Float = 0.0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Float = 0.0
    FOR i = 0 TO 199999
      LET v AS Float = toFloat(i) * 0.5 - 50000.0
      acc = acc + math::abs(v)
      acc = acc + toFloat(math::floor(v * 0.001))
      acc = acc + toFloat(math::ceil(v * 0.001))
      acc = acc + toFloat(math::round(v * 0.001))
      acc = acc + math::min(v, 0.0)
      acc = acc + math::max(v, 0.0)
      acc = acc + math::clamp(v, -10.0, 10.0)
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("math_float = " & toString(checksum, toByte(3)))
  RETURN collections::append(tests, makeResult("math", "float", times))
END FUNC

' Integer: abs, min, max, clamp, and the PCG64 generator (seed + rand). The
' generator is seeded to a fixed value so the checksum is reproducible.
FUNC test_math_int(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Integer = 0
    math::seed(123456789)
    FOR i = 0 TO 199999
      LET v AS Integer = i - 100000
      acc = acc + math::abs(v)
      acc = acc + math::min(v, 0)
      acc = acc + math::max(v, 0)
      acc = acc + math::clamp(v, -10, 10)
      acc = acc + math::rand(0, 100)
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("math_int = " & toString(checksum))
  RETURN collections::append(tests, makeResult("math", "int", times))
END FUNC

' Fixed: the whole deterministic Q32.32 surface — abs, floor, ceil, round, min,
' max, clamp, sqrt, pow, exp, log, log10, sin, cos, tan, asin, acos, atan,
' atan2. Arguments are kept inside each function's real domain.
FUNC test_math_fixed(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  LET fxNegHalf AS Fixed = -0.5
  LET fxHalf AS Fixed = 0.5
  LET fxOneHalf AS Fixed = 1.5
  MUT times AS List OF Integer = []
  MUT checksum AS Fixed = 0.0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Fixed = 0.0
    FOR i = 0 TO 19999
      LET fi AS Fixed = toFixed(i)
      LET pos AS Fixed = 0.5 + fi * 0.00005      ' 0.5 .. 1.5, always positive
      LET unit AS Fixed = -0.9 + fi * 0.00009    ' -0.9 .. 0.9, within [-1, 1]
      acc = acc + math::abs(unit)
      acc = acc + math::floor(pos)
      acc = acc + math::ceil(pos)
      acc = acc + math::round(pos)
      acc = acc + math::min(pos, unit)
      acc = acc + math::max(pos, unit)
      acc = acc + math::clamp(unit, fxNegHalf, fxHalf)
      acc = acc + math::sqrt(pos)
      acc = acc + math::pow(pos, fxOneHalf)
      acc = acc + math::exp(unit)
      acc = acc + math::log(pos)
      acc = acc + math::log10(pos)
      acc = acc + math::sin(unit)
      acc = acc + math::cos(unit)
      acc = acc + math::tan(unit)
      acc = acc + math::asin(unit)
      acc = acc + math::acos(unit)
      acc = acc + math::atan(unit)
      acc = acc + math::atan2(unit, pos)
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("math_fixed = " & toString(checksum, toByte(6)))
  RETURN collections::append(tests, makeResult("math", "fixed", times))
END FUNC

' Build a List OF Float of length n with values in (lo, hi].
FUNC mathRangeFloat(n AS Integer, lo AS Float, span AS Float) AS List OF Float
  MUT xs AS List OF Float = []
  FOR i = 0 TO n - 1
    xs = collections::append(xs, lo + toFloat(i) / toFloat(n) * span)
  NEXT
  RETURN xs
END FUNC

' Array (SIMD) overloads: every math:: member that has a Float[] overload,
' driven element-wise over freshly built lists and folded with collections::sum.
FUNC test_math_simd(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  LET unit AS List OF Float = mathRangeFloat(1024, -0.9, 1.8)      ' [-0.9, 0.9]
  LET pos AS List OF Float = mathRangeFloat(1024, 0.01, 4.0)       ' (0, ~4]
  LET big AS List OF Float = mathRangeFloat(1024, -1000.0, 2000.0)
  LET expo AS List OF Float = mathRangeFloat(1024, -2.0, 4.0)
  LET lo AS List OF Float = mathRangeFloat(1024, -5.0, 10.0)
  MUT times AS List OF Integer = []
  MUT checksum AS Float = 0.0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Float = 0.0
    FOR rep = 0 TO 199
      acc = acc + collections::sum(math::abs(big))
      acc = acc + toFloat(collections::sum(math::floor(pos)))
      acc = acc + toFloat(collections::sum(math::ceil(pos)))
      acc = acc + toFloat(collections::sum(math::round(pos)))
      acc = acc + collections::sum(math::min(big, lo))
      acc = acc + collections::sum(math::max(big, lo))
      acc = acc + collections::sum(math::clamp(big, -1.0, 1.0))
      acc = acc + collections::sum(math::sqrt(pos))
      acc = acc + collections::sum(math::log(pos))
      acc = acc + collections::sum(math::log10(pos))
      acc = acc + collections::sum(math::exp(expo))
      acc = acc + collections::sum(math::sin(unit))
      acc = acc + collections::sum(math::cos(unit))
      acc = acc + collections::sum(math::tan(unit))
      acc = acc + collections::sum(math::atan(unit))
      acc = acc + collections::sum(math::asin(unit))
      acc = acc + collections::sum(math::acos(unit))
      acc = acc + collections::sum(math::pow(pos, expo))
      acc = acc + collections::sum(math::atan2(unit, pos))
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("math_simd = " & toString(checksum, toByte(3)))
  RETURN collections::append(tests, makeResult("math", "simd", times))
END FUNC
