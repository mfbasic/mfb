FUNC test_list_removeAt(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  LET base AS List OF Integer = buildRange(1000)
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT nums AS List OF Integer = base
    MUT cnt AS Integer = 0
    WHILE len(nums) > 0
      nums = collections::removeAt(nums, 0)
      cnt = cnt + 1
    END WHILE
    checksum = cnt
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_removeAt = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "removeAt", times))
END FUNC

