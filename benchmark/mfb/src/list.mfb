TYPE CopyRec
  n AS Integer
  s AS String
END TYPE

FUNC copyStrings(xs AS List OF String) AS List OF String
  RETURN xs
END FUNC

FUNC copyRecs(xs AS List OF CopyRec) AS List OF CopyRec
  RETURN xs
END FUNC

FUNC test_list_copy(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT strs AS List OF String = []
  MUT recs AS List OF CopyRec = []
  FOR i = 0 TO 999
    strs = collections::append(strs, toString(i))
    recs = collections::append(recs, CopyRec[i, toString(i)])
  NEXT
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Integer = 0
    FOR i = 0 TO 999
      LET c AS List OF String = copyStrings(strs)
      acc = acc + len(c)
    NEXT
    FOR i = 0 TO 999
      LET cr AS List OF CopyRec = copyRecs(recs)
      acc = acc + len(cr)
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_copy = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "copy", times))
END FUNC

FUNC test_list_distinct(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    MUT nums AS List OF Integer = []
    FOR i = 0 TO 4999
      nums = collections::append(nums, i - (i / 1000) * 1000)
    NEXT
    LET t0 AS Integer = datetime::monotonicNanos()
    LET unique AS List OF Integer = collections::distinct(nums)
    LET t1 AS Integer = datetime::monotonicNanos()
    checksum = len(unique)
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_distinct = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "distinct", times))
END FUNC

FUNC bucketKey(n AS Integer) AS Integer
  RETURN n - (n / 100) * 100
END FUNC

FUNC identity(n AS Integer) AS Integer
  RETURN n
END FUNC

FUNC test_list_groupby(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    MUT nums AS List OF Integer = []
    FOR i = 0 TO 1999
      nums = collections::append(nums, i)
    NEXT
    LET t0 AS Integer = datetime::monotonicNanos()
    LET groups AS Map OF Integer TO List OF Integer = collections::groupBy(nums, bucketKey, identity)
    LET t1 AS Integer = datetime::monotonicNanos()
    checksum = len(groups)
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_groupby = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "groupby", times))
END FUNC

FUNC test_list_set(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    MUT nums AS List OF Integer = []
    FOR i = 0 TO 199
      nums = collections::append(nums, i)
    NEXT
    LET t0 AS Integer = datetime::monotonicNanos()
    FOR pass = 0 TO 9
      FOR j = 0 TO 199
        LET v AS Integer = collections::get(nums, j)
        nums = collections::set(nums, j, v + 1)
      NEXT
    NEXT
    LET t1 AS Integer = datetime::monotonicNanos()
    MUT sumv AS Integer = 0
    FOR j = 0 TO 199
      sumv = sumv + collections::get(nums, j)
    NEXT
    checksum = sumv
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_set = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "set", times))
END FUNC

FUNC test_list_sort(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    MUT base AS List OF Integer = []
    FOR i = 0 TO 49
      base = collections::append(base, math::rand(0, 1000000))
    NEXT
    LET t0 AS Integer = datetime::monotonicNanos()
    LET sorted AS List OF Integer = collections::sort(base)
    LET t1 AS Integer = datetime::monotonicNanos()
    checksum = collections::get(sorted, 0)
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_sort = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "sort", times))
END FUNC

' --- shared helpers + predicates for the remaining collections:: list ops ---

MUT forEachAcc AS Integer = 0

FUNC buildRange(n AS Integer) AS List OF Integer
  MUT xs AS List OF Integer = []
  FOR i = 0 TO n - 1
    xs = collections::append(xs, i)
  NEXT
  RETURN xs
END FUNC

FUNC buildPos(n AS Integer) AS List OF Integer
  MUT xs AS List OF Integer = []
  FOR i = 1 TO n
    xs = collections::append(xs, i)
  NEXT
  RETURN xs
END FUNC

FUNC buildNeg(n AS Integer) AS List OF Integer
  MUT xs AS List OF Integer = []
  FOR i = 1 TO n
    xs = collections::append(xs, 0 - i)
  NEXT
  RETURN xs
END FUNC

FUNC buildNested(outer AS Integer, inner AS Integer) AS List OF List OF Integer
  LET row AS List OF Integer = buildRange(inner)
  MUT xs AS List OF List OF Integer = []
  FOR i = 0 TO outer - 1
    xs = collections::append(xs, row)
  NEXT
  RETURN xs
END FUNC

FUNC isPos(n AS Integer) AS Boolean
  RETURN n > 0
END FUNC

FUNC isEvenN(n AS Integer) AS Boolean
  RETURN n - (n / 2) * 2 = 0
END FUNC

FUNC ge999(n AS Integer) AS Boolean
  RETURN n >= 999
END FUNC

FUNC le5(n AS Integer) AS Boolean
  RETURN n <= 5
END FUNC

FUNC addFn(acc AS Integer, n AS Integer) AS Integer
  RETURN acc + n
END FUNC

FUNC doubleFn(n AS Integer) AS Integer
  RETURN n + n
END FUNC

FUNC keyNeg(n AS Integer) AS Integer
  RETURN 0 - n
END FUNC

SUB bumpAcc(n AS Integer)
  forEachAcc = forEachAcc + n
END SUB

FUNC test_list_all(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  LET pos AS List OF Integer = buildPos(1000)
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Integer = 0
    FOR k = 0 TO 199
      IF collections::all(pos, isPos) THEN
        acc = acc + 1
      END IF
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_all = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "all", times))
END FUNC

FUNC test_list_any(run AS Integer, tests AS List OF BenchResult) AS List OF BenchResult
  LET neg AS List OF Integer = buildNeg(1000)
  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    MUT acc AS Integer = 0
    FOR k = 0 TO 199
      IF NOT collections::any(neg, isPos) THEN
        acc = acc + 1
      END IF
    NEXT
    checksum = acc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_any = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "any", times))
END FUNC

