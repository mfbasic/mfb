  MUT times AS List OF Integer = []
  MUT checksum AS Integer = 0
  FOR r = 0 TO run - 1
    LET t0 AS Integer = datetime::monotonicNanos()
    forEachAcc = 0
    FOR k = 0 TO 199
      collections::forEach(base, bumpAcc)
    NEXT
    checksum = forEachAcc
    LET t1 AS Integer = datetime::monotonicNanos()
    times = collections::append(times, t1 - t0)
  NEXT
  io::printError("list_forEach = " & toString(checksum))
  RETURN collections::append(tests, makeResult("list", "forEach", times))
END FUNC

