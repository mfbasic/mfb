IMPORT io

' Approximates pi via the Leibniz series:
'   pi = 4 * sum_{k=0..N-1} (-1)^k / (2k+1)
' Accumulated as a Float with an alternating sign.

FUNC main AS Integer
  MUT sum AS Float = 0.0
  MUT sign AS Float = 1.0
  FOR k = 0 TO 999999
    LET denom AS Float = toFloat(2 * k + 1)
    sum = sum + sign / denom
    sign = sign * -1.0
  NEXT
  LET pi AS Float = 4.0 * sum
  io::print("pi: " & toString(pi, toByte(5)))
  RETURN 0
END FUNC
