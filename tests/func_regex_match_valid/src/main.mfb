IMPORT io
IMPORT regex

REM regex.md §17.1 worked examples plus dialect coverage. A backslash in a
REM pattern is written "\\" in MFBASIC source.

FUNC show(pattern AS String, value AS String) AS Nothing
  io::print(value & " ~ " & pattern & " = " & toString(regex::match(value, pattern)))
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  REM §17.1
  show("ell", "hello")
  show("^h", "hello")
  show("^e", "hello")
  show("\\d+", "abc123")
  show("\\d", "abc")
  show("caf\\x{E9}", "café")
  show("(?i)hello", "Hello")
  show("a*", "")
  show("^$", "x")
  show("^$", "")
  REM alternation, grouping, quantifiers
  show("ab|abc", "abcd")
  show("(ab)+", "abab")
  show("a{2,3}", "aaaa")
  show("colou?r", "color")
  REM classes, ranges, negation, shorthands
  show("[a-cm-p]", "n")
  show("[^0-9]", "x")
  show("[^0-9]", "7")
  show("\\w+", "_id9")
  show("\\s", "a b")
  show("[[:alpha:]]", "Q")
  REM unicode property classes
  show("\\p{L}", "Z")
  show("\\p{Nd}", "9")
  show("\\P{L}", "5")
  REM anchors and boundaries
  show("o$", "hello")
  show("\\bbar\\b", "foo bar")
  show("\\Ahi\\z", "hi")
  REM flags: multiline, dotall, verbose, case-insensitive class
  show("(?m)^cd", "ab\ncd")
  show("(?s)a.b", "a\nb")
  show("a.b", "a\nb")
  show("(?x) a b  # spaces ignored", "ab")
  show("(?i)[a-z]", "K")
  REM lazy quantifier still matches
  show("<.+?>", "<a><b>")
  RETURN 0
END FUNC
