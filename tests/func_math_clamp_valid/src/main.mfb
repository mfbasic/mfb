IMPORT io
IMPORT math

FUNC main AS Integer
  LET p AS Byte = 2
  LET fixedValue AS Fixed = 0 - toFixed("1.25")
  LET fixedLow AS Fixed = 0 - toFixed("1.0")
  LET fixedHigh AS Fixed = toFixed("1.0")
  io::print(toString(math::clamp(12, 0, 10)))
  io::print(toString(math::clamp(-3, 0, 10)))
  io::print(toString(math::clamp(5, 0, 10)))
  io::print(toString(math::clamp(3.50, 0.0, 3.0), p))
  io::print(toString(math::clamp(fixedValue, fixedLow, fixedHigh), p))
  io::print(toString(math::clamp(0.50, 0.0, 1.0), p))
  RETURN 0
END FUNC
