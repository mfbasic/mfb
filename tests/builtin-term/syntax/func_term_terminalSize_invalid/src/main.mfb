IMPORT term

FUNC resize(size AS TermSize) AS TermSize
  RETURN WITH size { columns := 80 }
END FUNC

FUNC constructLet AS TermSize
  LET a AS TermSize = TermSize[rows := 10, columns := 10]
  RETURN a
END FUNC

FUNC constructMut AS TermSize
  MUT b AS TermSize = TermSize[rows := 10, columns := 10]
  RETURN b
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC
