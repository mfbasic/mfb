IMPORT csv
IMPORT collections
IMPORT strings

' Consolidated runtime-behavior acceptance for the csv builtins, converted from
' the tests/func_csv_*_valid fixtures plus the parse-trap behavior that the
' func_csv_parse_invalid_runtime fixture proved via a TRAP handler. Each
' assertion compares the SAME expression as the source fixture against that
' fixture's exact golden value, using the typed TESTING assertions.

' Carriage return (U+000D). The lexer decodes the "\r" escape (plan-27), so a
' "\r" literal is a one-character CR string; kept as a helper for readability.
FUNC crChar AS String
  RETURN "\r"
END FUNC

' csv::parse is inline-lowered, so wrap it in a user FUNC to make it
' trap-guardable by expectTrap/expectNTrap.
FUNC parse(text AS String) AS List OF List OF String
  RETURN csv::parse(text)
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC

TESTING
  TGROUP "parse"
    TCASE "mixed: CRLF + LF separators, quoted comma cell, trailing newline"
      LET cr AS String = crChar()
      LET rows AS List OF List OF String = parse("name,age" & cr & "\nAda,36\nGrace,\"Hop,per\"\n")
      expectInteger(len(rows), 3)
      LET r0 AS List OF String = collections::get(rows, 0)
      expectInteger(len(r0), 2)
      expectString(collections::get(r0, 0), "name")
      expectString(collections::get(r0, 1), "age")
      LET r1 AS List OF String = collections::get(rows, 1)
      expectInteger(len(r1), 2)
      expectString(collections::get(r1, 0), "Ada")
      expectString(collections::get(r1, 1), "36")
      LET r2 AS List OF String = collections::get(rows, 2)
      expectInteger(len(r2), 2)
      expectString(collections::get(r2, 0), "Grace")
      expectString(collections::get(r2, 1), "Hop,per")
    END TCASE
    TCASE "quoted: embedded LF, embedded comma, doubled quote"
      LET rows AS List OF List OF String = parse("\"a\nb\",\"x,y\",\"he said \"\"hi\"\"\"")
      expectInteger(len(rows), 1)
      LET r0 AS List OF String = collections::get(rows, 0)
      expectInteger(len(r0), 3)
      expectString(collections::get(r0, 0), "a\nb")
      expectInteger(strings::byteLen(collections::get(r0, 0)), 3)
      expectString(collections::get(r0, 1), "x,y")
      expectString(collections::get(r0, 2), "he said \"hi\"")
      expectInteger(strings::byteLen(collections::get(r0, 2)), 12)
    END TCASE
    TCASE "empties: empty fields and a blank middle line"
      LET rows AS List OF List OF String = parse("a,,c\n\nz")
      expectInteger(len(rows), 3)
      LET r0 AS List OF String = collections::get(rows, 0)
      expectInteger(len(r0), 3)
      expectString(collections::get(r0, 0), "a")
      expectString(collections::get(r0, 1), "")
      expectString(collections::get(r0, 2), "c")
      LET r1 AS List OF String = collections::get(rows, 1)
      expectInteger(len(r1), 1)
      expectString(collections::get(r1, 0), "")
      LET r2 AS List OF String = collections::get(rows, 2)
      expectInteger(len(r2), 1)
      expectString(collections::get(r2, 0), "z")
    END TCASE
    TCASE "none: empty input parses to zero rows"
      LET rows AS List OF List OF String = parse("")
      expectInteger(len(rows), 0)
    END TCASE
    TCASE "invalid: malformed input traps"
      ' unterminated quote
      expectTrap(parse("\"abc"))
      ' closing quote followed by stray data
      expectTrap(parse("\"ab\"c"))
      ' a space after the closing quote is also stray data
      expectTrap(parse("\"ab\" "))
    END TCASE
    TCASE "valid: well-formed input does not trap"
      expectNTrap(parse("a,b,c\n1,2,3\n"))
    END TCASE
  END TGROUP

  TGROUP "stringify"
    TCASE "bare: fields needing no quoting are emitted bare"
      LET doc AS List OF List OF String = [["a", "b", "c"], ["1", "2", "3"]]
      expectString(csv::stringify(doc), "a,b,c\n1,2,3")
    END TCASE
    TCASE "comma: a comma forces quoting"
      LET doc AS List OF List OF String = [["has,comma", "plain"]]
      expectString(csv::stringify(doc), "\"has,comma\",plain")
    END TCASE
    TCASE "quote: a double quote forces quoting and is doubled inside"
      LET doc AS List OF List OF String = [["he said \"hi\"", "x"]]
      expectString(csv::stringify(doc), "\"he said \"\"hi\"\"\",x")
    END TCASE
    TCASE "newline: an embedded LF forces quoting and is preserved"
      LET doc AS List OF List OF String = [["line1\nline2", "y"]]
      expectString(csv::stringify(doc), "\"line1\nline2\",y")
    END TCASE
    TCASE "ragged: rows of differing width render as-is"
      LET doc AS List OF List OF String = [["one"], ["a", "b"], []]
      expectString(csv::stringify(doc), "one\na,b\n")
    END TCASE
    TCASE "empty: the empty document stringifies to the empty String"
      LET empty AS List OF List OF String = []
      expectString(csv::stringify(empty), "")
    END TCASE
    TCASE "round-trip: parsed mixed doc re-stringifies to normalized LF text"
      LET cr AS String = crChar()
      LET rows AS List OF List OF String = parse("name,age" & cr & "\nAda,36\nGrace,\"Hop,per\"\n")
      expectString(csv::stringify(rows), "name,age\nAda,36\nGrace,\"Hop,per\"")
    END TCASE
  END TGROUP
END TESTING
