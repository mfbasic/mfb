IMPORT io
IMPORT strings

FUNC main AS Integer
  io::print("[" & strings::trimEnd("  Hello  ") & "]")
  io::print("[" & strings::trimEnd("	😀	") & "]")
  io::print("[" & strings::trimEnd(" é ") & "]")
  io::print("[" & strings::trimEnd("　wide　") & "]")
  io::print("[" & strings::trimEnd("") & "]")
  RETURN 0
END FUNC
