IMPORT collections
IMPORT io

SUB show(n AS Integer)
  io::print(toString(n))
END SUB

FUNC main AS Integer
  LET numbers AS List OF Integer = [1, 2, 3]
  ' collections::forEach is a callback member whose failure propagates via a plain
  ' return, not the raw-capture branch, so it has no inline raw lowering (plan-21-B)
  ' and an inline TRAP on it is still rejected as ON_INLINED_BUILTIN.
  collections::forEach(numbers, show) TRAP(e)
    RECOVER
  END TRAP
  RETURN 0
END FUNC
