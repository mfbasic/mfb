IMPORT net
IMPORT io

FUNC main AS Integer
  LET server = net::listenTcp("127.0.0.1", 0)
  LET bound = net::localAddress(server)
  LET client = net::connectTcp("127.0.0.1", bound.port)
  LET conn = net::accept(server)
  net::writeText(client, "x")
  LET ready = net::poll(conn, 1000)
  io::print("poll " & toString(ready))
  RETURN 0
END FUNC
