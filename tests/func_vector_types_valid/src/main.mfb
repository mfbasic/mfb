IMPORT vector
IMPORT io


FUNC main AS Integer
  LET vFloat2 AS vector::Float2 = vector::Float2[3.0, 4.0]
  io::print("Float2: " & toString(vFloat2.x) & "," & toString(vFloat2.y))
  LET vFloat3 AS vector::Float3 = vector::Float3[1.0, 2.0, 2.0]
  io::print("Float3: " & toString(vFloat3.x) & "," & toString(vFloat3.y) & "," & toString(vFloat3.z))
  LET vFloat4 AS vector::Float4 = vector::Float4[1.0, 2.0, 2.0, 4.0]
  io::print("Float4: " & toString(vFloat4.x) & "," & toString(vFloat4.y) & "," & toString(vFloat4.z) & "," & toString(vFloat4.w))
  LET vFixed2 AS vector::Fixed2 = vector::Fixed2[toFixed(3.0), toFixed(4.0)]
  io::print("Fixed2: " & toString(vFixed2.x) & "," & toString(vFixed2.y))
  LET vFixed3 AS vector::Fixed3 = vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)]
  io::print("Fixed3: " & toString(vFixed3.x) & "," & toString(vFixed3.y) & "," & toString(vFixed3.z))
  LET vFixed4 AS vector::Fixed4 = vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)]
  io::print("Fixed4: " & toString(vFixed4.x) & "," & toString(vFixed4.y) & "," & toString(vFixed4.z) & "," & toString(vFixed4.w))
  LET vInteger2 AS vector::Integer2 = vector::Integer2[3, 4]
  io::print("Integer2: " & toString(vInteger2.x) & "," & toString(vInteger2.y))
  LET vInteger3 AS vector::Integer3 = vector::Integer3[1, 2, 2]
  io::print("Integer3: " & toString(vInteger3.x) & "," & toString(vInteger3.y) & "," & toString(vInteger3.z))
  LET vInteger4 AS vector::Integer4 = vector::Integer4[1, 2, 2, 4]
  io::print("Integer4: " & toString(vInteger4.x) & "," & toString(vInteger4.y) & "," & toString(vInteger4.z) & "," & toString(vInteger4.w))
  RETURN 0
END FUNC
