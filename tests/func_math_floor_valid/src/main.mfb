IMPORT io
IMPORT math

FUNC main AS Integer
  LET fixedPositive AS Fixed = toFixed("3.75")
  LET fixedNegative AS Fixed = 0 - toFixed("3.25")
  io::print(toString(math::floor(3.75)))
  io::print(toString(math::floor(0 - 3.25)))
  io::print(toString(math::floor(4.0)))
  io::print(toString(math::floor(fixedPositive)))
  io::print(toString(math::floor(fixedNegative)))
  RETURN 0
END FUNC
