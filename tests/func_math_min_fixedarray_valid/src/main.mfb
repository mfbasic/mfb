IMPORT io
IMPORT math
SUB pX(label AS String, xs AS List OF Fixed, p AS Byte)
  MUT s AS String = label
  FOR EACH x IN xs
    s = s & " " & toString(x, p)
  NEXT
  io::print(s)
END SUB

FUNC main AS Integer
  LET p AS Byte = 2
  LET a AS List OF Fixed = [toFixed("3.5"), toFixed("-1.0"), toFixed("2.0")]
  LET b AS List OF Fixed = [toFixed("1.5"), toFixed("-2.0"), toFixed("9.0")]
  pX("min", math::min(a, b), p)
  pX("max", math::max(a, b), p)
  RETURN 0
END FUNC
