IMPORT fs
IMPORT io

FUNC main AS Integer
  LET path AS String = "target/func_fs_writeAll_valid.txt"
  IF fs::fileExists(path) THEN
    fs::deleteFile(path)
  END IF
  RES f AS File = fs::openFile(path, "write")
  fs::writeAll(f, "Hello é日😀")
  fs::close(f)
  io::print(toString(fs::fileExists(path)))
  fs::deleteFile(path)
  RETURN 0
END FUNC
