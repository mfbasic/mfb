IMPORT fs
IMPORT io

FUNC main AS Integer
  RES f AS File = fs::openFile("tests/builtin-fs/behavior/func_fs_openFile_valid/src/main.mfb")
  fs::close(f)
  io::print("default")

  RES read AS File = fs::openFile("tests/builtin-fs/behavior/func_fs_openFile_valid/src/main.mfb", "read")
  fs::close(read)
  io::print("read")

  RES r AS File = fs::openFile("tests/builtin-fs/behavior/func_fs_openFile_valid/src/main.mfb", "r")
  fs::close(r)
  io::print("r")

  LET writePath AS String = "target/func_fs_openFile_valid_w.txt"
  IF fs::fileExists(writePath) THEN
    fs::deleteFile(writePath)
  END IF
  RES w AS File = fs::openFile(path := writePath, mode := "w")
  fs::writeAll(w, "w")
  fs::close(w)
  io::print(fs::readText(writePath))
  fs::deleteFile(writePath)

  LET readWritePath AS String = "target/func_fs_openFile_valid_rw.txt"
  fs::writeText(readWritePath, "")
  RES rw AS File = fs::openFile(readWritePath, "rw")
  fs::writeAll(rw, "rw")
  fs::close(rw)
  io::print(fs::readText(readWritePath))
  fs::deleteFile(readWritePath)

  LET readWriteNamePath AS String = "target/func_fs_openFile_valid_readWrite.txt"
  fs::writeText(readWriteNamePath, "")
  RES readWrite AS File = fs::openFile(readWriteNamePath, "readWrite")
  fs::writeAll(readWrite, "readWrite")
  fs::close(readWrite)
  io::print(fs::readText(readWriteNamePath))
  fs::deleteFile(readWriteNamePath)

  LET appendAliasPath AS String = "target/func_fs_openFile_valid_a.txt"
  fs::writeText(appendAliasPath, "base")
  RES a AS File = fs::openFile(appendAliasPath, "a")
  fs::writeAll(a, "+a")
  fs::close(a)
  io::print(fs::readText(appendAliasPath))
  fs::deleteFile(appendAliasPath)

  LET appendPath AS String = "target/func_fs_openFile_valid_append.txt"
  fs::writeText(appendPath, "base")
  RES append AS File = fs::openFile(appendPath, "append")
  fs::writeAll(append, "+append")
  fs::close(append)
  io::print(fs::readText(appendPath))
  fs::deleteFile(appendPath)

  LET writeNamePath AS String = "target/func_fs_openFile_valid_write.txt"
  IF fs::fileExists(writeNamePath) THEN
    fs::deleteFile(writeNamePath)
  END IF
  RES write AS File = fs::openFile(path := writeNamePath, mode := "write")
  fs::writeAll(write, "write")
  fs::close(write)
  io::print(fs::readText(writeNamePath))
  fs::deleteFile(writeNamePath)

  RETURN 0
END FUNC
