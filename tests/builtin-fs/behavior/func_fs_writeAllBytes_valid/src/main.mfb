IMPORT fs
IMPORT io

FUNC main AS Integer
  LET path AS String = "target/func_fs_writeAllBytes_valid.txt"
  RES f AS File = fs::openFile(path, "write")
  LET bytes AS List OF Byte = [72, 101, 108, 108, 111, 33]
  fs::writeAllBytes(f, bytes)
  fs::close(f)
  io::print(fs::readText(path))
  fs::deleteFile(path)
  RETURN 0
END FUNC
