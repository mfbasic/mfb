IMPORT io
IMPORT math
SUB pI(label AS String, xs AS List OF Integer)
  MUT s AS String = label
  FOR EACH x IN xs
    s = s & " " & toString(x)
  NEXT
  io::print(s)
END SUB

FUNC main AS Integer
  LET xs AS List OF Fixed = [toFixed("2.3"), toFixed("-2.3"), toFixed("2.5"), toFixed("-2.5"), toFixed("3.75")]
  pI("round", math::round(xs))
  RETURN 0
END FUNC
