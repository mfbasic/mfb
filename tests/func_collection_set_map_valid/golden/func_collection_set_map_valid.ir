    "body": [
    { "op": "bind", "mutable": false, "name": "ages", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "Ada" }, "value": { "kind": "const", "type": "Integer", "value": "36" } }, { "key": { "kind": "const", "type": "String", "value": "Grace" }, "value": { "kind": "const", "type": "Integer", "value": "85" } }] } },
    { "op": "bind", "mutable": false, "name": "updated", "type": "Map OF String TO Integer", "value": { "kind": "call", "target": "collections.set", "args": [{ "kind": "local", "name": "ages" }, { "kind": "const", "type": "String", "value": "Ada" }, { "kind": "const", "type": "Integer", "value": "37" }] } },
    { "op": "bind", "mutable": false, "name": "inserted", "type": "Map OF String TO Integer", "value": { "kind": "call", "target": "collections.set", "args": [{ "kind": "local", "name": "updated" }, { "kind": "const", "type": "String", "value": "Katherine" }, { "kind": "const", "type": "Integer", "value": "99" }] } },
    { "op": "bind", "mutable": false, "name": "codes", "type": "Map OF Integer TO String", "value": { "kind": "call", "target": "collections.set", "args": [{ "kind": "map", "type": "Map OF Integer TO String", "entries": [{ "key": { "kind": "const", "type": "Integer", "value": "1" }, "value": { "kind": "const", "type": "String", "value": "one" } }] }, { "kind": "const", "type": "Integer", "value": "2" }, { "kind": "const", "type": "String", "value": "two" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "inserted" }, { "kind": "const", "type": "String", "value": "Ada" }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "inserted" }, { "kind": "const", "type": "String", "value": "Katherine" }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "codes" }, { "kind": "const", "type": "Integer", "value": "2" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "inserted" }] }] }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "inserted" }] }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "codes" }] } } }
