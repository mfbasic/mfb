IMPORT io
IMPORT encoding
IMPORT collections

FUNC asBytes(s AS String) AS List OF Byte
  RETURN encoding::utf8Encode(s)
END FUNC

FUNC asInts(s AS String) AS List OF Integer
  RETURN encoding::utf8Encode(s)
END FUNC

FUNC takeBytes(data AS List OF Byte) AS Integer
  RETURN len(data)
END FUNC

FUNC main AS Integer
  LET b AS List OF Byte = encoding::utf8Encode("Aé")
  LET n AS List OF Integer = encoding::utf8Encode("Aé")
  io::print(toString(len(b)))
  io::print(toString(collections::get(n, 0)))
  io::print(toString(collections::get(n, 1)))
  io::print(toString(len(asBytes("Aé"))))
  io::print(toString(collections::get(asInts("Aé"), 2)))
  io::print(toString(takeBytes(encoding::utf8Encode("Aé"))))
  RETURN 0
END FUNC
