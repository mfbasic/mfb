IMPORT io

TYPE Inner
  name AS String
  values AS List OF Integer
END TYPE

TYPE Outer
  inner AS Inner
  ready AS Boolean
END TYPE

FUNC main AS Integer
  MUT state AS Outer
  io::print(state.inner.name)
  io::print(toString(len(state.inner.values)))
  io::print(toString(state.ready))
  RETURN 0
END FUNC
