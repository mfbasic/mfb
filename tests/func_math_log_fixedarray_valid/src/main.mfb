IMPORT io
IMPORT math

' log/log10 over a List OF Fixed are per-lane scalar Q32.32 (NEON has no .2d
' 64-bit multiply-high/divide) and are bit-identical to the scalar kernels.
SUB show(xs AS List OF Fixed, p AS Byte)
  FOR EACH x IN xs
    io::print(toString(x, p))
  NEXT
END SUB

FUNC main AS Integer
  LET p AS Byte = 8
  LET xs AS List OF Fixed = [toFixed("2.0"), toFixed("4.0"), toFixed("9.0"), toFixed("0.25"), toFixed("100.0")]
  io::print("log:")
  show(math::log(xs), p)
  io::print("log10:")
  show(math::log10(xs), p)
  RETURN 0
END FUNC
