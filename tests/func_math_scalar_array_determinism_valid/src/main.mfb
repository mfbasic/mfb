IMPORT io
IMPORT math
IMPORT collections

' plan-01-simd §4.7 / plan-01-libm-kernels: scalar log/log10/sin/cos/tan run the
' SAME NEON kernel as the array overload, so math::f(x) == math::f([x])[0]
' bit-identically (each printed pair must be equal).
SUB one(x AS Float)
  LET p AS Byte = 17
  LET xl AS List OF Float = [x]
  io::print("exp " & toString(math::exp(x), p) & " " & toString(collections::get(math::exp(xl), 0), p))
  io::print("log " & toString(math::log(x), p) & " " & toString(collections::get(math::log(xl), 0), p))
  io::print("log10 " & toString(math::log10(x), p) & " " & toString(collections::get(math::log10(xl), 0), p))
  io::print("sin " & toString(math::sin(x), p) & " " & toString(collections::get(math::sin(xl), 0), p))
  io::print("cos " & toString(math::cos(x), p) & " " & toString(collections::get(math::cos(xl), 0), p))
  io::print("tan " & toString(math::tan(x), p) & " " & toString(collections::get(math::tan(xl), 0), p))
  io::print("pow " & toString(math::pow(x, 3.0), p) & " " & toString(collections::get(math::pow(xl, [3.0]), 0), p))
END SUB

FUNC main AS Integer
  one(0.5)
  one(2.0)
  one(5.0)
  one(0.1)
  RETURN 0
END FUNC
