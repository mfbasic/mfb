IMPORT http
IMPORT collections
IMPORT io

' http::Response is an ordinary value record. Build one directly (the transport
' is exercised by the gated loopback test) and read its standard map fields with
' the ordinary collections accessors. Response header names are lowercased on
' parse, so callers look them up in lowercase.
FUNC main AS Integer
  MUT headers AS Map OF String TO String = Map OF String TO String {}
  headers = collections::set(headers, "content-type", "text/html; charset=utf-8")
  headers = collections::set(headers, "content-length", "42")
  LET r AS http::Response = http::Response[200, "OK", "1.1", headers, "body", TRUE]

  io::print("status=" & toString(r.status))
  io::print("reason=" & r.reason)
  io::print("version=" & r.httpVersion)
  io::print("ok=" & toString(r.ok))
  io::print("body=" & r.body)
  ' Standard map access, no dedicated header function.
  io::print("ctype=" & collections::get(r.headers, "content-type"))
  io::print("clen=" & collections::getOr(r.headers, "content-length", "?"))
  ' A missing header falls back via getOr.
  io::print("missing=" & collections::getOr(r.headers, "x-absent", "fallback"))
  io::print("hasCtype=" & toString(collections::hasKey(r.headers, "content-type")))
  io::print("hasAbsent=" & toString(collections::hasKey(r.headers, "x-absent")))
  RETURN 0
END FUNC
