IMPORT errorCode

' Consolidated runtime-behavior acceptance for the errorCode builtin constants,
' converted from tests/func_errorcode_constant_valid. Each Err* constant is
' asserted against the exact integer value the source fixture printed, and the
' ErrNotFound trap-code usage is preserved via a fallible FUNC.

' A fallible FUNC that fails with a registry code named via errorCode::*.
FUNC lookup AS Integer
  FAIL error(errorCode::ErrNotFound, "missing")
END FUNC

TESTING
  TGROUP "Builtin: errorCode"
    TGROUP "constants"
      TCASE "documented codes"
        expectInteger(errorCode::ErrNotFound, 77050004)
        expectInteger(errorCode::ErrInvalidArgument, 77050002)
      END TCASE
      TCASE "runtime subsystem ranges"
        expectInteger(errorCode::ErrOutOfMemory, 77010001)
        expectInteger(errorCode::ErrReadFailed, 77020001)
        expectInteger(errorCode::ErrPathNotFound, 77030001)
        expectInteger(errorCode::ErrUnknown, 77050000)
        expectInteger(errorCode::ErrWrapped, 77060001)
        expectInteger(errorCode::ErrTlsFailed, 77070008)
      END TCASE
      TCASE "usable as a trap code"
        expectTrap(lookup(), errorCode::ErrNotFound)
      END TCASE
    END TGROUP
  END TGROUP
END TESTING
