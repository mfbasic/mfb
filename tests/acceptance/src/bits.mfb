IMPORT bits
IMPORT errorCode

TESTING
  TGROUP "Builtin: bits"
    TGROUP "bitwise"
      TCASE "band masks the overlapping bits"
        expectInteger(bits::band(65280, 4080), 3840)
        expectInteger(bits::band(255, 15), 15)
      END TCASE
      TCASE "bor sets the union of bits"
        expectInteger(bits::bor(255, 65280), 65535)
        expectInteger(bits::bor(0, 0), 0)
      END TCASE
      TCASE "bxor toggles differing bits"
        expectInteger(bits::bxor(65535, 3855), 61680)
        expectInteger(bits::bxor(10, 10), 0)
      END TCASE
      TCASE "bnot inverts every bit"
        expectInteger(bits::bnot(0), -1)
        expectInteger(bits::bnot(-1), 0)
      END TCASE
    END TGROUP

    TGROUP "shifts"
      TCASE "sl shifts left"
        expectInteger(bits::sl(1, 4), 16)
        expectInteger(bits::sl(255, 8), 65280)
        expectInteger(bits::sl(1, 0), 1)
      END TCASE
      TCASE "sr shifts right (logical, zero-fill)"
        expectInteger(bits::sr(256, 4), 16)
        expectInteger(bits::sr(-1, 1), 9223372036854775807)
      END TCASE
      TCASE "sra shifts right (arithmetic, sign-fill)"
        expectInteger(bits::sra(-8, 1), -4)
        expectInteger(bits::sra(8, 1), 4)
      END TCASE
      TCASE "sl traps on an out-of-range count"
        expectTrap(bits::sl(1, 64), errorCode::ErrInvalidArgument)
        expectTrap(bits::sl(1, -1), errorCode::ErrInvalidArgument)
      END TCASE
      TCASE "sl does not trap on an in-range count"
        expectNTrap(bits::sl(1, 4))
      END TCASE
    END TGROUP

    TGROUP "rotations"
      TCASE "rl32 rotates a 32-bit value left"
        expectInteger(bits::rl32(2147483648, 1), 1)
        expectInteger(bits::rl32(1, 32), 1)
      END TCASE
      TCASE "rl64 rotates a 64-bit value left"
        expectInteger(bits::rl64(1, 1), 2)
        expectInteger(bits::rl64(1, 64), 1)
      END TCASE
      TCASE "rr32 rotates a 32-bit value right"
        expectInteger(bits::rr32(1, 1), 2147483648)
        expectInteger(bits::rr32(1, 33), 2147483648)
      END TCASE
      TCASE "rr64 rotates a 64-bit value right"
        expectInteger(bits::rr64(2, 1), 1)
        expectInteger(bits::rr64(1, 64), 1)
      END TCASE
    END TGROUP

    TGROUP "byte swaps"
      TCASE "bswap16 reverses two bytes"
        expectInteger(bits::bswap16(4660), 13330)
      END TCASE
      TCASE "bswap32 reverses four bytes"
        expectInteger(bits::bswap32(305419896), 2018915346)
      END TCASE
      TCASE "bswap64 reverses eight bytes"
        expectInteger(bits::bswap64(72623859790382856), 578437695752307201)
      END TCASE
    END TGROUP

    TGROUP "bit counts"
      TCASE "clz counts leading zeros"
        expectInteger(bits::clz(1), 63)
        expectInteger(bits::clz(0), 64)
      END TCASE
      TCASE "ctz counts trailing zeros"
        expectInteger(bits::ctz(8), 3)
        expectInteger(bits::ctz(0), 64)
      END TCASE
      TCASE "popCount counts set bits"
        expectInteger(bits::popCount(255), 8)
        expectInteger(bits::popCount(0), 0)
        expectInteger(bits::popCount(-1), 64)
      END TCASE
    END TGROUP
  END TGROUP
END TESTING
