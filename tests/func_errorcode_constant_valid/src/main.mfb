IMPORT io
IMPORT errorCode

' A fallible FUNC that fails with a registry code named via errorCode::*.
FUNC lookup AS Integer
  FAIL error(errorCode::ErrNotFound, "missing")
END FUNC

FUNC main AS Integer
  ' The two values standard_package.md §13 calls out by number.
  io::print(toString(errorCode::ErrNotFound))
  io::print(toString(errorCode::ErrInvalidArgument))

  ' One sample from each runtime subsystem range, all folded to Integer literals.
  io::print(toString(errorCode::ErrOutOfMemory))   ' 7-701
  io::print(toString(errorCode::ErrReadFailed))    ' 7-702
  io::print(toString(errorCode::ErrPathNotFound))  ' 7-703
  io::print(toString(errorCode::ErrUnknown))       ' 7-705
  io::print(toString(errorCode::ErrWrapped))       ' 7-706
  io::print(toString(errorCode::ErrTlsFailed))     ' 7-707

  ' Use a constant in an IF guard.
  IF errorCode::ErrNotFound = 77050004 THEN
    io::print("not-found matches")
  END IF

  ' Use a constant in an inline TRAP handler (standard_package.md §3.2 pattern).
  LET idx AS Integer = lookup() TRAP(e)
    IF e.code = errorCode::ErrNotFound THEN RECOVER -1
    FAIL e
  END TRAP
  io::print(toString(idx))

  RETURN 0
END FUNC
