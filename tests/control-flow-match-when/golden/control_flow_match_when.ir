{
  "format": "mfb-ir",
  "version": 1,
  "project": "control_flow_match_when",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  {
    "kind": "type",
    "visibility": "private",
    "name": "Circle",
    "fields": [
    { "visibility": null, "name": "radius", "type": "Integer" }
    ]
  },
  {
    "kind": "type",
    "visibility": "private",
    "name": "Rect",
    "fields": [
    { "visibility": null, "name": "width", "type": "Integer" },
    { "visibility": null, "name": "height", "type": "Integer" }
    ]
  },
  {
    "kind": "union",
    "visibility": "private",
    "name": "Shape",
    "includes": [],
    "variants": [
    {
      "name": "Circle",
      "fields": [
      { "visibility": null, "name": "radius", "type": "Integer" }
      ]
    },
    {
      "name": "Rect",
      "fields": [
      { "visibility": null, "name": "width", "type": "Integer" },
      { "visibility": null, "name": "height", "type": "Integer" }
      ]
    }
    ]
  }
  ],
  "functions": [
  {
    "name": "score",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "shape", "type": "Shape", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "$match0", "type": "Shape", "value": { "kind": "local", "name": "shape" } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match0" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Circle" } },
        "guard": { "kind": "binary", "op": ">", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "bigCircle" }, "member": "radius" }, "right": { "kind": "const", "type": "Integer", "value": "5" } },
        "body": [
        { "op": "bind", "mutable": false, "name": "bigCircle", "type": "Circle", "value": { "kind": "unionExtract", "type": "Circle", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "100" } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Circle" } },
        "guard": { "kind": "binary", "op": "=", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "exactCircle" }, "member": "radius" }, "right": { "kind": "const", "type": "Integer", "value": "4" } },
        "body": [
        { "op": "bind", "mutable": false, "name": "exactCircle", "type": "Circle", "value": { "kind": "unionExtract", "type": "Circle", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "7" } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Rect" } },
        "guard": { "kind": "binary", "op": "=", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "square" }, "member": "width" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "square" }, "member": "height" } },
        "body": [
        { "op": "bind", "mutable": false, "name": "square", "type": "Rect", "value": { "kind": "unionExtract", "type": "Rect", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "50" } }
        ]
      },
      {
        "pattern": { "kind": "else" },
        "guard": null,
        "body": [
        { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "3" } }
        ]
      }
      ]
    }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "score", "args": [{ "kind": "unionWrap", "union": "Shape", "member": "Circle", "value": { "kind": "constructor", "type": "Circle", "args": [{ "kind": "const", "type": "Integer", "value": "4" }] } }] }, "right": { "kind": "call", "target": "score", "args": [{ "kind": "unionWrap", "union": "Shape", "member": "Rect", "value": { "kind": "constructor", "type": "Rect", "args": [{ "kind": "const", "type": "Integer", "value": "2" }, { "kind": "const", "type": "Integer", "value": "2" }] } }] } }, "right": { "kind": "call", "target": "score", "args": [{ "kind": "unionWrap", "union": "Shape", "member": "Circle", "value": { "kind": "constructor", "type": "Circle", "args": [{ "kind": "const", "type": "Integer", "value": "1" }] } }] } } }
    ]
  }
  ]
}
