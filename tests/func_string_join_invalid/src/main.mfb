IMPORT strings

FUNC main AS Integer
  LET missing AS String = strings::join(["a"])
  LET wrongList AS String = strings::join([1, 2], ",")
  LET wrongDelimiter AS String = strings::join(["a"], 1)
  LET tooMany AS String = strings::join(["a"], ",", ";")
  LET badName AS String = strings::join(items := ["a"], delimiter := ",")
  RETURN 0
END FUNC
