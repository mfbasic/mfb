IMPORT collections
IMPORT io

FUNC add(accumulator AS Integer, value AS Integer) AS Integer
  RETURN accumulator + value
END FUNC

FUNC join(accumulator AS String, value AS String) AS String
  RETURN accumulator & value
END FUNC

FUNC main AS Integer
  LET numbers AS List OF Integer = [1, 2, 3]
  LET words AS List OF String = ["Hello", " ", "World"]
  LET empty AS List OF Integer = []
  LET addNumbers AS FUNC(Integer, Integer) AS Integer = add

  LET total AS Integer = collections::reduce(numbers, 10, addNumbers)
  LET joined AS String = collections::reduce(words, "", join)
  LET product AS Integer = collections::reduce(numbers, 1, LAMBDA(accumulator AS Integer, value AS Integer) -> accumulator * value)
  LET emptyTotal AS Integer = collections::reduce(empty, 7, add)

  io::print(toString(total))
  io::print(joined)
  io::print(toString(product))
  io::print(toString(emptyTotal))

  RETURN total + product + emptyTotal
END FUNC
