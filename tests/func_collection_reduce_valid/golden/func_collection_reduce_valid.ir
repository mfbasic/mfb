  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "numbers", "type": "List OF Integer", "value": { "kind": "list", "type": "List OF Integer", "values": [{ "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "2" }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "bind", "mutable": false, "name": "words", "type": "List OF String", "value": { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Hello" }, { "kind": "const", "type": "String", "value": " " }, { "kind": "const", "type": "String", "value": "World" }] } },
    { "op": "bind", "mutable": false, "name": "empty", "type": "List OF Integer", "value": { "kind": "list", "type": "List OF Integer", "values": [] } },
    { "op": "bind", "mutable": false, "name": "addNumbers", "type": "FUNC(Integer, Integer) AS Integer", "value": { "kind": "functionRef", "name": "add", "type": "FUNC(Integer, Integer) AS Integer" } },
    { "op": "bind", "mutable": false, "name": "total", "type": "Integer", "value": { "kind": "call", "target": "collections.reduce", "args": [{ "kind": "local", "name": "numbers" }, { "kind": "const", "type": "Integer", "value": "10" }, { "kind": "local", "name": "addNumbers" }] } },
    { "op": "bind", "mutable": false, "name": "joined", "type": "String", "value": { "kind": "call", "target": "collections.reduce", "args": [{ "kind": "local", "name": "words" }, { "kind": "const", "type": "String", "value": "" }, { "kind": "functionRef", "name": "join", "type": "FUNC(String, String) AS String" }] } },
    { "op": "bind", "mutable": false, "name": "product", "type": "Integer", "value": { "kind": "call", "target": "collections.reduce", "args": [{ "kind": "local", "name": "numbers" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "functionRef", "name": "$lambda0", "type": "FUNC(Integer, Integer) AS Integer" }] } },
    { "op": "bind", "mutable": false, "name": "emptyTotal", "type": "Integer", "value": { "kind": "call", "target": "collections.reduce", "args": [{ "kind": "local", "name": "empty" }, { "kind": "const", "type": "Integer", "value": "7" }, { "kind": "functionRef", "name": "add", "type": "FUNC(Integer, Integer) AS Integer" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "total" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "joined" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "product" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "emptyTotal" }] }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "local", "name": "product" } }, "right": { "kind": "local", "name": "emptyTotal" } } }
    ]
  },
