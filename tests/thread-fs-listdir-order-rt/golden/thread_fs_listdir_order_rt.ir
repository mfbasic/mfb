{
  "format": "mfb-ir",
  "version": 1,
  "project": "thread_fs_listdir_order_rt",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "dir", "type": "String", "value": { "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir" } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.createDirectories", "args": [{ "kind": "local", "name": "dir" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.writeText", "args": [{ "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir/zebra.txt" }, { "kind": "const", "type": "String", "value": "z" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.writeText", "args": [{ "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir/apple.txt" }, { "kind": "const", "type": "String", "value": "a" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.writeText", "args": [{ "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir/mango.txt" }, { "kind": "const", "type": "String", "value": "m" }] } },
    { "op": "bind", "mutable": false, "name": "t", "type": "Thread OF String TO String", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "fs_thread_workers.listDirWorker", "type": "ISOLATED FUNC(ThreadWorker OF String TO String, String) AS String" }, { "kind": "local", "name": "dir" }] } },
    { "op": "bind", "mutable": false, "name": "names", "type": "String", "value": { "kind": "call", "target": "thread.waitFor", "args": [{ "kind": "local", "name": "t" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "names" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.deleteFile", "args": [{ "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir/zebra.txt" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.deleteFile", "args": [{ "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir/apple.txt" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.deleteFile", "args": [{ "kind": "const", "type": "String", "value": "target/thread_fs_listdir_order_rt_dir/mango.txt" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.deleteDirectory", "args": [{ "kind": "local", "name": "dir" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
