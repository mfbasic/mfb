TYPE Box OF T
  value AS T
END TYPE

UNION Maybe OF T
  Present(value AS T)
END UNION

FUNC box OF T(value AS T) AS Box OF T
  RETURN Box[value]
END FUNC

FUNC unbox OF T(boxed AS Box OF T) AS T
  RETURN boxed::value
END FUNC

FUNC present OF T(value AS T) AS Maybe OF T
  RETURN Present[value]
END FUNC

FUNC main AS Integer
  LET numberBox = box(41)
  LET textBox = box("abc")
  LET maybeNumber = present(5)
  RETURN unbox(numberBox) + len(unbox(textBox))
END FUNC
