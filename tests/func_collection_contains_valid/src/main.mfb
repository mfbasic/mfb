IMPORT io

TYPE Point
  x AS Integer
  y AS Integer
END TYPE

FUNC printBoolean(value AS Boolean) AS Nothing
  io::print(toString(value))
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  LET empty AS List OF Integer = []
  LET numbers AS List OF Integer = [10, 20, 30]
  LET names AS List OF String = ["Ada", "Grace"]
  LET points AS List OF Point = [Point[1, 2], Point[3, 4]]

  LET emptyMissing AS Boolean = contains(empty, 10)
  LET first AS Boolean = contains(numbers, 10)
  LET last AS Boolean = contains(numbers, 30)
  LET missing AS Boolean = contains(numbers, 40)
  LET stringHit AS Boolean = contains(names, "Grace")
  LET stringMiss AS Boolean = contains(names, "Katherine")
  LET pointHit AS Boolean = contains(points, Point[3, 4])
  LET pointMiss AS Boolean = contains(points, Point[5, 6])

  printBoolean(emptyMissing)
  printBoolean(first)
  printBoolean(last)
  printBoolean(missing)
  printBoolean(stringHit)
  printBoolean(stringMiss)
  printBoolean(pointHit)
  printBoolean(pointMiss)

  RETURN 0
END FUNC
