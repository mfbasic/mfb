IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("reject Float2 = " & toString(vector::reject(vector::Float2[3.0, 4.0], vector::Float2[1.0, 2.0])))
  io::print("reject Float3 = " & toString(vector::reject(vector::Float3[1.0, 2.0, 2.0], vector::Float3[2.0, 1.0, 2.0])))
  io::print("reject Float4 = " & toString(vector::reject(vector::Float4[1.0, 2.0, 2.0, 4.0], vector::Float4[2.0, 1.0, 0.0, 1.0])))
  io::print("reject Fixed2 = " & toString(vector::reject(vector::Fixed2[toFixed(3.0), toFixed(4.0)], vector::Fixed2[toFixed(1.0), toFixed(2.0)])))
  io::print("reject Fixed3 = " & toString(vector::reject(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)], vector::Fixed3[toFixed(2.0), toFixed(1.0), toFixed(2.0)])))
  io::print("reject Fixed4 = " & toString(vector::reject(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)], vector::Fixed4[toFixed(2.0), toFixed(1.0), toFixed(0.0), toFixed(1.0)])))
  io::print("reject Integer2 = " & toString(vector::reject(vector::Integer2[3, 4], vector::Integer2[1, 2])))
  io::print("reject Integer3 = " & toString(vector::reject(vector::Integer3[1, 2, 2], vector::Integer3[2, 1, 2])))
  io::print("reject Integer4 = " & toString(vector::reject(vector::Integer4[1, 2, 2, 4], vector::Integer4[2, 1, 0, 1])))
  RETURN 0
END FUNC
