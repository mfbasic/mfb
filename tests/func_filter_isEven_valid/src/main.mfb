IMPORT collections
IMPORT io

FUNC main AS Integer
  LET values AS List OF Integer = [-4, -3, 0, 1, 2]
  LET evens AS List OF Integer = collections::filter(values, isEven)

  io::print(toString(isEven(0)))
  io::print(toString(isEven(2)))
  io::print(toString(isEven(-4)))
  io::print(toString(isEven(1)))
  io::print(toString(isEven(-3)))
  io::print(toString(len(evens)))
  io::print(toString(collections::get(evens, 0)))
  io::print(toString(collections::get(evens, 1)))
  io::print(toString(collections::get(evens, 2)))

  RETURN 0
END FUNC
