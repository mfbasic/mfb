    { "op": "bind", "mutable": true, "name": "i", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "0" } },
    {
      "op": "while",
      "loop": "while",
      "condition": { "kind": "binary", "op": "<", "left": { "kind": "local", "name": "i" }, "right": { "kind": "local", "name": "rounds" } },
      "body": [
      { "op": "bind", "mutable": true, "name": "s", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Dot", "value": { "kind": "constructor", "type": "Dot", "args": [{ "kind": "local", "name": "i" }] } } },
      {
        "op": "if",
        "condition": { "kind": "binary", "op": "=", "left": { "kind": "binary", "op": "-", "left": { "kind": "local", "name": "i" }, "right": { "kind": "binary", "op": "*", "left": { "kind": "binary", "op": "/", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "2" } }, "right": { "kind": "const", "type": "Integer", "value": "2" } } }, "right": { "kind": "const", "type": "Integer", "value": "0" } },
        "then": [
        { "op": "assign", "name": "s", "value": { "kind": "unionWrap", "union": "Shape", "member": "Tag", "value": { "kind": "constructor", "type": "Tag", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "tag-" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "i" }] } }] } } }
        ],
        "else": [
        ]
      },
      { "op": "bind", "mutable": false, "name": "text", "type": "String", "value": { "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "s" }] } },
      { "op": "bind", "mutable": false, "name": "m", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "n" }, "value": { "kind": "local", "name": "i" } }, { "key": { "kind": "const", "type": "String", "value": "len" }, "value": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "text" }] } }] } },
      { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "text" }] } }, "right": { "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "m" }, { "kind": "const", "type": "String", "value": "n" }] } }, "right": { "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "m" }, { "kind": "const", "type": "String", "value": "len" }] } } },
      { "op": "assign", "name": "i", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } }
      ]
    },
    { "op": "return", "value": { "kind": "local", "name": "total" } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "a", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Dot", "value": { "kind": "constructor", "type": "Dot", "args": [{ "kind": "const", "type": "Integer", "value": "7" }] } } },
    { "op": "bind", "mutable": false, "name": "b", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Tag", "value": { "kind": "constructor", "type": "Tag", "args": [{ "kind": "const", "type": "String", "value": "hello-and-longer" }] } } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "a" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "b" }] }] } },
    { "op": "bind", "mutable": false, "name": "c", "type": "Shape", "value": { "kind": "local", "name": "b" } },
