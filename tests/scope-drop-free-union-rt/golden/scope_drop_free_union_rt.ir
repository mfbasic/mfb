    { "op": "bind", "mutable": false, "name": "xs", "type": "List OF Shape", "value": { "kind": "list", "type": "List OF Shape", "values": [{ "kind": "local", "name": "a" }, { "kind": "local", "name": "b" }, { "kind": "local", "name": "c" }] } },
    { "op": "bind", "mutable": true, "name": "joined", "type": "String", "value": { "kind": "const", "type": "String", "value": "" } },
