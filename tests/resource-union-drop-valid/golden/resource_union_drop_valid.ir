    { "name": "data", "type": "String", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "bind", "mutable": false, "name": "s", "type": "Stream", "value": { "kind": "unionWrap", "union": "Stream", "member": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "local", "name": "path" }, { "kind": "const", "type": "String", "value": "write" }] } } },
    { "op": "bind", "mutable": false, "name": "$match0", "type": "Stream", "value": { "kind": "local", "name": "s" } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match0" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "File" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "f", "type": "File", "value": { "kind": "unionExtract", "type": "File", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "eval", "value": { "kind": "call", "target": "fs.writeAll", "args": [{ "kind": "local", "name": "f" }, { "kind": "local", "name": "data" }] } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Socket" } },
        "guard": null,
        "body": [
