    { "op": "bind", "mutable": false, "name": "r", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "local", "name": "path" }] } },
    { "op": "bind", "mutable": false, "name": "back", "type": "String", "value": { "kind": "call", "target": "fs.readAll", "args": [{ "kind": "local", "name": "r" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "local", "name": "r" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "back" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.deleteFile", "args": [{ "kind": "local", "name": "path" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
