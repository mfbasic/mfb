        { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "unexpected socket" }] } }
        ]
      }
      ]
    }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
