FUNC parsePositive(value AS Integer) AS Integer
  IF value < 0 THEN FAIL Error[900, "negative"]
  RETURN value + 10
END FUNC

FUNC main AS Integer
  MATCH parsePositive(5)
    CASE Ok(value)
      RETURN value
  END MATCH

  MATCH 1
    CASE Ok(value)
      RETURN value
    CASE Error(err)
      RETURN err.code
  END MATCH

  RETURN 0
END FUNC
