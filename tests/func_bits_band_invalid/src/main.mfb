IMPORT bits

FUNC main AS Integer
  LET a AS Integer = bits::band(1)
  LET b AS Integer = bits::band(1, 2, 3)
  LET c AS Integer = bits::band(1.5, 2)
  LET d AS Integer = bits::band("x", 2)
  ' Inline TRAP on the inline-lowered bits::band is rejected
  ' (TYPE_INLINE_TRAP_ON_INLINED_BUILTIN) even with well-typed arguments.
  LET t AS Integer = bits::band(6, 3) TRAP(err)
    RECOVER 0
  END TRAP
  RETURN 0
END FUNC
