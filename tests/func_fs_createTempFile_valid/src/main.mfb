IMPORT fs
IMPORT io
IMPORT strings

FUNC main AS Integer
  fs::createDirectories("target/func_fs_createTempFile_valid")
  LET oldNames AS List OF String = fs::listDirectory("target/func_fs_createTempFile_valid")
  FOR EACH oldName IN oldNames
    fs::deleteFile(fs::pathJoin(["target/func_fs_createTempFile_valid", oldName]))
  NEXT

  LET scratch AS File = fs::createTempFile()
  fs::writeAll(scratch, "scratch")
  fs::close(scratch)

  LET f AS File = fs::createTempFile("target/func_fs_createTempFile_valid")
  fs::writeAll(f, "created")
  fs::close(f)

  LET names AS List OF String = fs::listDirectory("target/func_fs_createTempFile_valid")
  io::print(toString(len(names)))
  FOR EACH name IN names
    io::print(toString(strings::startsWith(name, "mfb-")))
    io::print(toString(strings::endsWith(name, ".tmp")))
  NEXT
  RETURN 0
END FUNC
