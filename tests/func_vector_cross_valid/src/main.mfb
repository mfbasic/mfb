IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("cross Float2 = " & toString(vector::cross(vector::Float2[3.0, 4.0])))
  io::print("cross Float3 = " & toString(vector::cross(vector::Float3[1.0, 2.0, 2.0], vector::Float3[2.0, 1.0, 2.0])))
  io::print("cross Float4 = " & toString(vector::cross(vector::Float4[1.0, 2.0, 2.0, 4.0], vector::Float4[2.0, 1.0, 0.0, 1.0], vector::Float4[0.0, 1.0, 1.0, 0.0])))
  io::print("cross Fixed2 = " & toString(vector::cross(vector::Fixed2[toFixed(3.0), toFixed(4.0)])))
  io::print("cross Fixed3 = " & toString(vector::cross(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)], vector::Fixed3[toFixed(2.0), toFixed(1.0), toFixed(2.0)])))
  io::print("cross Fixed4 = " & toString(vector::cross(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)], vector::Fixed4[toFixed(2.0), toFixed(1.0), toFixed(0.0), toFixed(1.0)], vector::Fixed4[toFixed(0.0), toFixed(1.0), toFixed(1.0), toFixed(0.0)])))
  io::print("cross Integer2 = " & toString(vector::cross(vector::Integer2[3, 4])))
  io::print("cross Integer3 = " & toString(vector::cross(vector::Integer3[1, 2, 2], vector::Integer3[2, 1, 2])))
  io::print("cross Integer4 = " & toString(vector::cross(vector::Integer4[1, 2, 2, 4], vector::Integer4[2, 1, 0, 1], vector::Integer4[0, 1, 1, 0])))
  RETURN 0
END FUNC
