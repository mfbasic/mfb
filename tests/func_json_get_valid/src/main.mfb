IMPORT io
IMPORT json

FUNC main AS Integer
  LET value AS Json = json::parse("{\"user\":{\"name\":\"Ada\",\"meta\":{\"active\":true}},\"nothing\":null}")
  LET emptyPath AS List OF String = []
  io::print(json::stringify(json::get(value, emptyPath)))
  io::print(json::stringify(json::get(value, ["user", "name"])))
  io::print(json::stringify(json::get(value, ["user", "meta", "active"])))
  io::print(json::stringify(json::get(value, ["nothing"])))
  RETURN 0
END FUNC
