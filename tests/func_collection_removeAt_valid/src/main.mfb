IMPORT collections
IMPORT io

FUNC main AS Integer
  LET numbers AS List OF Integer = collections::removeAt([1, 2, 3, 4], 1)
  LET names AS List OF String = collections::removeAt(["Ada", "Grace", "Katherine"], 2)

  FOR EACH value IN numbers
    io::print(toString(value))
  NEXT
  FOR EACH name IN names
    io::print(name)
  NEXT

  RETURN len(numbers) + len(names)
END FUNC
