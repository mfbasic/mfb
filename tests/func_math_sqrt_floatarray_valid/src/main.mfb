IMPORT io
IMPORT math
SUB pF(label AS String, xs AS List OF Float, p AS Byte)
  MUT s AS String = label
  FOR EACH x IN xs
    s = s & " " & toString(x, p)
  NEXT
  io::print(s)
END SUB

FUNC main AS Integer
  LET p AS Byte = 3
  LET xs AS List OF Float = [4.0, 9.0, 2.0]
  pF("sqrt", math::sqrt(xs), p)
  RETURN 0
END FUNC
