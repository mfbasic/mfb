TYPE Circle
  radius AS Integer
END TYPE

TYPE Rect
  width AS Integer
  height AS Integer
END TYPE

TYPE Point
  value AS Nothing
END TYPE

UNION Shape
  Circle
  Rect
  Point
END UNION

FUNC partialUnion(shape AS Shape) AS Integer
  MATCH shape
    CASE Circle(circle)
      RETURN circle.radius
    CASE Rect(rect)
      RETURN rect.width + rect.height
  END MATCH
  RETURN 0
END FUNC

FUNC openInteger(value AS Integer) AS Integer
  MATCH value
    CASE 1
      RETURN 1
    CASE 2
      RETURN 2
  END MATCH
  RETURN 0
END FUNC

FUNC guardedUnion(shape AS Shape) AS Integer
  MATCH shape
    CASE Circle(circle) WHEN circle.radius > 0
      RETURN circle.radius
    CASE Rect(rect)
      RETURN rect.width + rect.height
    CASE Point(point)
      RETURN 0
  END MATCH
  RETURN -1
END FUNC

FUNC main AS Integer
  RETURN partialUnion(Circle[1]) + openInteger(1) + guardedUnion(Point[NOTHING])
END FUNC
