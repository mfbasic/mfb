IMPORT io
IMPORT collections

FUNC isPos(n AS Integer) AS Boolean
  RETURN n > 0
END FUNC

FUNC neg(n AS Integer) AS Integer
  RETURN 0 - n
END FUNC

FUNC addN(a AS Integer, b AS Integer) AS Integer
  RETURN a + b
END FUNC

FUNC keyMod(n AS Integer) AS Integer
  RETURN n MOD 2
END FUNC

FUNC idn(n AS Integer) AS Integer
  RETURN n
END FUNC

FUNC dbl(n AS Integer) AS Integer
  RETURN n * 2
END FUNC

SUB pl(label AS String, v AS List OF Integer)
  MUT s AS String = label & ":"
  FOR EACH n IN v
    s = s & " " & toString(n)
  NEXT
  io::print(s)
END SUB

FUNC twoValues() AS Map OF Integer TO Integer
  RETURN Map OF Integer TO Integer { 1 := 10, 2 := 20 }
END FUNC

FUNC main AS Integer
  pl("sort", collections::sort([3, 1, 2]))
  pl("sortBy", collections::sortBy([3, 1, 2], neg))
  pl("take", collections::take([1, 2, 3, 4], 2))
  pl("drop", collections::drop([1, 2, 3, 4], 2))
  io::print("reduceRight " & toString(collections::reduceRight([1, 2, 3], 0, addN)))
  io::print("any " & toString(collections::any([0, 1], isPos)) & toString(collections::any([0, 0], isPos)))
  io::print("all " & toString(collections::all([1, 2], isPos)) & toString(collections::all([1, 0], isPos)))
  io::print("findIndex " & toString(collections::findIndex([0, 0, 5, 0], isPos)))
  io::print("findLastIndex " & toString(collections::findLastIndex([5, 0, 7, 0], isPos)))
  pl("flatten", collections::flatten([[1, 2], [3], [4, 5]]))
  pl("distinct", collections::distinct([1, 2, 2, 3, 1]))
  io::print("chunks " & toString(len(collections::chunks([1, 2, 3, 4, 5], 2))))
  io::print("window " & toString(len(collections::window([1, 2, 3, 4], 2))))
  LET z AS List OF Pair OF Integer, String = collections::zip([1, 2, 3], ["a", "b"])
  io::print("zip " & toString(len(z)) & " " & toString(collections::get(z, 1).first) & collections::get(z, 1).second)
  LET g AS Map OF Integer TO List OF Integer = collections::groupBy([1, 2, 3, 4], keyMod, idn)
  io::print("groupBy " & toString(len(collections::get(g, 0))) & " " & toString(len(collections::get(g, 1))))
  LET mv AS Map OF Integer TO Integer = collections::mapValues(twoValues(), dbl)
  io::print("mapValues " & toString(collections::get(mv, 1)) & " " & toString(collections::get(mv, 2)))
  LET pt AS Partition OF Integer = collections::partition([1, -2, 3, -4], isPos)
  pl("partition.matched", pt.matched)
  pl("partition.unmatched", pt.unmatched)
  RETURN 0
END FUNC
