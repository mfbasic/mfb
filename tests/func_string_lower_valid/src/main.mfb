IMPORT io
IMPORT strings

FUNC lowerValue(value AS String) AS String
  RETURN strings::lower(value)
END FUNC

FUNC main AS Integer
  LET mixed AS String = "CAFÉ"
  io::print(lowerValue(""))
  io::print(lowerValue("HELLO"))
  io::print(lowerValue(mixed))
  io::print(lowerValue("İ"))
  io::print(lowerValue("É日😀"))
  RETURN 0
END FUNC
