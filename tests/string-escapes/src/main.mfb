IMPORT strings

' plan-27: \r, \0, and \u{HEX} string escapes. Each escape-produced string is
' compared byte-for-byte against the same content built from raw bytes, proving
' the lexer decodes the exact scalars (not just golden text).

FUNC crFromByte AS String
  LET bytes AS List OF Byte = [toByte(13)]
  RETURN toString(bytes)
END FUNC

FUNC nulFromByte AS String
  LET bytes AS List OF Byte = [toByte(0)]
  RETURN toString(bytes)
END FUNC

FUNC smileFromBytes AS String
  LET bytes AS List OF Byte = [toByte(240), toByte(159), toByte(152), toByte(128)]
  RETURN toString(bytes)
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC

TESTING
  TGROUP "string escapes"
    TCASE "carriage return decodes to U+000D"
      expectString("\r", crFromByte())
    END TCASE
    TCASE "nul decodes to U+0000"
      expectString("\0", nulFromByte())
    END TCASE
    TCASE "unicode scalar escape decodes ASCII"
      expectString("\u{41}", "A")
      expectString("\u{6a}", "j")
    END TCASE
    TCASE "unicode scalar escape decodes 4-byte emoji"
      expectString("\u{1F600}", smileFromBytes())
    END TCASE
    TCASE "existing escapes unchanged"
      LET quote AS List OF Byte = [toByte(34)]
      LET backslash AS List OF Byte = [toByte(92)]
      LET lf AS List OF Byte = [toByte(10)]
      LET tab AS List OF Byte = [toByte(9)]
      expectString("\"", toString(quote))
      expectString("\\", toString(backslash))
      expectString("\n", toString(lf))
      expectString("\t", toString(tab))
      expectString("\q", "q")
    END TCASE
  END TGROUP
END TESTING
