IMPORT io
IMPORT math

FUNC main AS Integer
  LET p AS Byte = 6
  io::print(toString(math::sqrt(toFixed("2.0")), p))
  io::print(toString(math::exp(toFixed("1.0")), p))
  io::print(toString(math::log(toFixed("10.0")), p))
  io::print(toString(math::log10(toFixed("50.0")), p))
  io::print(toString(math::pow(toFixed("1.5"), toFixed("2.0")), p))
  io::print(toString(math::pow(toFixed("2.0"), toFixed("0.5")), p))
  io::print(toString(math::pow(toFixed("3.0"), toFixed("-2.0")), p))
  io::print(toString(math::sin(toFixed("0.5")), p))
  io::print(toString(math::cos(toFixed("0.5")), p))
  io::print(toString(math::tan(toFixed("1.0")), p))
  io::print(toString(math::asin(toFixed("0.8")), p))
  io::print(toString(math::acos(toFixed("-0.3")), p))
  io::print(toString(math::atan(toFixed("2.0")), p))
  io::print(toString(math::atan2(toFixed("3.0"), toFixed("-4.0")), p))
  RETURN 0
END FUNC
