{
  "format": "mfb-ir",
  "version": 1,
  "project": "control_flow_resource_fail_runtime",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "failOnce",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "path", "type": "String", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "bind", "mutable": false, "name": "f", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "local", "name": "path" }] } },
    { "op": "fail", "error": { "kind": "constructor", "type": "Error", "args": [{ "kind": "const", "type": "Integer", "value": "77050002" }, { "kind": "const", "type": "String", "value": "body fail" }] } }
    ]
  },
  {
    "name": "trapFail",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "path", "type": "String", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "failOnce", "args": [{ "kind": "local", "name": "path" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } },
    {
      "op": "trap",
      "name": "err",
      "body": [
      {
        "op": "if",
        "condition": { "kind": "binary", "op": "<>", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "err" }, "member": "code" }, "right": { "kind": "const", "type": "Integer", "value": "77050002" } },
        "then": [
        { "op": "fail", "error": { "kind": "local", "name": "err" } }
        ],
        "else": [
        ]
      },
      { "op": "return", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } }
      ]
    }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": true, "name": "i", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "0" } },
    {
      "op": "while",
      "loop": "while",
      "condition": { "kind": "binary", "op": "<", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "4000" } },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "trapFail", "args": [{ "kind": "const", "type": "String", "value": "tests/control-flow-resource-fail-runtime/src/main.mfb" }] } },
      { "op": "assign", "name": "i", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } }
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "fail" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
