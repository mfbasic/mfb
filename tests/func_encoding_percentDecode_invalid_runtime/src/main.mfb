IMPORT io
IMPORT encoding
IMPORT errorCode

FUNC doDecode(text AS String) AS String
  RETURN encoding::percentDecode(text)
END FUNC

FUNC attempt(label AS String, text AS String) AS Nothing
  LET r AS String = doDecode(text)
  io::print(label & ": ok")
  RETURN NOTHING
  TRAP(err)
    IF err.code = errorCode::ErrInvalidFormat THEN
      io::print(label & ": ErrInvalidFormat")
    ELSE
      io::print(label & ": other")
    END IF
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  attempt("badescape", "%zz")
  attempt("truncated", "%4")
  attempt("badutf8", "%FF")
  attempt("good", "a%20b")
  RETURN 0
END FUNC
