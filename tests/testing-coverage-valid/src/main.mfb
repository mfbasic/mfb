IMPORT io

FUNC classify(n AS Integer) AS String
  IF n > 0 THEN
    RETURN "positive"
  END IF
  RETURN "nonpositive"
END FUNC

FUNC main AS Integer
  io::print("dropped under mfb test")
  RETURN 0
END FUNC

TESTING
  TGROUP "classify"
    TCASE "only the positive branch is exercised"
      expectEQ(classify(5), "positive")
    END TCASE
    TCASE "this assertion fails on its line"
      expectEQ(classify(5), "negative")
    END TCASE
  END TGROUP
END TESTING
