  "types": [
  ],
  "functions": [
  {
    "name": "load",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "path", "type": "String", "default": null }
    ],
    "returns": "String",
    "body": [
    {
      "op": "if",
      "condition": { "kind": "binary", "op": "=", "left": { "kind": "local", "name": "path" }, "right": { "kind": "const", "type": "String", "value": "" } },
      "then": [
      { "op": "fail", "error": { "kind": "constructor", "type": "Error", "args": [{ "kind": "const", "type": "Integer", "value": "77050002" }, { "kind": "const", "type": "String", "value": "path is empty" }, { "kind": "constructor", "type": "ErrorLoc", "args": [{ "kind": "const", "type": "String", "value": "src/main.mfb" }, { "kind": "const", "type": "Integer", "value": "6" }, { "kind": "const", "type": "Integer", "value": "10" }] }] } }
      ],
      "else": [
      ]
    },
    { "op": "return", "value": { "kind": "local", "name": "path" } }
    ]
  },
  {
    "name": "reload",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "path", "type": "String", "default": null }
    ],
    "returns": "String",
    "body": [
    { "op": "return", "value": { "kind": "call", "target": "load", "args": [{ "kind": "local", "name": "path" }] } }
    ]
  },
  {
    "name": "divide",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "a", "type": "Integer", "default": null },
    { "name": "b", "type": "Integer", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "return", "value": { "kind": "binary", "op": "/", "left": { "kind": "local", "name": "a" }, "right": { "kind": "local", "name": "b" } } }
    ]
  },
  {
    "name": "show",
    "visibility": "private",
    "kind": "sub",
    "params": [
    { "name": "label", "type": "String", "default": null },
    { "name": "e", "type": "Error", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "label" }, "right": { "kind": "const", "type": "String", "value": " " } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "code" }] } }, "right": { "kind": "const", "type": "String", "value": " " } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "message" } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "  at " }, "right": { "kind": "memberAccess", "target": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "source" }, "member": "filename" } }, "right": { "kind": "const", "type": "String", "value": ":" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "source" }, "member": "line" }] } }, "right": { "kind": "const", "type": "String", "value": ":" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "source" }, "member": "char" }] } }] } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "$trap_res0", "type": "Result OF String", "value": { "kind": "callResult", "target": "load", "args": [{ "kind": "const", "type": "String", "value": "" }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val1", "type": "String", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res0" } },
      "then": [
      { "op": "assign", "name": "$trap_val1", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res0" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "e", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res0" } } },
      { "op": "eval", "value": { "kind": "call", "target": "show", "args": [{ "kind": "const", "type": "String", "value": "direct" }, { "kind": "local", "name": "e" }] } },
      { "op": "assign", "name": "$trap_val1", "value": { "kind": "const", "type": "String", "value": "" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "direct", "type": "String", "value": { "kind": "local", "name": "$trap_val1" } },
    { "op": "bind", "mutable": false, "name": "$trap_res2", "type": "Result OF String", "value": { "kind": "callResult", "target": "reload", "args": [{ "kind": "const", "type": "String", "value": "" }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val3", "type": "String", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res2" } },
      "then": [
      { "op": "assign", "name": "$trap_val3", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res2" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "e", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res2" } } },
      { "op": "eval", "value": { "kind": "call", "target": "show", "args": [{ "kind": "const", "type": "String", "value": "propagated" }, { "kind": "local", "name": "e" }] } },
      { "op": "assign", "name": "$trap_val3", "value": { "kind": "const", "type": "String", "value": "" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "propagated", "type": "String", "value": { "kind": "local", "name": "$trap_val3" } },
    { "op": "bind", "mutable": false, "name": "$trap_res4", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "divide", "args": [{ "kind": "const", "type": "Integer", "value": "10" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val5", "type": "Integer", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res4" } },
      "then": [
      { "op": "assign", "name": "$trap_val5", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res4" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "e", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res4" } } },
      { "op": "eval", "value": { "kind": "call", "target": "show", "args": [{ "kind": "const", "type": "String", "value": "divide" }, { "kind": "local", "name": "e" }] } },
      { "op": "assign", "name": "$trap_val5", "value": { "kind": "const", "type": "Integer", "value": "0" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "quotient", "type": "Integer", "value": { "kind": "local", "name": "$trap_val5" } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
