IMPORT net
IMPORT io

FUNC main AS Integer
  RES server = net::bindUdp("127.0.0.1", 0)
  net::setReadTimeout(server, 2000)
  LET bound = net::localAddress(server)
  RES client = net::bindUdp("127.0.0.1", 0)
  LET dest = get(net::lookup("127.0.0.1", bound.port), 0)
  LET payload AS List OF Byte = [65, 66, 67]
  net::sendTo(client, dest, payload)
  LET dg = net::receiveFrom(server, 16)
  io::print(toString(len(dg.bytes)))
  io::print(toString(get(dg.bytes, 0)))
  io::print(toString(get(dg.bytes, 2)))
  io::print(dg.from.host)
  net::close(server)
  net::close(client)
  RETURN 0
END FUNC
