IMPORT io
IMPORT math

FUNC main AS Integer
  LET pi AS Float = math::pi
  LET piFixed AS Fixed = math::piFixed
  LET twoPi AS Float = math::2pi
  LET twoPiFixed AS Fixed = math::2piFixed
  LET pi2 AS Float = math::pi2
  LET pi2Fixed AS Fixed = math::pi2Fixed
  LET pi4 AS Float = math::pi4
  LET pi4Fixed AS Fixed = math::pi4Fixed
  LET e AS Float = math::e
  LET eFixed AS Fixed = math::eFixed
  LET ln2 AS Float = math::ln2
  LET ln2Fixed AS Fixed = math::ln2Fixed
  LET ln10 AS Float = math::ln10
  LET ln10Fixed AS Fixed = math::ln10Fixed
  LET p AS Byte = 6
  LET fixedSpread AS Fixed = piFixed - eFixed
  LET fixedLow AS Fixed = toFixed("0.25")
  LET fixedHigh AS Fixed = toFixed("1.75")
  LET fixedOneHalf AS Fixed = toFixed("1.50")
  LET fixedTwo AS Fixed = toFixed("2.00")
  LET fixedThreeQuarter AS Fixed = toFixed("3.75")
  LET fixedThreeAndHalf AS Fixed = toFixed("3.5")
  LET fixedZero AS Fixed = toFixed("0.0")
  LET fixedHalf AS Fixed = toFixed("0.5")
  LET fixedAbsolute AS Fixed = math::abs(fixedSpread)
  LET fixedMinimum AS Fixed = math::min(piFixed, eFixed)
  LET fixedMaximum AS Fixed = math::max(piFixed, eFixed)
  LET fixedClamped AS Fixed = math::clamp(fixedSpread, eFixed, piFixed)
  LET fixedFloored AS Integer = math::floor(fixedSpread)
  LET fixedCeiled AS Integer = math::ceil(fixedSpread)
  LET fixedRounded AS Integer = math::round(fixedSpread)
  LET fixedRoot AS Fixed = math::sqrt(toFixed("9.0"))
  LET fixedRaised AS Fixed = math::pow(fixedOneHalf, fixedTwo)
  LET fixedExponential AS Fixed = math::exp(toFixed("1.0"))
  LET fixedNaturalLog AS Fixed = math::log(toFixed("1.0"))
  LET fixedCommonLog AS Fixed = math::log10(toFixed("100.0"))
  LET fixedSine AS Fixed = math::sin(piFixed)
  LET fixedCosine AS Fixed = math::cos(piFixed)
  LET fixedTangent AS Fixed = math::tan(fixedZero)
  LET fixedArcsine AS Fixed = math::asin(fixedHalf)
  LET fixedArccosine AS Fixed = math::acos(fixedHalf)
  LET fixedArctangent AS Fixed = math::atan(toFixed("1.0"))
  LET fixedArctangent2 AS Fixed = math::atan2(toFixed("1.0"), toFixed("1.0"))
  LET absoluteInteger AS Integer = math::abs(-42)
  LET absoluteFloat AS Float = math::abs(0.0 - 3.5)
  LET minimum AS Integer = math::min(4, 9)
  LET maximum AS Integer = math::max(4, 9)
  LET minimumFloat AS Float = math::min(pi, e)
  LET maximumFloat AS Float = math::max(pi, e)
  LET clamped AS Integer = math::clamp(12, 0, 10)
  LET clampedFloat AS Float = math::clamp(pi, e, 4.0)
  LET floored AS Integer = math::floor(3.75)
  LET ceiled AS Integer = math::ceil(3.25)
  LET rounded AS Integer = math::round(3.5)
  LET root AS Float = math::sqrt(9.0)
  LET raised AS Float = math::pow(2.0, 8.0)
  LET exponential AS Float = math::exp(1.0)
  LET naturalLog AS Float = math::log(e)
  LET commonLog AS Float = math::log10(100.0)
  LET sine AS Float = math::sin(pi)
  LET cosine AS Float = math::cos(pi)
  LET tangent AS Float = math::tan(0.0)
  LET arcsine AS Float = math::asin(0.5)
  LET arccosine AS Float = math::acos(0.5)
  LET arctangent AS Float = math::atan(1.0)
  LET arctangent2 AS Float = math::atan2(1.0, 1.0)
  io::print(toString(pi, p))
  io::print(toString(piFixed, p))
  io::print(toString(twoPi, p))
  io::print(toString(twoPiFixed, p))
  io::print(toString(pi2, p))
  io::print(toString(pi2Fixed, p))
  io::print(toString(pi4, p))
  io::print(toString(pi4Fixed, p))
  io::print(toString(e, p))
  io::print(toString(eFixed, p))
  io::print(toString(ln2, p))
  io::print(toString(ln2Fixed, p))
  io::print(toString(ln10, p))
  io::print(toString(ln10Fixed, p))
  io::print(toString(absoluteInteger))
  io::print(toString(absoluteFloat, p))
  io::print(toString(fixedAbsolute, p))
  io::print(toString(minimum))
  io::print(toString(minimumFloat, p))
  io::print(toString(fixedMinimum, p))
  io::print(toString(maximum))
  io::print(toString(maximumFloat, p))
  io::print(toString(fixedMaximum, p))
  io::print(toString(clamped))
  io::print(toString(clampedFloat, p))
  io::print(toString(math::clamp(fixedOneHalf, fixedLow, fixedHigh), p))
  io::print(toString(floored))
  io::print(toString(math::floor(fixedThreeQuarter)))
  io::print(toString(ceiled))
  io::print(toString(math::ceil(toFixed("3.25"))))
  io::print(toString(rounded))
  io::print(toString(math::round(fixedThreeAndHalf)))
  io::print(toString(root, p))
  io::print(toString(fixedRoot, p))
  io::print(toString(raised, p))
  io::print(toString(fixedRaised, p))
  io::print(toString(exponential, p))
  io::print(toString(fixedExponential, p))
  io::print(toString(naturalLog, p))
  io::print(toString(fixedNaturalLog, p))
  io::print(toString(commonLog, p))
  io::print(toString(fixedCommonLog, p))
  io::print(toString(sine, p))
  io::print(toString(fixedSine, p))
  io::print(toString(cosine, p))
  io::print(toString(fixedCosine, p))
  io::print(toString(tangent, p))
  io::print(toString(fixedTangent, p))
  io::print(toString(arcsine, p))
  io::print(toString(fixedArcsine, p))
  io::print(toString(arccosine, p))
  io::print(toString(fixedArccosine, p))
  io::print(toString(arctangent, p))
  io::print(toString(fixedArctangent, p))
  io::print(toString(arctangent2, p))
  io::print(toString(fixedArctangent2, p))

  RETURN absoluteInteger + minimum + maximum + clamped + floored + ceiled + rounded + fixedFloored + fixedCeiled + fixedRounded
END FUNC
