TYPE Empty
END TYPE

TYPE Pair
  left AS Integer
  right AS Integer
END TYPE

ENUM Mode
  On
END ENUM

UNION Shape
  Point
END UNION

SUB main()
  LET empty AS Empty = Empty[]
  LET tooFew AS Pair = Pair[1]
  LET tooMany AS Pair = Pair[1, 2, 3]
  LET wrongType AS Pair = Pair["left", 2]
  LET enumCtor = Mode[]
  LET unionCtor = Shape[]
END SUB
