TYPE Vec3
  x AS Float
  y AS Float
  z AS Float
END TYPE

UNION Shape
  Circle(radius AS Float)
  Rect(w AS Float, h AS Float)
  Point
END UNION

UNION ExtraShape INCLUDES Shape
  Triangle(a AS Float, b AS Float, c AS Float)
END UNION

ENUM Color
  Red, Green
  Blue
END ENUM

SUB main()
  LET name AS String = "Ada"
END SUB
