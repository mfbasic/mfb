    { "op": "bind", "mutable": false, "name": "list", "type": "List OF String", "value": { "kind": "call", "target": "passList", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "a" }, { "kind": "call", "target": "join", "args": [{ "kind": "const", "type": "String", "value": "b" }, { "kind": "const", "type": "String", "value": "c" }] }] }] } },
    { "op": "bind", "mutable": false, "name": "map", "type": "Map OF String TO Integer", "value": { "kind": "call", "target": "passMap", "args": [{ "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "x" }, "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "pair" }, "member": "value" } }, { "key": { "kind": "const", "type": "String", "value": "y" }, "value": { "kind": "const", "type": "Integer", "value": "2" } }] }] } },
    { "op": "bind", "mutable": false, "name": "seed", "type": "String", "value": { "kind": "const", "type": "String", "value": "0123456789012345678901234567890123456789012345678901234567890123" } },
    { "op": "bind", "mutable": false, "name": "grown", "type": "String", "value": { "kind": "call", "target": "grow", "args": [{ "kind": "call", "target": "grow", "args": [{ "kind": "call", "target": "grow", "args": [{ "kind": "call", "target": "grow", "args": [{ "kind": "call", "target": "grow", "args": [{ "kind": "call", "target": "grow", "args": [{ "kind": "call", "target": "grow", "args": [{ "kind": "local", "name": "seed" }] }] }] }] }] }] }] } },
    { "op": "return", "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "pair" }, "member": "value" } }
