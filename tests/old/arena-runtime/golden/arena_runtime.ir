    { "op": "bind", "mutable": false, "name": "text", "type": "String", "value": { "kind": "call", "target": "join", "args": [{ "kind": "const", "type": "String", "value": "arena" }, { "kind": "const", "type": "String", "value": "-value" }] } },
    { "op": "return", "value": { "kind": "constructor", "type": "Pair", "args": [{ "kind": "local", "name": "text" }, { "kind": "const", "type": "Integer", "value": "14" }] } }
    ]
  },
  {
