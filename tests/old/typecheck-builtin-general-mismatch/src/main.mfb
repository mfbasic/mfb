FUNC main AS Integer
  LET badLen AS Integer = len(TRUE)
  LET badFind AS Integer = find("abc", 1)
  LET badMid AS String = mid("abc", 0)
  LET badToString AS String = toString(Error[10002, "invalid"])
  LET badToInt AS Integer = toInt(TRUE)
  LET badToFloat AS Float = toFloat(TRUE)
  LET badToFixed AS Fixed = toFixed(TRUE)
  LET badToByte AS Byte = toByte("1")
  LET badIsNumeric AS Boolean = isNumeric(1)
  LET badIsEven AS Boolean = isEven("2")
  LET badIsPositive AS Boolean = isPositive(TRUE)
  LET badIsNegative AS Boolean = isNegative("1")
  LET badIsZero AS Boolean = isZero(TRUE)
  LET badIsEmpty AS Boolean = isEmpty(1)
  LET badIsNotEmpty AS Boolean = isNotEmpty(TRUE)
  RETURN badLen + badFind + badToInt
END FUNC
