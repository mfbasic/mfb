FUNC main AS Integer
  LET missing AS String = replace()
  LET wrongValue AS String = replace(42, "l", "x")
  LET wrongOld AS String = replace("hello", 1, "x")
  LET wrongNew AS String = replace("hello", "l", 1)
  LET tooMany AS String = replace("hello", "l", "x", "extra")
  LET badName AS String = replace(source := "hello", old := "l", new := "x")
  RETURN 0
END FUNC
