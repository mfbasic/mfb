IMPORT strings
IMPORT io

FUNC main AS Integer
  LET text AS String = "hello"
  LET simple AS String = strings::replace(text, "l", "x")
  LET named AS String = strings::replace(value := text, old := "l", new := "q")
  LET nonOverlap AS String = strings::replace("aaaa", "aa", "b")
  LET deleteMatch AS String = strings::replace("banana", "na", "")
  LET unicode AS String = strings::replace("aé日é", "é", "E")
  LET noMatch AS String = strings::replace(text, "z", "x")
  LET oldTooLong AS String = strings::replace("hi", "long", "x")
  LET emptyOld AS String = strings::replace("hi", "", "x")
  LET overlapCandidate AS String = strings::replace("ababa", "aba", "x")

  io::print(simple)
  io::print(named)
  io::print(nonOverlap)
  io::print(deleteMatch)
  io::print(unicode)
  io::print(noMatch)
  io::print(oldTooLong)
  io::print(emptyOld)
  io::print(overlapCandidate)

  LET simpleLen AS Integer = len(simple)
  LET namedLen AS Integer = len(named)
  LET nonOverlapLen AS Integer = len(nonOverlap)
  LET deleteLen AS Integer = len(deleteMatch)
  LET unicodeLen AS Integer = len(unicode)
  LET noMatchLen AS Integer = len(noMatch)
  LET oldTooLongLen AS Integer = len(oldTooLong)
  LET emptyOldLen AS Integer = len(emptyOld)
  LET overlapLen AS Integer = len(overlapCandidate)

  RETURN simpleLen + namedLen + nonOverlapLen + deleteLen + unicodeLen + noMatchLen + oldTooLongLen + emptyOldLen + overlapLen
END FUNC
