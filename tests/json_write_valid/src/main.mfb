IMPORT fs
IMPORT io
IMPORT json

FUNC main AS Integer
  LET path AS String = "target/json_write_valid.json"
  LET value AS Json = Obj[Map OF String TO Json { "name" := Str["Ada"], "enabled" := Bool[TRUE] }]
  LET text AS String = json::stringify(value)
  fs::writeText(path, text)
  io::print(fs::readText(path))
  io::print(json::stringify(json::get(json::parse(fs::readText(path)), ["name"])))
  fs::deleteFile(path)
  RETURN 0
END FUNC
