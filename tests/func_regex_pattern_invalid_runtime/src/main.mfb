IMPORT io
IMPORT regex

REM Invalid patterns (regex.md §14) must fail with ErrInvalidFormat (77050003)
REM at runtime — not map to FALSE, -1, or an unchanged string. Each call is
REM wrapped so the run reports "invalid" (with the code) instead of aborting.

FUNC tryMatch(pattern AS String) AS Nothing
  LET ok AS Boolean = regex::match("sample", pattern)
  io::print("matched " & toString(ok))
  RETURN NOTHING
  TRAP(err)
    io::print("invalid " & toString(err.code))
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  tryMatch("(")
  tryMatch(")")
  tryMatch("[")
  tryMatch("[]")
  tryMatch("[^]")
  tryMatch("[z-a]")
  tryMatch("a{2,1}")
  tryMatch("*")
  tryMatch("a**")
  tryMatch("\\q")
  tryMatch("\\1")
  tryMatch("(?=x)")
  tryMatch("(?!x)")
  tryMatch("(?<=x)")
  tryMatch("(?<!x)")
  tryMatch("(?P=name)")
  tryMatch("(?)")
  tryMatch("(?q)")
  tryMatch("(?-)")
  tryMatch("(?<>x)")
  tryMatch("\\p{Nope}")
  tryMatch("\\x{110000}")
  tryMatch("\\xZZ")
  tryMatch("[a&&b]")
  tryMatch("(?<dup>a)(?<dup>b)")
  REM a valid pattern still works after the failures
  tryMatch("sa.ple")
  RETURN 0
END FUNC
