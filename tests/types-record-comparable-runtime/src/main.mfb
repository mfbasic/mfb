IMPORT io

TYPE Point
  x AS Integer
  y AS Integer
END TYPE

TYPE Person
  name AS String
  city AS String
END TYPE

TYPE Badge
  owner AS Person
  level AS Integer
END TYPE

FUNC printBoolean(value AS Boolean) AS Nothing
  io::print(toString(value))
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  LET firstPoint AS Point = Point[1, 2]
  LET samePoint AS Point = Point[1, 2]
  LET otherPoint AS Point = Point[2, 1]

  LET ada AS Person = Person["A" & "da", "Love" & "lace"]
  LET sameAda AS Person = Person["Ad" & "a", "Lovel" & "ace"]
  LET grace AS Person = Person["Grace", "Hopper"]

  LET firstBadge AS Badge = Badge[ada, 7]
  LET sameBadge AS Badge = Badge[sameAda, 7]
  LET otherBadge AS Badge = Badge[sameAda, 8]

  printBoolean(firstPoint = samePoint)
  printBoolean(firstPoint <> otherPoint)
  printBoolean(ada = sameAda)
  printBoolean(ada <> grace)
  printBoolean(firstBadge = sameBadge)
  printBoolean(firstBadge <> otherBadge)

  LET people AS List OF Person = [ada, grace]
  LET pair AS List OF Person = [sameAda, grace]
  printBoolean(contains(people, sameAda))
  io::print(toString(find(people, sameAda)))
  io::print(toString(find(people, pair)))
  LET replaced AS List OF Person = replace(people, sameAda, Person["Katherine", "Johnson"])
  LET replacedFirst AS Person = get(replaced, 0)
  io::print(replacedFirst.name)

  LET pointLabels AS Map OF Point TO String = Map OF Point TO String { firstPoint := "first" }
  io::print(get(pointLabels, samePoint))

  LET scores AS Map OF Person TO Integer = Map OF Person TO Integer { ada := 1, grace := 2 }
  printBoolean(hasKey(scores, sameAda))
  io::print(toString(get(scores, sameAda)))
  LET updated AS Map OF Person TO Integer = set(scores, sameAda, 10)
  io::print(toString(get(updated, ada)))
  io::print(toString(len(updated)))
  LET removed AS Map OF Person TO Integer = removeKey(updated, sameAda)
  io::print(toString(len(removed)))
  printBoolean(hasKey(removed, ada))

  RETURN 0
END FUNC
