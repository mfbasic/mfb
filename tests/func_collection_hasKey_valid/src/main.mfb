IMPORT collections
IMPORT io

FUNC main AS Integer
  LET names AS Map OF String TO Integer = Map OF String TO Integer { "Ada" := 36, "Grace" := 85 }
  LET codes AS Map OF Integer TO String = Map OF Integer TO String { 1 := "one", 2 := "two" }
  LET hitString AS Boolean = collections::hasKey(names, "Ada")
  LET missString AS Boolean = collections::hasKey(names, "Katherine")
  LET hitInteger AS Boolean = collections::hasKey(codes, 2)
  LET missInteger AS Boolean = collections::hasKey(codes, 3)

  io::print(toString(hitString))
  io::print(toString(missString))
  io::print(toString(hitInteger))
  io::print(toString(missInteger))

  RETURN 0
END FUNC
