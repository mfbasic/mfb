    { "op": "bind", "mutable": false, "name": "names", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "Ada" }, "value": { "kind": "const", "type": "Integer", "value": "36" } }, { "key": { "kind": "const", "type": "String", "value": "Grace" }, "value": { "kind": "const", "type": "Integer", "value": "85" } }] } },
    { "op": "bind", "mutable": false, "name": "codes", "type": "Map OF Integer TO String", "value": { "kind": "map", "type": "Map OF Integer TO String", "entries": [{ "key": { "kind": "const", "type": "Integer", "value": "1" }, "value": { "kind": "const", "type": "String", "value": "one" } }, { "key": { "kind": "const", "type": "Integer", "value": "2" }, "value": { "kind": "const", "type": "String", "value": "two" } }] } },
    { "op": "bind", "mutable": false, "name": "hitString", "type": "Boolean", "value": { "kind": "call", "target": "hasKey", "args": [{ "kind": "local", "name": "names" }, { "kind": "const", "type": "String", "value": "Ada" }] } },
    { "op": "bind", "mutable": false, "name": "missString", "type": "Boolean", "value": { "kind": "call", "target": "hasKey", "args": [{ "kind": "local", "name": "names" }, { "kind": "const", "type": "String", "value": "Katherine" }] } },
    { "op": "bind", "mutable": false, "name": "hitInteger", "type": "Boolean", "value": { "kind": "call", "target": "hasKey", "args": [{ "kind": "local", "name": "codes" }, { "kind": "const", "type": "Integer", "value": "2" }] } },
    { "op": "bind", "mutable": false, "name": "missInteger", "type": "Boolean", "value": { "kind": "call", "target": "hasKey", "args": [{ "kind": "local", "name": "codes" }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "hitString" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "missString" }] }] } },
