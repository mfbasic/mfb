TYPE Pair
  text AS String
  value AS Integer
END TYPE

FUNC join(left AS String, right AS String) AS String
  RETURN left & right
END FUNC

FUNC grow(value AS String) AS String
  RETURN value & value
END FUNC

FUNC makePair() AS Pair
  LET text AS String = join("arena", "-value")
  RETURN Pair[text, 14]
END FUNC

FUNC passList(value AS List OF String) AS List OF String
  RETURN value
END FUNC

FUNC passMap(value AS Map OF String TO Integer) AS Map OF String TO Integer
  RETURN value
END FUNC

FUNC main() AS Integer
  LET pair AS Pair = makePair()
  LET list AS List OF String = passList(["a", join("b", "c")])
  LET map AS Map OF String TO Integer = passMap(Map OF String TO Integer { "x" := pair::value, "y" := 2 })
  LET seed AS String = "0123456789012345678901234567890123456789012345678901234567890123"
  LET grown AS String = grow(grow(grow(grow(grow(grow(grow(seed)))))))
  RETURN pair::value
END FUNC
