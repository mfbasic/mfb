IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("normalize Float2 = " & toString(vector::normalize(vector::Float2[3.0, 4.0])))
  io::print("normalize Float3 = " & toString(vector::normalize(vector::Float3[1.0, 2.0, 2.0])))
  io::print("normalize Float4 = " & toString(vector::normalize(vector::Float4[1.0, 2.0, 2.0, 4.0])))
  io::print("normalize Fixed2 = " & toString(vector::normalize(vector::Fixed2[toFixed(3.0), toFixed(4.0)])))
  io::print("normalize Fixed3 = " & toString(vector::normalize(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)])))
  io::print("normalize Fixed4 = " & toString(vector::normalize(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)])))
  io::print("normalize Integer2 = " & toString(vector::normalize(vector::Integer2[3, 4])))
  io::print("normalize Integer3 = " & toString(vector::normalize(vector::Integer3[1, 2, 2])))
  io::print("normalize Integer4 = " & toString(vector::normalize(vector::Integer4[1, 2, 2, 4])))
  RETURN 0
END FUNC
