IMPORT net
IMPORT io

FUNC main AS Integer
  RES server = net::listenTcp("127.0.0.1", 0)
  LET bound = net::localAddress(server)
  RES c1 = net::connectTcp("127.0.0.1", bound.port)
  RES c2 = net::connectTcp("127.0.0.1", bound.port)
  RES conn1 = net::accept(server)
  RES conn2 = net::accept(server, 5000)
  io::print("accepted two")
  RETURN 0
END FUNC
