IMPORT thread
IMPORT thread_workers

FUNC main AS Integer
  LET t AS Thread OF String TO Integer = thread::start(thread_workers::echoText, "a", 1, 1)
  LET wrongHandle AS Boolean = thread::isCancelled(t)
  LET wrongType AS Boolean = thread::isCancelled(1)
  LET tooMany AS Boolean = thread::isCancelled(1, 2)
  RETURN 0
END FUNC
