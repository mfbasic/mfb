IMPORT collections
IMPORT package_comparable_types AS comparable

FUNC main AS Integer
  LET first AS comparable::Box = comparable::Box[[1, 2]]
  LET second AS comparable::Box = comparable::Box[[3, 4]]
  LET items AS List OF comparable::Box = [first, second]
  LET badMap = Map OF comparable::Box TO Integer { first := 1 }
  LET badFind AS Integer = collections::find(items, second)
  RETURN len(badMap) + badFind
END FUNC
