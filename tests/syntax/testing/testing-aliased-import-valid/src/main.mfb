' bug-287: every package the synthesized test driver needs (io) and every
' package the coverage helpers need (collections, fs) is imported here ONLY
' under an alias. An aliased import binds just the alias, so `mfb test` must
' still inject the plain imports its generated code names.
IMPORT io AS console
IMPORT collections AS coll
IMPORT fs AS files

FUNC label(n AS Integer) AS String
  IF n > 0 THEN
    RETURN "positive"
  END IF
  RETURN "nonpositive"
END FUNC

FUNC main AS Integer
  console::print("dropped under mfb test")
  RETURN 0
END FUNC

TESTING
  TGROUP "aliased imports"
    TCASE "the driver runs"
      expectEqual(label(5), "positive")
    END TCASE
    TCASE "a failing case still reports"
      expectEqual(label(5), "negative")
    END TCASE
  END TGROUP
END TESTING
