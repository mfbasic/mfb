IMPORT io

FUNC encode(value AS String) AS List OF Byte
  RETURN [toByte(65)]
END FUNC

FUNC encode(value AS String) AS List OF Integer
  RETURN [1]
END FUNC

FUNC main AS Integer
  ' No annotation supplies an expected type, so the return-type overload is
  ' ambiguous (§F.3).
  LET x = encode("hi")
  RETURN 0
END FUNC
