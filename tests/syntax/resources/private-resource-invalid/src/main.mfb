' bug-288: PRIVATE on a RESOURCE was accepted by the parser but only
' half-applied by scope_privates - the declaration was renamed without being
' registered as a private type, so every reference kept the original spelling
' and the build failed with a wall of SYMBOL_UNKNOWN_TYPE plus a
' RESOURCE_CLOSE_SIGNATURE naming the mangled name. RESOURCE is not a
' visibility-carrying item per spec 13, so it is rejected outright.
IMPORT io

LINK "sqlite3" AS sql
  FUNC closeDb(h AS Integer) AS Integer
    SYMBOL "sqlite3_close"
    ABI (db CPtr) AS rc CInt
    RETURN rc
  END FUNC
END LINK

PRIVATE RESOURCE Db CLOSE BY sql::closeDb

FUNC main AS Integer
  io::print("hi")
  RETURN 0
END FUNC
