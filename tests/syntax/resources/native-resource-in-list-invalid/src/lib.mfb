' A List may hold borrows of a native resource, but the element must carry the
' `RES` ownership-axis marker (`List OF RES Db`); a bare `List OF Db` is rejected
' just like `AS Db` without `RES` (§15.6).
EXPORT RESOURCE Db CLOSE BY demoLink::close
LINK "demo" AS demoLink
  FUNC open(path AS String) AS RES Db
    SYMBOL "demo_open"
    ABI (path CString, return OUT CPtr) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
  FUNC close(RES db AS Db) AS Nothing
    SYMBOL "demo_close"
    ABI (db CPtr) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
  FUNC busy(RES db AS Db, ms AS Integer) AS Nothing
    SYMBOL "demo_busy"
    ABI (db CPtr, ms CInt32) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
END LINK

EXPORT FUNC bad(path AS String) AS List OF Db
  RES db AS Db = demoLink::open(path)
  LET xs AS List OF Db = [db]
  RETURN xs
END FUNC
