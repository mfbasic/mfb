' Closing on one branch then unconditionally closing double-closes a native
' resource on the flag=TRUE path (§12 control-flow).
EXPORT RESOURCE Db CLOSE BY demoLink::close
LINK "demo" AS demoLink
  FUNC open(path AS String) AS RES Db
    SYMBOL "demo_open"
    ABI (path CString, db OUT CPtr) AS status CInt32
    RETURN db
    SUCCESS_ON status = 0
  END FUNC
  FUNC close(RES db AS Db) AS Nothing
    SYMBOL "demo_close"
    ABI (db CPtr) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
END LINK

EXPORT FUNC bad(path AS String, flag AS Boolean) AS Nothing
  RES db AS Db = demoLink::open(path)
  IF flag THEN
    demoLink::close(db)
  END IF
  demoLink::close(db)
END FUNC
