IMPORT io
IMPORT fs

TYPE Cursor
  pos AS Integer
END TYPE

' plan-52-A row 4 (plan-52-C): a `STATE T` parameter given a STATELESS argument
' must be rejected — parameters observe, they never attach. Attachment happens
' exactly once, at the owning binding (§15.5).
'
' Param-attach is what makes two disagreeing borrows reachable with no stateful
' binding anywhere: a second parameter declaring `STATE Label` would then read
' this same block as a Label. See resource-state-param-mismatch-invalid.
SUB tag(RES p AS File STATE Cursor)
  p.state.pos = 7
  io::print(toString(p.state.pos))
END SUB

FUNC main AS Integer
  RES f AS File = fs::openFile("tests/syntax/resources/resource-state-param-attach-invalid/src/main.mfb")
  tag(f)
  fs::close(f)
  RETURN 0
END FUNC
