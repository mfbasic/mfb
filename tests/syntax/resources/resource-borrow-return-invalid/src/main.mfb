IMPORT fs

' plan-52-A row 10: `RETURN` of a borrowed parameter is rejected. This is the
' rule the whole STATE model rests on: a bare parameter may forget the state its
' argument carries (§15.5) ONLY because the borrow cannot outlive the frame that
' took it. If a borrow could escape, the opaque reading would leak a resource
' whose state type nobody agrees on.
'
' Its sibling resource-borrow-invalidate-invalid pins the close-a-borrow case;
' this one pins the escape.
FUNC steal(RES p AS File) AS RES File
  RETURN p
END FUNC

FUNC main AS Integer
  RES f AS File = fs::openFile("tests/syntax/resources/resource-borrow-return-invalid/src/main.mfb")
  RES g AS File = steal(f)
  fs::close(g)
  RETURN 0
END FUNC
