' plan-53-A guardrail: a native resource's STATE type is fixed, so two native
' declarations of one resource — a producer's `AS RES Db STATE A` and the close
' op's `RES db AS Db STATE B` — must agree. The payload carries no runtime tag,
' so a producer allocating an `A` and a close reading it as `B` is the same
' untagged type confusion plan-52-C rejects at an ordinary parameter, here at the
' native boundary (TYPE_STATE_MISMATCH).
EXPORT RESOURCE Db CLOSE BY sql::close

EXPORT TYPE A
  x AS Integer
END TYPE

EXPORT TYPE B
  y AS String
END TYPE

LINK "sqlite3" AS sql
  FUNC open(path AS String) AS RES Db STATE A
    SYMBOL "sqlite3_open"
    ABI (path CString, db OUT CPtr) AS status CInt32
    RETURN db
    SUCCESS_ON status = 0
  END FUNC
  FUNC close(RES db AS Db STATE B) AS Nothing
    SYMBOL "sqlite3_close"
    ABI (db CPtr) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
END LINK
