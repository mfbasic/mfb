' plan-58-A rule 9, tightened by plan-58-B: a `BUFFER … SIZE` expression may read
' the wrapper's PARAMETERS and its CONST pins, and nothing else.
'
' That is narrower than SUCCESS_ON/RETURN on purpose. Those are evaluated AFTER
' the native call; a SIZE expression is evaluated during STAGING, to decide how
' many bytes to allocate before the call runs. So the ABI return and every OUT
' slot are still uninitialized frame memory at that point — naming one is a
' causality error, and accepting it would size a buffer from stack garbage.
LINK "demo" AS demoLink
  ' An outright unknown name.
  FUNC badSize(n AS Integer) AS List OF Byte
    SYMBOL "demo_read"
    ABI (buf OUT CBuffer, n CInt64) AS status CInt32
    BUFFER buf SIZE nosuch
    RETURN buf
  END FUNC

  ' The ABI return: real, but does not exist yet.
  FUNC sizeFromStatus(n AS Integer) AS List OF Byte
    SYMBOL "demo_read2"
    ABI (buf OUT CBuffer, n CInt64) AS status CInt32
    BUFFER buf SIZE status
    RETURN buf
  END FUNC

  ' An OUT slot: whatever the callee writes, which has not happened yet.
  FUNC sizeFromOut(n AS Integer) AS List OF Byte
    SYMBOL "demo_read3"
    ABI (buf OUT CBuffer, n CInt64, written OUT CInt64) AS status CInt32
    BUFFER buf SIZE written
    RETURN buf
  END FUNC
END LINK
