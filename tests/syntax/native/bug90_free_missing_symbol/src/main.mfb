' bug-90: a FREE block missing its SYMBOL/ABI clauses was silently dropped (the
' declared deallocator vanished, leaking the native return buffer). It must now
' be diagnosed as a malformed FREE block (NATIVE_FREE_INVALID).
IMPORT io
RESOURCE Handle CLOSE BY demoLink::release
LINK "demo" AS demoLink
  FUNC release(RES h AS Handle) AS Nothing
    SYMBOL "demo_release"
    ABI (h CPtr) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
  FUNC describe(RES h AS Handle) AS String
    SYMBOL "demo_describe"
    ABI (h CPtr) AS return CPtr
    FREE return
    END FREE
  END FUNC
END LINK
FUNC main() AS Integer
  RETURN 0
END FUNC
