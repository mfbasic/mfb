IMPORT math

' plan-26-A: an inline TRAP is legal on any *call*, so the only rejections left
' are scrutinees with no runtime call to trap. A provably-infallible built-in like
' `len` is now ALLOWED (it warns TYPE_INLINE_TRAP_DEAD_HANDLER instead). These two
' still reject with TYPE_INLINE_TRAP_REQUIRES_FALLIBLE:
FUNC main AS Integer
  ' 1. a non-call literal expression.
  LET a AS Integer = 5 TRAP(e)
    RECOVER 0
  END TRAP
  ' 2. a package constant (not a runtime call).
  LET p AS Float = math::pi() TRAP(e)
    RECOVER 0.0
  END TRAP
  RETURN a
END FUNC
