IMPORT io
IMPORT math
IMPORT collections

' plan-01-libm-kernels Phase 1: scalar math::atan2 runs the SAME strict NEON
' Atan2 kernel as the array overload, so math::atan2(y, x) ==
' math::atan2([y], [x])[0] bit-identically (each printed pair must be equal),
' and no libm atan2 is imported.
SUB one(y AS Float, x AS Float)
  LET p AS Byte = 17
  LET yl AS List OF Float = [y]
  LET xl AS List OF Float = [x]
  io::print(toString(math::atan2(y, x), p) & " " & toString(collections::get(math::atan2(yl, xl), 0), p))
END SUB

FUNC main AS Integer
  one(1.0, 1.0)
  one(3.0, 4.0)
  LET ny AS Float = 0.0 - 2.0
  LET nx AS Float = 0.0 - 3.0
  one(ny, nx)
  one(0.5, 0.0)
  RETURN 0
END FUNC
