{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_collection_sum_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "integers", "type": "List OF Integer", "value": { "kind": "list", "type": "List OF Integer", "values": [{ "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "2" }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "bind", "mutable": false, "name": "floats", "type": "List OF Float", "value": { "kind": "list", "type": "List OF Float", "values": [{ "kind": "const", "type": "Float", "value": "1.5" }, { "kind": "const", "type": "Float", "value": "2.25" }] } },
    { "op": "bind", "mutable": false, "name": "fixeds", "type": "List OF Fixed", "value": { "kind": "list", "type": "List OF Fixed", "values": [{ "kind": "const", "type": "Fixed", "value": "1.250" }, { "kind": "const", "type": "Fixed", "value": "2.500" }] } },
    { "op": "bind", "mutable": false, "name": "empty", "type": "List OF Integer", "value": { "kind": "list", "type": "List OF Integer", "values": [] } },
    { "op": "bind", "mutable": false, "name": "intTotal", "type": "Integer", "value": { "kind": "call", "target": "collections.sum", "args": [{ "kind": "local", "name": "integers" }] } },
    { "op": "bind", "mutable": false, "name": "floatTotal", "type": "Float", "value": { "kind": "call", "target": "collections.sum", "args": [{ "kind": "local", "name": "floats" }] } },
    { "op": "bind", "mutable": false, "name": "fixedTotal", "type": "Fixed", "value": { "kind": "call", "target": "collections.sum", "args": [{ "kind": "local", "name": "fixeds" }] } },
    { "op": "bind", "mutable": false, "name": "emptyTotal", "type": "Integer", "value": { "kind": "call", "target": "collections.sum", "args": [{ "kind": "local", "name": "empty" }] } },
    { "op": "bind", "mutable": false, "name": "floatPrecision", "type": "Byte", "value": { "kind": "const", "type": "Byte", "value": "2" } },
    { "op": "bind", "mutable": false, "name": "fixedPrecision", "type": "Byte", "value": { "kind": "const", "type": "Byte", "value": "3" } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "intTotal" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "floatTotal" }, { "kind": "local", "name": "floatPrecision" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "fixedTotal" }, { "kind": "local", "name": "fixedPrecision" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "emptyTotal" }] }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "intTotal" }, "right": { "kind": "local", "name": "emptyTotal" } } }
    ]
  }
  ]
}
