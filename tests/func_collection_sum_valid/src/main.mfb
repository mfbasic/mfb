IMPORT io

FUNC main AS Integer
  LET integers AS List OF Integer = [1, 2, 3]
  LET floats AS List OF Float = [1.5, 2.25]
  LET fixeds AS List OF Fixed = [1.250, 2.500]
  LET empty AS List OF Integer = []

  LET intTotal AS Integer = sum(integers)
  LET floatTotal AS Float = sum(floats)
  LET fixedTotal AS Fixed = sum(fixeds)
  LET emptyTotal AS Integer = sum(empty)
  LET floatPrecision AS Byte = 2
  LET fixedPrecision AS Byte = 3

  io::print(toString(intTotal))
  io::print(toString(floatTotal, floatPrecision))
  io::print(toString(fixedTotal, fixedPrecision))
  io::print(toString(emptyTotal))

  RETURN intTotal + emptyTotal
END FUNC
