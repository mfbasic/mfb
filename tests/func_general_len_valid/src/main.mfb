IMPORT io

FUNC stringLens AS Integer
  LET emptyText AS String = ""
  LET asciiText AS String = "hello"
  LET unicodeText AS String = "aé日"
  LET emojiText AS String = "a😀é"
  LET familyText AS String = "👨‍👩‍👧‍👦"

  io::print("len-string-empty")
  io::print("len-string-ascii")
  io::print("len-string-unicode")
  io::print("len-string-emoji-combining")
  io::print("len-string-grapheme-cluster")

  LET emptyCount AS Integer = len(emptyText)
  LET asciiCount AS Integer = len(asciiText)
  LET unicodeCount AS Integer = len(unicodeText)
  LET emojiCount AS Integer = len(emojiText)
  LET familyCount AS Integer = len(familyText)
  RETURN emptyCount + asciiCount + unicodeCount + emojiCount + familyCount
END FUNC

FUNC listLens AS Integer
  LET emptyList AS List OF Integer = []
  LET numbers AS List OF Integer = [10, 20, 30]

  io::print("len-list-empty")
  io::print("len-list-values")

  LET emptyCount AS Integer = len(emptyList)
  LET valueCount AS Integer = len(numbers)
  RETURN emptyCount + valueCount
END FUNC

FUNC mapLens AS Integer
  LET emptyMap AS Map OF String TO Integer = Map OF String TO Integer {}
  LET ages AS Map OF String TO Integer = Map OF String TO Integer { "Ada" := 36, "Grace" := 85 }

  io::print("len-map-empty")
  io::print("len-map-values")

  LET emptyCount AS Integer = len(emptyMap)
  LET valueCount AS Integer = len(ages)
  RETURN emptyCount + valueCount
END FUNC

FUNC main AS Integer
  LET strings AS Integer = stringLens()
  LET lists AS Integer = listLens()
  LET maps AS Integer = mapLens()
  RETURN strings + lists + maps
END FUNC
