IMPORT io
IMPORT math

' Vectorized math::atan2(y, x) over two Float lists — atan(y/x) with quadrant
' adjustment. Faithfully rounded (within a few ULP of libm). Length 5 odd.
FUNC main AS Integer
  LET p AS Byte = 14
  LET ys AS List OF Float = [1.0, 1.0, 0.0 - 1.0, 0.0, 2.0]
  LET xs AS List OF Float = [1.0, 0.0 - 1.0, 0.0 - 1.0, 1.0, 2.0]
  FOR EACH r IN math::atan2(ys, xs)
    io::print(toString(r, p))
  NEXT
  RETURN 0
END FUNC
