{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_fs_openFile_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "f", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "const", "type": "String", "value": "tests/func_fs_openFile_valid/src/main.mfb" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "default" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "local", "name": "f" }] } },
    { "op": "bind", "mutable": false, "name": "out", "type": "String", "value": { "kind": "const", "type": "String", "value": "target/func_fs_openFile_valid.txt" } },
    {
      "op": "if",
      "condition": { "kind": "call", "target": "fs.fileExists", "args": [{ "kind": "local", "name": "out" }] },
      "then": [
      { "op": "eval", "value": { "kind": "call", "target": "fs.deleteFile", "args": [{ "kind": "local", "name": "out" }] } }
      ],
      "else": [
      ]
    },
    { "op": "bind", "mutable": false, "name": "w", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "local", "name": "out" }, { "kind": "const", "type": "String", "value": "write" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "local", "name": "w" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "fs.fileExists", "args": [{ "kind": "local", "name": "out" }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.deleteFile", "args": [{ "kind": "local", "name": "out" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
