IMPORT io
IMPORT thread
IMPORT fs_thread_workers

FUNC main AS Integer
  LET t AS Thread OF String TO String = thread::start(fs_thread_workers::readTextWorker, "tests/rt-error/threads/thread-fs-readtext-utf8-rt/data/bad.txt")
  LET content AS String = thread::waitFor(t)
  io::print(content)
  RETURN 0
END FUNC
