FUNC main AS Integer
  ' (1e200*1e200) / (1e200*1e200) = (+Inf) / (+Inf) = NaN. Both products
  ' are anonymous intermediates (no trap); the NaN reaches the named
  ' binding and traps there with ErrFloatNaN (plan-17). Division (not
  ' subtraction) keeps the two products un-fused: FMA fusion (plan-02) only
  ' folds a product into an `+`/`-`, so with `/` each product still rounds to
  ' +Inf independently, preserving the Inf/Inf = NaN this test pins.
  LET big AS Float = toFloat("1e200")
  LET x AS Float = (big * big) / (big * big)
  RETURN 0
END FUNC
