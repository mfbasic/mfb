TYPE Circle
  radius AS Integer
END TYPE

TYPE Rect
  width AS Integer
  height AS Integer
END TYPE

UNION Shape
  Circle
  Rect
END UNION

FUNC score(shape AS Shape) AS Integer
  MATCH shape
    CASE Circle(bigCircle) WHEN bigCircle.radius > 5
      RETURN 100
    CASE Circle(exactCircle) WHEN exactCircle.radius = 4
      RETURN 7
    CASE Rect(square) WHEN square.width = square.height
      RETURN 50
    CASE ELSE
      RETURN 3
  END MATCH
END FUNC

FUNC main() AS Integer
  RETURN score(Circle[4]) + score(Rect[2, 2]) + score(Circle[1])
END FUNC
