IMPORT io
IMPORT math

' abs over a List OF Fixed raises ErrOverflow when a lane is the minimum Fixed
' (raw INT64_MIN, value -2147483648.0), whose magnitude is not representable.
FUNC main AS Integer
  ' Kept as toFixed: the `F` literal `-2147483648.0F` parses as -(2147483648.0F),
  ' and the positive magnitude overflows Fixed's range at compile time. toFixed
  ' builds the representable minimum directly, so abs() can trap at runtime.
  LET m AS Fixed = toFixed("-2147483648.0")
  LET xs AS List OF Fixed = [1.0F, m]
  LET ys AS List OF Fixed = math::abs(xs)
  io::print(toString(len(ys)))
  RETURN 0
END FUNC
