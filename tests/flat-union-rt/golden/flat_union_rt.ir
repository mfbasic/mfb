    { "name": "s", "type": "Shape", "default": null }
    ],
    "returns": "String",
    "body": [
    { "op": "bind", "mutable": false, "name": "$match0", "type": "Shape", "value": { "kind": "local", "name": "s" } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match0" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Dot" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "d", "type": "Dot", "value": { "kind": "unionExtract", "type": "Dot", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "return", "value": { "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "dot:" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "d" }, "member": "x" }] } } }
        ]
      },
