        { "op": "return", "value": { "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "tag:" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "t" }, "member": "name" } } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Boxed" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "p", "type": "Boxed", "value": { "kind": "unionExtract", "type": "Boxed", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "return", "value": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "pair:" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "memberAccess", "target": { "kind": "local", "name": "p" }, "member": "dot" }, "member": "x" }] } }, "right": { "kind": "const", "type": "String", "value": "/" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "p" }, "member": "label" } } }
        ]
