  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "a", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Dot", "value": { "kind": "constructor", "type": "Dot", "args": [{ "kind": "const", "type": "Integer", "value": "7" }] } } },
    { "op": "bind", "mutable": false, "name": "b", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Tag", "value": { "kind": "constructor", "type": "Tag", "args": [{ "kind": "const", "type": "String", "value": "hello" }] } } },
    { "op": "bind", "mutable": false, "name": "c", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Boxed", "value": { "kind": "constructor", "type": "Boxed", "args": [{ "kind": "constructor", "type": "Dot", "args": [{ "kind": "const", "type": "Integer", "value": "3" }] }, { "kind": "const", "type": "String", "value": "boxed-and-longer" }] } } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "a" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "b" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "c" }] }] } },
    { "op": "bind", "mutable": false, "name": "d", "type": "Shape", "value": { "kind": "local", "name": "c" } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "d" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "a" }] }, "right": { "kind": "const", "type": "String", "value": "|" } }, "right": { "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "b" }] } }] } },
    { "op": "bind", "mutable": false, "name": "xs", "type": "List OF Shape", "value": { "kind": "list", "type": "List OF Shape", "values": [{ "kind": "local", "name": "a" }, { "kind": "local", "name": "b" }, { "kind": "local", "name": "c" }] } },
    { "op": "bind", "mutable": true, "name": "joined", "type": "String", "value": { "kind": "const", "type": "String", "value": "" } },
    {
      "op": "forEach",
      "name": "s",
      "type": "Shape",
      "iterable": { "kind": "local", "name": "xs" },
      "body": [
      { "op": "assign", "name": "joined", "value": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "joined" }, "right": { "kind": "call", "target": "describe", "args": [{ "kind": "local", "name": "s" }] } }, "right": { "kind": "const", "type": "String", "value": ";" } } }
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "joined" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "xs" }] }] }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
