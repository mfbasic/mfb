  "format": "mfb-ir",
  "version": 1,
  "project": "function_overloads",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "score$Integer",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "Integer", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "value" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } }
    ]
  },
  {
    "name": "score$String",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "String", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "return", "value": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "value" }] } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "score$Integer", "args": [{ "kind": "const", "type": "Integer", "value": "4" }] }, "right": { "kind": "call", "target": "score$String", "args": [{ "kind": "const", "type": "String", "value": "Ada" }] } } }
    ]
  }
  ]
