IMPORT collections
IMPORT io

' REGRESSION: growing a `MUT` collection with `append` in a loop once crossed a
' boundary (16 -> 17 elements) and corrupted memory -> SIGSEGV, then runaway OOM.
' Root cause: `lower_list_insert_collection` computed the new buffer's data length
' in x15, but `_mfb_arena_alloc` clobbers x15 in its block-grow path, so the
' header write stored a stale pointer into the DATA_LENGTH field. The next append
' read that pointer as a huge size, forcing an ever-larger grow until mmap failed.
' Fixed by spilling the data length to the stack across the alloc call (same fix
' applied to remove-at, map-concat, and map-remove-key, which shared the pattern).
' The `.run` golden now asserts the loop reaches 17 and prints `len=17`.
FUNC main AS Integer
  MUT xs AS List OF Integer = []
  MUT j AS Integer = 0
  WHILE j < 17
    xs = collections::append(xs, j)
    j = j + 1
  WEND
  io::print("len=" & toString(len(xs)))
  RETURN 0
END FUNC
