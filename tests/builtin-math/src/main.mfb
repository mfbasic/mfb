IMPORT math

FUNC main AS Integer
  LET pi AS Float = math::piFloat
  LET piFixed AS Fixed = math::piFixed
  LET e AS Float = math::eFloat
  LET eFixed AS Fixed = math::eFixed
  LET floatSum AS Float = pi + e
  LET floatDifference AS Float = pi - e
  LET floatProduct AS Float = pi * e
  LET floatRatio AS Float = pi / e
  LET integerDivision AS Float = 3 / 2
  LET integerFloatSum AS Float = 2 + pi
  LET floatIntegerDifference AS Float = pi - 1
  LET integerFixedSum AS Float = 2 + piFixed
  LET fixedIntegerDifference AS Float = piFixed - 1
  LET floatFixedProduct AS Float = pi * piFixed
  LET fixedFloatRatio AS Float = piFixed / pi
  LET floatGreater AS Boolean = pi > e
  LET floatLessEqual AS Boolean = e <= pi
  LET integerFloatComparison AS Boolean = 2 < pi
  LET fixedIntegerComparison AS Boolean = piFixed > 3
  LET floatFixedComparison AS Boolean = pi >= piFixed
  LET fixedSpread AS Fixed = piFixed - eFixed
  LET fixedProduct AS Fixed = piFixed * eFixed
  LET fixedRatio AS Fixed = piFixed / eFixed
  LET fixedAbsolute AS Fixed = math::abs(fixedSpread)
  LET fixedMinimum AS Fixed = math::min(piFixed, eFixed)
  LET fixedMaximum AS Fixed = math::max(piFixed, eFixed)
  LET fixedClamped AS Fixed = math::clamp(fixedSpread, eFixed, piFixed)
  LET fixedFloored AS Integer = math::floor(fixedSpread)
  LET fixedCeiled AS Integer = math::ceil(fixedSpread)
  LET fixedRounded AS Integer = math::round(fixedSpread)
  LET fixedTruncated AS Integer = math::trunc(fixedSpread)
  LET fixedRoot AS Fixed = math::sqrt(toFixed("9.0"))
  LET fixedRaised AS Fixed = math::pow(toFixed("2.0"), toFixed("8.0"))
  LET fixedExponential AS Fixed = math::exp(toFixed("1.0"))
  LET fixedNaturalLog AS Fixed = math::log(eFixed)
  LET fixedCommonLog AS Fixed = math::log10(toFixed("100.0"))
  LET fixedSine AS Fixed = math::sin(piFixed)
  LET fixedCosine AS Fixed = math::cos(piFixed)
  LET fixedTangent AS Fixed = math::tan(toFixed("0.0"))
  LET fixedArcsine AS Fixed = math::asin(toFixed("0.5"))
  LET fixedArccosine AS Fixed = math::acos(toFixed("0.5"))
  LET fixedArctangent AS Fixed = math::atan(toFixed("1.0"))
  LET fixedArctangent2 AS Fixed = math::atan2(toFixed("1.0"), toFixed("1.0"))
  LET fixedRadians AS Float = math::radians(toFixed("180.0"))
  LET fixedDegrees AS Float = math::degrees(piFixed)
  LET absoluteInteger AS Integer = math::abs(-42)
  LET absoluteFloat AS Float = math::abs(-3.5)
  LET signNegative AS Integer = math::sign(-7)
  LET signFloat AS Integer = math::sign(-3.5)
  LET minimum AS Integer = math::min(4, 9)
  LET maximum AS Integer = math::max(4, 9)
  LET minimumFloat AS Float = math::min(pi, e)
  LET maximumFloat AS Float = math::max(pi, e)
  LET clamped AS Integer = math::clamp(12, 0, 10)
  LET clampedFloat AS Float = math::clamp(pi, e, 4.0)
  LET floored AS Integer = math::floor(3.75)
  LET ceiled AS Integer = math::ceil(3.25)
  LET rounded AS Integer = math::round(3.5)
  LET truncated AS Integer = math::trunc(3.75)
  LET root AS Float = math::sqrt(9.0)
  LET raised AS Float = math::pow(2.0, 8.0)
  LET exponential AS Float = math::exp(1.0)
  LET naturalLog AS Float = math::log(e)
  LET commonLog AS Float = math::log10(100.0)
  LET sine AS Float = math::sin(pi)
  LET cosine AS Float = math::cos(pi)
  LET tangent AS Float = math::tan(0.0)
  LET arcsine AS Float = math::asin(0.5)
  LET arccosine AS Float = math::acos(0.5)
  LET arctangent AS Float = math::atan(1.0)
  LET arctangent2 AS Float = math::atan2(1.0, 1.0)
  LET radians AS Float = math::radians(180.0)
  LET degrees AS Float = math::degrees(pi)
  LET finite AS Boolean = math::isFinite(degrees)

  IF finite THEN
    RETURN absoluteInteger + signNegative + minimum + maximum + clamped + floored + ceiled + rounded + truncated
  ELSE
    RETURN 1
  END IF
END FUNC
