{
  "format": "mfb-ir",
  "version": 1,
  "project": "builtin_math",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "pi", "type": "Float", "value": { "kind": "call", "target": "math.piFloat", "args": [] } },
    { "op": "bind", "mutable": false, "name": "piFixed", "type": "Fixed", "value": { "kind": "call", "target": "math.piFixed", "args": [] } },
    { "op": "bind", "mutable": false, "name": "e", "type": "Float", "value": { "kind": "call", "target": "math.eFloat", "args": [] } },
    { "op": "bind", "mutable": false, "name": "eFixed", "type": "Fixed", "value": { "kind": "call", "target": "math.eFixed", "args": [] } },
    { "op": "bind", "mutable": false, "name": "floatSum", "type": "Float", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "e" } } },
    { "op": "bind", "mutable": false, "name": "floatDifference", "type": "Float", "value": { "kind": "binary", "op": "-", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "e" } } },
    { "op": "bind", "mutable": false, "name": "floatProduct", "type": "Float", "value": { "kind": "binary", "op": "*", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "e" } } },
    { "op": "bind", "mutable": false, "name": "floatRatio", "type": "Float", "value": { "kind": "binary", "op": "/", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "e" } } },
    { "op": "bind", "mutable": false, "name": "integerDivision", "type": "Float", "value": { "kind": "binary", "op": "/", "left": { "kind": "const", "type": "Integer", "value": "3" }, "right": { "kind": "const", "type": "Integer", "value": "2" } } },
    { "op": "bind", "mutable": false, "name": "integerFloatSum", "type": "Float", "value": { "kind": "binary", "op": "+", "left": { "kind": "const", "type": "Integer", "value": "2" }, "right": { "kind": "local", "name": "pi" } } },
    { "op": "bind", "mutable": false, "name": "floatIntegerDifference", "type": "Float", "value": { "kind": "binary", "op": "-", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } },
    { "op": "bind", "mutable": false, "name": "integerFixedSum", "type": "Float", "value": { "kind": "binary", "op": "+", "left": { "kind": "const", "type": "Integer", "value": "2" }, "right": { "kind": "local", "name": "piFixed" } } },
    { "op": "bind", "mutable": false, "name": "fixedIntegerDifference", "type": "Float", "value": { "kind": "binary", "op": "-", "left": { "kind": "local", "name": "piFixed" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } },
    { "op": "bind", "mutable": false, "name": "floatFixedProduct", "type": "Float", "value": { "kind": "binary", "op": "*", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "piFixed" } } },
    { "op": "bind", "mutable": false, "name": "fixedFloatRatio", "type": "Float", "value": { "kind": "binary", "op": "/", "left": { "kind": "local", "name": "piFixed" }, "right": { "kind": "local", "name": "pi" } } },
    { "op": "bind", "mutable": false, "name": "floatGreater", "type": "Boolean", "value": { "kind": "binary", "op": ">", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "e" } } },
    { "op": "bind", "mutable": false, "name": "floatLessEqual", "type": "Boolean", "value": { "kind": "binary", "op": "<=", "left": { "kind": "local", "name": "e" }, "right": { "kind": "local", "name": "pi" } } },
    { "op": "bind", "mutable": false, "name": "integerFloatComparison", "type": "Boolean", "value": { "kind": "binary", "op": "<", "left": { "kind": "const", "type": "Integer", "value": "2" }, "right": { "kind": "local", "name": "pi" } } },
    { "op": "bind", "mutable": false, "name": "fixedIntegerComparison", "type": "Boolean", "value": { "kind": "binary", "op": ">", "left": { "kind": "local", "name": "piFixed" }, "right": { "kind": "const", "type": "Integer", "value": "3" } } },
    { "op": "bind", "mutable": false, "name": "floatFixedComparison", "type": "Boolean", "value": { "kind": "binary", "op": ">=", "left": { "kind": "local", "name": "pi" }, "right": { "kind": "local", "name": "piFixed" } } },
    { "op": "bind", "mutable": false, "name": "fixedSpread", "type": "Fixed", "value": { "kind": "binary", "op": "-", "left": { "kind": "local", "name": "piFixed" }, "right": { "kind": "local", "name": "eFixed" } } },
    { "op": "bind", "mutable": false, "name": "fixedProduct", "type": "Fixed", "value": { "kind": "binary", "op": "*", "left": { "kind": "local", "name": "piFixed" }, "right": { "kind": "local", "name": "eFixed" } } },
    { "op": "bind", "mutable": false, "name": "fixedRatio", "type": "Fixed", "value": { "kind": "binary", "op": "/", "left": { "kind": "local", "name": "piFixed" }, "right": { "kind": "local", "name": "eFixed" } } },
    { "op": "bind", "mutable": false, "name": "fixedAbsolute", "type": "Fixed", "value": { "kind": "call", "target": "math.abs", "args": [{ "kind": "local", "name": "fixedSpread" }] } },
    { "op": "bind", "mutable": false, "name": "fixedMinimum", "type": "Fixed", "value": { "kind": "call", "target": "math.min", "args": [{ "kind": "local", "name": "piFixed" }, { "kind": "local", "name": "eFixed" }] } },
    { "op": "bind", "mutable": false, "name": "fixedMaximum", "type": "Fixed", "value": { "kind": "call", "target": "math.max", "args": [{ "kind": "local", "name": "piFixed" }, { "kind": "local", "name": "eFixed" }] } },
    { "op": "bind", "mutable": false, "name": "fixedClamped", "type": "Fixed", "value": { "kind": "call", "target": "math.clamp", "args": [{ "kind": "local", "name": "fixedSpread" }, { "kind": "local", "name": "eFixed" }, { "kind": "local", "name": "piFixed" }] } },
    { "op": "bind", "mutable": false, "name": "fixedFloored", "type": "Integer", "value": { "kind": "call", "target": "math.floor", "args": [{ "kind": "local", "name": "fixedSpread" }] } },
    { "op": "bind", "mutable": false, "name": "fixedCeiled", "type": "Integer", "value": { "kind": "call", "target": "math.ceil", "args": [{ "kind": "local", "name": "fixedSpread" }] } },
    { "op": "bind", "mutable": false, "name": "fixedRounded", "type": "Integer", "value": { "kind": "call", "target": "math.round", "args": [{ "kind": "local", "name": "fixedSpread" }] } },
    { "op": "bind", "mutable": false, "name": "fixedTruncated", "type": "Integer", "value": { "kind": "call", "target": "math.trunc", "args": [{ "kind": "local", "name": "fixedSpread" }] } },
    { "op": "bind", "mutable": false, "name": "fixedRoot", "type": "Fixed", "value": { "kind": "call", "target": "math.sqrt", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "9.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedRaised", "type": "Fixed", "value": { "kind": "call", "target": "math.pow", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "2.0" }] }, { "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "8.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedExponential", "type": "Fixed", "value": { "kind": "call", "target": "math.exp", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "1.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedNaturalLog", "type": "Fixed", "value": { "kind": "call", "target": "math.log", "args": [{ "kind": "local", "name": "eFixed" }] } },
    { "op": "bind", "mutable": false, "name": "fixedCommonLog", "type": "Fixed", "value": { "kind": "call", "target": "math.log10", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "100.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedSine", "type": "Fixed", "value": { "kind": "call", "target": "math.sin", "args": [{ "kind": "local", "name": "piFixed" }] } },
    { "op": "bind", "mutable": false, "name": "fixedCosine", "type": "Fixed", "value": { "kind": "call", "target": "math.cos", "args": [{ "kind": "local", "name": "piFixed" }] } },
    { "op": "bind", "mutable": false, "name": "fixedTangent", "type": "Fixed", "value": { "kind": "call", "target": "math.tan", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "0.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedArcsine", "type": "Fixed", "value": { "kind": "call", "target": "math.asin", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "0.5" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedArccosine", "type": "Fixed", "value": { "kind": "call", "target": "math.acos", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "0.5" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedArctangent", "type": "Fixed", "value": { "kind": "call", "target": "math.atan", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "1.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedArctangent2", "type": "Fixed", "value": { "kind": "call", "target": "math.atan2", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "1.0" }] }, { "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "1.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedRadians", "type": "Float", "value": { "kind": "call", "target": "math.radians", "args": [{ "kind": "call", "target": "toFixed", "args": [{ "kind": "const", "type": "String", "value": "180.0" }] }] } },
    { "op": "bind", "mutable": false, "name": "fixedDegrees", "type": "Float", "value": { "kind": "call", "target": "math.degrees", "args": [{ "kind": "local", "name": "piFixed" }] } },
    { "op": "bind", "mutable": false, "name": "absoluteInteger", "type": "Integer", "value": { "kind": "call", "target": "math.abs", "args": [{ "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "42" } }] } },
    { "op": "bind", "mutable": false, "name": "absoluteFloat", "type": "Float", "value": { "kind": "call", "target": "math.abs", "args": [{ "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Float", "value": "3.5" } }] } },
    { "op": "bind", "mutable": false, "name": "signNegative", "type": "Integer", "value": { "kind": "call", "target": "math.sign", "args": [{ "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "7" } }] } },
    { "op": "bind", "mutable": false, "name": "signFloat", "type": "Integer", "value": { "kind": "call", "target": "math.sign", "args": [{ "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Float", "value": "3.5" } }] } },
    { "op": "bind", "mutable": false, "name": "minimum", "type": "Integer", "value": { "kind": "call", "target": "math.min", "args": [{ "kind": "const", "type": "Integer", "value": "4" }, { "kind": "const", "type": "Integer", "value": "9" }] } },
    { "op": "bind", "mutable": false, "name": "maximum", "type": "Integer", "value": { "kind": "call", "target": "math.max", "args": [{ "kind": "const", "type": "Integer", "value": "4" }, { "kind": "const", "type": "Integer", "value": "9" }] } },
    { "op": "bind", "mutable": false, "name": "minimumFloat", "type": "Float", "value": { "kind": "call", "target": "math.min", "args": [{ "kind": "local", "name": "pi" }, { "kind": "local", "name": "e" }] } },
    { "op": "bind", "mutable": false, "name": "maximumFloat", "type": "Float", "value": { "kind": "call", "target": "math.max", "args": [{ "kind": "local", "name": "pi" }, { "kind": "local", "name": "e" }] } },
    { "op": "bind", "mutable": false, "name": "clamped", "type": "Integer", "value": { "kind": "call", "target": "math.clamp", "args": [{ "kind": "const", "type": "Integer", "value": "12" }, { "kind": "const", "type": "Integer", "value": "0" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
    { "op": "bind", "mutable": false, "name": "clampedFloat", "type": "Float", "value": { "kind": "call", "target": "math.clamp", "args": [{ "kind": "local", "name": "pi" }, { "kind": "local", "name": "e" }, { "kind": "const", "type": "Float", "value": "4.0" }] } },
    { "op": "bind", "mutable": false, "name": "floored", "type": "Integer", "value": { "kind": "call", "target": "math.floor", "args": [{ "kind": "const", "type": "Float", "value": "3.75" }] } },
    { "op": "bind", "mutable": false, "name": "ceiled", "type": "Integer", "value": { "kind": "call", "target": "math.ceil", "args": [{ "kind": "const", "type": "Float", "value": "3.25" }] } },
    { "op": "bind", "mutable": false, "name": "rounded", "type": "Integer", "value": { "kind": "call", "target": "math.round", "args": [{ "kind": "const", "type": "Float", "value": "3.5" }] } },
    { "op": "bind", "mutable": false, "name": "truncated", "type": "Integer", "value": { "kind": "call", "target": "math.trunc", "args": [{ "kind": "const", "type": "Float", "value": "3.75" }] } },
    { "op": "bind", "mutable": false, "name": "root", "type": "Float", "value": { "kind": "call", "target": "math.sqrt", "args": [{ "kind": "const", "type": "Float", "value": "9.0" }] } },
    { "op": "bind", "mutable": false, "name": "raised", "type": "Float", "value": { "kind": "call", "target": "math.pow", "args": [{ "kind": "const", "type": "Float", "value": "2.0" }, { "kind": "const", "type": "Float", "value": "8.0" }] } },
    { "op": "bind", "mutable": false, "name": "exponential", "type": "Float", "value": { "kind": "call", "target": "math.exp", "args": [{ "kind": "const", "type": "Float", "value": "1.0" }] } },
    { "op": "bind", "mutable": false, "name": "naturalLog", "type": "Float", "value": { "kind": "call", "target": "math.log", "args": [{ "kind": "local", "name": "e" }] } },
    { "op": "bind", "mutable": false, "name": "commonLog", "type": "Float", "value": { "kind": "call", "target": "math.log10", "args": [{ "kind": "const", "type": "Float", "value": "100.0" }] } },
    { "op": "bind", "mutable": false, "name": "sine", "type": "Float", "value": { "kind": "call", "target": "math.sin", "args": [{ "kind": "local", "name": "pi" }] } },
    { "op": "bind", "mutable": false, "name": "cosine", "type": "Float", "value": { "kind": "call", "target": "math.cos", "args": [{ "kind": "local", "name": "pi" }] } },
    { "op": "bind", "mutable": false, "name": "tangent", "type": "Float", "value": { "kind": "call", "target": "math.tan", "args": [{ "kind": "const", "type": "Float", "value": "0.0" }] } },
    { "op": "bind", "mutable": false, "name": "arcsine", "type": "Float", "value": { "kind": "call", "target": "math.asin", "args": [{ "kind": "const", "type": "Float", "value": "0.5" }] } },
    { "op": "bind", "mutable": false, "name": "arccosine", "type": "Float", "value": { "kind": "call", "target": "math.acos", "args": [{ "kind": "const", "type": "Float", "value": "0.5" }] } },
    { "op": "bind", "mutable": false, "name": "arctangent", "type": "Float", "value": { "kind": "call", "target": "math.atan", "args": [{ "kind": "const", "type": "Float", "value": "1.0" }] } },
    { "op": "bind", "mutable": false, "name": "arctangent2", "type": "Float", "value": { "kind": "call", "target": "math.atan2", "args": [{ "kind": "const", "type": "Float", "value": "1.0" }, { "kind": "const", "type": "Float", "value": "1.0" }] } },
    { "op": "bind", "mutable": false, "name": "radians", "type": "Float", "value": { "kind": "call", "target": "math.radians", "args": [{ "kind": "const", "type": "Float", "value": "180.0" }] } },
    { "op": "bind", "mutable": false, "name": "degrees", "type": "Float", "value": { "kind": "call", "target": "math.degrees", "args": [{ "kind": "local", "name": "pi" }] } },
    { "op": "bind", "mutable": false, "name": "finite", "type": "Boolean", "value": { "kind": "call", "target": "math.isFinite", "args": [{ "kind": "local", "name": "degrees" }] } },
    {
      "op": "if",
      "condition": { "kind": "local", "name": "finite" },
      "then": [
      { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "absoluteInteger" }, "right": { "kind": "local", "name": "signNegative" } }, "right": { "kind": "local", "name": "minimum" } }, "right": { "kind": "local", "name": "maximum" } }, "right": { "kind": "local", "name": "clamped" } }, "right": { "kind": "local", "name": "floored" } }, "right": { "kind": "local", "name": "ceiled" } }, "right": { "kind": "local", "name": "rounded" } }, "right": { "kind": "local", "name": "truncated" } } }
      ],
      "else": [
      { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "1" } }
      ]
    }
    ]
  }
  ]
}
