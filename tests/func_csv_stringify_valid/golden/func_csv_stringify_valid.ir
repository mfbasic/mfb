    { "op": "bind", "mutable": true, "name": "firstField", "type": "Boolean", "value": { "kind": "const", "type": "Boolean", "value": "true" } },
    {
      "op": "forEach",
      "name": "field",
      "type": "String",
      "iterable": { "kind": "local", "name": "row" },
      "body": [
      {
        "op": "if",
        "condition": { "kind": "local", "name": "firstField" },
        "then": [
        { "op": "assign", "name": "firstField", "value": { "kind": "const", "type": "Boolean", "value": "false" } }
        ],
        "else": [
