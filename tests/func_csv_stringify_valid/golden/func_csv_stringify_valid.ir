    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "--bare--" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "#csv_stringify", "args": [{ "kind": "list", "type": "List OF List OF String", "values": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "a" }, { "kind": "const", "type": "String", "value": "b" }, { "kind": "const", "type": "String", "value": "c" }] }, { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "1" }, { "kind": "const", "type": "String", "value": "2" }, { "kind": "const", "type": "String", "value": "3" }] }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "--comma--" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "#csv_stringify", "args": [{ "kind": "list", "type": "List OF List OF String", "values": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "has,comma" }, { "kind": "const", "type": "String", "value": "plain" }] }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "--quote--" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "#csv_stringify", "args": [{ "kind": "list", "type": "List OF List OF String", "values": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "he said \"hi\"" }, { "kind": "const", "type": "String", "value": "x" }] }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "--newline--" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "#csv_stringify", "args": [{ "kind": "list", "type": "List OF List OF String", "values": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "line1\nline2" }, { "kind": "const", "type": "String", "value": "y" }] }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "--ragged--" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "#csv_stringify", "args": [{ "kind": "list", "type": "List OF List OF String", "values": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "one" }] }, { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "a" }, { "kind": "const", "type": "String", "value": "b" }] }, { "kind": "list", "type": "List OF String", "values": [] }] }] }] } },
    { "op": "bind", "mutable": false, "name": "empty", "type": "List OF List OF String", "value": { "kind": "list", "type": "List OF List OF String", "values": [] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "--empty--" }] } },
