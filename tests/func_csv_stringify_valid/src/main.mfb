IMPORT csv
IMPORT io

FUNC main AS Integer
  ' Fields that need no quoting are emitted bare.
  io::print("--bare--")
  io::print(csv::stringify([["a", "b", "c"], ["1", "2", "3"]]))

  ' A comma forces quoting.
  io::print("--comma--")
  io::print(csv::stringify([["has,comma", "plain"]]))

  ' A double quote forces quoting and is doubled inside the quoted field.
  io::print("--quote--")
  io::print(csv::stringify([["he said \"hi\"", "x"]]))

  ' An embedded line feed forces quoting; the LF is preserved inside the quotes.
  io::print("--newline--")
  io::print(csv::stringify([["line1\nline2", "y"]]))

  ' A ragged grid (rows of differing width) is rendered as-is.
  io::print("--ragged--")
  io::print(csv::stringify([["one"], ["a", "b"], []]))

  ' The empty document stringifies to the empty String.
  LET empty AS List OF List OF String = []
  io::print("--empty--")
  io::print("[" & csv::stringify(empty) & "]")
  RETURN 0
END FUNC
