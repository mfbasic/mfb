IMPORT io
IMPORT math

FUNC main AS Integer
  LET p AS Byte = 2
  LET fixedPiQuarter AS Fixed = toFixed("0.7853981634")
  io::print(toString(math::tan(0.0), p))
  io::print(toString(math::tan(0.7853981634), p))
  io::print(toString(math::tan(fixedPiQuarter), p))
  ' Scalar kernel quadrant coverage: the scalar path branches on the reduced
  ' quadrant's bit0, so exercise both branches (and a negative argument) at full
  ' precision. tan has period pi, so bit1 must not change the result.
  LET q AS Byte = 15
  io::print(toString(math::tan(0.7), q))    ' bit0 clear: sin_r/cos_r
  io::print(toString(math::tan(2.0), q))    ' bit0 set: -cos_r/sin_r
  io::print(toString(math::tan(4.0), q))    ' bit0 clear, +pi (bit1 set)
  io::print(toString(math::tan(5.0), q))    ' bit0 set, +pi (bit1 set)
  io::print(toString(math::tan(-2.0), q))   ' negative argument
  RETURN 0
END FUNC
