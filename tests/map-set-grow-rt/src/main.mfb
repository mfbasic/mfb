IMPORT collections
IMPORT io

' Runtime proof for plan-02 Phase 3: in-place map `set` — new-key insert into
' spare slot/data headroom with geometric grow (no per-insert rebuild), value
' overwrite-when-fits, and the longer-value rebuild fallback. Deterministic.

FUNC main AS Integer
  ' --- 1000 new-key inserts (grow path). ---
  MUT m AS Map OF String TO Integer = Map OF String TO Integer {}
  FOR i = 0 TO 999
    m = collections::set(m, toString(i), i * 2)
  NEXT
  MUT sum AS Integer = 0
  FOR i = 0 TO 999
    sum = sum + collections::get(m, toString(i))
  NEXT
  LET c0 AS Integer = collections::get(m, "0")
  LET c999 AS Integer = collections::get(m, "999")
  io::print("insert count=" & toString(len(m)) & " sum=" & toString(sum) & " [0]=" & toString(c0) & " [999]=" & toString(c999))

  ' --- Overwrite an existing key (same-size value, in place). ---
  m = collections::set(m, "500", 123456)
  LET ow AS Integer = collections::get(m, "500")
  io::print("overwrite [500]=" & toString(ow) & " count=" & toString(len(m)))

  ' --- String-valued map: overwrite shorter (fits) then longer (rebuild). ---
  MUT s AS Map OF String TO String = Map OF String TO String {}
  s = collections::set(s, "k1", "first")
  s = collections::set(s, "k2", "second")
  s = collections::set(s, "k1", "x")
  LET s1 AS String = collections::get(s, "k1")
  LET s2 AS String = collections::get(s, "k2")
  s = collections::set(s, "k1", "muchlongervalue")
  LET s1b AS String = collections::get(s, "k1")
  LET s2b AS String = collections::get(s, "k2")
  io::print("strval fits=" & s1 & "|" & s2 & " grow=" & s1b & "|" & s2b)

  ' --- Integer keys + insertion-order iteration. ---
  MUT im AS Map OF Integer TO Integer = Map OF Integer TO Integer {}
  FOR i = 0 TO 4
    im = collections::set(im, i * 10, i)
  NEXT
  im = collections::set(im, 20, 999)
  MUT order AS String = ""
  FOR EACH e IN im
    order = order & toString(e.key) & ":" & toString(e.value) & " "
  NEXT
  io::print("intkeys " & order)
  RETURN 0
END FUNC
