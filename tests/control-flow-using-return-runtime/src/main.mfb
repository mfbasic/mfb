IMPORT fs
IMPORT io

FUNC useOnce(path AS String) AS Nothing
  USING f = fs::openFile(path)
    RETURN NOTHING
  END USING
END FUNC

FUNC main AS Integer
  MUT i AS Integer = 0
  WHILE i < 4000
    useOnce("tests/control-flow-using-return-runtime/src/main.mfb")
    i = i + 1
  WEND
  io::print("return")
  RETURN 0
END FUNC
