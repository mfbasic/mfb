IMPORT collections
IMPORT io

FUNC main AS Integer
  LET ages AS Map OF String TO Integer = Map OF String TO Integer { "Ada" := 36, "Grace" := 85, "Katherine" := 99 }
  LET codes AS Map OF Integer TO String = Map OF Integer TO String { 1 := "one", 2 := "two" }
  LET removed AS Map OF String TO Integer = collections::removeKey(ages, "Grace")
  LET missing AS Map OF Integer TO String = collections::removeKey(codes, 3)

  io::print(toString(len(removed)))
  io::print(toString(collections::hasKey(removed, "Ada")))
  io::print(toString(collections::hasKey(removed, "Grace")))
  io::print(toString(len(missing)))
  io::print(collections::get(missing, 2))

  RETURN len(removed) + len(missing)
END FUNC
