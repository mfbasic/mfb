    { "op": "bind", "mutable": true, "name": "booleanValue", "type": "Boolean", "value": { "kind": "const", "type": "Boolean", "value": "true" } },
    { "op": "assign", "name": "booleanValue", "value": { "kind": "call", "target": "passBoolean", "args": [{ "kind": "local", "name": "booleanValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeBoolean", "args": [{ "kind": "local", "name": "booleanValue" }] } },
    { "op": "bind", "mutable": true, "name": "stringValue", "type": "String", "value": { "kind": "const", "type": "String", "value": "hello" } },
    { "op": "assign", "name": "stringValue", "value": { "kind": "call", "target": "passString", "args": [{ "kind": "local", "name": "stringValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeString", "args": [{ "kind": "local", "name": "stringValue" }] } },
    { "op": "bind", "mutable": true, "name": "byteValue", "type": "Byte", "value": { "kind": "const", "type": "Integer", "value": "7" } },
    { "op": "assign", "name": "byteValue", "value": { "kind": "call", "target": "passByte", "args": [{ "kind": "local", "name": "byteValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeByte", "args": [{ "kind": "local", "name": "byteValue" }] } },
    { "op": "bind", "mutable": true, "name": "nothingValue", "type": "Nothing", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } },
    { "op": "assign", "name": "nothingValue", "value": { "kind": "call", "target": "passNothing", "args": [{ "kind": "local", "name": "nothingValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeNothing", "args": [{ "kind": "local", "name": "nothingValue" }] } },
    { "op": "bind", "mutable": true, "name": "errorValue", "type": "Error", "value": { "kind": "constructor", "type": "Error", "args": [{ "kind": "const", "type": "Integer", "value": "10002" }, { "kind": "const", "type": "String", "value": "invalid" }] } },
    { "op": "assign", "name": "errorValue", "value": { "kind": "call", "target": "passError", "args": [{ "kind": "local", "name": "errorValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeError", "args": [{ "kind": "local", "name": "errorValue" }] } },
    { "op": "bind", "mutable": true, "name": "resultValue", "type": "Result OF Integer", "value": { "kind": "constructor", "type": "Ok", "args": [{ "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "assign", "name": "resultValue", "value": { "kind": "constructor", "type": "Err", "args": [{ "kind": "constructor", "type": "Error", "args": [{ "kind": "const", "type": "Integer", "value": "10003" }, { "kind": "const", "type": "String", "value": "bad" }] }] } },
    { "op": "bind", "mutable": false, "name": "inspected", "type": "Integer", "value": { "kind": "call", "target": "inspectResult", "args": [{ "kind": "local", "name": "resultValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeResult", "args": [{ "kind": "local", "name": "resultValue" }] } },
    { "op": "bind", "mutable": true, "name": "listValue", "type": "List OF String", "value": { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "a" }, { "kind": "const", "type": "String", "value": "b" }] } },
    { "op": "assign", "name": "listValue", "value": { "kind": "call", "target": "passList", "args": [{ "kind": "local", "name": "listValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeList", "args": [{ "kind": "local", "name": "listValue" }] } },
    { "op": "bind", "mutable": true, "name": "emptyList", "type": "List OF String", "value": { "kind": "list", "type": "List OF Unknown", "values": [] } },
    { "op": "assign", "name": "emptyList", "value": { "kind": "call", "target": "passList", "args": [{ "kind": "local", "name": "emptyList" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeList", "args": [{ "kind": "local", "name": "emptyList" }] } },
    { "op": "bind", "mutable": true, "name": "mapValue", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "a" }, "value": { "kind": "const", "type": "Integer", "value": "1" } }, { "key": { "kind": "const", "type": "String", "value": "b" }, "value": { "kind": "const", "type": "Integer", "value": "2" } }] } },
    { "op": "assign", "name": "mapValue", "value": { "kind": "call", "target": "passMap", "args": [{ "kind": "local", "name": "mapValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeMap", "args": [{ "kind": "local", "name": "mapValue" }] } },
    { "op": "bind", "mutable": true, "name": "emptyMap", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [] } },
