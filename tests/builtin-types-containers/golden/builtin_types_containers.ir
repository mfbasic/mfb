  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": true, "name": "integerValue", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "1" } },
    { "op": "assign", "name": "integerValue", "value": { "kind": "call", "target": "passInteger", "args": [{ "kind": "local", "name": "integerValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeInteger", "args": [{ "kind": "local", "name": "integerValue" }] } },
    { "op": "bind", "mutable": true, "name": "floatValue", "type": "Float", "value": { "kind": "const", "type": "Float", "value": "1.5" } },
    { "op": "assign", "name": "floatValue", "value": { "kind": "call", "target": "passFloat", "args": [{ "kind": "local", "name": "floatValue" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "takeFloat", "args": [{ "kind": "local", "name": "floatValue" }] } },
    { "op": "bind", "mutable": true, "name": "fixedValue", "type": "Fixed", "value": { "kind": "const", "type": "Fixed", "value": "2.25" } },
    { "op": "assign", "name": "fixedValue", "value": { "kind": "call", "target": "passFixed", "args": [{ "kind": "local", "name": "fixedValue" }] } },
