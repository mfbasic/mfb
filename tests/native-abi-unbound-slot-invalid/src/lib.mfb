' Every ABI slot must bind to a parameter, a CONST pin, or the result (§5c).
EXPORT RESOURCE Db CLOSE BY demoLink::close

LINK "demo" AS demoLink
  FUNC close(RES db AS Db) AS Nothing
    SYMBOL "demo_close"
    ABI (db CPtr, mystery CInt32) AS status CInt32
    SUCCESS_ON status = 0
  END FUNC
END LINK
