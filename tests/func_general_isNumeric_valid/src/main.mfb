IMPORT io

FUNC main AS Integer
  io::print(toString(isNumeric("0")))
  io::print(toString(isNumeric("-2.50")))
  io::print(toString(isNumeric(".5")))
  io::print(toString(isNumeric("1.25e2")))
  io::print(toString(isNumeric("1e308")))
  io::print(toString(isNumeric("1e309")))
  io::print(toString(isNumeric("-1e309")))
  io::print(toString(isNumeric("9223372036854775807")))
  io::print(toString(isNumeric("9223372036854775808")))
  io::print(toString(isNumeric("2147483647.999999999")))
  io::print(toString(isNumeric("2147483648")))
  io::print(toString(isNumeric("x")))
  io::print(toString(isNumeric("1x")))
  RETURN 0
END FUNC
