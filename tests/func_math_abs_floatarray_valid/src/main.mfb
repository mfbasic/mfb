IMPORT io
IMPORT math
SUB pF(label AS String, xs AS List OF Float, p AS Byte)
  MUT s AS String = label
  FOR EACH x IN xs
    s = s & " " & toString(x, p)
  NEXT
  io::print(s)
END SUB

FUNC main AS Integer
  LET p AS Byte = 2
  LET xs AS List OF Float = [0.0 - 1.5, 2.25, 0.0 - 3.0, 4.5, 0.0 - 0.5]
  pF("abs", math::abs(xs), p)
  RETURN 0
END FUNC
