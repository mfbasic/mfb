IMPORT io
IMPORT strings

FUNC main AS Integer
  io::print("[" & strings::trimStart("  Hello  ") & "]")
  io::print("[" & strings::trimStart("	😀	") & "]")
  io::print("[" & strings::trimStart(" é ") & "]")
  io::print("[" & strings::trimStart("　wide　") & "]")
  io::print("[" & strings::trimStart("") & "]")
  RETURN 0
END FUNC
