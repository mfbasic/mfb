IMPORT collections
IMPORT io

FUNC main AS Integer
  LET numbers AS List OF Integer = collections::append([1, 2], 3)
  LET more AS List OF Integer = collections::append(numbers, [4, 5])
  LET names AS List OF String = collections::append(["Ada"], "Grace")
  LET moreNames AS List OF String = collections::append(names, ["Katherine"])

  FOR EACH value IN more
    io::print(toString(value))
  NEXT
  FOR EACH name IN moreNames
    io::print(name)
  NEXT

  ' Bulk in-place append: `x = collections::append(x, sublist)` on a uniquely
  ' owned MUT list grows the buffer once per batch (amortized O(sublist)), not
  ' the O(n) rebuild the value path does. The result equals the value path.
  MUT acc AS List OF Integer = []
  MUT k AS Integer = 0
  WHILE k < 4
    LET part AS List OF Integer = [k, k + 100]
    acc = collections::append(acc, part)
    k = k + 1
  WEND
  io::print("acc=" & toString(len(acc)))
  FOR EACH value IN acc
    io::print(toString(value))
  NEXT

  RETURN len(more) + len(moreNames)
END FUNC
