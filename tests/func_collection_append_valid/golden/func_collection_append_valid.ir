{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_collection_append_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "numbers", "type": "List OF Integer", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "list", "type": "List OF Integer", "values": [{ "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "bind", "mutable": false, "name": "more", "type": "List OF Integer", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "local", "name": "numbers" }, { "kind": "list", "type": "List OF Integer", "values": [{ "kind": "const", "type": "Integer", "value": "4" }, { "kind": "const", "type": "Integer", "value": "5" }] }] } },
    { "op": "bind", "mutable": false, "name": "names", "type": "List OF String", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Ada" }] }, { "kind": "const", "type": "String", "value": "Grace" }] } },
    { "op": "bind", "mutable": false, "name": "moreNames", "type": "List OF String", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "local", "name": "names" }, { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Katherine" }] }] } },
    {
      "op": "forEach",
      "name": "value",
      "type": "Integer",
      "iterable": { "kind": "local", "name": "more" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "value" }] }] } }
      ]
    },
    {
      "op": "forEach",
      "name": "name",
      "type": "String",
      "iterable": { "kind": "local", "name": "moreNames" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "name" }] } }
      ]
    },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "more" }] }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "moreNames" }] } } }
    ]
  }
