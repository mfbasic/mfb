IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("clamp_length Float2 = " & toString(vector::clamp_length(vector::Float2[3.0, 4.0], 2.0)))
  io::print("clamp_length Float3 = " & toString(vector::clamp_length(vector::Float3[1.0, 2.0, 2.0], 2.0)))
  io::print("clamp_length Float4 = " & toString(vector::clamp_length(vector::Float4[1.0, 2.0, 2.0, 4.0], 2.0)))
  io::print("clamp_length Fixed2 = " & toString(vector::clamp_length(vector::Fixed2[toFixed(3.0), toFixed(4.0)], toFixed(2.0))))
  io::print("clamp_length Fixed3 = " & toString(vector::clamp_length(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)], toFixed(2.0))))
  io::print("clamp_length Fixed4 = " & toString(vector::clamp_length(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)], toFixed(2.0))))
  io::print("clamp_length Integer2 = " & toString(vector::clamp_length(vector::Integer2[3, 4], 2)))
  io::print("clamp_length Integer3 = " & toString(vector::clamp_length(vector::Integer3[1, 2, 2], 2)))
  io::print("clamp_length Integer4 = " & toString(vector::clamp_length(vector::Integer4[1, 2, 2, 4], 2)))
  RETURN 0
END FUNC
