    { "op": "bind", "mutable": false, "name": "x", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "2" } },
    { "op": "bind", "mutable": false, "name": "e", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "5" } },
    { "op": "bind", "mutable": false, "name": "f", "type": "Fixed", "value": { "kind": "const", "type": "Fixed", "value": "2.0" } },
