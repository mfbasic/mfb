IMPORT strings

FUNC main AS Integer
  LET padded AS String = "  Hello,World  "
  LET csv AS String = "Ada,Grace,Mary"
  LET needle AS String = "World"
  LET pieces AS List OF String = ["Ada", "Grace", "Mary"]

  LET trimmed AS String = strings.trim(padded)
  LET leftTrimmed AS String = strings.trimStart(padded)
  LET rightTrimmed AS String = strings.trimEnd(padded)
  LET upper AS String = strings.upper(trimmed)
  LET lower AS String = strings.lower(upper)
  LET folded AS String = strings.caseFold(upper)
  LET normalized AS String = strings.normalizeNfc(trimmed)
  LET chars AS List OF String = strings.graphemes("abc")
  LET starts AS Boolean = strings.startsWith(trimmed, "Hello")
  LET ends AS Boolean = strings.endsWith(trimmed, needle)
  LET hasNeedle AS Boolean = strings.contains(trimmed, needle)
  LET splitParts AS List OF String = strings.split(csv, ",")
  LET joined AS String = strings.join(pieces, "|")
  LET bytes AS Integer = strings.byteLen(joined)
  LET regexMatches AS Boolean = strings.regexMatch(trimmed, needle)
  LET regexFound AS Integer = strings.regexFind(trimmed, needle)
  LET regexFoundFromStart AS Integer = strings.regexFind(trimmed, needle, 1)
  LET regexReplaced AS String = strings.regexReplace(trimmed, needle, "MFB")

  RETURN len(trimmed) + len(leftTrimmed) + len(rightTrimmed) + len(upper) + len(lower) + len(folded) + len(normalized) + len(chars) + len(splitParts) + len(regexReplaced) + bytes + regexFound + regexFoundFromStart
END FUNC
