IMPORT strings
IMPORT collections

' Consolidated runtime-behavior acceptance for the strings builtins, converted
' from the tests/func_string_*_valid and tests/func_strings_*_valid fixtures.
' Each assertion compares the SAME expression as the source fixture against that
' fixture's exact golden value, using the typed TESTING assertions so no
' toString formatting is needed.

' The unicode-table string builtins (caseFold/lower/upper/normalizeNfc) are
' routed through these user FUNCs (as the source fixtures did) so their large
' data relocations live outside the single generated TESTING driver FUNC; called
' inline in that driver they trigger a layout-sensitive codegen miscompile that
' corrupts adjacent assertions.
FUNC foldValue(value AS String) AS String
  RETURN strings::caseFold(value)
END FUNC

FUNC lowerValue(value AS String) AS String
  RETURN strings::lower(value)
END FUNC

FUNC upperValue(value AS String) AS String
  RETURN strings::upper(value)
END FUNC

FUNC nfcValue(value AS String) AS String
  RETURN strings::normalizeNfc(value)
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC

TESTING
  TGROUP "byteLen"
    TCASE "scalar"
      expectInteger(strings::byteLen(""), 0)
      expectInteger(strings::byteLen("Hello"), 5)
      expectInteger(strings::byteLen("é"), 2)
      expectInteger(strings::byteLen("😀"), 4)
      expectInteger(strings::byteLen("A😀é"), 7)
    END TCASE
  END TGROUP

  TGROUP "caseFold"
    TCASE "scalar"
      LET german AS String = "Straße"
      expectString(foldValue(""), "")
      expectString(foldValue("HELLO"), "hello")
      expectString(foldValue(german), "strasse")
      expectString(foldValue("İ"), "i̇")
      expectString(foldValue("É日😀"), "é日😀")
    END TCASE
  END TGROUP

  TGROUP "contains"
    TCASE "scalar"
      expectEqual(strings::contains("Hello", ""), TRUE)
      expectEqual(strings::contains("Hello", "ell"), TRUE)
      expectEqual(strings::contains("Hello 😀", "😀"), TRUE)
      expectEqual(strings::contains("café", "fé"), TRUE)
      expectEqual(strings::contains("Hello", "xyz"), FALSE)
      expectEqual(strings::contains("", "x"), FALSE)
    END TCASE
  END TGROUP

  TGROUP "endsWith"
    TCASE "scalar"
      expectEqual(strings::endsWith("Hello", ""), TRUE)
      expectEqual(strings::endsWith("Hello", "lo"), TRUE)
      expectEqual(strings::endsWith("Hello 😀", "😀"), TRUE)
      expectEqual(strings::endsWith("café", "é"), TRUE)
      expectEqual(strings::endsWith("Hello", "he"), FALSE)
      expectEqual(strings::endsWith("Hi", "Hello"), FALSE)
    END TCASE
  END TGROUP

  TGROUP "graphemes"
    TCASE "empty"
      LET r AS List OF String = strings::graphemes("")
      expectInteger(len(r), 0)
    END TCASE
    TCASE "combining"
      LET r AS List OF String = strings::graphemes("áb")
      expectInteger(len(r), 2)
      expectString(collections::get(r, 0), "á")
      expectString(collections::get(r, 1), "b")
    END TCASE
    TCASE "family emoji zwj sequence"
      LET r AS List OF String = strings::graphemes("👨‍👩‍👧‍👦x")
      expectInteger(len(r), 2)
      expectString(collections::get(r, 0), "👨‍👩‍👧‍👦")
      expectString(collections::get(r, 1), "x")
    END TCASE
    TCASE "regional indicator flags"
      LET r AS List OF String = strings::graphemes("🇺🇸🇨🇦")
      expectInteger(len(r), 2)
      expectString(collections::get(r, 0), "🇺🇸")
      expectString(collections::get(r, 1), "🇨🇦")
    END TCASE
  END TGROUP

  TGROUP "startsWithAny / endsWithAny"
    TCASE "any-prefix"
      LET empty AS List OF String = []
      LET p1 AS List OF String = ["he", "xy"]
      LET p2 AS List OF String = ["xy", "zz"]
      expectEqual(strings::startsWithAny("hello", p1), TRUE)
      expectEqual(strings::startsWithAny("hello", p2), FALSE)
      expectEqual(strings::startsWithAny("hello", empty), FALSE)
    END TCASE
    TCASE "any-suffix"
      LET empty AS List OF String = []
      LET s1 AS List OF String = ["lo", "xy"]
      expectEqual(strings::endsWithAny("hello", s1), TRUE)
      expectEqual(strings::endsWithAny("hello", empty), FALSE)
    END TCASE
  END TGROUP

  TGROUP "stripPrefix / stripSuffix"
    TCASE "stripPrefix"
      expectString(strings::stripPrefix("foobar", "foo"), "bar")
      expectString(strings::stripPrefix("foobar", "xyz"), "foobar")
      expectString(strings::stripPrefix("foo", ""), "foo")
    END TCASE
    TCASE "stripSuffix"
      expectString(strings::stripSuffix("foobar", "bar"), "foo")
      expectString(strings::stripSuffix("foobar", "xyz"), "foobar")
    END TCASE
  END TGROUP

  TGROUP "count"
    TCASE "overlapping and disjoint"
      expectInteger(strings::count("aaa", "a"), 3)
      expectInteger(strings::count("aaa", "aa"), 1)
      expectInteger(strings::count("abcabc", "bc"), 2)
      expectInteger(strings::count("xyz", "a"), 0)
    END TCASE
    TCASE "needle longer than value"
      expectInteger(strings::count("ab", "abcdef"), 0)
    END TCASE
  END TGROUP

  TGROUP "left / right"
    TCASE "left"
      expectString(strings::left("hello", 3), "hel")
      expectString(strings::left("hi", 5), "hi")
      expectString(strings::left("hi", 0), "")
    END TCASE
    TCASE "right"
      expectString(strings::right("hello", 3), "llo")
      expectString(strings::right("hi", 5), "hi")
      expectString(strings::right("hi", 0), "")
    END TCASE
    TCASE "grapheme-aware slicing"
      expectString(strings::left("a😀bc", 2), "a😀")
      expectString(strings::right("ab😀c", 2), "😀c")
    END TCASE
  END TGROUP

  TGROUP "repeat"
    TCASE "scalar"
      expectString(strings::repeat("ab", 3), "ababab")
      expectString(strings::repeat("x", 0), "")
    END TCASE
  END TGROUP

  TGROUP "padLeft / padRight"
    TCASE "padLeft"
      expectString(strings::padLeft("42", 5), "   42")
      expectString(strings::padLeft("42", 5, "0"), "00042")
      expectString(strings::padLeft("hello", 3), "hello")
      expectString(strings::padLeft("x", 3, "😀"), "😀😀x")
    END TCASE
    TCASE "padRight"
      expectString(strings::padRight("42", 5), "42   ")
      expectString(strings::padRight("42", 5, "0"), "42000")
    END TCASE
  END TGROUP

  TGROUP "graphemeAt / graphemesCount"
    TCASE "scalar"
      expectString(strings::graphemeAt("abc", 1), "b")
      expectInteger(strings::graphemesCount("abc"), 3)
      expectInteger(strings::graphemesCount("e" & "́" & "fg"), 3)
    END TCASE
  END TGROUP

  TGROUP "trimChars"
    TCASE "scalar"
      expectString(strings::trimChars("xxhelloxx", "x"), "hello")
      expectString(strings::trimChars("--a-b--", "-"), "a-b")
      expectString(strings::trimChars("aaa", "a"), "")
      expectString(strings::trimChars("hello", ""), "hello")
    END TCASE
  END TGROUP

  TGROUP "join"
    TCASE "scalar"
      LET empty AS List OF String = []
      expectString(strings::join(empty, ","), "")
      expectString(strings::join(["Hello"], ","), "Hello")
      expectString(strings::join(["Hello", "World"], " "), "Hello World")
      expectString(strings::join(parts := ["left", "right"], delimiter := "/"), "left/right")
      expectString(strings::join(["a", "b", "c"], ""), "abc")
      expectString(strings::join(["😀", "é", "wide"], "|"), "😀|é|wide")
      expectString(strings::join(["left", "", "right"], "-"), "left--right")
    END TCASE
  END TGROUP

  TGROUP "lower"
    TCASE "scalar"
      LET mixed AS String = "CAFÉ"
      expectString(lowerValue(""), "")
      expectString(lowerValue("HELLO"), "hello")
      expectString(lowerValue(mixed), "café")
      expectString(lowerValue("İ"), "i̇")
      expectString(lowerValue("É日😀"), "é日😀")
    END TCASE
  END TGROUP

  TGROUP "upper"
    TCASE "scalar"
      LET german AS String = "straße"
      expectString(upperValue(""), "")
      expectString(upperValue("hello"), "HELLO")
      expectString(upperValue(german), "STRASSE")
      expectString(upperValue("é日😀"), "É日😀")
      expectString(upperValue("i̇"), "İ")
    END TCASE
  END TGROUP

  TGROUP "normalizeNfc"
    TCASE "scalar"
      LET cafe AS String = "Café"
      expectString(nfcValue(""), "")
      expectString(nfcValue(cafe), "Café")
      expectString(nfcValue("Å"), "Å")
      expectString(nfcValue("Å"), "Å")
      expectString(nfcValue("가"), "가")
      expectString(nfcValue("😀é"), "😀é")
    END TCASE
  END TGROUP

  TGROUP "split"
    TCASE "csv"
      LET r AS List OF String = strings::split("a,b,c", ",")
      expectInteger(len(r), 3)
      expectString(collections::get(r, 0), "a")
      expectString(collections::get(r, 1), "b")
      expectString(collections::get(r, 2), "c")
    END TCASE
    TCASE "emoji delimiter"
      LET r AS List OF String = strings::split("a😀b😀c", "😀")
      expectInteger(len(r), 3)
      expectString(collections::get(r, 0), "a")
      expectString(collections::get(r, 1), "b")
      expectString(collections::get(r, 2), "c")
    END TCASE
    TCASE "empty fields at edges"
      LET r AS List OF String = strings::split(",a,,", ",")
      expectInteger(len(r), 4)
      expectString(collections::get(r, 0), "")
      expectString(collections::get(r, 1), "a")
      expectString(collections::get(r, 2), "")
      expectString(collections::get(r, 3), "")
    END TCASE
    TCASE "no match"
      LET r AS List OF String = strings::split("abc", "|")
      expectInteger(len(r), 1)
      expectString(collections::get(r, 0), "abc")
    END TCASE
  END TGROUP

  TGROUP "startsWith"
    TCASE "scalar"
      expectEqual(strings::startsWith("Hello", ""), TRUE)
      expectEqual(strings::startsWith("Hello", "He"), TRUE)
      expectEqual(strings::startsWith("😀 Hello", "😀"), TRUE)
      expectEqual(strings::startsWith("éclair", "é"), TRUE)
      expectEqual(strings::startsWith("Hello", "hello"), FALSE)
      expectEqual(strings::startsWith("Hi", "Hello"), FALSE)
    END TCASE
  END TGROUP

  TGROUP "trim"
    TCASE "scalar"
      expectString(strings::trim("  Hello  "), "Hello")
      expectString(strings::trim("	😀	"), "😀")
      expectString(strings::trim(" é "), "é")
      expectString(strings::trim("　wide　"), "wide")
      expectString(strings::trim(""), "")
      expectString(strings::trim("   "), "")
    END TCASE
  END TGROUP

  TGROUP "trimStart"
    TCASE "scalar"
      expectString(strings::trimStart("  Hello  "), "Hello  ")
      expectString(strings::trimStart("	😀	"), "😀	")
      expectString(strings::trimStart(" é "), "é ")
      expectString(strings::trimStart("　wide　"), "wide　")
      expectString(strings::trimStart(""), "")
    END TCASE
  END TGROUP

  TGROUP "trimEnd"
    TCASE "scalar"
      expectString(strings::trimEnd("  Hello  "), "  Hello")
      expectString(strings::trimEnd("	😀	"), "	😀")
      expectString(strings::trimEnd(" é "), " é")
      expectString(strings::trimEnd("　wide　"), "　wide")
      expectString(strings::trimEnd(""), "")
    END TCASE
  END TGROUP

  TGROUP "toBytes"
    TCASE "multibyte"
      LET b AS List OF Byte = strings::toBytes("héllo")
      expectInteger(len(b), 6)
      expectEqual(collections::get(b, 0), 104)
      expectEqual(collections::get(b, 1), 195)
      expectEqual(collections::get(b, 2), 169)
      expectEqual(collections::get(b, 3), 108)
      expectEqual(collections::get(b, 4), 108)
      expectEqual(collections::get(b, 5), 111)
    END TCASE
    TCASE "mutated string and empty"
      MUT s AS String = "AB"
      s = s & "C"
      LET sb AS List OF Byte = strings::toBytes(s)
      expectInteger(len(sb), 3)
      LET eb AS List OF Byte = strings::toBytes("")
      expectInteger(len(eb), 0)
    END TCASE
  END TGROUP
END TESTING
