{
  "format": "mfb-ir",
  "version": 1,
  "project": "builtin_strings",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "padded", "type": "String", "value": { "kind": "const", "type": "String", "value": "  Hello,World  " } },
    { "op": "bind", "mutable": false, "name": "csv", "type": "String", "value": { "kind": "const", "type": "String", "value": "Ada,Grace,Mary" } },
    { "op": "bind", "mutable": false, "name": "needle", "type": "String", "value": { "kind": "const", "type": "String", "value": "World" } },
    { "op": "bind", "mutable": false, "name": "pieces", "type": "List OF String", "value": { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Ada" }, { "kind": "const", "type": "String", "value": "Grace" }, { "kind": "const", "type": "String", "value": "Mary" }] } },
    { "op": "bind", "mutable": false, "name": "trimmed", "type": "String", "value": { "kind": "call", "target": "strings.trim", "args": [{ "kind": "local", "name": "padded" }] } },
    { "op": "bind", "mutable": false, "name": "leftTrimmed", "type": "String", "value": { "kind": "call", "target": "strings.trimStart", "args": [{ "kind": "local", "name": "padded" }] } },
    { "op": "bind", "mutable": false, "name": "rightTrimmed", "type": "String", "value": { "kind": "call", "target": "strings.trimEnd", "args": [{ "kind": "local", "name": "padded" }] } },
    { "op": "bind", "mutable": false, "name": "upper", "type": "String", "value": { "kind": "call", "target": "strings.upper", "args": [{ "kind": "local", "name": "trimmed" }] } },
    { "op": "bind", "mutable": false, "name": "lower", "type": "String", "value": { "kind": "call", "target": "strings.lower", "args": [{ "kind": "local", "name": "upper" }] } },
    { "op": "bind", "mutable": false, "name": "folded", "type": "String", "value": { "kind": "call", "target": "strings.caseFold", "args": [{ "kind": "local", "name": "upper" }] } },
    { "op": "bind", "mutable": false, "name": "normalized", "type": "String", "value": { "kind": "call", "target": "strings.normalizeNfc", "args": [{ "kind": "local", "name": "trimmed" }] } },
    { "op": "bind", "mutable": false, "name": "chars", "type": "List OF String", "value": { "kind": "call", "target": "strings.graphemes", "args": [{ "kind": "const", "type": "String", "value": "abc" }] } },
    { "op": "bind", "mutable": false, "name": "starts", "type": "Boolean", "value": { "kind": "call", "target": "strings.startsWith", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "const", "type": "String", "value": "Hello" }] } },
    { "op": "bind", "mutable": false, "name": "ends", "type": "Boolean", "value": { "kind": "call", "target": "strings.endsWith", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "local", "name": "needle" }] } },
    { "op": "bind", "mutable": false, "name": "hasNeedle", "type": "Boolean", "value": { "kind": "call", "target": "strings.contains", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "local", "name": "needle" }] } },
    { "op": "bind", "mutable": false, "name": "splitParts", "type": "List OF String", "value": { "kind": "call", "target": "strings.split", "args": [{ "kind": "local", "name": "csv" }, { "kind": "const", "type": "String", "value": "," }] } },
    { "op": "bind", "mutable": false, "name": "joined", "type": "String", "value": { "kind": "call", "target": "strings.join", "args": [{ "kind": "local", "name": "pieces" }, { "kind": "const", "type": "String", "value": "|" }] } },
    { "op": "bind", "mutable": false, "name": "bytes", "type": "Integer", "value": { "kind": "call", "target": "strings.byteLen", "args": [{ "kind": "local", "name": "joined" }] } },
    { "op": "bind", "mutable": false, "name": "regexMatches", "type": "Boolean", "value": { "kind": "call", "target": "strings.regexMatch", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "local", "name": "needle" }] } },
    { "op": "bind", "mutable": false, "name": "regexFound", "type": "Integer", "value": { "kind": "call", "target": "strings.regexFind", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "local", "name": "needle" }] } },
    { "op": "bind", "mutable": false, "name": "regexFoundFromStart", "type": "Integer", "value": { "kind": "call", "target": "strings.regexFind", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "local", "name": "needle" }, { "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "bind", "mutable": false, "name": "regexReplaced", "type": "String", "value": { "kind": "call", "target": "strings.regexReplace", "args": [{ "kind": "local", "name": "trimmed" }, { "kind": "local", "name": "needle" }, { "kind": "const", "type": "String", "value": "MFB" }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "trimmed" }] }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "leftTrimmed" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "rightTrimmed" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "upper" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "lower" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "folded" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "normalized" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "chars" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "splitParts" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "regexReplaced" }] } }, "right": { "kind": "local", "name": "bytes" } }, "right": { "kind": "local", "name": "regexFound" } }, "right": { "kind": "local", "name": "regexFoundFromStart" } } }
    ]
  }
  ]
}
