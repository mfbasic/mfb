{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_collection_mid_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "printIntegers",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "values", "type": "List OF Integer", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    {
      "op": "forEach",
      "name": "item",
      "type": "Integer",
      "iterable": { "kind": "local", "name": "values" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "item" }] }] } }
      ]
    },
    { "op": "return", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } }
    ]
  },
  {
    "name": "printStrings",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "values", "type": "List OF String", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    {
      "op": "forEach",
      "name": "item",
      "type": "String",
      "iterable": { "kind": "local", "name": "values" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "item" }] } }
      ]
    },
    { "op": "return", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "numbers", "type": "List OF Integer", "value": { "kind": "list", "type": "List OF Integer", "values": [{ "kind": "const", "type": "Integer", "value": "10" }, { "kind": "const", "type": "Integer", "value": "20" }, { "kind": "const", "type": "Integer", "value": "30" }, { "kind": "const", "type": "Integer", "value": "40" }] } },
    { "op": "bind", "mutable": false, "name": "names", "type": "List OF String", "value": { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Ada" }, { "kind": "const", "type": "String", "value": "Grace" }, { "kind": "const", "type": "String", "value": "Katherine" }] } },
    { "op": "bind", "mutable": false, "name": "numberSlice", "type": "List OF Integer", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "local", "name": "numbers" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "2" }] } },
    { "op": "bind", "mutable": false, "name": "stringSlice", "type": "List OF String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "local", "name": "names" }, { "kind": "const", "type": "Integer", "value": "0" }, { "kind": "const", "type": "Integer", "value": "2" }] } },
    { "op": "bind", "mutable": false, "name": "emptySlice", "type": "List OF Integer", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "local", "name": "numbers" }, { "kind": "const", "type": "Integer", "value": "4" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "printIntegers", "args": [{ "kind": "local", "name": "numberSlice" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "printStrings", "args": [{ "kind": "local", "name": "stringSlice" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "emptySlice" }] }] }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "numberSlice" }] }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "stringSlice" }] } }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "emptySlice" }] } } }
    ]
  }
  ]
}
