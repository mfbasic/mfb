IMPORT io
IMPORT strings

FUNC foldValue(value AS String) AS String
  RETURN strings::caseFold(value)
END FUNC

FUNC main AS Integer
  LET german AS String = "Straße"
  io::print(foldValue(""))
  io::print(foldValue("HELLO"))
  io::print(foldValue(german))
  io::print(foldValue("İ"))
  io::print(foldValue("É日😀"))
  RETURN 0
END FUNC
