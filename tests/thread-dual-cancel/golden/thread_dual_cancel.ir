    { "op": "bind", "mutable": false, "name": "hasLetter3", "type": "Boolean", "value": { "kind": "call", "target": "thread.poll", "args": [{ "kind": "local", "name": "letters" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
