    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "letters" }, { "kind": "const", "type": "String", "value": "next" }] } },
    { "op": "bind", "mutable": false, "name": "hasCount3", "type": "Boolean", "value": { "kind": "call", "target": "thread.poll", "args": [{ "kind": "local", "name": "counts" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
    { "op": "bind", "mutable": false, "name": "count3", "type": "String", "value": { "kind": "call", "target": "thread.read", "args": [{ "kind": "local", "name": "counts" }] } },
