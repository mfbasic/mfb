    "body": [
    { "op": "bind", "mutable": false, "name": "counts", "type": "Thread OF String TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_runtime_workers.countWorker", "type": "ISOLATED FUNC(Thread OF String TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "count" }] } },
    { "op": "bind", "mutable": false, "name": "letters", "type": "Thread OF String TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_runtime_workers.alphabetWorker", "type": "ISOLATED FUNC(Thread OF String TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "alpha" }] } },
    { "op": "bind", "mutable": false, "name": "hasCount1", "type": "Boolean", "value": { "kind": "call", "target": "thread.poll", "args": [{ "kind": "local", "name": "counts" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
    { "op": "bind", "mutable": false, "name": "count1", "type": "String", "value": { "kind": "call", "target": "thread.read", "args": [{ "kind": "local", "name": "counts" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "count:" }, "right": { "kind": "local", "name": "count1" } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "counts" }, { "kind": "const", "type": "String", "value": "next" }] } },
    { "op": "bind", "mutable": false, "name": "hasLetter1", "type": "Boolean", "value": { "kind": "call", "target": "thread.poll", "args": [{ "kind": "local", "name": "letters" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
    { "op": "bind", "mutable": false, "name": "letter1", "type": "String", "value": { "kind": "call", "target": "thread.read", "args": [{ "kind": "local", "name": "letters" }] } },
