    { "op": "bind", "mutable": false, "name": "hasLetter2", "type": "Boolean", "value": { "kind": "call", "target": "thread.poll", "args": [{ "kind": "local", "name": "letters" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
    { "op": "bind", "mutable": false, "name": "letter2", "type": "String", "value": { "kind": "call", "target": "thread.read", "args": [{ "kind": "local", "name": "letters" }] } },
