IMPORT fs

FUNC main AS Integer
  LET missing AS File = fs::openFileNoFollow()
  LET wrongPath AS File = fs::openFileNoFollow(1)
  LET wrongMode AS File = fs::openFileNoFollow("a", 1)
  LET tooMany AS File = fs::openFileNoFollow("a", "read", "x")
  LET badName AS File = fs::openFileNoFollow(file := "a")
  RETURN 0
END FUNC
