    { "op": "bind", "mutable": true, "name": "request", "type": "String", "value": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "method" }, "right": { "kind": "const", "type": "String", "value": " " } }, "right": { "kind": "call", "target": "#http_requestTarget", "args": [{ "kind": "local", "name": "url" }] } }, "right": { "kind": "const", "type": "String", "value": " HTTP/1.1" } }, "right": { "kind": "local", "name": "crlf" } } },
    { "op": "assign", "name": "request", "value": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "request" }, "right": { "kind": "const", "type": "String", "value": "Host: " } }, "right": { "kind": "call", "target": "#http_headerValue", "args": [{ "kind": "local", "name": "headers" }, { "kind": "const", "type": "String", "value": "Host" }, { "kind": "call", "target": "#http_hostHeader", "args": [{ "kind": "local", "name": "url" }] }] } }, "right": { "kind": "local", "name": "crlf" } } },
