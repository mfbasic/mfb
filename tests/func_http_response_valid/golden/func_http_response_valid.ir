    { "op": "assign", "name": "request", "value": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "request" }, "right": { "kind": "const", "type": "String", "value": "Connection: close" } }, "right": { "kind": "local", "name": "crlf" } } },
    {
      "op": "if",
