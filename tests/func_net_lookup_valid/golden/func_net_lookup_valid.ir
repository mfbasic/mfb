    { "op": "bind", "mutable": false, "name": "one", "type": "List OF Address", "value": { "kind": "call", "target": "net.lookup", "args": [{ "kind": "const", "type": "String", "value": "127.0.0.1" }] } },
    { "op": "bind", "mutable": false, "name": "two", "type": "List OF Address", "value": { "kind": "call", "target": "net.lookup", "args": [{ "kind": "const", "type": "String", "value": "127.0.0.1" }, { "kind": "const", "type": "Integer", "value": "443" }] } },
    { "op": "bind", "mutable": false, "name": "a", "type": "Address", "value": { "kind": "call", "target": "get", "args": [{ "kind": "local", "name": "one" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "bind", "mutable": false, "name": "b", "type": "Address", "value": { "kind": "call", "target": "get", "args": [{ "kind": "local", "name": "two" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "a" }, "member": "host" }, "right": { "kind": "const", "type": "String", "value": " " } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "a" }, "member": "port" }] } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "b" }, "member": "host" }, "right": { "kind": "const", "type": "String", "value": " " } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "b" }, "member": "port" }] } }] } },
