    { "op": "bind", "mutable": false, "name": "wholeLen", "type": "Integer", "value": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "whole" }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "asciiLen" }, "right": { "kind": "local", "name": "unicodeLen" } }, "right": { "kind": "local", "name": "emptyMiddleLen" } }, "right": { "kind": "local", "name": "emptyEndLen" } }, "right": { "kind": "local", "name": "wholeLen" } } }
