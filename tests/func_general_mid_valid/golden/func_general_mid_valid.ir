    "body": [
    { "op": "bind", "mutable": false, "name": "ascii", "type": "String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "const", "type": "String", "value": "hello" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "bind", "mutable": false, "name": "unicode", "type": "String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "const", "type": "String", "value": "aé日b" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "2" }] } },
    { "op": "bind", "mutable": false, "name": "emptyMiddle", "type": "String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "const", "type": "String", "value": "hello" }, { "kind": "const", "type": "Integer", "value": "2" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "bind", "mutable": false, "name": "emptyEnd", "type": "String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "const", "type": "String", "value": "hello" }, { "kind": "const", "type": "Integer", "value": "5" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "bind", "mutable": false, "name": "whole", "type": "String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "const", "type": "String", "value": "hello" }, { "kind": "const", "type": "Integer", "value": "0" }, { "kind": "const", "type": "Integer", "value": "5" }] } },
