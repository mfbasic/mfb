IMPORT io

FUNC main AS Integer
  LET ascii AS String = mid("hello", 1, 3)
  LET unicode AS String = mid("aé日b", 1, 2)
  LET emptyMiddle AS String = mid("hello", 2, 0)
  LET emptyEnd AS String = mid("hello", 5, 0)
  LET whole AS String = mid("hello", 0, 5)

  io::print(ascii)
  io::print(unicode)
  io::print(emptyMiddle)
  io::print(emptyEnd)
  io::print(whole)

  LET asciiLen AS Integer = len(ascii)
  LET unicodeLen AS Integer = len(unicode)
  LET emptyMiddleLen AS Integer = len(emptyMiddle)
  LET emptyEndLen AS Integer = len(emptyEnd)
  LET wholeLen AS Integer = len(whole)
  RETURN asciiLen + unicodeLen + emptyMiddleLen + emptyEndLen + wholeLen
END FUNC
