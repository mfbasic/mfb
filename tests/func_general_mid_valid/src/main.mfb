IMPORT strings
IMPORT io

FUNC main AS Integer
  LET ascii AS String = strings::mid("hello", 1, 3)
  LET unicode AS String = strings::mid("aé日b", 1, 2)
  LET emptyMiddle AS String = strings::mid("hello", 2, 0)
  LET emptyEnd AS String = strings::mid("hello", 5, 0)
  LET whole AS String = strings::mid("hello", 0, 5)
  LET emoji AS String = strings::mid("a😀é日", 1, 2)
  LET combining AS String = strings::mid("éx", 0, 2)
  LET family AS String = strings::mid("x👨‍👩‍👧‍👦y", 1, 7)

  io::print(ascii)
  io::print(unicode)
  io::print(emptyMiddle)
  io::print(emptyEnd)
  io::print(whole)
  io::print(emoji)
  io::print(combining)
  io::print(family)

  LET asciiLen AS Integer = len(ascii)
  LET unicodeLen AS Integer = len(unicode)
  LET emptyMiddleLen AS Integer = len(emptyMiddle)
  LET emptyEndLen AS Integer = len(emptyEnd)
  LET wholeLen AS Integer = len(whole)
  LET emojiLen AS Integer = len(emoji)
  LET combiningLen AS Integer = len(combining)
  LET familyLen AS Integer = len(family)
  RETURN asciiLen + unicodeLen + emptyMiddleLen + emptyEndLen + wholeLen + emojiLen + combiningLen + familyLen
END FUNC
