{
  "format": "mfb-ir",
  "version": 1,
  "project": "control_flow_match_destructuring",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  {
    "kind": "type",
    "visibility": "private",
    "name": "Circle",
    "fields": [
    { "visibility": null, "name": "radius", "type": "Integer" }
    ]
  },
  {
    "kind": "type",
    "visibility": "private",
    "name": "Rect",
    "fields": [
    { "visibility": null, "name": "width", "type": "Integer" },
    { "visibility": null, "name": "height", "type": "Integer" }
    ]
  },
  {
    "kind": "union",
    "visibility": "private",
    "name": "Shape",
    "includes": [],
    "variants": [
    {
      "name": "Circle",
      "fields": [
      { "visibility": null, "name": "radius", "type": "Integer" }
      ]
    },
    {
      "name": "Rect",
      "fields": [
      { "visibility": null, "name": "width", "type": "Integer" },
      { "visibility": null, "name": "height", "type": "Integer" }
      ]
    }
    ]
  }
  ],
  "functions": [
  {
    "name": "parsePositive",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "Integer", "default": null }
    ],
    "returns": "Integer",
    "body": [
    {
      "op": "if",
      "condition": { "kind": "binary", "op": "<", "left": { "kind": "local", "name": "value" }, "right": { "kind": "const", "type": "Integer", "value": "0" } },
      "then": [
      { "op": "fail", "error": { "kind": "constructor", "type": "Error", "args": [{ "kind": "const", "type": "Integer", "value": "100" }, { "kind": "const", "type": "String", "value": "negative" }, { "kind": "constructor", "type": "ErrorLoc", "args": [{ "kind": "const", "type": "String", "value": "src/main.mfb" }, { "kind": "const", "type": "Integer", "value": "16" }, { "kind": "const", "type": "Integer", "value": "26" }] }] } }
      ],
      "else": [
      ]
    },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "value" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": true, "name": "total", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "0" } },
    { "op": "bind", "mutable": false, "name": "firstShape", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Circle", "value": { "kind": "constructor", "type": "Circle", "args": [{ "kind": "const", "type": "Integer", "value": "5" }] } } },
    { "op": "bind", "mutable": false, "name": "secondShape", "type": "Shape", "value": { "kind": "unionWrap", "union": "Shape", "member": "Rect", "value": { "kind": "constructor", "type": "Rect", "args": [{ "kind": "const", "type": "Integer", "value": "10" }, { "kind": "const", "type": "Integer", "value": "20" }] } } },
    { "op": "bind", "mutable": false, "name": "$match0", "type": "Shape", "value": { "kind": "local", "name": "firstShape" } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match0" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Circle" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "circle", "type": "Circle", "value": { "kind": "unionExtract", "type": "Circle", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "circle" }, "member": "radius" } } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Rect" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "rect", "type": "Rect", "value": { "kind": "unionExtract", "type": "Rect", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "rect" }, "member": "width" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "rect" }, "member": "height" } } }
        ]
      }
      ]
    },
    { "op": "bind", "mutable": false, "name": "$match1", "type": "Shape", "value": { "kind": "local", "name": "secondShape" } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match1" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Circle" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "circle", "type": "Circle", "value": { "kind": "unionExtract", "type": "Circle", "value": { "kind": "local", "name": "$match1" } } },
        { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "circle" }, "member": "radius" } } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "Rect" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "rect", "type": "Rect", "value": { "kind": "unionExtract", "type": "Rect", "value": { "kind": "local", "name": "$match1" } } },
        { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "rect" }, "member": "width" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "rect" }, "member": "height" } } }
        ]
      }
      ]
    },
    { "op": "bind", "mutable": false, "name": "$trap_res2", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "parsePositive", "args": [{ "kind": "const", "type": "Integer", "value": "9" }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val3", "type": "Integer", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res2" } },
      "then": [
      { "op": "assign", "name": "$trap_val3", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res2" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "err", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res2" } } },
      { "op": "assign", "name": "$trap_val3", "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "err" }, "member": "code" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "parsedOk", "type": "Integer", "value": { "kind": "local", "name": "$trap_val3" } },
    { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "local", "name": "parsedOk" } } },
    { "op": "bind", "mutable": false, "name": "$trap_res4", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "parsePositive", "args": [{ "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "1" } }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val5", "type": "Integer", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res4" } },
      "then": [
      { "op": "assign", "name": "$trap_val5", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res4" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "err", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res4" } } },
      { "op": "assign", "name": "$trap_val5", "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "err" }, "member": "code" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "parsedErr", "type": "Integer", "value": { "kind": "local", "name": "$trap_val5" } },
    { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "local", "name": "parsedErr" } } },
    { "op": "return", "value": { "kind": "local", "name": "total" } }
    ]
  }
  ]
}
