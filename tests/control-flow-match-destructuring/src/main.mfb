TYPE Circle
  radius AS Integer
END TYPE

TYPE Rect
  width AS Integer
  height AS Integer
END TYPE

UNION Shape
  Circle
  Rect
END UNION

FUNC parsePositive(value AS Integer) AS Integer
  IF value < 0 THEN FAIL Error[100, "negative"]
  RETURN value + 1
END FUNC

FUNC main() AS Integer
  MUT total AS Integer = 0
  LET firstShape AS Shape = Circle[5]
  LET secondShape AS Shape = Rect[10, 20]

  MATCH firstShape
    CASE Circle(circle)
      total = total + circle.radius
    CASE Rect(rect)
      total = total + rect.width + rect.height
  END MATCH

  MATCH secondShape
    CASE Circle(circle)
      total = total + circle.radius
    CASE Rect(rect)
      total = total + rect.width + rect.height
  END MATCH

  LET parsedOk = parsePositive(9) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + parsedOk

  LET parsedErr = parsePositive(-1) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + parsedErr

  RETURN total
END FUNC
