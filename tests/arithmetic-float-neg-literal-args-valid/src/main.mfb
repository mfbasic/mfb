IMPORT io
IMPORT math

' Two inline negative Float literals as call arguments must lower correctly:
' the Float unary negation flips the sign bit only and needs no inf/NaN result
' check (a finite operand stays finite), so it does not exhaust the register
' file or corrupt the value through scratch-register reuse.
FUNC main AS Integer
  LET p AS Byte = 6
  io::print(toString(math::min(-1.1, -1.0), p))
  io::print(toString(math::max(-3.5, -2.5), p))
  io::print(toString(math::atan2(-1.1, -1.0), p))
  io::print(toString(math::pow(-2.0, -2.0), p))
  io::print(toString(math::clamp(-5.0, -4.0, -1.0), p))
  RETURN 0
END FUNC
