{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_string_join_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "empty", "type": "List OF String", "value": { "kind": "list", "type": "List OF String", "values": [] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "[" }, "right": { "kind": "call", "target": "strings.join", "args": [{ "kind": "local", "name": "empty" }, { "kind": "const", "type": "String", "value": "," }] } }, "right": { "kind": "const", "type": "String", "value": "]" } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "strings.join", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Hello" }] }, { "kind": "const", "type": "String", "value": "," }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "strings.join", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "Hello" }, { "kind": "const", "type": "String", "value": "World" }] }, { "kind": "const", "type": "String", "value": " " }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "strings.join", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "a" }, { "kind": "const", "type": "String", "value": "b" }, { "kind": "const", "type": "String", "value": "c" }] }, { "kind": "const", "type": "String", "value": "" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "strings.join", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "😀" }, { "kind": "const", "type": "String", "value": "é" }, { "kind": "const", "type": "String", "value": "wide" }] }, { "kind": "const", "type": "String", "value": "|" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "strings.join", "args": [{ "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "left" }, { "kind": "const", "type": "String", "value": "" }, { "kind": "const", "type": "String", "value": "right" }] }, { "kind": "const", "type": "String", "value": "-" }] }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
