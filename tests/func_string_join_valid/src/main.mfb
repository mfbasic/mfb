IMPORT io
IMPORT strings

FUNC main AS Integer
  LET empty AS List OF String = []
  io::print("[" & strings::join(empty, ",") & "]")
  io::print(strings::join(["Hello"], ","))
  io::print(strings::join(["Hello", "World"], " "))
  io::print(strings::join(["a", "b", "c"], ""))
  io::print(strings::join(["😀", "é", "wide"], "|"))
  io::print(strings::join(["left", "", "right"], "-"))
  RETURN 0
END FUNC
