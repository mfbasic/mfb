IMPORT fs
IMPORT io

FUNC readMissing(p AS String) AS String
  RETURN fs::readText(p)
END FUNC
FUNC openMissing(p AS String) AS Integer
  LET f AS File = fs::openFile(p)
  fs::close(f)
  RETURN 1
END FUNC
FUNC delMissing(p AS String) AS Integer
  fs::deleteFile(p)
  RETURN 0
END FUNC

FUNC main AS Integer
  MUT a AS Integer = 0
  readMissing("target/fs_path_errors_rt_missing.txt") TRAP(e)
    a = e.code
    RECOVER ""
  END TRAP
  io::print(toString(a))
  MUT b AS Integer = 0
  openMissing("target/fs_path_errors_rt_missing.txt") TRAP(e)
    b = e.code
    RECOVER 0
  END TRAP
  io::print(toString(b))
  MUT c AS Integer = 0
  delMissing("target/fs_path_errors_rt_missing.txt") TRAP(e)
    c = e.code
    RECOVER 0
  END TRAP
  io::print(toString(c))
  RETURN 0
END FUNC
