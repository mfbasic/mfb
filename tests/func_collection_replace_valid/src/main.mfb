IMPORT collections
IMPORT io

TYPE Point
  x AS Integer
  y AS Integer
END TYPE

FUNC printIntegers(values AS List OF Integer) AS Nothing
  FOR EACH item IN values
    io::print(toString(item))
  NEXT
  RETURN NOTHING
END FUNC

FUNC printStrings(values AS List OF String) AS Nothing
  FOR EACH item IN values
    io::print(item)
  NEXT
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  LET numbers AS List OF Integer = [1, 2, 1, 3]
  LET names AS List OF String = ["Ada", "Grace", "Ada"]
  LET points AS List OF Point = [Point[1, 2], Point[3, 4], Point[1, 2]]
  LET noMatch AS List OF Integer = collections::replace(numbers, 9, 8)
  LET replacedNumbers AS List OF Integer = collections::replace(numbers, 1, 7)
  LET replacedNames AS List OF String = collections::replace(names, "Ada", "Katherine")
  LET replacedPoints AS List OF Point = collections::replace(points, Point[1, 2], Point[8, 9])

  printIntegers(replacedNumbers)
  printStrings(replacedNames)
  printIntegers(noMatch)
  io::print(toString(len(replacedPoints)))

  RETURN len(replacedNumbers) + len(replacedNames) + len(noMatch) + len(replacedPoints)
END FUNC
