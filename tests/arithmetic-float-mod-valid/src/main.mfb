IMPORT io

' plan-01-libm-kernels Phase 2: Float MOD Float lowers to the in-tree exact
' fmod kernel (bit-identical to libm, no platform fmod import). Cases lock the
' special paths: |a|<|b| -> a, exact multiple -> +/-0, sign of dividend, large.
FUNC main AS Integer
  LET p AS Byte = 17
  LET a AS Float = 5.3
  LET b AS Float = 2.0
  io::print(toString(a MOD b, p))
  LET small AS Float = 1.5
  LET big AS Float = 7.0
  io::print(toString(small MOD big, p))
  LET nine AS Float = 9.0
  LET three AS Float = 3.0
  io::print(toString(nine MOD three, p))
  LET na AS Float = 0.0 - 5.3
  io::print(toString(na MOD b, p))
  LET nb AS Float = 0.0 - 2.0
  io::print(toString(a MOD nb, p))
  LET big2 AS Float = 1000000.123
  LET div2 AS Float = 3.14159
  io::print(toString(big2 MOD div2, p))
  RETURN 0
END FUNC
