IMPORT io
IMPORT errorCode
IMPORT math
IMPORT strings

FUNC add(a AS Integer, b AS Integer) AS Integer
  RETURN a + b
END FUNC

FUNC parseIt(s AS String) AS Integer
  RETURN toInt(s)
END FUNC

FUNC main AS Integer
  io::print("normal program body — dropped under mfb test")
  RETURN 0
END FUNC

TESTING
  TGROUP "equality"
    TCASE "expectEqual passes"
      expectEqual(add(2, 3), 5)
    END TCASE
    TCASE "expectEqual fails"
      expectEqual(add(2, 3), 6)
    END TCASE
    TCASE "expectNEqual passes"
      expectNEqual(add(2, 3), 6)
    END TCASE
  END TGROUP
  TGROUP "typed equality"
    TCASE "expectInteger / expectNInteger"
      expectInteger(add(2, 3), 5)
      expectNInteger(add(2, 3), 6)
    END TCASE
    TCASE "expectFloat / expectNFloat"
      expectFloat(math::sqrt(4.0), 2.0)
      expectNFloat(math::sqrt(2.0), 2.0)
    END TCASE
    TCASE "expectFixed / expectNFixed"
      expectFixed(math::abs(0 - toFixed("1.5")), toFixed("1.5"))
      expectNFixed(math::abs(0 - toFixed("1.5")), toFixed("2.0"))
    END TCASE
    TCASE "expectString / expectNString"
      expectString(strings::upper("ab"), "AB")
      expectNString(strings::upper("ab"), "ab")
    END TCASE
    TCASE "expectFloat fails with a typed detail"
      expectFloat(math::sqrt(4.0), 3.0)
    END TCASE
  END TGROUP
  TGROUP "traps"
    TCASE "expectTrap passes"
      expectTrap(parseIt("bad"))
    END TCASE
    TCASE "expectTrap with matching code passes"
      expectTrap(parseIt("bad"), errorCode::ErrInvalidFormat)
    END TCASE
    TCASE "expectNTrap passes"
      expectNTrap(parseIt("42"))
    END TCASE
    TCASE "expectNTrap on a trapping call fails"
      expectNTrap(parseIt("bad"))
    END TCASE
  END TGROUP
  TGROUP "runtime errors"
    TCASE "a genuine runtime error is a failure, not a crash"
      LET x AS Integer = parseIt("notanumber")
      expectEqual(x, 0)
    END TCASE
  END TGROUP
END TESTING
