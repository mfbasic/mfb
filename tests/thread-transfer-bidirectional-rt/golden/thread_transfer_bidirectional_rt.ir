{
  "format": "mfb-ir",
  "version": 1,
  "project": "thread_transfer_bidirectional_rt",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "t", "type": "Thread OF RES File TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "xfer_bidi_worker.exchange", "type": "ISOLATED FUNC(ThreadWorker OF RES File TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "seed" }] } },
    { "op": "bind", "mutable": false, "name": "pf", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "const", "type": "String", "value": "tests/thread-transfer-bidirectional-rt/data/parent.txt" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.transferResource", "args": [{ "kind": "local", "name": "t" }, { "kind": "local", "name": "pf" }] } },
    { "op": "bind", "mutable": false, "name": "wf", "type": "File", "value": { "kind": "call", "target": "thread.acceptResource", "args": [{ "kind": "local", "name": "t" }, { "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "1" } }] } },
    { "op": "bind", "mutable": false, "name": "parentReceived", "type": "Integer", "value": { "kind": "call", "target": "len", "args": [{ "kind": "call", "target": "fs.readAll", "args": [{ "kind": "local", "name": "wf" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "local", "name": "wf" }] } },
    { "op": "bind", "mutable": false, "name": "workerReceived", "type": "Integer", "value": { "kind": "call", "target": "thread.waitFor", "args": [{ "kind": "local", "name": "t" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "workerReceived" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "parentReceived" }] }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
