IMPORT io
IMPORT math
IMPORT collections

' Vectorized math::abs over a Float/Integer/Fixed list (plan-01-simd §4.4).
' The Integer overload returns a new List OF Integer with each lane = |x|.
' Length 5 is odd and crosses multiple 2-lane NEON chunks, exercising both the
' vector body and the scalar tail.

SUB printAll(xs AS List OF Integer)
  FOR EACH x IN xs
    io::print(toString(x))
  NEXT
END SUB

FUNC main AS Integer
  LET xs AS List OF Integer = [0 - 7, 3, 0 - 1, 0, 0 - 9]
  LET ys AS List OF Integer = math::abs(xs)
  printAll(ys)
  ' The input list is unchanged (inputs are read-only).
  io::print("input0=" & toString(collections::get(xs, 0)))
  ' Empty array returns an empty array (no error).
  LET empty AS List OF Integer = []
  LET emptyAbs AS List OF Integer = math::abs(empty)
  io::print("emptyLen=" & toString(len(emptyAbs)))
  RETURN 0
END FUNC
