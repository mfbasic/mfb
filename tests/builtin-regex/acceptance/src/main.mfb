IMPORT regex
IMPORT collections
IMPORT errorCode

' Consolidated runtime-behavior acceptance for the regex builtins, converted
' from the tests/func_regex_*_valid fixtures. Each assertion compares the SAME
' expression as the source fixture against that fixture's exact golden value,
' using the typed TESTING assertions. regex::find/findAll fail with
' ErrIndexOutOfRange when `start` is out of range, and regex::match traps with
' ErrInvalidFormat on an invalid pattern; those trapping paths are wrapped in a
' local FUNC so expectTrap/expectNTrap can guard them.

FUNC findAt(value AS String, pattern AS String, start AS Integer) AS Integer
  RETURN regex::find(value, pattern, start)
END FUNC

FUNC findAllAt(value AS String, pattern AS String, start AS Integer) AS Integer
  LET r AS List OF Integer = regex::findAll(value, pattern, start)
  RETURN len(r)
END FUNC

FUNC matchPat(value AS String, pattern AS String) AS Boolean
  RETURN regex::match(value, pattern)
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC

TESTING
  TGROUP "match"
    TCASE "worked examples"
      expectEqual(regex::match("hello", "ell"), TRUE)
      expectEqual(regex::match("hello", "^h"), TRUE)
      expectEqual(regex::match("hello", "^e"), FALSE)
      expectEqual(regex::match("abc123", "\\d+"), TRUE)
      expectEqual(regex::match("abc", "\\d"), FALSE)
      expectEqual(regex::match("café", "caf\\x{E9}"), TRUE)
      expectEqual(regex::match("Hello", "(?i)hello"), TRUE)
      expectEqual(regex::match("", "a*"), TRUE)
      expectEqual(regex::match("x", "^$"), FALSE)
      expectEqual(regex::match("", "^$"), TRUE)
    END TCASE
    TCASE "alternation grouping quantifiers"
      expectEqual(regex::match("abcd", "ab|abc"), TRUE)
      expectEqual(regex::match("abab", "(ab)+"), TRUE)
      expectEqual(regex::match("aaaa", "a{2,3}"), TRUE)
      expectEqual(regex::match("color", "colou?r"), TRUE)
    END TCASE
    TCASE "classes ranges negation shorthands"
      expectEqual(regex::match("n", "[a-cm-p]"), TRUE)
      expectEqual(regex::match("x", "[^0-9]"), TRUE)
      expectEqual(regex::match("7", "[^0-9]"), FALSE)
      expectEqual(regex::match("_id9", "\\w+"), TRUE)
      expectEqual(regex::match("a b", "\\s"), TRUE)
      expectEqual(regex::match("Q", "[[:alpha:]]"), TRUE)
    END TCASE
    TCASE "unicode property classes"
      expectEqual(regex::match("Z", "\\p{L}"), TRUE)
      expectEqual(regex::match("9", "\\p{Nd}"), TRUE)
      expectEqual(regex::match("5", "\\P{L}"), TRUE)
    END TCASE
    TCASE "anchors and boundaries"
      expectEqual(regex::match("hello", "o$"), TRUE)
      expectEqual(regex::match("foo bar", "\\bbar\\b"), TRUE)
      expectEqual(regex::match("hi", "\\Ahi\\z"), TRUE)
    END TCASE
    TCASE "flags"
      expectEqual(regex::match("ab\ncd", "(?m)^cd"), TRUE)
      expectEqual(regex::match("a\nb", "(?s)a.b"), TRUE)
      expectEqual(regex::match("a\nb", "a.b"), FALSE)
      expectEqual(regex::match("ab", "(?x) a b  # spaces ignored"), TRUE)
      expectEqual(regex::match("K", "(?i)[a-z]"), TRUE)
    END TCASE
    TCASE "lazy quantifier"
      expectEqual(regex::match("<a><b>", "<.+?>"), TRUE)
    END TCASE
  END TGROUP

  TGROUP "find"
    TCASE "worked examples"
      expectInteger(regex::find("hello", "l", 0), 2)
      expectInteger(regex::find("hello", "l", 3), 3)
      expectInteger(regex::find("hello", "l", 4), -1)
      expectInteger(regex::find("a1b2c3", "\\d", 0), 1)
      expectInteger(regex::find("aaa", "a+", 0), 0)
      expectInteger(regex::find("abc", "x", 0), -1)
      expectInteger(regex::find("abc", "", 0), 0)
      expectInteger(regex::find("abc", "^b", 1), -1)
      expectInteger(regex::find("hello", "o$", 0), 4)
    END TCASE
    TCASE "default start and edge positions"
      expectInteger(regex::find("a1b2c3", "\\d"), 1)
      expectInteger(regex::find("abc", "$", 3), 3)
      expectInteger(regex::find("abc", "\\b", 0), 0)
    END TCASE
    TCASE "out-of-range start traps"
      expectTrap(findAt("hello", "l", 6), errorCode::ErrIndexOutOfRange)
    END TCASE
    TCASE "in-range start does not trap"
      expectNTrap(findAt("hello", "l", 0))
    END TCASE
  END TGROUP

  TGROUP "findAll"
    TCASE "worked examples"
      LET r0 AS List OF Integer = regex::findAll("hello", "l", 0)
      expectInteger(len(r0), 2)
      expectInteger(collections::get(r0, 0), 2)
      expectInteger(collections::get(r0, 1), 3)
      LET r1 AS List OF Integer = regex::findAll("a1b2c3", "\\d", 0)
      expectInteger(len(r1), 3)
      expectInteger(collections::get(r1, 0), 1)
      expectInteger(collections::get(r1, 1), 3)
      expectInteger(collections::get(r1, 2), 5)
      LET r2 AS List OF Integer = regex::findAll("abc", "x", 0)
      expectInteger(len(r2), 0)
      LET r3 AS List OF Integer = regex::findAll("aaa", "a+", 0)
      expectInteger(len(r3), 1)
      expectInteger(collections::get(r3, 0), 0)
      LET r4 AS List OF Integer = regex::findAll("abc", "", 0)
      expectInteger(len(r4), 4)
      expectInteger(collections::get(r4, 0), 0)
      expectInteger(collections::get(r4, 1), 1)
      expectInteger(collections::get(r4, 2), 2)
      expectInteger(collections::get(r4, 3), 3)
      LET r5 AS List OF Integer = regex::findAll("x1y2", "\\d", 2)
      expectInteger(len(r5), 1)
      expectInteger(collections::get(r5, 0), 3)
    END TCASE
    TCASE "default start overlap and captures"
      LET rd AS List OF Integer = regex::findAll("a-b-c", "-")
      expectInteger(len(rd), 2)
      expectInteger(collections::get(rd, 0), 1)
      expectInteger(collections::get(rd, 1), 3)
      LET ro AS List OF Integer = regex::findAll("aaaa", "aa")
      expectInteger(len(ro), 2)
      expectInteger(collections::get(ro, 0), 0)
      expectInteger(collections::get(ro, 1), 2)
      LET rc AS List OF Integer = regex::findAll("2024-06", "(\\d+)")
      expectInteger(len(rc), 2)
      expectInteger(collections::get(rc, 0), 0)
      expectInteger(collections::get(rc, 1), 5)
    END TCASE
    TCASE "out-of-range start traps"
      expectTrap(findAllAt("hello", "l", 6), errorCode::ErrIndexOutOfRange)
    END TCASE
    TCASE "in-range start does not trap"
      expectNTrap(findAllAt("hello", "l", 0))
    END TCASE
  END TGROUP

  TGROUP "replace"
    TCASE "worked examples"
      expectString(regex::replace("a-b-c", "-", ":"), "a:b:c")
      expectString(regex::replace("hello", "l", "L"), "heLLo")
      expectString(regex::replace("2024-06-24", "(\\d+)-(\\d+)-(\\d+)", "$3/$2/$1"), "24/06/2024")
      expectString(regex::replace("foo", "(?<x>o)", "[${x}]"), "f[o][o]")
      expectString(regex::replace("abc", "", "-"), "-a-b-c-")
      expectString(regex::replace("a1b2", "\\d", ""), "ab")
      expectString(regex::replace("price", "x", "y"), "price")
      expectString(regex::replace("5", "5", "$$"), "$")
      expectString(regex::replace("ab", "a", "${1}z"), "zb")
      expectString(regex::replace("cat", "a", "4"), "c4t")
    END TCASE
    TCASE "zero-length advance and references"
      expectString(regex::replace("abc", "x*", "-"), "-a-b-c-")
      expectString(regex::replace("ab", "(a)(b)", "${1}0"), "a0")
      expectString(regex::replace("ab", "(a)(b)", "$10"), "")
      expectString(regex::replace("ab", "(?<n>a)", "${n}_x"), "a_xb")
      expectString(regex::replace("x", "x", "$ y"), "$ y")
      expectString(regex::replace("abc", "a", "$9z"), "zbc")
      expectString(regex::replace("hello", "l+", "[$0]"), "he[ll]o")
    END TCASE
  END TGROUP

  TGROUP "pattern"
    TCASE "invalid patterns trap with ErrInvalidFormat"
      expectTrap(matchPat("sample", "("), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", ")"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "["), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "[]"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "[^]"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "[z-a]"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "a{2,1}"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "*"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "a**"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "\\q"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "\\1"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?=x)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?!x)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?<=x)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?<!x)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?P=name)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?q)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?-)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?<>x)"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "\\p{Nope}"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "\\x{110000}"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "\\xZZ"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "[a&&b]"), errorCode::ErrInvalidFormat)
      expectTrap(matchPat("sample", "(?<dup>a)(?<dup>b)"), errorCode::ErrInvalidFormat)
    END TCASE
    TCASE "valid pattern still works after failures"
      expectNTrap(matchPat("sample", "sa.ple"))
      expectEqual(regex::match("sample", "sa.ple"), TRUE)
    END TCASE
  END TGROUP
END TESTING
