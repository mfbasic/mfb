{
  "format": "mfb-ir",
  "version": 1,
  "project": "types_with_update_owned",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  {
    "kind": "type",
    "visibility": "private",
    "name": "Payload",
    "fields": [
    { "visibility": null, "name": "label", "type": "String" },
    { "visibility": null, "name": "first", "type": "Integer" },
    { "visibility": null, "name": "second", "type": "Integer" }
    ]
  }
  ],
  "functions": [
  {
    "name": "promote",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "seed", "type": "Integer", "default": null }
    ],
    "returns": "Payload",
    "body": [
    { "op": "bind", "mutable": false, "name": "base", "type": "Payload", "value": { "kind": "constructor", "type": "Payload", "args": [{ "kind": "const", "type": "String", "value": "base" }, { "kind": "local", "name": "seed" }, { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "seed" }, "right": { "kind": "const", "type": "Integer", "value": "10" } }] } },
    { "op": "return", "value": { "kind": "with", "type": "Payload", "target": { "kind": "local", "name": "base" }, "updates": [{ "field": "label", "value": { "kind": "const", "type": "String", "value": "owned" } }] } }
    ]
  },
  {
    "name": "rewrite",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "Payload", "default": null },
    { "name": "delta", "type": "Integer", "default": null }
    ],
    "returns": "Payload",
    "body": [
    { "op": "return", "value": { "kind": "with", "type": "Payload", "target": { "kind": "local", "name": "value" }, "updates": [{ "field": "label", "value": { "kind": "const", "type": "String", "value": "rewritten" } }, { "field": "first", "value": { "kind": "binary", "op": "+", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "value" }, "member": "first" }, "right": { "kind": "local", "name": "delta" } } }] } }
    ]
  },
  {
    "name": "occupy",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "seed", "type": "Integer", "default": null }
    ],
    "returns": "Payload",
    "body": [
    { "op": "bind", "mutable": false, "name": "base", "type": "Payload", "value": { "kind": "constructor", "type": "Payload", "args": [{ "kind": "const", "type": "String", "value": "noise-base" }, { "kind": "local", "name": "seed" }, { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "seed" }, "right": { "kind": "const", "type": "Integer", "value": "1" } }] } },
    { "op": "return", "value": { "kind": "with", "type": "Payload", "target": { "kind": "local", "name": "base" }, "updates": [{ "field": "label", "value": { "kind": "const", "type": "String", "value": "noise" } }, { "field": "first", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "seed" }, "right": { "kind": "const", "type": "Integer", "value": "10" } } }, { "field": "second", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "seed" }, "right": { "kind": "const", "type": "Integer", "value": "20" } } }] } }
    ]
  },
  {
    "name": "readAfterCalls",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "Payload", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "firstNoise", "type": "Payload", "value": { "kind": "call", "target": "occupy", "args": [{ "kind": "const", "type": "Integer", "value": "7" }] } },
    { "op": "bind", "mutable": false, "name": "secondNoise", "type": "Payload", "value": { "kind": "call", "target": "occupy", "args": [{ "kind": "const", "type": "Integer", "value": "8" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "firstNoise" }, "member": "label" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "secondNoise" }, "member": "label" }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "value" }, "member": "first" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "value" }, "member": "second" } } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "kept", "type": "Payload", "value": { "kind": "call", "target": "promote", "args": [{ "kind": "const", "type": "Integer", "value": "5" }] } },
    { "op": "bind", "mutable": false, "name": "changed", "type": "Payload", "value": { "kind": "call", "target": "rewrite", "args": [{ "kind": "local", "name": "kept" }, { "kind": "const", "type": "Integer", "value": "20" }] } },
    { "op": "bind", "mutable": false, "name": "noise", "type": "Payload", "value": { "kind": "call", "target": "occupy", "args": [{ "kind": "const", "type": "Integer", "value": "9" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kept" }, "member": "label" }] } },
    { "op": "bind", "mutable": false, "name": "after", "type": "Integer", "value": { "kind": "call", "target": "readAfterCalls", "args": [{ "kind": "local", "name": "kept" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kept" }, "member": "label" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "changed" }, "member": "label" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "noise" }, "member": "label" }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "after" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "changed" }, "member": "first" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "changed" }, "member": "second" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "noise" }, "member": "first" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "noise" }, "member": "second" } } }
    ]
  }
  ]
}
