IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("zeroFloat2 = " & toString(vector::zeroFloat2))
  io::print("zeroFloat3 = " & toString(vector::zeroFloat3))
  io::print("zeroFloat4 = " & toString(vector::zeroFloat4))
  io::print("zeroFixed2 = " & toString(vector::zeroFixed2))
  io::print("zeroFixed3 = " & toString(vector::zeroFixed3))
  io::print("zeroFixed4 = " & toString(vector::zeroFixed4))
  io::print("zeroInteger2 = " & toString(vector::zeroInteger2))
  io::print("zeroInteger3 = " & toString(vector::zeroInteger3))
  io::print("zeroInteger4 = " & toString(vector::zeroInteger4))
  io::print("oneFloat2 = " & toString(vector::oneFloat2))
  io::print("oneFloat3 = " & toString(vector::oneFloat3))
  io::print("oneFloat4 = " & toString(vector::oneFloat4))
  io::print("oneFixed2 = " & toString(vector::oneFixed2))
  io::print("oneFixed3 = " & toString(vector::oneFixed3))
  io::print("oneFixed4 = " & toString(vector::oneFixed4))
  io::print("oneInteger2 = " & toString(vector::oneInteger2))
  io::print("oneInteger3 = " & toString(vector::oneInteger3))
  io::print("oneInteger4 = " & toString(vector::oneInteger4))
  io::print("upFloat2 = " & toString(vector::upFloat2))
  io::print("upFloat3 = " & toString(vector::upFloat3))
  io::print("upFloat4 = " & toString(vector::upFloat4))
  io::print("upFixed2 = " & toString(vector::upFixed2))
  io::print("upFixed3 = " & toString(vector::upFixed3))
  io::print("upFixed4 = " & toString(vector::upFixed4))
  io::print("upInteger2 = " & toString(vector::upInteger2))
  io::print("upInteger3 = " & toString(vector::upInteger3))
  io::print("upInteger4 = " & toString(vector::upInteger4))
  io::print("rightFloat2 = " & toString(vector::rightFloat2))
  io::print("rightFloat3 = " & toString(vector::rightFloat3))
  io::print("rightFloat4 = " & toString(vector::rightFloat4))
  io::print("rightFixed2 = " & toString(vector::rightFixed2))
  io::print("rightFixed3 = " & toString(vector::rightFixed3))
  io::print("rightFixed4 = " & toString(vector::rightFixed4))
  io::print("rightInteger2 = " & toString(vector::rightInteger2))
  io::print("rightInteger3 = " & toString(vector::rightInteger3))
  io::print("rightInteger4 = " & toString(vector::rightInteger4))
  io::print("forwardFloat3 = " & toString(vector::forwardFloat3))
  io::print("forwardFloat4 = " & toString(vector::forwardFloat4))
  io::print("forwardFixed3 = " & toString(vector::forwardFixed3))
  io::print("forwardFixed4 = " & toString(vector::forwardFixed4))
  io::print("forwardInteger3 = " & toString(vector::forwardInteger3))
  io::print("forwardInteger4 = " & toString(vector::forwardInteger4))
  RETURN 0
END FUNC
