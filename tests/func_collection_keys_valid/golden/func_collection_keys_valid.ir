{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_collection_keys_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "names", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "Ada" }, "value": { "kind": "const", "type": "Integer", "value": "36" } }, { "key": { "kind": "const", "type": "String", "value": "Grace" }, "value": { "kind": "const", "type": "Integer", "value": "85" } }] } },
    { "op": "bind", "mutable": false, "name": "codes", "type": "Map OF Integer TO String", "value": { "kind": "map", "type": "Map OF Integer TO String", "entries": [{ "key": { "kind": "const", "type": "Integer", "value": "1" }, "value": { "kind": "const", "type": "String", "value": "one" } }, { "key": { "kind": "const", "type": "Integer", "value": "2" }, "value": { "kind": "const", "type": "String", "value": "two" } }] } },
    { "op": "bind", "mutable": false, "name": "nameKeys", "type": "List OF String", "value": { "kind": "call", "target": "collections.keys", "args": [{ "kind": "local", "name": "names" }] } },
    { "op": "bind", "mutable": false, "name": "codeKeys", "type": "List OF Integer", "value": { "kind": "call", "target": "collections.keys", "args": [{ "kind": "local", "name": "codes" }] } },
    {
      "op": "forEach",
      "name": "name",
      "type": "String",
      "iterable": { "kind": "local", "name": "nameKeys" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "name" }] } }
      ]
    },
    {
      "op": "forEach",
      "name": "code",
      "type": "Integer",
      "iterable": { "kind": "local", "name": "codeKeys" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "code" }] }] } }
      ]
    },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "nameKeys" }] }, "right": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "codeKeys" }] } } }
    ]
  }
  ]
}
