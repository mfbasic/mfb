IMPORT io

' Absurdly large decimal exponents must not wrap the parser's 64-bit exponent
' accumulator. Positive exponents beyond the double range overflow (rejected by
' isNumeric), while negative exponents underflow to a finite zero (accepted).
FUNC main AS Integer
  LET p AS Byte = 1
  io::print(toString(isNumeric("1e18446744073709551616")))    ' +2^64 exp -> overflow -> FALSE
  io::print(toString(isNumeric("1e-18446744073709551616")))   ' -2^64 exp -> underflow 0 -> TRUE
  io::print(toString(isNumeric("9e999999")))                  ' huge +exp -> overflow -> FALSE
  io::print(toString(isNumeric("1e308")))                     ' in range -> TRUE
  io::print(toString(isNumeric("1e309")))                     ' just past range -> FALSE
  io::print(toString(toFloat("1e-18446744073709551616"), p))  ' underflow -> 0.0
  io::print(toString(toFixed("1e-18446744073709551616"), p))  ' underflow -> 0.0
  RETURN 0
END FUNC
