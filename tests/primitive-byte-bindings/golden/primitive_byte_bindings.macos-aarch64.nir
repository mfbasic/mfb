{
  "format": "mfb-nir",
  "version": 1,
  "target": "macos-aarch64",
  "buildMode": "console",
  "project": "primitive_byte_bindings",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "imports": [
  ],
  "runtimeHelpers": [],
  "functions": [
  {
    "name": "main",
    "visibility": "public",
    "kind": "func",
    "isolated": false,
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "letValue", "type": "Byte", "value": { "kind": "const", "type": "Byte", "value": "2" } },
    { "op": "bind", "mutable": true, "name": "mutValue", "type": "Byte", "value": { "kind": "const", "type": "Byte", "value": "3" } },
    { "op": "assign", "name": "mutValue", "value": { "kind": "const", "type": "Byte", "value": "4" } },
    { "op": "return", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "binary", "op": "+", "left": { "kind": "local", "name": "letValue" }, "right": { "kind": "local", "name": "mutValue" } }] } }
    ]
  }
  ]
}
