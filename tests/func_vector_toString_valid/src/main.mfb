IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print(toString(vector::Float2[3.0, 4.0]))
  io::print(toString(vector::Float3[1.0, 2.0, 2.0]))
  io::print(toString(vector::Float4[1.0, 2.0, 2.0, 4.0]))
  io::print(toString(vector::Fixed2[toFixed(3.0), toFixed(4.0)]))
  io::print(toString(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)]))
  io::print(toString(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)]))
  io::print(toString(vector::Integer2[3, 4]))
  io::print(toString(vector::Integer3[1, 2, 2]))
  io::print(toString(vector::Integer4[1, 2, 2, 4]))
  RETURN 0
END FUNC
