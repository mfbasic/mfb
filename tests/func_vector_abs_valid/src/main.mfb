IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("abs Float2 = " & toString(vector::abs(vector::Float2[-3.0, 4.0])))
  io::print("abs Float3 = " & toString(vector::abs(vector::Float3[-3.0, 4.0, -5.0])))
  io::print("abs Float4 = " & toString(vector::abs(vector::Float4[-3.0, 4.0, -5.0, 6.0])))
  io::print("abs Fixed2 = " & toString(vector::abs(vector::Fixed2[toFixed(-3.0), toFixed(4.0)])))
  io::print("abs Fixed3 = " & toString(vector::abs(vector::Fixed3[toFixed(-3.0), toFixed(4.0), toFixed(-5.0)])))
  io::print("abs Fixed4 = " & toString(vector::abs(vector::Fixed4[toFixed(-3.0), toFixed(4.0), toFixed(-5.0), toFixed(6.0)])))
  io::print("abs Integer2 = " & toString(vector::abs(vector::Integer2[-3, 4])))
  io::print("abs Integer3 = " & toString(vector::abs(vector::Integer3[-3, 4, -5])))
  io::print("abs Integer4 = " & toString(vector::abs(vector::Integer4[-3, 4, -5, 6])))
  RETURN 0
END FUNC
