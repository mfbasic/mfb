IMPORT io
IMPORT json

FUNC controlChar(value AS Integer) AS String
  LET bytes AS List OF Byte = [toByte(value)]
  RETURN toString(bytes)
END FUNC

FUNC showInvalid(label AS String, value AS String) AS Nothing
  io::print("BEGIN")
  io::print(label)
  io::print(json::stringify(json::parse(value)))
  RETURN NOTHING
  TRAP(err)
    io::print("invalid")
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  showInvalid("unpaired surrogate", "\"\\uD83D\"")
  showInvalid("leading zero", "01")
  showInvalid("trailing token", "true false")
  showInvalid("raw newline", "\"" & "\n" & "\"")
  showInvalid("raw tab", "\"" & "\t" & "\"")
  showInvalid("raw nul", "\"" & controlChar(0) & "\"")
  showInvalid("raw unit separator", "\"" & controlChar(31) & "\"")
  RETURN 0
END FUNC
