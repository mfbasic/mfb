FUNC parsePositive(value AS Integer) AS Integer
  IF value < 0 THEN FAIL Error[900, "negative"]
  RETURN value + 10
END FUNC

FUNC main AS Integer
  MUT total AS Integer = 0

  LET parsedOk = parsePositive(5) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + parsedOk

  LET parsedErr = parsePositive(-1) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + parsedErr

  IF total <> 915 THEN RETURN 1
  RETURN 0
END FUNC
