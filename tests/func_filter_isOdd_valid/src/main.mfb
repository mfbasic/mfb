IMPORT collections
IMPORT io

FUNC main AS Integer
  LET values AS List OF Integer = [-4, -3, 0, 1, 2]
  LET odds AS List OF Integer = collections::filter(values, isOdd)

  io::print(toString(isOdd(0)))
  io::print(toString(isOdd(2)))
  io::print(toString(isOdd(-4)))
  io::print(toString(isOdd(1)))
  io::print(toString(isOdd(-3)))
  io::print(toString(len(odds)))
  io::print(toString(collections::get(odds, 0)))
  io::print(toString(collections::get(odds, 1)))

  RETURN 0
END FUNC
