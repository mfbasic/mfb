{
  "format": "mfb-ir",
  "version": 1,
  "project": "project_entry_args_runtime",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": true
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "args", "type": "List OF String", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "args" }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "get", "args": [{ "kind": "local", "name": "args" }, { "kind": "const", "type": "Integer", "value": "0" }] }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
