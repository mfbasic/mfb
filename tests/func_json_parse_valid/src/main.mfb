IMPORT io
IMPORT json
IMPORT strings

FUNC printStringByteLen(value AS Json) AS Nothing
  MATCH value
    CASE JsonStr(strValue)
      io::print("bytes=" & toString(strings::byteLen(strValue.value)))
    CASE ELSE
      io::print("not string")
  END MATCH
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  io::print(json::stringify(json::parse(" null ")))
  io::print(json::stringify(json::parse("\"hi\"")))
  io::print(json::stringify(json::parse("\"\\n\"")))
  io::print(json::stringify(json::parse("\"\\t\"")))
  io::print(json::stringify(json::parse("\"\\b\"")))
  io::print(json::stringify(json::parse("\"\\f\"")))
  io::print(json::stringify(json::parse("\"\\u0041\\uD83D\\uDE00\"")))
  printStringByteLen(json::parse("\"\\u0000\""))
  printStringByteLen(json::parse("\"\\u001F\""))
  io::print(json::stringify(json::parse("[true,false,null,{\"x\":\"y\"}]")))
  io::print(json::stringify(json::parse("-12.5e+2")))
  io::print(json::stringify(json::parse(value := "{\"named\":true}")))
  RETURN 0
END FUNC
