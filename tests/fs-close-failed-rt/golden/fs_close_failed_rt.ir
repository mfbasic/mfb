  "types": [
  ],
  "functions": [
  {
    "name": "closeOnce",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "p", "type": "String", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "f", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "local", "name": "p" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "local", "name": "f" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": true, "name": "ok", "type": "Integer", "value": { "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "1" } } },
    { "op": "bind", "mutable": false, "name": "$match0", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "closeOnce", "args": [{ "kind": "const", "type": "String", "value": "tests/fs-close-failed-rt/data/in.txt" }] } },
    { "op": "bind", "mutable": false, "name": "$match_ok1", "type": "Boolean", "value": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$match0" } } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match_ok1" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "const", "type": "Boolean", "value": "true" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "v", "type": "Integer", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "assign", "name": "ok", "value": { "kind": "local", "name": "v" } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "const", "type": "Boolean", "value": "false" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "e", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "assign", "name": "ok", "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "code" } }
        ]
      }
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "ok" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "closed" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
