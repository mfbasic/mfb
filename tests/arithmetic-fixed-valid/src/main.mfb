FUNC main AS Integer
  LET a AS Fixed = 1.5
  LET b AS Fixed = 2.0
  LET c AS Fixed = 3.0
  LET d AS Fixed = 5.0
  LET e AS Fixed = 2.5
  LET one AS Fixed = 1.0
  LET three AS Fixed = 3.0
  LET third AS Fixed = one / three
  IF a * b = c THEN
    IF d / b = e THEN
      IF third * three < one THEN
        RETURN 7
      END IF
    END IF
  END IF
  RETURN 1
END FUNC
