    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "unary", "op": "NOT", "operand": { "kind": "const", "type": "Boolean", "value": "false" } }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "binary", "op": "AND", "left": { "kind": "const", "type": "Boolean", "value": "true" }, "right": { "kind": "const", "type": "Boolean", "value": "true" } }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "binary", "op": "OR", "left": { "kind": "const", "type": "Boolean", "value": "true" }, "right": { "kind": "const", "type": "Boolean", "value": "false" } }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "binary", "op": "XOR", "left": { "kind": "const", "type": "Boolean", "value": "true" }, "right": { "kind": "const", "type": "Boolean", "value": "false" } }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "binary", "op": "AND", "left": { "kind": "const", "type": "Boolean", "value": "false" }, "right": { "kind": "call", "target": "markTrue", "args": [{ "kind": "const", "type": "String", "value": "and-rhs" }] } }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "binary", "op": "OR", "left": { "kind": "const", "type": "Boolean", "value": "true" }, "right": { "kind": "call", "target": "markFalse", "args": [{ "kind": "const", "type": "String", "value": "or-rhs" }] } }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "binary", "op": "XOR", "left": { "kind": "const", "type": "Boolean", "value": "false" }, "right": { "kind": "call", "target": "markTrue", "args": [{ "kind": "const", "type": "String", "value": "xor-rhs" }] } }] }] } },
