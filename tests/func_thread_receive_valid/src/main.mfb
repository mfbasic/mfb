IMPORT thread

EXPORT ISOLATED FUNC worker(t AS ThreadWorker OF String TO Integer, seed AS String) AS Integer
  LET first AS String = thread::receive(t)
  LET immediate AS String = thread::receive(t, 0)
  LET timed AS String = thread::receive(t, 1)
  LET indefinite AS String = thread::receive(t, -1)
  RETURN len(seed) + len(first) + len(immediate) + len(timed) + len(indefinite)
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC
