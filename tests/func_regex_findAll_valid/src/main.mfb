IMPORT io
IMPORT regex
IMPORT collections

REM regex.md §17.3 findAll worked examples. findAll is total: no match yields an
REM empty list, and an out-of-range start fails with ErrIndexOutOfRange.

FUNC render(hits AS List OF Integer) AS String
  MUT s AS String = "["
  MUT first AS Boolean = TRUE
  FOR EACH h IN hits
    IF first THEN
      first = FALSE
    ELSE
      s = s & ","
    END IF
    s = s & toString(h)
  NEXT
  RETURN s & "]"
END FUNC

FUNC show(value AS String, pattern AS String, start AS Integer) AS String
  RETURN render(regex::findAll(value, pattern, start))
  TRAP(err)
    RETURN "Err" & toString(err.code)
  END TRAP
END FUNC

FUNC main AS Integer
  io::print(show("hello", "l", 0))
  io::print(show("a1b2c3", "\\d", 0))
  io::print(show("abc", "x", 0))
  io::print(show("aaa", "a+", 0))
  io::print(show("abc", "", 0))
  io::print(show("x1y2", "\\d", 2))
  io::print(show("hello", "l", 6))
  REM default start = 0
  io::print(render(regex::findAll("a-b-c", "-")))
  REM overlapping candidates are non-overlapping in the result
  io::print(render(regex::findAll("aaaa", "aa")))
  REM capture groups do not change reported start positions
  io::print(render(regex::findAll("2024-06", "(\\d+)")))
  RETURN 0
END FUNC
