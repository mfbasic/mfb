IMPORT io
IMPORT math

' Vectorized math::acos over a Float list — NEON kernel (acos via atan(x/sqrt(1-x^2))).
' ErrInvalidArgument for |x|>1. Faithfully rounded (within a few ULP of libm).
FUNC main AS Integer
  LET p AS Byte = 15
  LET xs AS List OF Float = [0.0, 0.5, 0.0 - 0.5, 1.0, 0.25]
  FOR EACH y IN math::acos(xs)
    io::print(toString(y, p))
  NEXT
  RETURN 0
END FUNC
