IMPORT io

TYPE Tag
  id AS Integer
END TYPE

' An EXPORT override is visible across the whole project (and beyond).
FUNC toString(t AS Tag) AS String
  RETURN "tag#" & toString(t.id)
END FUNC

' A PRIVATE override is visible only inside this file.
PRIVATE FUNC len(t AS Tag) AS Integer
  RETURN t.id
END FUNC

' Exercises the file-local PRIVATE len override.
FUNC describe(t AS Tag) AS String
  RETURN toString(t) & " len=" & toString(len(t))
END FUNC
