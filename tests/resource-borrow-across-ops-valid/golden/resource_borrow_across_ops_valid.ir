{
  "format": "mfb-ir",
  "version": 1,
  "project": "resource_borrow_across_ops_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "logLine",
    "visibility": "private",
    "kind": "sub",
    "params": [
    { "name": "f", "type": "File", "default": null },
    { "name": "msg", "type": "String", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "fs.writeAll", "args": [{ "kind": "local", "name": "f" }, { "kind": "local", "name": "msg" }] } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "f", "type": "File", "value": { "kind": "call", "target": "fs.createTempFile", "args": [] } },
    { "op": "eval", "value": { "kind": "call", "target": "logLine", "args": [{ "kind": "local", "name": "f" }, { "kind": "const", "type": "String", "value": "first" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "logLine", "args": [{ "kind": "local", "name": "f" }, { "kind": "const", "type": "String", "value": "second" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "local", "name": "f" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "borrowed" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
