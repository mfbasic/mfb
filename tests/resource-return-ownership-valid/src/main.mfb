IMPORT fs
IMPORT io

' Returns a live File resource; ownership moves out to the caller (event #3).
FUNC reopen(path AS String) AS RES File
  RES f = fs::openFile(path)
  RETURN f
END FUNC

FUNC main AS Integer
  LET path AS String = "target/resource_return_ownership_valid.txt"
  IF fs::fileExists(path) THEN
    fs::deleteFile(path)
  END IF
  RES w AS File = fs::openFile(path, "write")
  fs::writeAll(w, "returned-handle")
  fs::close(w)
  RES g AS File = reopen(path)         ' caller now owns the returned resource
  LET back AS String = fs::readAll(g)
  fs::close(g)                         ' caller closes it: ownership truly moved
  io::print(back)
  fs::deleteFile(path)
  RETURN 0
END FUNC
