IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("length Float2 = " & toString(vector::length(vector::Float2[3.0, 4.0])))
  io::print("length Float3 = " & toString(vector::length(vector::Float3[1.0, 2.0, 2.0])))
  io::print("length Float4 = " & toString(vector::length(vector::Float4[1.0, 2.0, 2.0, 4.0])))
  io::print("length Fixed2 = " & toString(vector::length(vector::Fixed2[toFixed(3.0), toFixed(4.0)])))
  io::print("length Fixed3 = " & toString(vector::length(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)])))
  io::print("length Fixed4 = " & toString(vector::length(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)])))
  io::print("length Integer2 = " & toString(vector::length(vector::Integer2[3, 4])))
  io::print("length Integer3 = " & toString(vector::length(vector::Integer3[1, 2, 2])))
  io::print("length Integer4 = " & toString(vector::length(vector::Integer4[1, 2, 2, 4])))
  RETURN 0
END FUNC
