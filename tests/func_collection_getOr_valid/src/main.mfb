IMPORT collections
IMPORT io

FUNC main AS Integer
  LET numbers AS List OF Integer = [10, 20, 30]
  LET names AS Map OF String TO Integer = Map OF String TO Integer { "Ada" := 36 }
  LET codes AS Map OF Integer TO String = Map OF Integer TO String { 1 := "one" }

  LET first AS Integer = collections::getOr(numbers, 0, -1)
  LET missingHigh AS Integer = collections::getOr(numbers, 99, -2)
  LET missingNegative AS Integer = collections::getOr(numbers, -1, -3)
  LET namedList AS Integer = collections::getOr(value := numbers, index := 1, default := -4)
  LET ada AS Integer = collections::getOr(names, "Ada", 0)
  LET grace AS Integer = collections::getOr(names, "Grace", 7)
  LET namedMap AS Integer = collections::getOr(default := 8, key := "Grace", value := names)
  LET two AS String = collections::getOr(codes, 2, "two")

  io::print(toString(first))
  io::print(toString(missingHigh))
  io::print(toString(missingNegative))
  io::print(toString(namedList))
  io::print(toString(ada))
  io::print(toString(grace))
  io::print(toString(namedMap))
  io::print(two)

  RETURN first + missingHigh + missingNegative + namedList + ada + grace + namedMap
END FUNC
