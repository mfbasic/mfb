IMPORT io

FUNC main AS Integer
  LET numbers AS List OF Integer = [10, 20, 30]
  LET names AS Map OF String TO Integer = Map OF String TO Integer { "Ada" := 36 }
  LET codes AS Map OF Integer TO String = Map OF Integer TO String { 1 := "one" }

  LET first AS Integer = getOr(numbers, 0, -1)
  LET missingHigh AS Integer = getOr(numbers, 99, -2)
  LET missingNegative AS Integer = getOr(numbers, -1, -3)
  LET ada AS Integer = getOr(names, "Ada", 0)
  LET grace AS Integer = getOr(names, "Grace", 7)
  LET two AS String = getOr(codes, 2, "two")

  io::print(toString(first))
  io::print(toString(missingHigh))
  io::print(toString(missingNegative))
  io::print(toString(ada))
  io::print(toString(grace))
  io::print(two)

  RETURN first + missingHigh + missingNegative + ada + grace
END FUNC
