IMPORT io

TYPE Circle
  radius AS Integer
END TYPE

TYPE Rect
  w AS Integer
  h AS Integer
END TYPE

TYPE Point
  value AS Nothing
END TYPE

TYPE Triangle
  a AS Integer
  b AS Integer
  c AS Integer
END TYPE

UNION Shape
  Circle
  Rect
  Point
END UNION

UNION ExtraShape INCLUDES Shape
  Triangle
END UNION

TYPE ShapeBag
  shapes AS List OF Shape
END TYPE

FUNC shapeScore(s AS Shape) AS Integer
  MATCH s
    CASE Circle(circle)
      RETURN circle.radius
    CASE Rect(rect)
      RETURN rect.w + rect.h
    CASE Point(point)
      RETURN 1
  END MATCH
END FUNC

FUNC extraScore(s AS ExtraShape) AS Integer
  MATCH s
    CASE Circle(circle)
      RETURN circle.radius + 100
    CASE Rect(rect)
      RETURN rect.w + rect.h + 200
    CASE Point(point)
      RETURN 300
    CASE Triangle(triangle)
      RETURN triangle.a + triangle.b + triangle.c
  END MATCH
END FUNC

FUNC listScore(shapes AS List OF Shape) AS Integer
  MUT total AS Integer = 0
  FOR EACH shape IN shapes
    total = total + shapeScore(shape)
  NEXT
  RETURN total
END FUNC

FUNC main AS Integer
  LET circle AS Shape = Circle[5]
  LET rect AS Shape = Rect[2, 3]
  LET point AS Shape = Point[NOTHING]
  LET extraCircle AS ExtraShape = Circle[7]
  LET extraRect AS ExtraShape = Rect[4, 5]
  LET extraPoint AS ExtraShape = Point[NOTHING]
  LET triangle AS ExtraShape = Triangle[6, 7, 8]
  LET shapes AS List OF Shape = [Circle[5], Rect[2, 3]]
  LET bag AS ShapeBag = ShapeBag[[Circle[1], Rect[1, 2]]]

  io::print(typeName(circle))
  io::print(typeName(extraCircle))
  LET a AS Integer = shapeScore(circle)
  LET b AS Integer = shapeScore(rect)
  LET c AS Integer = shapeScore(point)
  LET d AS Integer = extraScore(extraCircle)
  LET e AS Integer = extraScore(extraRect)
  LET f AS Integer = extraScore(extraPoint)
  LET g AS Integer = extraScore(triangle)
  LET h AS Integer = listScore(shapes)
  LET i AS Integer = listScore(bag.shapes)
  io::print(toString(h))
  io::print(toString(i))
  RETURN a + b + c + d + e + f + g + h + i
END FUNC
