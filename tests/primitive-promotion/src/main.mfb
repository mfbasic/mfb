IMPORT io

FUNC main AS Integer
  rowByteByte()
  rowByteInteger()
  rowByteFixed()
  rowByteFloat()
  rowIntegerByte()
  rowIntegerInteger()
  rowIntegerFixed()
  rowIntegerFloat()
  rowFixedByte()
  rowFixedInteger()
  rowFixedFixed()
  rowFixedFloat()
  rowFloatByte()
  rowFloatInteger()
  rowFloatFixed()
  rowFloatFloat()
  RETURN 0
END FUNC

SUB rowByteByte()
  LET left AS Byte = 2
  LET right AS Byte = 2
  io::print(typeName(left) & " + " & typeName(right) & " = " & typeName(left + right))
  io::print(typeName(left) & " - " & typeName(right) & " = " & typeName(left - right))
  io::print(typeName(left) & " * " & typeName(right) & " = " & typeName(left * right))
  io::print(typeName(left) & " ^ " & typeName(right) & " = " & typeName(left ^ right))
  io::print(typeName(left) & " / " & typeName(right) & " = " & typeName(left / right))
  io::print(typeName(left) & " MOD " & typeName(right) & " = " & typeName(left MOD right))
  io::print(typeName(left) & " DIV " & typeName(right) & " = " & typeName(left DIV right))
END SUB

