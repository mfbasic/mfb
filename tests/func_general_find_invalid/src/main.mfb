IMPORT strings
FUNC main AS Integer
  LET missing AS Integer = strings::find()
  LET wrongNeedle AS Integer = strings::find("hello", 1)
  LET wrongStart AS Integer = strings::find("hello", "l", "0")
  LET tooMany AS Integer = strings::find("hello", "l", 0, 1)
  RETURN missing + wrongNeedle + wrongStart + tooMany
END FUNC
