IMPORT io
IMPORT math

' Vectorized math::log / math::log10 over a Float list — NEON f64 kernel
' (x = 2^k*m, ln(x) = k*ln2 + s*P(s^2)), within <=1 ULP of macOS libm. Length 5
' is odd, exercising the broadcast tail.
SUB show(xs AS List OF Float, p AS Byte)
  FOR EACH x IN xs
    io::print(toString(x, p))
  NEXT
END SUB

FUNC main AS Integer
  LET p AS Byte = 15
  LET xs AS List OF Float = [0.5, 1.0, 2.0, 10.0, 100.0]
  io::print("log:")
  show(math::log(xs), p)
  io::print("log10:")
  show(math::log10(xs), p)
  RETURN 0
END FUNC
