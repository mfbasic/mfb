IMPORT io

' Float comparisons follow IEEE 754 even for the non-finite intermediates
' the boundary rule permits (a comparison is not an observation boundary,
' so comparing a transient non-finite never traps; plan-17).
FUNC main AS Integer
  LET z AS Float = 0.0
  LET one AS Float = 1.0
  LET negone AS Float = 0.0 - 1.0
  io::print(toString((one / z) > 5.0))
  io::print(toString((one / z) < 5.0))
  io::print(toString((z / z) < 5.0))
  io::print(toString((z / z) > 5.0))
  io::print(toString((z / z) <= 5.0))
  io::print(toString((z / z) >= 5.0))
  io::print(toString((z / z) = 5.0))
  io::print(toString((z / z) <> 5.0))
  io::print(toString((negone / z) < 5.0))
  RETURN 0
END FUNC
