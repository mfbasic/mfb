    { "op": "bind", "mutable": false, "name": "p", "type": "Byte", "value": { "kind": "const", "type": "Byte", "value": "2" } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "fromString", "args": [{ "kind": "const", "type": "String", "value": "2.50" }] }, { "kind": "local", "name": "p" }] }] } },
