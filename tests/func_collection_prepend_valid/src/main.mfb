IMPORT collections
IMPORT io

FUNC main AS Integer
  LET numbers AS List OF Integer = collections::prepend([2, 3], 1)
  LET names AS List OF String = collections::prepend(["Grace"], "Ada")

  FOR EACH value IN numbers
    io::print(toString(value))
  NEXT
  FOR EACH name IN names
    io::print(name)
  NEXT

  RETURN len(numbers) + len(names)
END FUNC
