SUB viaReturn(flag AS Boolean)
  IF flag THEN
    RETURN
  ELSE
    FAIL Error[10, "return path failed"]
  END IF
  TRAP(err)
  RETURN
  END TRAP
END SUB

SUB viaTrapReturn(flag AS Boolean)
  IF flag THEN
    RETURN
  ELSE
    FAIL Error[11, "trap path failed"]
  END IF
  TRAP(err)
  RETURN
  END TRAP
END SUB

FUNC main AS Integer
  viaReturn(TRUE)
  viaReturn(FALSE)
  viaTrapReturn(TRUE)
  viaTrapReturn(FALSE)
  RETURN 0
END FUNC
