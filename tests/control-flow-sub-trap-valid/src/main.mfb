SUB viaReturn(flag AS Boolean)
  IF flag THEN
    RETURN
  ELSE
    FAIL Error[10, "return path failed"]
  END IF
  TRAP(err)
  RETURN
  END TRAP
END SUB

SUB viaReturnNothing(flag AS Boolean)
  IF flag THEN
    RETURN NOTHING
  ELSE
    FAIL Error[11, "nothing path failed"]
  END IF
  TRAP(err)
  RETURN NOTHING
  END TRAP
END SUB

FUNC main AS Integer
  viaReturn(TRUE)
  viaReturn(FALSE)
  viaReturnNothing(TRUE)
  viaReturnNothing(FALSE)
  RETURN 0
END FUNC
