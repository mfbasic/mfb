SUB viaReturn(flag AS Boolean)
  IF flag THEN
    EXIT SUB
  ELSE
    FAIL error(10, "return path failed")
  END IF
  TRAP(err)
  EXIT SUB
  END TRAP
END SUB

SUB viaTrapReturn(flag AS Boolean)
  IF flag THEN
    EXIT SUB
  ELSE
    FAIL error(11, "trap path failed")
  END IF
  TRAP(err)
  EXIT SUB
  END TRAP
END SUB

FUNC main AS Integer
  viaReturn(TRUE)
  viaReturn(FALSE)
  viaTrapReturn(TRUE)
  viaTrapReturn(FALSE)
  RETURN 0
END FUNC
