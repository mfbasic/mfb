IMPORT io

FUNC main AS Integer
  LET numbers AS List OF Integer = [10, 20, 30, 20]
  LET names AS List OF String = ["Ada", "Grace", "Ada"]
  LET numberNeedle AS List OF Integer = [20, 30]
  LET nameNeedle AS List OF String = ["Grace", "Ada"]
  LET emptyNeedle AS List OF Integer = []

  LET firstTwenty AS Integer = find(numbers, 20)
  LET secondTwenty AS Integer = find(numbers, 20, 2)
  LET secondAda AS Integer = find(names, "Ada", 1)
  LET numberSublist AS Integer = find(numbers, numberNeedle)
  LET nameSublist AS Integer = find(names, nameNeedle)
  LET emptySublist AS Integer = find(numbers, emptyNeedle, 4)

  io::print(toString(firstTwenty))
  io::print(toString(secondTwenty))
  io::print(toString(secondAda))
  io::print(toString(numberSublist))
  io::print(toString(nameSublist))
  io::print(toString(emptySublist))

  RETURN firstTwenty + secondTwenty + secondAda + numberSublist + nameSublist + emptySublist
END FUNC
