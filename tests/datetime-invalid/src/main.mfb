IMPORT io
IMPORT datetime
IMPORT errorCode

FUNC badDate AS Integer
  LET d AS Date = datetime::date(2026, 2, 29)
  RETURN d.day
  TRAP(err)
    io::print("badDate=" & toString(err.code = errorCode::ErrInvalidArgument))
    RETURN -1
  END TRAP
END FUNC

FUNC badMonth AS Integer
  LET d AS Date = datetime::date(2026, 13, 1)
  RETURN d.month
  TRAP(err)
    io::print("badMonth=" & toString(err.code = errorCode::ErrInvalidArgument))
    RETURN -1
  END TRAP
END FUNC

FUNC badHour AS Integer
  LET t AS Time = datetime::time(24, 0, 0)
  RETURN t.hour
  TRAP(err)
    io::print("badHour=" & toString(err.code = errorCode::ErrInvalidArgument))
    RETURN -1
  END TRAP
END FUNC

FUNC badOffset AS Integer
  LET z AS Zone = datetime::fixedOffset(30, 0)
  RETURN z.offsetSeconds
  TRAP(err)
    io::print("badOffset=" & toString(err.code = errorCode::ErrInvalidArgument))
    RETURN -1
  END TRAP
END FUNC

FUNC badParse AS Integer
  LET dt AS DateTime = datetime::parse("not-a-date", "yyyy-MM-dd")
  RETURN dt.date.year
  TRAP(err)
    io::print("badParse=" & toString(err.code = errorCode::ErrInvalidFormat))
    RETURN -1
  END TRAP
END FUNC

FUNC badIso AS Integer
  LET dt AS DateTime = datetime::parseIso("2026/06/25")
  RETURN dt.date.year
  TRAP(err)
    io::print("badIso=" & toString(err.code = errorCode::ErrInvalidFormat))
    RETURN -1
  END TRAP
END FUNC

FUNC main AS Integer
  LET r AS Integer = badDate() + badMonth() + badHour() + badOffset() + badParse() + badIso()
  io::print("all_trapped=" & toString(r = -6))
  RETURN 0
END FUNC
