    { "op": "bind", "mutable": false, "name": "w", "type": "Wrapper", "value": { "kind": "constructor", "type": "Wrapper", "args": [{ "kind": "local", "name": "a" }, { "kind": "const", "type": "String", "value": "first" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "memberAccess", "target": { "kind": "memberAccess", "target": { "kind": "local", "name": "w" }, "member": "who" }, "member": "name" }, "right": { "kind": "const", "type": "String", "value": ":" } }, "right": { "kind": "memberAccess", "target": { "kind": "memberAccess", "target": { "kind": "local", "name": "w" }, "member": "who" }, "member": "city" } }, "right": { "kind": "const", "type": "String", "value": ":" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "w" }, "member": "tag" } }] } },
    { "op": "bind", "mutable": false, "name": "w2", "type": "Wrapper", "value": { "kind": "with", "type": "Wrapper", "target": { "kind": "local", "name": "w" }, "updates": [{ "field": "tag", "value": { "kind": "const", "type": "String", "value": "second-and-longer" } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "w" }, "member": "tag" }, "right": { "kind": "const", "type": "String", "value": "|" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "w2" }, "member": "tag" } }] } },
