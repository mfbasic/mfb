    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "memberAccess", "target": { "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "more" }, { "kind": "const", "type": "Integer", "value": "2" }] }, "member": "name" }, "right": { "kind": "const", "type": "String", "value": "/" } }, "right": { "kind": "memberAccess", "target": { "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "more" }, { "kind": "const", "type": "Integer", "value": "2" }] }, "member": "city" } }] } },
    { "op": "bind", "mutable": false, "name": "scores", "type": "Map OF Person TO Integer", "value": { "kind": "map", "type": "Map OF Person TO Integer", "entries": [{ "key": { "kind": "local", "name": "a" }, "value": { "kind": "const", "type": "Integer", "value": "1" } }, { "key": { "kind": "local", "name": "c" }, "value": { "kind": "const", "type": "Integer", "value": "2" } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "scores" }, { "kind": "constructor", "type": "Person", "args": [{ "kind": "const", "type": "String", "value": "Ada" }, { "kind": "const", "type": "String", "value": "London" }] }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "scores" }, { "kind": "constructor", "type": "Person", "args": [{ "kind": "const", "type": "String", "value": "Augusta" }, { "kind": "const", "type": "String", "value": "London" }] }] }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "collections.hasKey", "args": [{ "kind": "local", "name": "scores" }, { "kind": "constructor", "type": "Person", "args": [{ "kind": "const", "type": "String", "value": "Grace" }, { "kind": "const", "type": "String", "value": "Newport" }] }] }] }] } },
    { "op": "bind", "mutable": false, "name": "e", "type": "Person", "value": { "kind": "constructor", "type": "Person", "args": [{ "kind": "const", "type": "String", "value": "" }, { "kind": "const", "type": "String", "value": "x" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "[" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "name" } }, "right": { "kind": "const", "type": "String", "value": "][" } }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "e" }, "member": "city" } }, "right": { "kind": "const", "type": "String", "value": "]" } }] } },
