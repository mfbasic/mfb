IMPORT fs
IMPORT io

FUNC alwaysFail AS Nothing
  FAIL Error[77050002, "propagate fail"]
END FUNC

FUNC propagateOnce(path AS String) AS Nothing
  USING f = fs::openFile(path)
    alwaysFail()
  END USING
  RETURN NOTHING
END FUNC

FUNC trapPropagate(path AS String) AS Nothing
  propagateOnce(path)
  RETURN NOTHING
  TRAP err
    IF err.code <> 77050002 THEN FAIL err
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  MUT i AS Integer = 0
  WHILE i < 4000
    trapPropagate("tests/control-flow-using-propagate-runtime/src/main.mfb")
    i = i + 1
  WEND
  io::print("propagate")
  RETURN 0
END FUNC
