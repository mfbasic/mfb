{
  "format": "mfb-ir",
  "version": 1,
  "project": "thread_return_union",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "t", "type": "Thread OF String TO ReturnChoice", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_runtime_workers.returnUnion", "type": "ISOLATED FUNC(ThreadWorker OF String TO ReturnChoice, String) AS ReturnChoice" }, { "kind": "const", "type": "String", "value": "seed" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t" }, { "kind": "const", "type": "String", "value": "sent-union" }, { "kind": "const", "type": "Integer", "value": "10" }] } },
    { "op": "bind", "mutable": false, "name": "result", "type": "ReturnChoice", "value": { "kind": "call", "target": "thread.waitFor", "args": [{ "kind": "local", "name": "t" }] } },
    { "op": "bind", "mutable": false, "name": "$match0", "type": "ReturnChoice", "value": { "kind": "local", "name": "result" } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match0" },
      "cases": [
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "ReturnOk" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "value", "type": "ReturnOk", "value": { "kind": "unionExtract", "type": "ReturnOk", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "value" }, "member": "message" }] } }
        ]
      },
      {
        "pattern": { "kind": "value", "value": { "kind": "local", "name": "ReturnMissing" } },
        "guard": null,
        "body": [
        { "op": "bind", "mutable": false, "name": "value", "type": "ReturnMissing", "value": { "kind": "unionExtract", "type": "ReturnMissing", "value": { "kind": "local", "name": "$match0" } } },
        { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "returned-missing" }] } }
        ]
      }
      ]
    },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
