IMPORT fs
IMPORT io

FUNC main AS Integer
  LET path AS String = "target/func_fs_readAll_valid.txt"
  fs::writeText(path, "first\nsecond é日😀")
  RES f AS File = fs::openFile(path)
  io::print(fs::readAll(f))
  io::print(toString(fs::eof(f)))
  fs::close(f)
  fs::deleteFile(path)
  RETURN 0
END FUNC
