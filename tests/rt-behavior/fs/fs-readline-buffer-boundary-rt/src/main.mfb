IMPORT io
IMPORT fs
IMPORT strings

' Exercises the transparent read buffer (plan-14-C): a line far larger than the
' 16 KiB read block (so the growing accumulator spans several refills), plain
' short lines, and a final line with no trailing newline — read back byte-for-byte.
FUNC main AS Integer
  RES f = fs::openFile("tests/rt-behavior/fs/fs-readline-buffer-boundary-rt/data.txt", "read")
  MUT idx AS Integer = 0
  WHILE NOT fs::eof(f)
    LET line AS String = fs::readLine(f)
    io::print(toString(idx) & ":" & toString(strings::byteLen(line)))
    idx = idx + 1
  WEND
  io::print("lines=" & toString(idx))
  RETURN 0
END FUNC
