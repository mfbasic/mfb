IMPORT strings

' Consolidated lexer-literal behavior (tests reorg): radix/separators,
' scientific notation & type suffixes, and string escapes (unicode, cr, nul).

FUNC crFromByte AS String
  LET bytes AS List OF Byte = [toByte(13)]
  RETURN toString(bytes)
END FUNC
FUNC nulFromByte AS String
  LET bytes AS List OF Byte = [toByte(0)]
  RETURN toString(bytes)
END FUNC
FUNC smileFromBytes AS String
  LET bytes AS List OF Byte = [toByte(240), toByte(159), toByte(152), toByte(128)]
  RETURN toString(bytes)
END FUNC

FUNC main AS Integer
  RETURN 0
END FUNC

TESTING
  TGROUP "radix prefixes"
    TCASE "hexadecimal"
      expectInteger(0xFFF, 4095)
      expectInteger(0XaB, 171)
      expectInteger(0x0, 0)
    END TCASE
    TCASE "octal"
      expectInteger(0o777, 511)
      expectInteger(0O10, 8)
    END TCASE
    TCASE "binary"
      expectInteger(0b1010, 10)
      expectInteger(0B1111_1111, 255)
    END TCASE
    TCASE "u64-max hex decodes"
      expectInteger(0x7FFFFFFFFFFFFFFF, 9223372036854775807)
    END TCASE
  END TGROUP
  TGROUP "integer range boundaries"
    ' bug-286: `-9223372036854775808` is spec-legal (§4.12) but its positive
    ' magnitude overflows i64, so lowering must fold the minus into the literal.
    ' Unfolded it built cleanly and then trapped at runtime on the negate.
    TCASE "most-negative Integer literal evaluates to i64::MIN"
      LET min AS Integer = -9223372036854775808
      expectString(toString(min), "-9223372036854775808")
      expectInteger(min + 1, -9223372036854775807)
      expectEqual(min < -9223372036854775807, TRUE)
    END TCASE
    TCASE "the hex spelling of the minimum folds identically"
      expectInteger(-0x8000000000000000, -9223372036854775808)
    END TCASE
    TCASE "the maximum is unaffected"
      expectInteger(9223372036854775807, 9223372036854775807)
      expectInteger(-9223372036854775807 - 1, -9223372036854775808)
    END TCASE
  END TGROUP
  TGROUP "digit separators"
    TCASE "decimal separators are stripped"
      expectInteger(1_000_000, 1000000)
      expectInteger(1_2_3, 123)
    END TCASE
    TCASE "separators in radix literals"
      expectInteger(0xFF_FF, 65535)
    END TCASE
  END TGROUP
  TGROUP "byte coercion"
    TCASE "byte slot accepts 0xFF"
      LET b AS Byte = 0xFF
      expectInteger(toInt(b), 255)
    END TCASE
  END TGROUP
  TGROUP "scientific notation"
    TCASE "exponent literals are Float"
      expectString(typeName(1e3), "Float")
      expectString(toString(1e3), "1000")
      expectString(toString(2.5e2), "250")
      expectString(toString(1e-3), "0.001")
      expectString(toString(1_0e1_0), "100000000000")
    END TCASE
  END TGROUP
  TGROUP "type suffixes"
    TCASE "f suffix is Float, F suffix is Fixed"
      expectString(typeName(2f), "Float")
      expectString(typeName(2F), "Fixed")
      expectString(typeName(1.5f), "Float")
      expectString(typeName(1.5F), "Fixed")
    END TCASE
    TCASE "intrinsic Fixed literal without annotation"
      LET x = 2F
      expectString(typeName(x), "Fixed")
      ' A constant `toString` folds to the expanded plain decimal.
      expectString(toString(2F), "2")
      expectString(toString(1.5F), "1.5")
    END TCASE
    TCASE "exponent plus suffix"
      expectString(typeName(1e3f), "Float")
      expectString(typeName(1e3F), "Fixed")
      expectString(toString(2.5e2F), "250")
    END TCASE
    TCASE "negated suffix keeps type"
      LET n = -2F
      expectString(typeName(n), "Fixed")
    END TCASE
  END TGROUP
  TGROUP "string escapes"
    TCASE "carriage return decodes to U+000D"
      expectString("\r", crFromByte())
    END TCASE
    TCASE "nul decodes to U+0000"
      expectString("\0", nulFromByte())
    END TCASE
    TCASE "unicode scalar escape decodes ASCII"
      expectString("\u{41}", "A")
      expectString("\u{6a}", "j")
    END TCASE
    TCASE "unicode scalar escape decodes 4-byte emoji"
      expectString("\u{1F600}", smileFromBytes())
    END TCASE
    TCASE "existing escapes unchanged"
      LET quote AS List OF Byte = [toByte(34)]
      LET backslash AS List OF Byte = [toByte(92)]
      LET lf AS List OF Byte = [toByte(10)]
      LET tab AS List OF Byte = [toByte(9)]
      expectString("\"", toString(quote))
      expectString("\\", toString(backslash))
      expectString("\n", toString(lf))
      expectString("\t", toString(tab))
      expectString("\q", "q")
    END TCASE
  END TGROUP
END TESTING
