IMPORT io

REM top-level comment skips ignored tokens: )
' apostrophe comments skip ignored tokens too: )

SUB main()
  REM comment inside a block skips ignored tokens: )
  LET remembered AS String = "ordinary rem identifier"
  LET premium AS String = remembered
  io::print(premium) ' inline apostrophe comment skips ignored tokens: )
  io::print("rem comment after colon")
  LET value AS Integer = 1 : rEm comment after separator skips ignored tokens: )
  io::print(toString(value))
END SUB
