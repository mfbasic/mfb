' plan-58-B Phase 1 — the spike that falsifies the sub-plan's one unproven
' premise: that an arena allocation can happen DURING slot staging without
' destroying another slot's staged value.
'
' Every other ABI slot kind stages into frame storage sized at compile time. A
' CBuffer cannot — its size is a runtime value and its storage must outlive the
' call — so it is an arena block, and `_mfb_arena_alloc` destroys every
' caller-saved register with no survivor set.
'
' `pread(2)` is chosen deliberately over `read(2)`: it has FOUR arguments, so the
' buffer has a scalar slot staged before it (fd) and TWO after it (nbyte,
' offset). If the allocation clobbered its neighbours, the wrong length or the
' wrong offset would reach the callee and the bytes would come back wrong — an
' observable failure rather than a latent one.
'
'   ssize_t pread(int fd, void *buf, size_t nbyte, off_t offset);
IMPORT io
IMPORT fs
IMPORT encoding

LINK "c" AS libc
  FUNC openRead(path AS String) AS Integer
    SYMBOL "open"
    ABI (path CString, flags CInt32) AS fd CInt32
    CONST flags = 0
    RETURN fd
  END FUNC

  ' The buffer sits BETWEEN fd and (nbyte, offset) in native argument order.
  FUNC preadBytes(fd AS Integer, nbyte AS Integer, offset AS Integer) AS List OF Byte
    SYMBOL "pread"
    ABI (fd CInt32, buf OUT CBuffer, nbyte CInt64, offset CInt64) AS got CInt64
    BUFFER buf SIZE nbyte
    RETURN buf LENGTH got
  END FUNC

  ' plan-58-B Phase 2: a SIZE expression with arithmetic. This is the shape every
  ' real C bulk API needs — a buffer sized from a frame/element count times a
  ' width, never from a constant. Before the Mul/Add/Sub arms existed, `pairs * 2`
  ' fell through lowering's `_` arm to the literal 0, so this would have allocated
  ' a zero-length buffer with no diagnostic.
  ' `pairs` has NO ABI slot of its own — it exists only to size the buffer. That
  ' is the case NATIVE_ABI_UNBOUND_PARAM had to be taught about, the same way
  ' plan-50-E taught it about BIND IN fields.
  FUNC preadPairs(fd AS Integer, nbyte AS Integer, pairs AS Integer, offset AS Integer) AS List OF Byte
    SYMBOL "pread"
    ABI (fd CInt32, buf OUT CBuffer, nbyte CInt64, offset CInt64) AS got CInt64
    BUFFER buf SIZE pairs * 2
    RETURN buf LENGTH got
  END FUNC

  FUNC closeFd(fd AS Integer) AS Integer
    SYMBOL "close"
    ABI (fd CInt32) AS status CInt32
    RETURN status
  END FUNC
END LINK

FUNC main() AS Integer
  LET path AS String = "target/native_cbuffer_read_rt.bin"
  fs::writeText(path, "ABCDEFGHIJKLMNOPQRSTUVWXYZ")

  LET fd AS Integer = libc::openRead(path)
  io::print("fd_ok " & toString(fd > 0))

  ' Full-capacity read from offset 0: every byte the callee writes is observable,
  ' which is what catches a dataBase/block pointer swap. Handing over the BLOCK
  ' instead of dataBase would let the callee overwrite the 40-byte header, so a
  ' full write corrupts count/capacity and the list stops reading back cleanly.
  LET head AS List OF Byte = libc::preadBytes(fd, 8, 0)
  io::print("head_len " & toString(len(head)))
  ' base64 rather than a text decode: it renders every byte exactly, so a
  ' single wrong or uninitialized byte shows up in the golden.
  io::print("head " & encoding::base64Encode(head))

  ' A non-zero offset proves the LAST staged slot survived the allocation: if
  ' `offset` were clobbered to 0 this would return "ABCDEFGH" again.
  LET mid AS List OF Byte = libc::preadBytes(fd, 6, 10)
  io::print("mid " & encoding::base64Encode(mid))

  ' And a different nbyte proves the middle one survived.
  LET tail AS List OF Byte = libc::preadBytes(fd, 4, 22)
  io::print("tail " & encoding::base64Encode(tail))

  ' Phase 2: `SIZE pairs * 2` must allocate exactly 2*pairs bytes. 5 pairs = 10
  ' bytes from offset 0 is "ABCDEFGHIJ"; a zero-length buffer or a wrong product
  ' shows up in both the length and the bytes.
  LET pairs AS List OF Byte = libc::preadPairs(fd, 10, 5, 0)
  io::print("pairs_len " & toString(len(pairs)))
  io::print("pairs " & encoding::base64Encode(pairs))

  ' Phase 3, the short read — the case LENGTH exists for. The file is 26 bytes;
  ' asking for 100 from offset 20 leaves pread able to write only 6. Without a
  ' LENGTH clause `count` would be the full 100-byte capacity and the trailing 94
  ' bytes of uninitialized arena memory would be readable as data. With it,
  ' `count` is what the callee reported.
  LET short AS List OF Byte = libc::preadBytes(fd, 100, 20)
  io::print("short_len " & toString(len(short)))
  io::print("short " & encoding::base64Encode(short))

  ' The clamp's negative arm: pread on a closed/bad fd returns -1. An unclamped
  ' -1 stored to `count` is a huge UNSIGNED value, and every later read walks off
  ' the block. Clamped to 0, this is simply an empty list.
  LET bad AS List OF Byte = libc::preadBytes(-1, 8, 0)
  io::print("bad_len " & toString(len(bad)))

  ' Reading entirely past EOF: pread returns 0, so the list is empty rather than
  ' 8 bytes of arena garbage.
  LET past AS List OF Byte = libc::preadBytes(fd, 8, 900)
  io::print("past_len " & toString(len(past)))

  ' plan-58-C: the maxBuffer ceiling. This project.json sets `"maxBuffer": 1`,
  ' so a SIZE of 1 MiB is allowed and 1 MiB + 1 is not. The gate runs BEFORE the
  ' allocation, so an over-cap request costs nothing and raises
  ' ErrInvalidArgument rather than claiming the arena.
  LET big AS List OF Byte = libc::preadBytes(fd, 1048576, 0)
  io::print("at_cap_len " & toString(len(big)))

  LET over AS List OF Byte = libc::preadBytes(fd, 1048577, 0)
  io::print("over_cap unreachable " & toString(len(over)))

  LET closed AS Integer = libc::closeFd(fd)
  io::print("closed " & toString(closed))
  RETURN 0
END FUNC
