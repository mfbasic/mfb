{
  "name": "libsnd_playback_rt",
  "version": "0.1.0",
  "mfb": "1.0",
  "kind": "executable",
  "packages": [
    {
      "name": "libsnd",
      "version": "=1.5.0",
      "source": "file:packages/libsnd.mfp"
    }
  ],
  "sources": [
    {
      "root": "src",
      "role": "main",
      "include": [
        "**/*.mfb"
      ]
    }
  ],
  "entry": "main",
  "targets": [
    "native"
  ],
  "resources": [
    {
      "src": "data/tone.flac",
      "dst": "./"
    }
  ]
}
