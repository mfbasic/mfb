IMPORT io

' plan-39 I1: overflow checks on `local - const` / `local + 1` are elided only when
' a guard proves it safe (a `IF local < K` lower bound, or a `WHILE local < S`
' strict upper bound). This fixture pins the soundness: safe cases elide with
' correct results, and cases where the value can still overflow keep the check.

FUNC safeSub(n AS Integer) AS Integer
  IF n < 2 THEN
    RETURN n
  END IF
  RETURN n - 6
END FUNC

FUNC nearMinSub(n AS Integer) AS Integer
  IF n < -9223372036854775803 THEN
    RETURN n
  END IF
  RETURN n - 6
END FUNC

FUNC safeLoopSum(n AS Integer) AS Integer
  MUT total AS Integer = 0
  MUT i AS Integer = 0
  WHILE i < n
    total = total + i
    i = i + 1
  END WHILE
  RETURN total
END FUNC

FUNC reassignThenAdd(s AS Integer) AS Integer
  MUT i AS Integer = s
  WHILE i < 100
    i = 9223372036854775807
    RETURN i + 1
  END WHILE
  RETURN -1
END FUNC

SUB main()
  io::print("safeSub(2)=" & toString(safeSub(2)))
  io::print("safeSub(100)=" & toString(safeSub(100)))
  io::print("safeLoopSum(5)=" & toString(safeLoopSum(5)))
  io::print("safeLoopSum(100)=" & toString(safeLoopSum(100)))

  MUT t1 AS Boolean = FALSE
  LET a AS Integer = nearMinSub(-9223372036854775803) TRAP(e)
    t1 = TRUE
    RECOVER 0
  END TRAP
  IF t1 THEN
    io::print("nearMinSub underflow trapped: correct")
  ELSE
    io::print("nearMinSub NOT trapped: UNSOUND a=" & toString(a))
  END IF

  MUT t2 AS Boolean = FALSE
  LET b AS Integer = reassignThenAdd(0) TRAP(e)
    t2 = TRUE
    RECOVER 0
  END TRAP
  IF t2 THEN
    io::print("reassignThenAdd overflow trapped: correct")
  ELSE
    io::print("reassignThenAdd NOT trapped: UNSOUND b=" & toString(b))
  END IF
END SUB
