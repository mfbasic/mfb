IMPORT collections
IMPORT csv
IMPORT fs
IMPORT io

' Consolidated runtime-behavior coverage (tests reorg). Each former per-case
' main is a <case>_run helper; main drives them in order so stdout is the
' concatenation of every case's output.

' ---- from csv_read_valid ----

FUNC csv_read_valid_run AS Integer
  LET path AS String = "target/csv_read_valid.csv"
  fs::writeText(path, "name,age\nAda,36\nGrace,\"Hop,per\"")
  LET doc AS List OF List OF String = csv::parse(fs::readText(path))
  io::print("rows=" & toString(len(doc)))

  ' Indexing is the collections package — no csv-specific accessors.
  LET header AS List OF String = collections::get(doc, 0)
  io::print(collections::get(header, 1))
  LET grace AS List OF String = collections::get(doc, 2)
  io::print(collections::get(grace, 1))

  fs::deleteFile(path)
  RETURN 0
END FUNC

' ---- from csv_write_valid ----

' A parse -> stringify -> parse round-trip asserting the §6 guarantee: every cell
' survives unchanged through quoting, even those holding a comma, an embedded
' line feed, or a literal double quote.
FUNC csv_write_valid_run AS Integer
  LET original AS List OF List OF String = [["a,b", "c\nd", "he\"o"], ["plain", "x", "y"]]
  LET text AS String = csv::stringify(original)
  LET path AS String = "target/csv_write_valid.csv"
  fs::writeText(path, text)
  LET back AS List OF List OF String = csv::parse(fs::readText(path))
  io::print("rows=" & toString(len(back)))

  MUT allEqual AS Boolean = TRUE
  MUT i AS Integer = 0
  FOR EACH row IN original
    LET backRow AS List OF String = collections::get(back, i)
    MUT j AS Integer = 0
    FOR EACH cell IN row
      IF cell <> collections::get(backRow, j) THEN
        allEqual = FALSE
      END IF
      j = j + 1
    NEXT
    i = i + 1
  NEXT
  io::print("roundtrip equal=" & toString(allEqual))

  fs::deleteFile(path)
  RETURN 0
END FUNC

FUNC main AS Integer
  LET _csv_read_valid AS Integer = csv_read_valid_run()
  LET _csv_write_valid AS Integer = csv_write_valid_run()
  RETURN 0
END FUNC
