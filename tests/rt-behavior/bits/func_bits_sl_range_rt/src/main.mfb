IMPORT io
IMPORT bits
IMPORT errorCode

FUNC doShift(value AS Integer, count AS Integer) AS Integer
  RETURN bits::sl(value, count)
END FUNC

FUNC attempt(count AS Integer) AS Nothing
  io::print(toString(doShift(1, count)))
  RETURN NOTHING
  TRAP(err)
    IF err.code = errorCode::ErrInvalidArgument THEN
      io::print("ErrInvalidArgument")
    ELSE
      io::print("other")
    END IF
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  attempt(4)
  attempt(64)
  attempt(-1)
  RETURN 0
END FUNC
