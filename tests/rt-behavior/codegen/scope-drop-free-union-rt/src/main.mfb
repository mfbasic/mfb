' plan-01 Phase 5 / plan-02 Phase 8 proof (unions + maps): a flat data union
' {tag, size, variant-block} and a Map are freed as one block at scope-drop, and
' a `MATCH`-extracted field returned from a function is copied so the caller owns
' it. The churn loop alternates union variants (so the freed block size differs
' each round) and rebuilds a Map every iteration; under entropy poisoning a
' wrong-size free, double-free, or freed-and-reused union/map block surfaces as a
' loud crash. Deterministic output.
IMPORT io
IMPORT collections

TYPE Dot
  x AS Integer
END TYPE

TYPE Tag
  name AS String
END TYPE

UNION Shape
  Dot
  Tag
END UNION

FUNC describe(s AS Shape) AS String
  MATCH s
    CASE Dot(d)
      RETURN "dot:" & toString(d.x)
    CASE Tag(t)
      RETURN t.name
  END MATCH
END FUNC

FUNC churn(rounds AS Integer) AS Integer
  MUT total AS Integer = 0
  MUT i AS Integer = 0
  WHILE i < rounds
    MUT s AS Shape = Dot[i]
    IF i - (i / 2) * 2 = 0 THEN
      s = Tag["tag-" & toString(i)]
    END IF
    LET text AS String = describe(s)
    LET m AS Map OF String TO Integer = Map OF String TO Integer { "n" := i, "len" := len(text) }
    total = total + len(text) + collections::get(m, "n") + collections::get(m, "len")
    i = i + 1
  END WHILE
  RETURN total
END FUNC

FUNC main AS Integer
  LET a AS Shape = Dot[7]
  LET b AS Shape = Tag["hello-and-longer"]
  io::print(describe(a))
  io::print(describe(b))

  ' Copy independence: c is an independent copy of b.
  LET c AS Shape = b
  io::print(describe(c) & "|" & describe(a))

  ' List of variable-size unions, each freed with the list as one block.
  LET xs AS List OF Shape = [a, b, c]
  MUT joined AS String = ""
  FOR EACH s IN xs
    joined = joined & describe(s) & ";"
  NEXT
  io::print(joined)

  io::print(toString(churn(400)))
  RETURN 0
END FUNC
