IMPORT io
IMPORT thread
IMPORT thread_runtime_workers

FUNC main AS Integer
  LET t AS Thread OF String TO Integer = thread::start(thread_runtime_workers::printReceived, "start")
  thread::send(t, "alpha")
  LET hasAck1 AS Boolean = thread::poll(t, 10)
  LET ack1 AS String = thread::receive(t)
  thread::send(t, "beta")
  LET hasAck2 AS Boolean = thread::poll(t, 10)
  LET ack2 AS String = thread::receive(t)
  thread::send(t, "gamma")
  LET hasAck3 AS Boolean = thread::poll(t, 10)
  LET ack3 AS String = thread::receive(t)
  LET result AS Integer = thread::waitFor(t)
  RETURN result
END FUNC
