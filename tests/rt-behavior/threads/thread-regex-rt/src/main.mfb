IMPORT io
IMPORT thread
IMPORT regex_thread_workers

REM Proves the regex package works inside an isolated worker thread (own arena).
REM This is also the fixture that proves an ISOLATED worker can import the regex
REM package at all, so it asserts both the build and the run.
REM
REM It is what exposed bug-369. A worker's arena block was sized to the arena
REM state alone, with no globals region, so regex's
REM `LET __REGEX_DEPTH_LIMIT AS Integer = 600` read whatever lay past the end of
REM that block. That was usually 0, which makes the guard
REM `IF depth > __REGEX_DEPTH_LIMIT` true at the first node and fails EVERY regex
REM call in a worker with "nesting limit exceeded" — but it was arbitrary memory,
REM not zeros, so occasionally the slot held a large value and the run passed.
REM Measured 7 of 8 runs failing, which is why the `.run` golden was withdrawn
REM (a ~12%-flaky fixture is worse than none) until the bug was fixed.
REM
REM Restored here: `thread::start` now sizes the worker arena to include the
REM globals region, and the trampoline runs the module's global initializer on it
REM before the worker body.

FUNC main AS Integer
  LET t1 AS Thread OF Nothing TO Integer = thread::start(regex_thread_workers::countDigits, "a1b2c3d4")
  LET t2 AS Thread OF Nothing TO String = thread::start(regex_thread_workers::normalizeSpaces, "hello   world  foo")
  LET digits AS Integer = thread::waitFor(t1)
  LET normalized AS String = thread::waitFor(t2)
  io::print("digits=" & toString(digits))
  io::print("normalized=" & normalized)
  RETURN 0
END FUNC
