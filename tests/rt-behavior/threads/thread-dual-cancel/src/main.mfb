IMPORT io
IMPORT thread
IMPORT thread_runtime_workers

FUNC main AS Integer
  LET left AS Thread OF String TO String = thread::start(thread_runtime_workers::readFileText, "tests/rt-behavior/threads/thread-fs-read-return/data/input.txt")
  LET right AS Thread OF String TO String = thread::start(thread_runtime_workers::readTextPath, "tests/rt-behavior/threads/thread-fs-readtext-return/data/input.txt")

  LET leftText AS String = thread::waitFor(left)
  LET rightText AS String = thread::waitFor(right)
  io::print(leftText)
  io::print(rightText)
  RETURN 0
END FUNC
