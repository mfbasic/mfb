IMPORT fs
IMPORT io

FUNC alwaysFail AS Nothing
  FAIL error(77050002, "propagate fail")
END FUNC

FUNC propagateOnce(path AS String) AS Nothing
  RES f = fs::openFile(path)
  alwaysFail()
  RETURN NOTHING
END FUNC

FUNC trapPropagate(path AS String) AS Nothing
  propagateOnce(path)
  RETURN NOTHING
  TRAP(err)
    IF err.code <> 77050002 THEN FAIL err
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  MUT i AS Integer = 0
  WHILE i < 4000
    trapPropagate("tests/rt-behavior/resources/control-flow-resource-propagate-runtime/src/main.mfb")
    i = i + 1
  END WHILE
  io::print("propagate")
  RETURN 0
END FUNC
