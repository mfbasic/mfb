IMPORT io
IMPORT fs
IMPORT resource_state_export_valid

' plan-52-D Phase 3: a stateful return CROSSES A PACKAGE BOUNDARY. The exporter
' populated the Cursor; this consumer only imported a signature.
'
' This is the case that decides whether the feature is actually useful:
' `bindings/libsnd` is a package boundary, so a stateful return that worked
' in-package and silently degraded across an import would leave it blocked.
' `pos=42 len=7` proves the exporter's state arrived; `pos=0 len=0` would mean the
' binding re-default-initialized it and the STATE never rode the `.mfp`.
FUNC main AS Integer
  RES h AS File STATE Cursor = resource_state_export_valid::openTagged("tests/rt-behavior/resources/resource-state-import-rt/src/main.mfb")
  io::print("pos=" & toString(h.state.pos))
  io::print("len=" & toString(h.state.len))
  fs::close(h)
  RETURN 0
END FUNC
