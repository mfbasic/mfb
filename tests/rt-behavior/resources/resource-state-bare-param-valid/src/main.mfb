IMPORT io
IMPORT fs

TYPE Cursor
  pos AS Integer
END TYPE

' plan-52-A row 1: a BARE `RES` parameter accepts an argument whose owner
' attached a STATE. Bare reads as "opaque" at a parameter — `p.state` is
' inaccessible inside (rows 2/3) — and that erasure is sound only because a
' borrow cannot escape the frame that borrowed it. The owner's state must
' therefore survive the call untouched. See `mfb spec language
' resource-management` §15.5.
SUB opaque(RES p AS File)
  fs::writeAll(p, "x")
END SUB

FUNC main AS Integer
  LET path AS String = "target/resource_state_bare_param_valid.txt"
  RES f AS File STATE Cursor = fs::openFile(path, "write")
  f.state.pos = 42
  opaque(f)
  io::print(toString(f.state.pos))   ' 42 — the borrow did not disturb the state
  fs::close(f)
  fs::deleteFile(path)
  RETURN 0
END FUNC
