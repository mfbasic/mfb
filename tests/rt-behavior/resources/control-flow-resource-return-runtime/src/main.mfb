IMPORT fs
IMPORT io

FUNC useOnce(path AS String) AS Nothing
  RES f = fs::openFile(path)
  IF path <> "" THEN
    RETURN NOTHING
  END IF
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  MUT i AS Integer = 0
  WHILE i < 4000
    useOnce("tests/rt-behavior/resources/control-flow-resource-return-runtime/src/main.mfb")
    i = i + 1
  WEND
  io::print("return")
  RETURN 0
END FUNC
