IMPORT io

' plan-37: PROPAGATE inside a bare *inline* handler still re-propagates the same
' caught Error — with its `code`, `message`, and `source` intact — to the
' enclosing trap or caller, even though the user has no name for it. This is the
' sharpest proof that a bare inline TRAP keeps the error live internally rather
' than discarding it.

' Bare inline handler that PROPAGATEs the toInt failure to the caller.
FUNC inner(s AS String) AS Integer
  LET n AS Integer = toInt(s) TRAP
    PROPAGATE
  END TRAP
  RETURN n
END FUNC

' Named catcher observes the re-propagated Error unchanged from the origin.
FUNC outer(s AS String) AS String
  LET n AS Integer = inner(s) TRAP(e)
    RETURN "ERR code=" & toString(e.code) & " msg=" & e.message & " line=" & toString(e.source.line)
  END TRAP
  RETURN "OK " & toString(n)
END FUNC

FUNC main() AS Integer
  io::print(outer("42"))
  io::print(outer("bad"))
  RETURN 0
END FUNC
