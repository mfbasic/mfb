IMPORT io

' bug-151: the caught Error `e` was allocated a function-level slot but never
' registered for scope-drop, so every taken TRAP(e) leaked one Error block — a
' trap-in-a-loop grew RSS unbounded. The fix registers `e` as an owned value of
' the handler body's scope, freed exactly once on RETURN / FAIL / fall-through and
' never on the success path that skips the handler. This loop catches an error
' every iteration and reads e.code/e.message; it must produce correct output and
' not crash (a wrong free would be a double-free). RSS-flatness is verified out of
' band (a golden cannot assert it).
FUNC boom(n AS Integer) AS Integer
  FAIL error(600 + (n MOD 3), "boom " & toString(n MOD 3))
  RETURN n
END FUNC

FUNC handle(n AS Integer) AS Integer
  LET v AS Integer = boom(n)
  RETURN v
  TRAP(e)
    ' Read both fields so a use-after-free of the caught Error would corrupt them.
    LET c AS Integer = e.code
    LET m AS String = e.message
    IF len(m) > 0 THEN
      RETURN c
    END IF
    RETURN 0
  END TRAP
END FUNC

FUNC main() AS Integer
  MUT i AS Integer = 0
  MUT sum AS Integer = 0
  WHILE i < 20000
    sum = sum + handle(i)
    i = i + 1
  WEND
  io::print("sum=" & toString(sum))
  io::print("one=" & toString(handle(1)))
  RETURN 0
END FUNC
