IMPORT io

FUNC ifOnly(flag AS Boolean) AS Integer
  IF flag THEN
    RETURN 1
  END IF
  RETURN 0
END FUNC

FUNC ifElse(flag AS Boolean) AS Integer
  IF flag THEN
    RETURN 1
  ELSE
    RETURN 2
  END IF
END FUNC

FUNC ifElseIf(first AS Boolean, second AS Boolean) AS Integer
  IF first THEN
    RETURN 1
  ELSEIF second THEN
    RETURN 2
  END IF
  RETURN 0
END FUNC

FUNC ifElseIfElse(first AS Boolean, second AS Boolean) AS Integer
  IF first THEN
    RETURN 1
  ELSEIF second THEN
    RETURN 2
  ELSE
    RETURN 3
  END IF
END FUNC

FUNC inlineIfElse(flag AS Boolean) AS Integer
  IF flag THEN RETURN 4 ELSE RETURN 5
END FUNC

FUNC inlineIfAssign(flag AS Boolean) AS Integer
  MUT result AS Integer = 0
  IF flag THEN result = 6 ELSE result = 7
  RETURN result
END FUNC

FUNC main() AS Integer
  LET total AS Integer = ifOnly(FALSE) + ifElse(TRUE) + ifElseIf(FALSE, TRUE) + ifElseIfElse(FALSE, FALSE) + inlineIfElse(TRUE) + inlineIfElse(FALSE) + inlineIfAssign(TRUE) + inlineIfAssign(FALSE)
  io::print(toString(total))
  RETURN 0
END FUNC
