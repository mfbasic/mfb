IMPORT io

FUNC fromString(value AS String) AS Integer
  RETURN toInt(value)
END FUNC

FUNC fromByte(value AS Byte) AS Integer
  RETURN toInt(value)
END FUNC

FUNC fromFloat(value AS Float) AS Integer
  RETURN toInt(value)
END FUNC

FUNC fromFixed(value AS Fixed) AS Integer
  RETURN toInt(value)
END FUNC

FUNC negativeFloat(value AS Float) AS Float
  RETURN 0.0 - value
END FUNC

FUNC negativeFixed(value AS Fixed) AS Fixed
  RETURN 0 - value
END FUNC

FUNC printInt(value AS Integer) AS Nothing
  io::print(toString(value))
  RETURN NOTHING
END FUNC

FUNC fromBase(value AS String, base AS Integer) AS Integer
  RETURN toInt(value, base)
END FUNC

FUNC main AS Integer
  printInt(fromString("0"))
  printInt(fromString("+42"))
  printInt(fromString("-42"))
  printInt(fromString("9223372036854775807"))
  printInt(fromString("-9223372036854775808"))
  printInt(fromByte(255))
  printInt(fromFloat(3.9))
  printInt(fromFloat(negativeFloat(3.9)))
  printInt(fromFixed(12.75))
  printInt(fromFixed(negativeFixed(12.75)))
  REM 2-arg radix form: base 10 matches the 1-arg path; other bases parse digits
  REM 0-9a-z up to `base`, with the same optional leading sign and i64 boundaries.
  printInt(fromBase("65535", 10))
  printInt(fromBase("ff", 16))
  printInt(fromBase("FF", 16))
  printInt(fromBase("-1a", 16))
  printInt(fromBase("+1a", 16))
  printInt(fromBase("101", 2))
  printInt(fromBase("777", 8))
  printInt(fromBase("z", 36))
  printInt(fromBase("zz", 36))
  printInt(fromBase("0", 16))
  printInt(fromBase("7fffffffffffffff", 16))
  printInt(fromBase("-8000000000000000", 16))
  RETURN 0
END FUNC
