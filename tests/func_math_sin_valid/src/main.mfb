IMPORT io
IMPORT math

FUNC main AS Integer
  LET p AS Byte = 2
  LET fixedHalfPi AS Fixed = toFixed("1.5707963268")
  io::print(toString(math::sin(0.0), p))
  io::print(toString(math::sin(1.5707963268), p))
  io::print(toString(math::sin(fixedHalfPi), p))
  ' Scalar kernel quadrant coverage: the scalar path branches on the reduced
  ' quadrant, so exercise all four (and a negative argument) at full precision.
  LET q AS Byte = 15
  io::print(toString(math::sin(0.7), q))    ' quadrant 0: sin_r branch
  io::print(toString(math::sin(2.0), q))    ' quadrant 1: cos_r branch
  io::print(toString(math::sin(4.0), q))    ' quadrant 2: sin_r branch, negated
  io::print(toString(math::sin(5.0), q))    ' quadrant 3: cos_r branch, negated
  io::print(toString(math::sin(-2.0), q))   ' negative argument
  RETURN 0
END FUNC
