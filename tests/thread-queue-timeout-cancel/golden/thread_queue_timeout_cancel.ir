      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "unexpected cancel result" }] } },
      { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
