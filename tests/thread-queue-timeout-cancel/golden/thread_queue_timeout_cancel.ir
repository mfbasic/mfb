  "functions": [
  {
    "name": "fullQueueScenario",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "t", "type": "Thread OF String TO Integer", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "hasFullMessage", "type": "Boolean", "value": { "kind": "call", "target": "thread.poll", "args": [{ "kind": "local", "name": "t" }, { "kind": "const", "type": "Integer", "value": "100" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t" }, { "kind": "const", "type": "String", "value": "held" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t" }, { "kind": "const", "type": "String", "value": "full" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "unexpected send" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "1" } },
    {
      "op": "trap",
      "name": "err",
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "timeout" }] } },
      { "op": "bind", "mutable": false, "name": "$trap_res0", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "thread.waitFor", "args": [{ "kind": "local", "name": "t" }] } },
      { "op": "bind", "mutable": true, "name": "$trap_val1", "type": "Integer", "value": null },
      {
        "op": "if",
        "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res0" } },
        "then": [
        { "op": "assign", "name": "$trap_val1", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res0" } } }
        ],
        "else": [
        { "op": "bind", "mutable": false, "name": "workerErr", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res0" } } },
        { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "worker timeout" }] } },
        { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
        ]
      },
      { "op": "bind", "mutable": false, "name": "value", "type": "Integer", "value": { "kind": "local", "name": "$trap_val1" } },
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "unexpected full result" }] } },
      { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
      ]
    }
    ]
  },
  {
