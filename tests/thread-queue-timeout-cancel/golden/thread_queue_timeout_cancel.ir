    { "op": "eval", "value": { "kind": "call", "target": "thread.cancel", "args": [{ "kind": "local", "name": "t" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t" }, { "kind": "const", "type": "String", "value": "after-cancel" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "unexpected cancel send" }] } },
