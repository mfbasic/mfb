IMPORT io
IMPORT strings

FUNC upperValue(value AS String) AS String
  RETURN strings::upper(value)
END FUNC

FUNC main AS Integer
  LET german AS String = "straße"
  io::print(upperValue(""))
  io::print(upperValue("hello"))
  io::print(upperValue(german))
  io::print(upperValue("é日😀"))
  io::print(upperValue("i̇"))
  RETURN 0
END FUNC
