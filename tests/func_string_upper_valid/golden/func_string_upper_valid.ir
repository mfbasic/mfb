{
  "format": "mfb-ir",
  "version": 1,
  "project": "func_string_upper_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "upperValue",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "String", "default": null }
    ],
    "returns": "String",
    "body": [
    { "op": "return", "value": { "kind": "call", "target": "strings.upper", "args": [{ "kind": "local", "name": "value" }] } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "german", "type": "String", "value": { "kind": "const", "type": "String", "value": "straße" } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "upperValue", "args": [{ "kind": "const", "type": "String", "value": "" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "upperValue", "args": [{ "kind": "const", "type": "String", "value": "hello" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "upperValue", "args": [{ "kind": "local", "name": "german" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "upperValue", "args": [{ "kind": "const", "type": "String", "value": "é日😀" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "upperValue", "args": [{ "kind": "const", "type": "String", "value": "i̇" }] }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
