    "params": [
    { "name": "p", "type": "Point", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "memberAccess", "target": { "kind": "local", "name": "p" }, "member": "x" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "p" }, "member": "y" } } }
    ]
  },
  {
    "name": "describeFlags",
    "visibility": "private",
