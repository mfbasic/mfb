IMPORT io

FUNC main AS Integer
  LET middle AS List OF Integer = insert([1, 3], 1, 2)
  LET start AS List OF Integer = insert(middle, 0, 0)
  LET finalValues AS List OF Integer = insert(start, 4, 4)
  LET names AS List OF String = insert(["Ada", "Katherine"], 1, "Grace")

  FOR EACH value IN finalValues
    io::print(toString(value))
  NEXT
  FOR EACH name IN names
    io::print(name)
  NEXT

  RETURN len(finalValues) + len(names)
END FUNC
