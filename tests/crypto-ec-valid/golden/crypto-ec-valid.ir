    ]
  },
  {
    "name": "#crypto_beWord",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "data", "type": "List OF Byte", "default": null },
    { "name": "o", "type": "Integer", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "b0", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "data" }, { "kind": "local", "name": "o" }] }] } },
    { "op": "bind", "mutable": false, "name": "b1", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "data" }, { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "o" }, "right": { "kind": "const", "type": "Integer", "value": "1" } }] }] } },
    { "op": "bind", "mutable": false, "name": "b2", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "data" }, { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "o" }, "right": { "kind": "const", "type": "Integer", "value": "2" } }] }] } },
    { "op": "bind", "mutable": false, "name": "b3", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "local", "name": "data" }, { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "o" }, "right": { "kind": "const", "type": "Integer", "value": "3" } }] }] } },
    { "op": "bind", "mutable": false, "name": "w0", "type": "Integer", "value": { "kind": "call", "target": "bits.sl", "args": [{ "kind": "local", "name": "b0" }, { "kind": "const", "type": "Integer", "value": "24" }] } },
    { "op": "bind", "mutable": false, "name": "w1", "type": "Integer", "value": { "kind": "call", "target": "bits.sl", "args": [{ "kind": "local", "name": "b1" }, { "kind": "const", "type": "Integer", "value": "16" }] } },
    { "op": "bind", "mutable": false, "name": "w2", "type": "Integer", "value": { "kind": "call", "target": "bits.sl", "args": [{ "kind": "local", "name": "b2" }, { "kind": "const", "type": "Integer", "value": "8" }] } },
    { "op": "bind", "mutable": false, "name": "hi", "type": "Integer", "value": { "kind": "call", "target": "bits.bor", "args": [{ "kind": "local", "name": "w0" }, { "kind": "local", "name": "w1" }] } },
    { "op": "bind", "mutable": false, "name": "lo", "type": "Integer", "value": { "kind": "call", "target": "bits.bor", "args": [{ "kind": "local", "name": "w2" }, { "kind": "local", "name": "b3" }] } },
    { "op": "return", "value": { "kind": "call", "target": "bits.bor", "args": [{ "kind": "local", "name": "hi" }, { "kind": "local", "name": "lo" }] } }
    ]
  },
  {
    "name": "#crypto_appendBeWord",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "out", "type": "List OF Byte", "default": null },
    { "name": "w", "type": "Integer", "default": null }
    ],
    "returns": "List OF Byte",
    "body": [
    { "op": "bind", "mutable": true, "name": "result", "type": "List OF Byte", "value": { "kind": "local", "name": "out" } },
    { "op": "bind", "mutable": false, "name": "a", "type": "Integer", "value": { "kind": "call", "target": "bits.band", "args": [{ "kind": "call", "target": "bits.sr", "args": [{ "kind": "local", "name": "w" }, { "kind": "const", "type": "Integer", "value": "24" }] }, { "kind": "const", "type": "Integer", "value": "255" }] } },
    { "op": "bind", "mutable": false, "name": "b", "type": "Integer", "value": { "kind": "call", "target": "bits.band", "args": [{ "kind": "call", "target": "bits.sr", "args": [{ "kind": "local", "name": "w" }, { "kind": "const", "type": "Integer", "value": "16" }] }, { "kind": "const", "type": "Integer", "value": "255" }] } },
    { "op": "bind", "mutable": false, "name": "c", "type": "Integer", "value": { "kind": "call", "target": "bits.band", "args": [{ "kind": "call", "target": "bits.sr", "args": [{ "kind": "local", "name": "w" }, { "kind": "const", "type": "Integer", "value": "8" }] }, { "kind": "const", "type": "Integer", "value": "255" }] } },
    { "op": "bind", "mutable": false, "name": "d", "type": "Integer", "value": { "kind": "call", "target": "bits.band", "args": [{ "kind": "local", "name": "w" }, { "kind": "const", "type": "Integer", "value": "255" }] } },
    { "op": "assign", "name": "result", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "local", "name": "result" }, { "kind": "call", "target": "toByte", "args": [{ "kind": "local", "name": "a" }] }] } },
    { "op": "assign", "name": "result", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "local", "name": "result" }, { "kind": "call", "target": "toByte", "args": [{ "kind": "local", "name": "b" }] }] } },
    { "op": "assign", "name": "result", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "local", "name": "result" }, { "kind": "call", "target": "toByte", "args": [{ "kind": "local", "name": "c" }] }] } },
    { "op": "assign", "name": "result", "value": { "kind": "call", "target": "collections.append", "args": [{ "kind": "local", "name": "result" }, { "kind": "call", "target": "toByte", "args": [{ "kind": "local", "name": "d" }] }] } },
    { "op": "return", "value": { "kind": "local", "name": "result" } }
