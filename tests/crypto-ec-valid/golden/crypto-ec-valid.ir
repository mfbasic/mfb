  "functions": [
  {
    "name": "check",
    "visibility": "private",
    "kind": "sub",
    "params": [
    { "name": "label", "type": "String", "default": null },
    { "name": "field", "type": "Integer", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "bind", "mutable": false, "name": "point", "type": "Integer", "value": { "kind": "binary", "op": "+", "left": { "kind": "const", "type": "Integer", "value": "1" }, "right": { "kind": "binary", "op": "*", "left": { "kind": "const", "type": "Integer", "value": "2" }, "right": { "kind": "local", "name": "field" } } } },
    { "op": "bind", "mutable": false, "name": "priv", "type": "Integer", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "point" }, "right": { "kind": "local", "name": "field" } } },
    { "op": "bind", "mutable": true, "name": "kp", "type": "KeyPair", "value": { "kind": "call", "target": "#crypto_generateP256", "args": [] } },
    {
      "op": "if",
      "condition": { "kind": "binary", "op": "=", "left": { "kind": "local", "name": "field" }, "right": { "kind": "const", "type": "Integer", "value": "48" } },
      "then": [
      { "op": "assign", "name": "kp", "value": { "kind": "call", "target": "#crypto_generateP384", "args": [] } }
      ],
      "else": [
      ]
    },
    {
      "op": "if",
      "condition": { "kind": "binary", "op": "=", "left": { "kind": "local", "name": "field" }, "right": { "kind": "const", "type": "Integer", "value": "66" } },
      "then": [
      { "op": "assign", "name": "kp", "value": { "kind": "call", "target": "#crypto_generateP521", "args": [] } }
      ],
      "else": [
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "label" }, "right": { "kind": "const", "type": "String", "value": " priv-len=" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "len", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp" }, "member": "privateKey" }] }] } }, "right": { "kind": "const", "type": "String", "value": "/" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "priv" }] } }, "right": { "kind": "const", "type": "String", "value": " pub-len=" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "len", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp" }, "member": "publicKey" }] }] } }, "right": { "kind": "const", "type": "String", "value": "/" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "point" }] } }] } },
    { "op": "bind", "mutable": true, "name": "prefixOk", "type": "Boolean", "value": { "kind": "const", "type": "Boolean", "value": "true" } },
    { "op": "bind", "mutable": true, "name": "i", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "0" } },
    {
      "op": "while",
      "loop": "while",
      "condition": { "kind": "binary", "op": "<", "left": { "kind": "local", "name": "i" }, "right": { "kind": "local", "name": "point" } },
      "body": [
      {
        "op": "if",
        "condition": { "kind": "binary", "op": "<>", "left": { "kind": "call", "target": "collections.get", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp" }, "member": "privateKey" }, { "kind": "local", "name": "i" }] }, "right": { "kind": "call", "target": "collections.get", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp" }, "member": "publicKey" }, { "kind": "local", "name": "i" }] } },
        "then": [
        { "op": "assign", "name": "prefixOk", "value": { "kind": "const", "type": "Boolean", "value": "false" } }
        ],
        "else": [
        ]
      },
      { "op": "assign", "name": "i", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } }
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "label" }, "right": { "kind": "const", "type": "String", "value": " pub-is-point-prefix=" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "prefixOk" }] } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "local", "name": "label" }, "right": { "kind": "const", "type": "String", "value": " first-byte-uncompressed=" } }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "collections.get", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp" }, "member": "publicKey" }, { "kind": "const", "type": "Integer", "value": "0" }] }] } }] } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "sub",
    "params": [
    ],
    "returns": "Nothing",
    "body": [
    { "op": "bind", "mutable": false, "name": "msg", "type": "List OF Byte", "value": { "kind": "call", "target": "#encoding_utf8EncodeBytes", "args": [{ "kind": "const", "type": "String", "value": "The quick brown fox" }] } },
    { "op": "bind", "mutable": false, "name": "tampered", "type": "List OF Byte", "value": { "kind": "call", "target": "#encoding_utf8EncodeBytes", "args": [{ "kind": "const", "type": "String", "value": "The quick brown Fox" }] } },
    { "op": "bind", "mutable": false, "name": "kp256", "type": "KeyPair", "value": { "kind": "call", "target": "#crypto_generateP256", "args": [] } },
    { "op": "bind", "mutable": false, "name": "s256", "type": "List OF Byte", "value": { "kind": "call", "target": "crypto.p256Sign", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp256" }, "member": "privateKey" }, { "kind": "local", "name": "msg" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p256-good=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p256Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp256" }, "member": "publicKey" }, { "kind": "local", "name": "msg" }, { "kind": "local", "name": "s256" }] }] } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p256-tamper=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p256Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp256" }, "member": "publicKey" }, { "kind": "local", "name": "tampered" }, { "kind": "local", "name": "s256" }] }] } }] } },
    { "op": "bind", "mutable": false, "name": "kp384", "type": "KeyPair", "value": { "kind": "call", "target": "#crypto_generateP384", "args": [] } },
    { "op": "bind", "mutable": false, "name": "s384", "type": "List OF Byte", "value": { "kind": "call", "target": "crypto.p384Sign", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp384" }, "member": "privateKey" }, { "kind": "local", "name": "msg" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p384-good=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p384Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp384" }, "member": "publicKey" }, { "kind": "local", "name": "msg" }, { "kind": "local", "name": "s384" }] }] } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p384-tamper=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p384Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp384" }, "member": "publicKey" }, { "kind": "local", "name": "tampered" }, { "kind": "local", "name": "s384" }] }] } }] } },
    { "op": "bind", "mutable": false, "name": "kp521", "type": "KeyPair", "value": { "kind": "call", "target": "#crypto_generateP521", "args": [] } },
    { "op": "bind", "mutable": false, "name": "s521", "type": "List OF Byte", "value": { "kind": "call", "target": "crypto.p521Sign", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp521" }, "member": "privateKey" }, { "kind": "local", "name": "msg" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p521-good=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p521Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp521" }, "member": "publicKey" }, { "kind": "local", "name": "msg" }, { "kind": "local", "name": "s521" }] }] } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p521-tamper=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p521Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "kp521" }, "member": "publicKey" }, { "kind": "local", "name": "tampered" }, { "kind": "local", "name": "s521" }] }] } }] } },
    { "op": "bind", "mutable": false, "name": "other", "type": "KeyPair", "value": { "kind": "call", "target": "#crypto_generateP256", "args": [] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "p256-crosskey=" }, "right": { "kind": "call", "target": "toString", "args": [{ "kind": "call", "target": "crypto.p256Verify", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "other" }, "member": "publicKey" }, { "kind": "local", "name": "msg" }, { "kind": "local", "name": "s256" }] }] } }] } },
    { "op": "eval", "value": { "kind": "call", "target": "check", "args": [{ "kind": "const", "type": "String", "value": "p256" }, { "kind": "const", "type": "Integer", "value": "32" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "check", "args": [{ "kind": "const", "type": "String", "value": "p384" }, { "kind": "const", "type": "Integer", "value": "48" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "check", "args": [{ "kind": "const", "type": "String", "value": "p521" }, { "kind": "const", "type": "Integer", "value": "66" }] } }
