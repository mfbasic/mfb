IMPORT io

FUNC fromString(value AS String) AS Float
  RETURN toFloat(value)
END FUNC

FUNC fromInteger(value AS Integer) AS Float
  RETURN toFloat(value)
END FUNC

FUNC fromFixed(value AS Fixed) AS Float
  RETURN toFloat(value)
END FUNC

FUNC main AS Integer
  LET p AS Byte = 2
  LET fixedValue AS Fixed = 1.25
  io::print(toString(fromString("2.50"), p))
  io::print(toString(fromString("-3.75"), p))
  io::print(toString(fromString("1.25e2"), p))
  io::print(toString(fromInteger(42), p))
  io::print(toString(fromFixed(fixedValue), p))
  RETURN 0
END FUNC
