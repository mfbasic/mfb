        ]
      }
      ]
    },
    { "op": "bind", "mutable": false, "name": "$match4", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "compute", "args": [{ "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg3-value" }, { "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "1" } }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-multiplier" }, { "kind": "const", "type": "Integer", "value": "5" }] }] } },
