    { "op": "bind", "mutable": false, "name": "$match0", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "compute", "args": [{ "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg1-value" }, { "kind": "const", "type": "Integer", "value": "3" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-multiplier" }, { "kind": "const", "type": "Integer", "value": "5" }] }] } },
    { "op": "bind", "mutable": false, "name": "$match_ok1", "type": "Boolean", "value": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$match0" } } },
    {
      "op": "match",
      "value": { "kind": "local", "name": "$match_ok1" },
