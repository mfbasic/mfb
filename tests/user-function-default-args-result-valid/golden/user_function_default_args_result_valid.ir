        { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "memberAccess", "target": { "kind": "local", "name": "err" }, "member": "code" } } }
        ]
      }
      ]
    },
    { "op": "bind", "mutable": false, "name": "$match2", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "compute", "args": [{ "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg2-value" }, { "kind": "const", "type": "Integer", "value": "1" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg2-multiplier" }, { "kind": "const", "type": "Integer", "value": "2" }] }] } },
    { "op": "bind", "mutable": false, "name": "$match_ok3", "type": "Boolean", "value": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$match2" } } },
    {
      "op": "match",
