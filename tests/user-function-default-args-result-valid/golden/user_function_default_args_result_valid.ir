  "types": [
  ],
  "functions": [
  {
    "name": "mark",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "label", "type": "String", "default": null },
    { "name": "value", "type": "Integer", "default": null }
    ],
    "returns": "Integer",
    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "local", "name": "label" }] } },
    { "op": "return", "value": { "kind": "local", "name": "value" } }
    ]
  },
  {
    "name": "compute",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "value", "type": "Integer", "default": null },
    { "name": "extra", "type": "Integer", "default": { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] } },
    { "name": "multiplier", "type": "Integer", "default": { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-multiplier" }, { "kind": "const", "type": "Integer", "value": "5" }] } }
    ],
    "returns": "Integer",
    "body": [
    {
      "op": "if",
      "condition": { "kind": "binary", "op": "<", "left": { "kind": "local", "name": "value" }, "right": { "kind": "const", "type": "Integer", "value": "0" } },
      "then": [
      { "op": "fail", "error": { "kind": "constructor", "type": "Error", "args": [{ "kind": "binary", "op": "+", "left": { "kind": "const", "type": "Integer", "value": "100" }, "right": { "kind": "local", "name": "extra" } }, { "kind": "const", "type": "String", "value": "negative" }, { "kind": "constructor", "type": "ErrorLoc", "args": [{ "kind": "const", "type": "String", "value": "src/main.mfb" }, { "kind": "const", "type": "Integer", "value": "9" }, { "kind": "const", "type": "Integer", "value": "26" }] }] } }
      ],
      "else": [
      ]
    },
    { "op": "return", "value": { "kind": "binary", "op": "*", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "value" }, "right": { "kind": "local", "name": "extra" } }, "right": { "kind": "local", "name": "multiplier" } } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": true, "name": "total", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "0" } },
    { "op": "bind", "mutable": false, "name": "$trap_res0", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "compute", "args": [{ "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg1-value" }, { "kind": "const", "type": "Integer", "value": "3" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-multiplier" }, { "kind": "const", "type": "Integer", "value": "5" }] }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val1", "type": "Integer", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res0" } },
      "then": [
      { "op": "assign", "name": "$trap_val1", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res0" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "err", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res0" } } },
      { "op": "assign", "name": "$trap_val1", "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "err" }, "member": "code" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "first", "type": "Integer", "value": { "kind": "local", "name": "$trap_val1" } },
    { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "local", "name": "first" } } },
    { "op": "bind", "mutable": false, "name": "$trap_res2", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "compute", "args": [{ "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg2-value" }, { "kind": "const", "type": "Integer", "value": "1" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg2-multiplier" }, { "kind": "const", "type": "Integer", "value": "2" }] }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val3", "type": "Integer", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res2" } },
      "then": [
      { "op": "assign", "name": "$trap_val3", "value": { "kind": "resultValue", "value": { "kind": "local", "name": "$trap_res2" } } }
      ],
      "else": [
      { "op": "bind", "mutable": false, "name": "err", "type": "Error", "value": { "kind": "resultError", "value": { "kind": "local", "name": "$trap_res2" } } },
      { "op": "assign", "name": "$trap_val3", "value": { "kind": "memberAccess", "target": { "kind": "local", "name": "err" }, "member": "code" } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "second", "type": "Integer", "value": { "kind": "local", "name": "$trap_val3" } },
    { "op": "assign", "name": "total", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "total" }, "right": { "kind": "local", "name": "second" } } },
    { "op": "bind", "mutable": false, "name": "$trap_res4", "type": "Result OF Integer", "value": { "kind": "callResult", "target": "compute", "args": [{ "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "arg3-value" }, { "kind": "unary", "op": "-", "operand": { "kind": "const", "type": "Integer", "value": "1" } }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-extra" }, { "kind": "const", "type": "Integer", "value": "2" }] }, { "kind": "call", "target": "mark", "args": [{ "kind": "const", "type": "String", "value": "default-multiplier" }, { "kind": "const", "type": "Integer", "value": "5" }] }] } },
    { "op": "bind", "mutable": true, "name": "$trap_val5", "type": "Integer", "value": null },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res4" } },
      "then": [
