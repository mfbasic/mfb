IMPORT io

FUNC mark(label AS String, value AS Integer) AS Integer
  io::print(label)
  RETURN value
END FUNC

FUNC compute(value AS Integer, extra AS Integer = mark("default-extra", 2), multiplier AS Integer = mark("default-multiplier", 5)) AS Integer
  IF value < 0 THEN FAIL error(100 + extra, "negative")
  RETURN (value + extra) * multiplier
END FUNC

FUNC main() AS Integer
  MUT total AS Integer = 0

  LET first = compute(mark("arg1-value", 3)) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + first

  LET second = compute(mark("arg2-value", 1), multiplier := mark("arg2-multiplier", 2)) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + second

  LET third = compute(mark("arg3-value", -1)) TRAP(err)
    RECOVER err.code
  END TRAP
  total = total + third

  io::print(toString(total))
  RETURN 0
END FUNC
