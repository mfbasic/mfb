FUNC main AS Integer
  LET text AS String = "hello"
  LET numericText AS String = "42"
  LET bytes AS List OF Byte = []
  LET strings AS List OF String = ["a", "b"]
  LET scores AS Map OF String TO Integer = Map OF String TO Integer { "a" := 1 }
  LET integerValue AS Integer = 42
  LET floatValue AS Float = 1.5
  LET fixedValue AS Fixed = 2.25
  LET booleanValue AS Boolean = TRUE
  LET byteValue AS Byte = 7

  LET stringLen AS Integer = len(text)
  LET listLen AS Integer = len(strings)
  LET mapLen AS Integer = len(scores)

  LET foundDefaultStart AS Integer = find(text, "l")
  LET foundExplicitStart AS Integer = find(text, "l", 3)
  LET middle AS String = mid(text, 1, 3)
  LET replaced AS String = replace(text, "l", "x")
  LET staticType AS String = typeName(scores)

  LET integerString AS String = toString(integerValue)
  LET floatString AS String = toString(floatValue)
  LET fixedString AS String = toString(fixedValue)
  LET booleanString AS String = toString(booleanValue)
  LET sameString AS String = toString(text)
  LET byteString AS String = toString(byteValue)
  LET bytesString AS String = toString(bytes)

  LET parsedInt AS Integer = toInt(numericText)
  LET truncatedIntFromFloat AS Integer = toInt(floatValue)
  LET truncatedIntFromFixed AS Integer = toInt(fixedValue)

  LET parsedFloat AS Float = toFloat(numericText)
  LET floatFromInteger AS Float = toFloat(integerValue)
  LET floatFromFixed AS Float = toFloat(fixedValue)

  LET parsedFixed AS Fixed = toFixed(numericText)
  LET fixedFromInteger AS Fixed = toFixed(integerValue)
  LET fixedFromFloat AS Fixed = toFixed(floatValue)

  LET convertedByte AS Byte = toByte(integerValue)
  LET numeric AS Boolean = isNumeric(numericText)

  RETURN stringLen + listLen + mapLen + foundDefaultStart + foundExplicitStart
END FUNC
