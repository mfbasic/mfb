{
  "format": "mfb-ir",
  "version": 1,
  "project": "builtin_general",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "text", "type": "String", "value": { "kind": "const", "type": "String", "value": "hello" } },
    { "op": "bind", "mutable": false, "name": "numericText", "type": "String", "value": { "kind": "const", "type": "String", "value": "42" } },
    { "op": "bind", "mutable": false, "name": "bytes", "type": "List OF Byte", "value": { "kind": "list", "type": "List OF Unknown", "values": [] } },
    { "op": "bind", "mutable": false, "name": "strings", "type": "List OF String", "value": { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "a" }, { "kind": "const", "type": "String", "value": "b" }] } },
    { "op": "bind", "mutable": false, "name": "scores", "type": "Map OF String TO Integer", "value": { "kind": "map", "type": "Map OF String TO Integer", "entries": [{ "key": { "kind": "const", "type": "String", "value": "a" }, "value": { "kind": "const", "type": "Integer", "value": "1" } }] } },
    { "op": "bind", "mutable": false, "name": "integerValue", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "42" } },
    { "op": "bind", "mutable": false, "name": "floatValue", "type": "Float", "value": { "kind": "const", "type": "Float", "value": "1.5" } },
    { "op": "bind", "mutable": false, "name": "fixedValue", "type": "Fixed", "value": { "kind": "const", "type": "Float", "value": "2.25" } },
    { "op": "bind", "mutable": false, "name": "booleanValue", "type": "Boolean", "value": { "kind": "const", "type": "Boolean", "value": "true" } },
    { "op": "bind", "mutable": false, "name": "byteValue", "type": "Byte", "value": { "kind": "const", "type": "Integer", "value": "7" } },
    { "op": "bind", "mutable": false, "name": "stringLen", "type": "Integer", "value": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "text" }] } },
    { "op": "bind", "mutable": false, "name": "listLen", "type": "Integer", "value": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "strings" }] } },
    { "op": "bind", "mutable": false, "name": "mapLen", "type": "Integer", "value": { "kind": "call", "target": "len", "args": [{ "kind": "local", "name": "scores" }] } },
    { "op": "bind", "mutable": false, "name": "foundDefaultStart", "type": "Integer", "value": { "kind": "call", "target": "find", "args": [{ "kind": "local", "name": "text" }, { "kind": "const", "type": "String", "value": "l" }] } },
    { "op": "bind", "mutable": false, "name": "foundExplicitStart", "type": "Integer", "value": { "kind": "call", "target": "find", "args": [{ "kind": "local", "name": "text" }, { "kind": "const", "type": "String", "value": "l" }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "bind", "mutable": false, "name": "middle", "type": "String", "value": { "kind": "call", "target": "mid", "args": [{ "kind": "local", "name": "text" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "3" }] } },
    { "op": "bind", "mutable": false, "name": "replaced", "type": "String", "value": { "kind": "call", "target": "replace", "args": [{ "kind": "local", "name": "text" }, { "kind": "const", "type": "String", "value": "l" }, { "kind": "const", "type": "String", "value": "x" }] } },
    { "op": "bind", "mutable": false, "name": "staticType", "type": "String", "value": { "kind": "call", "target": "typeName", "args": [{ "kind": "local", "name": "scores" }] } },
    { "op": "bind", "mutable": false, "name": "integerString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "integerValue" }] } },
    { "op": "bind", "mutable": false, "name": "floatString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "floatValue" }] } },
    { "op": "bind", "mutable": false, "name": "fixedString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "fixedValue" }] } },
    { "op": "bind", "mutable": false, "name": "booleanString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "booleanValue" }] } },
    { "op": "bind", "mutable": false, "name": "sameString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "text" }] } },
    { "op": "bind", "mutable": false, "name": "byteString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "byteValue" }] } },
    { "op": "bind", "mutable": false, "name": "bytesString", "type": "String", "value": { "kind": "call", "target": "toString", "args": [{ "kind": "local", "name": "bytes" }] } },
    { "op": "bind", "mutable": false, "name": "parsedInt", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "local", "name": "numericText" }] } },
    { "op": "bind", "mutable": false, "name": "truncatedIntFromFloat", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "local", "name": "floatValue" }] } },
    { "op": "bind", "mutable": false, "name": "truncatedIntFromFixed", "type": "Integer", "value": { "kind": "call", "target": "toInt", "args": [{ "kind": "local", "name": "fixedValue" }] } },
    { "op": "bind", "mutable": false, "name": "parsedFloat", "type": "Float", "value": { "kind": "call", "target": "toFloat", "args": [{ "kind": "local", "name": "numericText" }] } },
    { "op": "bind", "mutable": false, "name": "floatFromInteger", "type": "Float", "value": { "kind": "call", "target": "toFloat", "args": [{ "kind": "local", "name": "integerValue" }] } },
    { "op": "bind", "mutable": false, "name": "floatFromFixed", "type": "Float", "value": { "kind": "call", "target": "toFloat", "args": [{ "kind": "local", "name": "fixedValue" }] } },
    { "op": "bind", "mutable": false, "name": "parsedFixed", "type": "Fixed", "value": { "kind": "call", "target": "toFixed", "args": [{ "kind": "local", "name": "numericText" }] } },
    { "op": "bind", "mutable": false, "name": "fixedFromInteger", "type": "Fixed", "value": { "kind": "call", "target": "toFixed", "args": [{ "kind": "local", "name": "integerValue" }] } },
    { "op": "bind", "mutable": false, "name": "fixedFromFloat", "type": "Fixed", "value": { "kind": "call", "target": "toFixed", "args": [{ "kind": "local", "name": "floatValue" }] } },
    { "op": "bind", "mutable": false, "name": "convertedByte", "type": "Byte", "value": { "kind": "call", "target": "toByte", "args": [{ "kind": "local", "name": "integerValue" }] } },
    { "op": "bind", "mutable": false, "name": "numeric", "type": "Boolean", "value": { "kind": "call", "target": "isNumeric", "args": [{ "kind": "local", "name": "numericText" }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "stringLen" }, "right": { "kind": "local", "name": "listLen" } }, "right": { "kind": "local", "name": "mapLen" } }, "right": { "kind": "local", "name": "foundDefaultStart" } }, "right": { "kind": "local", "name": "foundExplicitStart" } } }
    ]
  }
  ]
