IMPORT io
IMPORT json

FUNC main AS Integer
  LET value AS Json = json::parse("{\"user\":{\"name\":\"Ada\"},\"flag\":true}")
  LET fallback AS Json = Str["fallback"]
  LET emptyPath AS List OF String = []
  io::print(json::stringify(json::getOr(value, emptyPath, fallback)))
  io::print(json::stringify(json::getOr(value, ["user", "name"], fallback)))
  io::print(json::stringify(json::getOr(value, ["user", "missing"], fallback)))
  io::print(json::stringify(json::getOr(value, ["flag", "x"], fallback)))
  RETURN 0
END FUNC
