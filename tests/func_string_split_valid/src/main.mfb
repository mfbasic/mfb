IMPORT io
IMPORT strings

FUNC printParts(parts AS List OF String) AS Nothing
  io::print(toString(len(parts)))
  FOR EACH part IN parts
    io::print("[" & part & "]")
  NEXT
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  LET csv AS List OF String = strings::split("a,b,c", ",")
  LET emoji AS List OF String = strings::split("a😀b😀c", "😀")
  LET edges AS List OF String = strings::split(",a,,", ",")
  LET noMatch AS List OF String = strings::split("abc", "|")

  printParts(csv)
  printParts(emoji)
  printParts(edges)
  printParts(noMatch)
  RETURN 0
END FUNC
