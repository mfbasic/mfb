IMPORT thread
IMPORT thread_workers

FUNC main AS Integer
  LET t1 AS Thread OF String TO Integer = thread::start(thread_workers::echoText, "a", 1, 1)
  LET t2 AS Thread OF String TO Integer = thread::start(thread_workers::echoText, "b", 1, 1)
  LET t3 AS Thread OF String TO Integer = thread::start(thread_workers::echoText, "c", 1, 1)
  thread::send(t1, "d")
  thread::send(t2, "e", 0)
  thread::send(t3, "f", 1)
  RETURN 0
END FUNC
