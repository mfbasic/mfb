    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "t1", "type": "Thread OF String TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_workers.echoText", "type": "ISOLATED FUNC(ThreadWorker OF String TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "a" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "bind", "mutable": false, "name": "t2", "type": "Thread OF String TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_workers.echoText", "type": "ISOLATED FUNC(ThreadWorker OF String TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "b" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "bind", "mutable": false, "name": "t3", "type": "Thread OF String TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_workers.echoText", "type": "ISOLATED FUNC(ThreadWorker OF String TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "c" }, { "kind": "const", "type": "Integer", "value": "1" }, { "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "bind", "mutable": false, "name": "fileThread", "type": "Thread OF RES File TO Integer", "value": { "kind": "call", "target": "thread.start", "args": [{ "kind": "functionRef", "name": "thread_file_workers.receiveFile", "type": "ISOLATED FUNC(ThreadWorker OF RES File TO Integer, String) AS Integer" }, { "kind": "const", "type": "String", "value": "file" }, { "kind": "const", "type": "Integer", "value": "2" }, { "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t1" }, { "kind": "const", "type": "String", "value": "d" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t2" }, { "kind": "const", "type": "String", "value": "e" }, { "kind": "const", "type": "Integer", "value": "0" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.send", "args": [{ "kind": "local", "name": "t3" }, { "kind": "const", "type": "String", "value": "f" }, { "kind": "const", "type": "Integer", "value": "1" }] } },
    { "op": "bind", "mutable": false, "name": "sentFile", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "const", "type": "String", "value": "tests/func_thread_send_valid/src/main.mfb" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "thread.transferResource", "args": [{ "kind": "local", "name": "fileThread" }, { "kind": "local", "name": "sentFile" }] } },
    { "op": "bind", "mutable": false, "name": "recoverFile", "type": "File", "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "const", "type": "String", "value": "tests/func_thread_send_valid/src/main.mfb" }] } },
    { "op": "bind", "mutable": false, "name": "$trap_res0", "type": "Result OF Nothing", "value": { "kind": "callResult", "target": "thread.transferResource", "args": [{ "kind": "local", "name": "fileThread" }, { "kind": "local", "name": "recoverFile" }] } },
    {
      "op": "if",
      "condition": { "kind": "resultIsOk", "value": { "kind": "local", "name": "$trap_res0" } },
