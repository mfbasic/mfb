IMPORT io
IMPORT thread
IMPORT fs_thread_workers

FUNC main AS Integer
  LET t AS Thread OF String TO Integer = thread::start(fs_thread_workers::openNoFollowWorker, "tests/thread-fs-nofollow-symlink-rt/data/link.txt")
  LET r AS Integer = thread::waitFor(t)
  io::print(toString(r))
  RETURN 0
END FUNC
