EXPORT TYPE Point
  x AS Float
  y AS Float
END TYPE

EXPORT TYPE Circle
  radius AS Float
END TYPE

EXPORT TYPE Rectangle
  width AS Float
  height AS Float
END TYPE

EXPORT TYPE PointShape
  point AS Point
END TYPE

EXPORT ENUM ShapeKind
  Circle, Rectangle, PointShape
END ENUM

EXPORT UNION Shape
  Circle
  Rectangle
  PointShape
END UNION

EXPORT FUNC shapeKind(shape AS Shape) AS ShapeKind
  MATCH shape
    CASE Circle(circle)
      RETURN ShapeKind.Circle
    CASE Rectangle(rectangle)
      RETURN ShapeKind.Rectangle
    CASE PointShape(pointShape)
      RETURN ShapeKind.PointShape
  END MATCH
END FUNC

EXPORT SUB translate(point AS Point, dx AS Float, dy AS Float)
  LET nextX = point.x + dx
  LET nextY = point.y + dy
END SUB
