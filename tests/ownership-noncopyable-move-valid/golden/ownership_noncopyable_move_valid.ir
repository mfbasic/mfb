{
  "format": "mfb-ir",
  "version": 1,
  "project": "ownership_noncopyable_move_valid",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  {
    "kind": "type",
    "visibility": "private",
    "name": "FileBox",
    "fields": [
    { "visibility": null, "name": "handle", "type": "File" }
    ]
  }
  ],
  "functions": [
  {
    "name": "closeBox",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "box", "type": "FileBox", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    { "op": "eval", "value": { "kind": "call", "target": "fs.close", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "box" }, "member": "handle" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "box", "type": "FileBox", "value": { "kind": "constructor", "type": "FileBox", "args": [{ "kind": "call", "target": "fs.openFile", "args": [{ "kind": "const", "type": "String", "value": "tests/ownership-noncopyable-move-valid/src/main.mfb" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "closeBox", "args": [{ "kind": "local", "name": "box" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "moved" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
