IMPORT fs
IMPORT io

TYPE FileBox
  handle AS File
END TYPE

FUNC closeBox(box AS FileBox) AS Nothing
  fs::close(box.handle)
  RETURN NOTHING
END FUNC

FUNC main AS Integer
  LET box AS FileBox = FileBox[fs::openFile("tests/ownership-noncopyable-move-valid/src/main.mfb")]
  closeBox(box)
  io::print("moved")
  RETURN 0
END FUNC
