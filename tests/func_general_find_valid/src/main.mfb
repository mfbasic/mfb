IMPORT strings
IMPORT io

FUNC main AS Integer

  io::print("find-string-first: strings::find(\"hello\", \"l\") = " & toString(strings::find("hello", "l")))
  io::print("find-string-start: strings::find(\"hello\", \"l\", 3) = " & toString(strings::find("hello", "l", 3)))
  io::print("find-string-unicode: strings::find(\"aé日é\", \"日\") = " & toString(strings::find("aé日é", "日")))
  io::print("find-string-empty-needle: strings::find(\"abcdef\", \"\", 2) = " & toString(strings::find("abcdef", "", 2)))
  io::print("find-string-emoji: strings::find(\"a😀é\", \"😀\") = " & toString(strings::find("a😀é", "😀")))
  io::print("find-string-combining-mark: strings::find(\"éx\", \"́\") = " & toString(strings::find("éx", "́")))

  RETURN 0
END FUNC
