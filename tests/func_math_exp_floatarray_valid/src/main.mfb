IMPORT io
IMPORT math

' Vectorized math::exp over a Float list — hand-written NEON f64 polynomial
' kernel (range-reduce x = n*ln2 + r, Horner via fmla, scale by 2^n), within
' <=1 ULP of macOS libm. Length 5 is odd, exercising the broadcast tail. Very
' negative lanes flush to 0 (no error).
FUNC main AS Integer
  LET p AS Byte = 15
  LET xs AS List OF Float = [0.0, 1.0, 0.0 - 1.0, 0.5, 2.0]
  FOR EACH y IN math::exp(xs)
    io::print(toString(y, p))
  NEXT
  LET zs AS List OF Float = [0.0 - 800.0, 3.0]
  io::print("underflow-ok len=" & toString(len(math::exp(zs))))
  RETURN 0
END FUNC
