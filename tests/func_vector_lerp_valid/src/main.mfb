IMPORT vector
IMPORT io


FUNC main AS Integer
  io::print("lerp Float2 t=0.5 = " & toString(vector::lerp(vector::Float2[3.0, 4.0], vector::Float2[1.0, 2.0], 0.5)))
  io::print("lerp Float2 t=2.0 = " & toString(vector::lerp(vector::Float2[3.0, 4.0], vector::Float2[1.0, 2.0], 2.0)))
  io::print("lerp Float3 t=0.5 = " & toString(vector::lerp(vector::Float3[1.0, 2.0, 2.0], vector::Float3[2.0, 1.0, 2.0], 0.5)))
  io::print("lerp Float3 t=2.0 = " & toString(vector::lerp(vector::Float3[1.0, 2.0, 2.0], vector::Float3[2.0, 1.0, 2.0], 2.0)))
  io::print("lerp Float4 t=0.5 = " & toString(vector::lerp(vector::Float4[1.0, 2.0, 2.0, 4.0], vector::Float4[2.0, 1.0, 0.0, 1.0], 0.5)))
  io::print("lerp Float4 t=2.0 = " & toString(vector::lerp(vector::Float4[1.0, 2.0, 2.0, 4.0], vector::Float4[2.0, 1.0, 0.0, 1.0], 2.0)))
  io::print("lerp Fixed2 t=0.5 = " & toString(vector::lerp(vector::Fixed2[toFixed(3.0), toFixed(4.0)], vector::Fixed2[toFixed(1.0), toFixed(2.0)], 0.5)))
  io::print("lerp Fixed2 t=2.0 = " & toString(vector::lerp(vector::Fixed2[toFixed(3.0), toFixed(4.0)], vector::Fixed2[toFixed(1.0), toFixed(2.0)], 2.0)))
  io::print("lerp Fixed3 t=0.5 = " & toString(vector::lerp(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)], vector::Fixed3[toFixed(2.0), toFixed(1.0), toFixed(2.0)], 0.5)))
  io::print("lerp Fixed3 t=2.0 = " & toString(vector::lerp(vector::Fixed3[toFixed(1.0), toFixed(2.0), toFixed(2.0)], vector::Fixed3[toFixed(2.0), toFixed(1.0), toFixed(2.0)], 2.0)))
  io::print("lerp Fixed4 t=0.5 = " & toString(vector::lerp(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)], vector::Fixed4[toFixed(2.0), toFixed(1.0), toFixed(0.0), toFixed(1.0)], 0.5)))
  io::print("lerp Fixed4 t=2.0 = " & toString(vector::lerp(vector::Fixed4[toFixed(1.0), toFixed(2.0), toFixed(2.0), toFixed(4.0)], vector::Fixed4[toFixed(2.0), toFixed(1.0), toFixed(0.0), toFixed(1.0)], 2.0)))
  io::print("lerp Integer2 t=0.5 = " & toString(vector::lerp(vector::Integer2[3, 4], vector::Integer2[1, 2], 0.5)))
  io::print("lerp Integer2 t=2.0 = " & toString(vector::lerp(vector::Integer2[3, 4], vector::Integer2[1, 2], 2.0)))
  io::print("lerp Integer3 t=0.5 = " & toString(vector::lerp(vector::Integer3[1, 2, 2], vector::Integer3[2, 1, 2], 0.5)))
  io::print("lerp Integer3 t=2.0 = " & toString(vector::lerp(vector::Integer3[1, 2, 2], vector::Integer3[2, 1, 2], 2.0)))
  io::print("lerp Integer4 t=0.5 = " & toString(vector::lerp(vector::Integer4[1, 2, 2, 4], vector::Integer4[2, 1, 0, 1], 0.5)))
  io::print("lerp Integer4 t=2.0 = " & toString(vector::lerp(vector::Integer4[1, 2, 2, 4], vector::Integer4[2, 1, 0, 1], 2.0)))
  RETURN 0
END FUNC
