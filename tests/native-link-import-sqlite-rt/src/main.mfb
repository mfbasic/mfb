IMPORT collections
' Runtime test that IMPORTS the reusable bindings/sqlite package (plan-linker.md
' §12 + package serialization). It exercises the package's exported wrappers,
' including the overloaded createTable/query (imported-overload resolution) and
' query's nested List OF List OF String result.
IMPORT sqlite
IMPORT io

FUNC main AS Integer
  RES db AS sqlite::Db = sqlite::create(":memory:")
  sqlite::createTable(db, "users", "id INTEGER, name TEXT")
  sqlite::query(db, "INSERT INTO users VALUES (1, ?)", ["alice"])
  sqlite::query(db, "INSERT INTO users VALUES (2, ?)", ["bob"])
  LET rows = sqlite::query(db, "SELECT id, name FROM users ORDER BY id", [])
  FOR EACH row IN rows
    io::print(collections::get(row, 0) & "=" & collections::get(row, 1))
  NEXT
  LET tables AS List OF String = sqlite::listTables(db)
  FOR EACH name IN tables
    io::print("table: " & name)
  NEXT
  sqlite::close(db)
  io::print("done")
  RETURN 0
END FUNC
