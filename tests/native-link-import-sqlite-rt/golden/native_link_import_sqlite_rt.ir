{
  "format": "mfb-ir",
  "version": 1,
  "project": "native_link_import_sqlite_rt",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": false, "name": "db", "type": "sqlite.Db", "value": { "kind": "call", "target": "sqlite.create", "args": [{ "kind": "const", "type": "String", "value": ":memory:" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "sqlite.createTable$Db$String$String", "args": [{ "kind": "local", "name": "db" }, { "kind": "const", "type": "String", "value": "users" }, { "kind": "const", "type": "String", "value": "id INTEGER, name TEXT" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "sqlite.query$Db$String$List$OF$String", "args": [{ "kind": "local", "name": "db" }, { "kind": "const", "type": "String", "value": "INSERT INTO users VALUES (1, ?)" }, { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "alice" }] }] } },
    { "op": "eval", "value": { "kind": "call", "target": "sqlite.query$Db$String$List$OF$String", "args": [{ "kind": "local", "name": "db" }, { "kind": "const", "type": "String", "value": "INSERT INTO users VALUES (2, ?)" }, { "kind": "list", "type": "List OF String", "values": [{ "kind": "const", "type": "String", "value": "bob" }] }] } },
    { "op": "bind", "mutable": false, "name": "rows", "type": "List OF List OF String", "value": { "kind": "call", "target": "sqlite.query$Db$String$List$OF$String", "args": [{ "kind": "local", "name": "db" }, { "kind": "const", "type": "String", "value": "SELECT id, name FROM users ORDER BY id" }, { "kind": "list", "type": "List OF String", "values": [] }] } },
    {
      "op": "forEach",
      "name": "row",
      "type": "List OF String",
      "iterable": { "kind": "local", "name": "rows" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "binary", "op": "&", "left": { "kind": "call", "target": "get", "args": [{ "kind": "local", "name": "row" }, { "kind": "const", "type": "Integer", "value": "0" }] }, "right": { "kind": "const", "type": "String", "value": "=" } }, "right": { "kind": "call", "target": "get", "args": [{ "kind": "local", "name": "row" }, { "kind": "const", "type": "Integer", "value": "1" }] } }] } }
      ]
    },
    { "op": "bind", "mutable": false, "name": "tables", "type": "List OF String", "value": { "kind": "call", "target": "sqlite.listTables", "args": [{ "kind": "local", "name": "db" }] } },
    {
      "op": "forEach",
      "name": "name",
      "type": "String",
      "iterable": { "kind": "local", "name": "tables" },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "binary", "op": "&", "left": { "kind": "const", "type": "String", "value": "table: " }, "right": { "kind": "local", "name": "name" } }] } }
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "sqlite.close", "args": [{ "kind": "local", "name": "db" }] } },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "done" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
