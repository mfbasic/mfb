IMPORT io

FUNC main AS Integer
  FOR i = 1 TO 5 STEP 2 : io::print("int=" & toString(i)) : NEXT
  FOR down = 5 TO 1 STEP -2 : io::print("down=" & toString(down)) : NEXT
  FOR b = toByte(1) TO toByte(5) STEP toByte(2) : io::print("byte=" & toString(b)) : NEXT
  FOR f = toFixed("1.0") TO toFixed("2.0") STEP toFixed("0.5") : io::print("fixed=" & toString(f)) : NEXT
  FOR x = 1.0 TO 2.0 STEP 0.5 : io::print("float=" & toString(x)) : NEXT

  LET lines AS List OF String = ["alpha", "beta"]
  FOR EACH item IN lines : io::print("line=" & item) : NEXT

  LET scores AS Map OF String TO Integer = Map OF String TO Integer { "ada" := 10 }
  FOR EACH entry IN scores : io::print(entry.key & "=" & toString(entry.value)) : NEXT

  MUT counter AS Integer = 0
  WHILE counter < 3 : counter = counter + 1 : io::print("while=" & toString(counter)) : WEND

  MUT once AS Integer = 0
  DO : once = once + 1 : io::print("doUntil=" & toString(once)) : LOOP UNTIL once >= 2

  MUT ready AS Boolean = TRUE
  MUT spins AS Integer = 0
  DO WHILE ready : spins = spins + 1 : io::print("doWhile=" & toString(spins)) : ready = FALSE : LOOP

  MUT skipped AS Integer = 0
  DO WHILE skipped < 0 : skipped = skipped + 1 : LOOP
  io::print("skipped=" & toString(skipped))
  RETURN 0
END FUNC
