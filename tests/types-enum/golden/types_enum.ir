    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "call", "target": "typeName", "args": [{ "kind": "local", "name": "mode" }] }] } },
    { "op": "return", "value": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "binary", "op": "+", "left": { "kind": "call", "target": "colorScore", "args": [{ "kind": "local", "name": "inferred" }] }, "right": { "kind": "call", "target": "colorScore", "args": [{ "kind": "local", "name": "annotated" }] } }, "right": { "kind": "call", "target": "colorScore", "args": [{ "kind": "local", "name": "current" }] } }, "right": { "kind": "call", "target": "colorFallback", "args": [{ "kind": "memberAccess", "target": { "kind": "local", "name": "Color" }, "member": "Blue" }] } }, "right": { "kind": "call", "target": "modeScore", "args": [{ "kind": "local", "name": "mode" }] } } }
