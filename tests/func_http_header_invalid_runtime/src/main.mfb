IMPORT http
IMPORT collections
IMPORT io

' `http::header` fails ErrNotFound (77050004) when the field is absent; a
' function-level TRAP turns that into its code for a deterministic run.
FUNC lookup(r AS http::Result, name AS String) AS String
  RETURN "ok:" & http::header(r, name)
  TRAP(e)
    RETURN "err:" & toString(e.code)
  END TRAP
END FUNC

FUNC main AS Integer
  LET headers AS List OF http::Header = [ http::Header["Content-Length", "10"] ]
  LET r AS http::Result = http::Result[204, "No Content", "1.1", headers, "", FALSE]
  io::print(lookup(r, "Content-Length"))
  io::print(lookup(r, "Content-Type"))
  RETURN 0
END FUNC
