{
  "format": "mfb-ir",
  "version": 1,
  "project": "control_flow_using_normal_runtime",
  "entry": {
    "name": "main",
    "returns": "Integer",
    "accepts_args": false
  },
  "types": [
  ],
  "functions": [
  {
    "name": "useOnce",
    "visibility": "private",
    "kind": "func",
    "params": [
    { "name": "path", "type": "String", "default": null }
    ],
    "returns": "Nothing",
    "body": [
    {
      "op": "using",
      "name": "f",
      "type": "File",
      "close": "fs.close",
      "value": { "kind": "call", "target": "fs.openFile", "args": [{ "kind": "local", "name": "path" }] },
      "body": [
      ]
    },
    { "op": "return", "value": { "kind": "const", "type": "Nothing", "value": "NOTHING" } }
    ]
  },
  {
    "name": "main",
    "visibility": "private",
    "kind": "func",
    "params": [
    ],
    "returns": "Integer",
    "body": [
    { "op": "bind", "mutable": true, "name": "i", "type": "Integer", "value": { "kind": "const", "type": "Integer", "value": "0" } },
    {
      "op": "while",
      "condition": { "kind": "binary", "op": "<", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "4000" } },
      "body": [
      { "op": "eval", "value": { "kind": "call", "target": "useOnce", "args": [{ "kind": "const", "type": "String", "value": "tests/control-flow-using-normal-runtime/src/main.mfb" }] } },
      { "op": "assign", "name": "i", "value": { "kind": "binary", "op": "+", "left": { "kind": "local", "name": "i" }, "right": { "kind": "const", "type": "Integer", "value": "1" } } }
      ]
    },
    { "op": "eval", "value": { "kind": "call", "target": "io.print", "args": [{ "kind": "const", "type": "String", "value": "normal" }] } },
    { "op": "return", "value": { "kind": "const", "type": "Integer", "value": "0" } }
    ]
  }
  ]
}
