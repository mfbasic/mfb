IMPORT io
IMPORT encoding
IMPORT errorCode

FUNC doDecode(units AS List OF Integer) AS String
  RETURN encoding::utf16Decode(units)
END FUNC

FUNC attempt(label AS String, units AS List OF Integer) AS Nothing
  LET r AS String = doDecode(units)
  io::print(label & ": ok")
  RETURN NOTHING
  TRAP(err)
    IF err.code = errorCode::ErrInvalidFormat THEN
      io::print(label & ": ErrInvalidFormat")
    ELSE
      io::print(label & ": other")
    END IF
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  attempt("unpaired", [55296])
  attempt("outofrange", [99999999])
  attempt("good", [104])
  RETURN 0
END FUNC
