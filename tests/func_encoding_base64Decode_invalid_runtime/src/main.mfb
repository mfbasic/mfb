IMPORT io
IMPORT encoding
IMPORT errorCode

FUNC doDecode(text AS String) AS List OF Byte
  RETURN encoding::base64Decode(text)
END FUNC

FUNC attempt(label AS String, text AS String) AS Nothing
  LET r AS List OF Byte = doDecode(text)
  io::print(label & ": ok len=" & toString(len(r)))
  RETURN NOTHING
  TRAP(err)
    IF err.code = errorCode::ErrInvalidFormat THEN
      io::print(label & ": ErrInvalidFormat")
    ELSE
      io::print(label & ": other")
    END IF
    RETURN NOTHING
  END TRAP
END FUNC

FUNC main AS Integer
  attempt("alphabet", "....")
  attempt("length", "ab")
  attempt("padding", "a===")
  attempt("good", "aGVsbG8=")
  RETURN 0
END FUNC
