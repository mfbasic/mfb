FUNC __vector_reject_float4(a AS Float4, b AS Float4) AS Float4
  LET p AS Float4 = __vector_project_float4(a, b)
  RETURN Float4[a.x - p.x, a.y - p.y, a.z - p.z, a.w - p.w]
END FUNC

FUNC __vector_angle_float4(a AS Float4, b AS Float4) AS Float
  LET la AS Float = math::sqrt(__vector_dot_float4(a, a))
  LET lb AS Float = math::sqrt(__vector_dot_float4(b, b))
  IF la = 0.0 OR lb = 0.0 THEN
