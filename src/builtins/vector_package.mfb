' ---- presentation ----

FUNC __vector_toString_float2(v AS Float2) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ")"
END FUNC

FUNC __vector_toString_float3(v AS Float3) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ", " & toString(v.z) & ")"
END FUNC

FUNC __vector_toString_float4(v AS Float4) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ", " & toString(v.z) & ", " & toString(v.w) & ")"
END FUNC

FUNC __vector_toString_fixed2(v AS Fixed2) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ")"
END FUNC

FUNC __vector_toString_fixed3(v AS Fixed3) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ", " & toString(v.z) & ")"
END FUNC

FUNC __vector_toString_fixed4(v AS Fixed4) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ", " & toString(v.z) & ", " & toString(v.w) & ")"
END FUNC

FUNC __vector_toString_integer2(v AS Integer2) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ")"
END FUNC

FUNC __vector_toString_integer3(v AS Integer3) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ", " & toString(v.z) & ")"
END FUNC

FUNC __vector_toString_integer4(v AS Integer4) AS String
  RETURN "(" & toString(v.x) & ", " & toString(v.y) & ", " & toString(v.z) & ", " & toString(v.w) & ")"
END FUNC

' ---- 2D-only members ----

FUNC __vector_perpendicular_float2(v AS Float2) AS Float2
  RETURN Float2[0.0 - v.y, v.x]
END FUNC

FUNC __vector_rotate_2d_float2(v AS Float2, ang AS Float) AS Float2
  LET c AS Float = math::cos(ang)
  LET s AS Float = math::sin(ang)
  LET rx AS Float = v.x * c - v.y * s
  LET ry AS Float = v.x * s + v.y * c
  RETURN Float2[rx, ry]
END FUNC

FUNC __vector_perpendicular_fixed2(v AS Fixed2) AS Fixed2
  RETURN Fixed2[0.0 - v.y, v.x]
END FUNC

FUNC __vector_rotate_2d_fixed2(v AS Fixed2, ang AS Float) AS Fixed2
  LET af AS Fixed = toFixed(ang)
  LET c AS Fixed = math::cos(af)
  LET s AS Fixed = math::sin(af)
  LET rx AS Fixed = v.x * c - v.y * s
  LET ry AS Fixed = v.x * s + v.y * c
  RETURN Fixed2[rx, ry]
END FUNC

FUNC __vector_perpendicular_integer2(v AS Integer2) AS Integer2
  RETURN Integer2[0 - v.y, v.x]
END FUNC

FUNC __vector_rotate_2d_integer2(v AS Integer2, ang AS Float) AS Integer2
  LET af AS Fixed = toFixed(ang)
  LET c AS Fixed = math::cos(af)
  LET s AS Fixed = math::sin(af)
  LET xf AS Fixed = toFixed(v.x)
  LET yf AS Fixed = toFixed(v.y)
  LET rx AS Integer = math::round(xf * c - yf * s)
  LET ry AS Integer = math::round(xf * s + yf * c)
  RETURN Integer2[rx, ry]
END FUNC
