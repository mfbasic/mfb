  RETURN Float4[cx, cy, cz, cw]
END FUNC

FUNC __vector_slerp_float4(a AS Float4, b AS Float4, t AS Float) AS Float4
  LET omega AS Float = __vector_angle_float4(a, b)
  LET s AS Float = math::sin(omega)
  IF math::abs(s) < 0.000001 THEN
    RETURN __vector_lerp_unclamped_float4(a, b, t)
  END IF
  LET w0 AS Float = math::sin((1.0 - t) * omega) / s
  LET w1 AS Float = math::sin(t * omega) / s
  LET cx AS Float = w0 * a.x + w1 * b.x
  LET cy AS Float = w0 * a.y + w1 * b.y
  LET cz AS Float = w0 * a.z + w1 * b.z
  LET cw AS Float = w0 * a.w + w1 * b.w
  RETURN Float4[cx, cy, cz, cw]
END FUNC

FUNC __vector_clamp_length_float4(v AS Float4, maxLen AS Float) AS Float4
  IF maxLen < 0.0 THEN
    FAIL error(77050002, "vector::clamp_length with negative max")
  END IF
  LET len AS Float = math::sqrt(v.x * v.x + v.y * v.y + v.z * v.z + v.w * v.w)
  IF len <= maxLen OR len = 0.0 THEN
    RETURN v
  END IF
  LET ratio AS Float = maxLen / len
  LET cx AS Float = v.x * ratio
  LET cy AS Float = v.y * ratio
  LET cz AS Float = v.z * ratio
  LET cw AS Float = v.w * ratio
