  IF len <= maxLen OR len = 0.0 THEN
    RETURN v
  END IF
  LET ratio AS Fixed = maxLen / len
  LET cx AS Fixed = v.x * ratio
  LET cy AS Fixed = v.y * ratio
  LET cz AS Fixed = v.z * ratio
  LET cw AS Fixed = v.w * ratio
  RETURN Fixed4[cx, cy, cz, cw]
END FUNC

FUNC __vector_lerp_integer2(a AS Integer2, b AS Integer2, t AS Float) AS Integer2
  LET tc AS Float = math::clamp(t, 0.0, 1.0)
  LET cx AS Integer = math::round(toFloat(a.x) + (toFloat(b.x) - toFloat(a.x)) * tc)
  LET cy AS Integer = math::round(toFloat(a.y) + (toFloat(b.y) - toFloat(a.y)) * tc)
  RETURN Integer2[cx, cy]
END FUNC

FUNC __vector_lerp_unclamped_integer2(a AS Integer2, b AS Integer2, t AS Float) AS Integer2
  LET cx AS Integer = math::round(toFloat(a.x) + (toFloat(b.x) - toFloat(a.x)) * t)
  LET cy AS Integer = math::round(toFloat(a.y) + (toFloat(b.y) - toFloat(a.y)) * t)
  RETURN Integer2[cx, cy]
END FUNC

FUNC __vector_slerp_integer2(a AS Integer2, b AS Integer2, t AS Float) AS Integer2
  LET omega AS Fixed = __vector_angleFixed_integer2(a, b)
  LET s AS Fixed = math::sin(omega)
  IF math::abs(s) < toFixed(0.000001) THEN
    RETURN __vector_lerp_unclamped_integer2(a, b, t)
  END IF
  LET tf AS Fixed = toFixed(t)
  LET w0 AS Fixed = math::sin((toFixed(1.0) - tf) * omega) / s
  LET w1 AS Fixed = math::sin(tf * omega) / s
  LET cx AS Integer = math::round(w0 * toFixed(a.x) + w1 * toFixed(b.x))
  LET cy AS Integer = math::round(w0 * toFixed(a.y) + w1 * toFixed(b.y))
  RETURN Integer2[cx, cy]
END FUNC

FUNC __vector_clamp_length_integer2(v AS Integer2, maxLen AS Integer) AS Integer2
  IF maxLen < 0 THEN
    FAIL error(77050002, "vector::clamp_length with negative max")
  END IF
  LET s AS Integer = v.x * v.x + v.y * v.y
  LET len AS Integer = __vector_isqrtRound(s)
  IF len <= maxLen OR len = 0 THEN
    RETURN v
  END IF
  LET ratio AS Float = toFloat(maxLen) / toFloat(len)
  LET cx AS Integer = math::round(toFloat(v.x) * ratio)
  LET cy AS Integer = math::round(toFloat(v.y) * ratio)
  RETURN Integer2[cx, cy]
END FUNC

FUNC __vector_lerp_integer3(a AS Integer3, b AS Integer3, t AS Float) AS Integer3
  LET tc AS Float = math::clamp(t, 0.0, 1.0)
  LET cx AS Integer = math::round(toFloat(a.x) + (toFloat(b.x) - toFloat(a.x)) * tc)
  LET cy AS Integer = math::round(toFloat(a.y) + (toFloat(b.y) - toFloat(a.y)) * tc)
  LET cz AS Integer = math::round(toFloat(a.z) + (toFloat(b.z) - toFloat(a.z)) * tc)
  RETURN Integer3[cx, cy, cz]
END FUNC

FUNC __vector_lerp_unclamped_integer3(a AS Integer3, b AS Integer3, t AS Float) AS Integer3
  LET cx AS Integer = math::round(toFloat(a.x) + (toFloat(b.x) - toFloat(a.x)) * t)
  LET cy AS Integer = math::round(toFloat(a.y) + (toFloat(b.y) - toFloat(a.y)) * t)
  LET cz AS Integer = math::round(toFloat(a.z) + (toFloat(b.z) - toFloat(a.z)) * t)
  RETURN Integer3[cx, cy, cz]
END FUNC

FUNC __vector_slerp_integer3(a AS Integer3, b AS Integer3, t AS Float) AS Integer3
  LET omega AS Fixed = __vector_angleFixed_integer3(a, b)
  LET s AS Fixed = math::sin(omega)
  IF math::abs(s) < toFixed(0.000001) THEN
    RETURN __vector_lerp_unclamped_integer3(a, b, t)
  END IF
  LET tf AS Fixed = toFixed(t)
  LET w0 AS Fixed = math::sin((toFixed(1.0) - tf) * omega) / s
  LET w1 AS Fixed = math::sin(tf * omega) / s
  LET cx AS Integer = math::round(w0 * toFixed(a.x) + w1 * toFixed(b.x))
  LET cy AS Integer = math::round(w0 * toFixed(a.y) + w1 * toFixed(b.y))
  LET cz AS Integer = math::round(w0 * toFixed(a.z) + w1 * toFixed(b.z))
  RETURN Integer3[cx, cy, cz]
END FUNC

FUNC __vector_clamp_length_integer3(v AS Integer3, maxLen AS Integer) AS Integer3
  IF maxLen < 0 THEN
    FAIL error(77050002, "vector::clamp_length with negative max")
  END IF
  LET s AS Integer = v.x * v.x + v.y * v.y + v.z * v.z
  LET len AS Integer = __vector_isqrtRound(s)
  IF len <= maxLen OR len = 0 THEN
    RETURN v
  END IF
  LET ratio AS Float = toFloat(maxLen) / toFloat(len)
  LET cx AS Integer = math::round(toFloat(v.x) * ratio)
  LET cy AS Integer = math::round(toFloat(v.y) * ratio)
  LET cz AS Integer = math::round(toFloat(v.z) * ratio)
  RETURN Integer3[cx, cy, cz]
END FUNC

FUNC __vector_lerp_integer4(a AS Integer4, b AS Integer4, t AS Float) AS Integer4
  LET tc AS Float = math::clamp(t, 0.0, 1.0)
  LET cx AS Integer = math::round(toFloat(a.x) + (toFloat(b.x) - toFloat(a.x)) * tc)
  LET cy AS Integer = math::round(toFloat(a.y) + (toFloat(b.y) - toFloat(a.y)) * tc)
  LET cz AS Integer = math::round(toFloat(a.z) + (toFloat(b.z) - toFloat(a.z)) * tc)
  LET cw AS Integer = math::round(toFloat(a.w) + (toFloat(b.w) - toFloat(a.w)) * tc)
  RETURN Integer4[cx, cy, cz, cw]
END FUNC

FUNC __vector_lerp_unclamped_integer4(a AS Integer4, b AS Integer4, t AS Float) AS Integer4
  LET cx AS Integer = math::round(toFloat(a.x) + (toFloat(b.x) - toFloat(a.x)) * t)
  LET cy AS Integer = math::round(toFloat(a.y) + (toFloat(b.y) - toFloat(a.y)) * t)
  LET cz AS Integer = math::round(toFloat(a.z) + (toFloat(b.z) - toFloat(a.z)) * t)
  LET cw AS Integer = math::round(toFloat(a.w) + (toFloat(b.w) - toFloat(a.w)) * t)
  RETURN Integer4[cx, cy, cz, cw]
END FUNC

FUNC __vector_slerp_integer4(a AS Integer4, b AS Integer4, t AS Float) AS Integer4
  LET omega AS Fixed = __vector_angleFixed_integer4(a, b)
  LET s AS Fixed = math::sin(omega)
  IF math::abs(s) < toFixed(0.000001) THEN
    RETURN __vector_lerp_unclamped_integer4(a, b, t)
  END IF
  LET tf AS Fixed = toFixed(t)
  LET w0 AS Fixed = math::sin((toFixed(1.0) - tf) * omega) / s
  LET w1 AS Fixed = math::sin(tf * omega) / s
  LET cx AS Integer = math::round(w0 * toFixed(a.x) + w1 * toFixed(b.x))
  LET cy AS Integer = math::round(w0 * toFixed(a.y) + w1 * toFixed(b.y))
  LET cz AS Integer = math::round(w0 * toFixed(a.z) + w1 * toFixed(b.z))
  LET cw AS Integer = math::round(w0 * toFixed(a.w) + w1 * toFixed(b.w))
  RETURN Integer4[cx, cy, cz, cw]
END FUNC

FUNC __vector_clamp_length_integer4(v AS Integer4, maxLen AS Integer) AS Integer4
  IF maxLen < 0 THEN
    FAIL error(77050002, "vector::clamp_length with negative max")
  END IF
  LET s AS Integer = v.x * v.x + v.y * v.y + v.z * v.z + v.w * v.w
  LET len AS Integer = __vector_isqrtRound(s)
  IF len <= maxLen OR len = 0 THEN
    RETURN v
  END IF
  LET ratio AS Float = toFloat(maxLen) / toFloat(len)
  LET cx AS Integer = math::round(toFloat(v.x) * ratio)
  LET cy AS Integer = math::round(toFloat(v.y) * ratio)
  LET cz AS Integer = math::round(toFloat(v.z) * ratio)
  LET cw AS Integer = math::round(toFloat(v.w) * ratio)
  RETURN Integer4[cx, cy, cz, cw]
END FUNC

' ---- component-wise utilities ----

FUNC __vector_scale_float2(a AS Float2, b AS Float2) AS Float2
  LET cx AS Float = a.x * b.x
  LET cy AS Float = a.y * b.y
  RETURN Float2[cx, cy]
END FUNC

FUNC __vector_min_float2(a AS Float2, b AS Float2) AS Float2
  LET cx AS Float = math::min(a.x, b.x)
  LET cy AS Float = math::min(a.y, b.y)
  RETURN Float2[cx, cy]
END FUNC

FUNC __vector_max_float2(a AS Float2, b AS Float2) AS Float2
  LET cx AS Float = math::max(a.x, b.x)
  LET cy AS Float = math::max(a.y, b.y)
  RETURN Float2[cx, cy]
END FUNC

FUNC __vector_abs_float2(v AS Float2) AS Float2
  LET cx AS Float = math::abs(v.x)
  LET cy AS Float = math::abs(v.y)
  RETURN Float2[cx, cy]
END FUNC

