END FUNC

FUNC __vector_angle_integer3(a AS Integer3, b AS Integer3) AS Integer
  RETURN math::round(__vector_angleFixed_integer3(a, b))
END FUNC

FUNC __vector_reflect_integer4(v AS Integer4, n AS Integer4) AS Integer4
  LET d AS Integer = __vector_dot_integer4(v, n)
  LET k AS Integer = 2 * d
