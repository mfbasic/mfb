  LET cx AS Fixed = v.x / len
  LET cy AS Fixed = v.y / len
  RETURN Fixed2[cx, cy]
END FUNC

FUNC __vector_cross_fixed2(v AS Fixed2) AS Fixed2
  RETURN Fixed2[0.0 - v.y, v.x]
END FUNC

FUNC __vector_normalize_fixed3(v AS Fixed3) AS Fixed3
