IMPORT crypto
IMPORT bits
IMPORT strings
IMPORT collections
IMPORT encoding

' ===========================================================================
' crypto — cryptographic hashes, HMAC, KDF, AEAD, CSPRNG, public-key
' (plan-04-crypto.md).
'
' Hybrid backend (see the plan's reconciliation note): every symmetric,
' hashing, AEAD, and Ed25519 primitive is a portable software core written here
' over the `bits` package, so the output is byte-identical on every target and
' uses no deprecated platform functions. Only `crypto::randomBytes` (OS entropy)
' and the NIST-EC public-key operations are native runtime helpers, presented by
' the Rust seam in src/builtins/crypto.rs; these `__crypto_*` helpers are the
' source bodies it maps the remaining public calls to.
'
' 32-bit arithmetic keeps every working value masked to 0..2^32-1 (`__crypto_m32`
' below): a sum of two such values is at most 2^33-2, well within the trapping
' 63-bit `+`, and is masked straight back. 64-bit modular addition (SHA-512,
' Poly1305) is done through `__crypto_add64`, which never lets an intermediate
' cross 2^63.
' ===========================================================================

' The public types (plan-04-crypto.md §A.1). Plain copyable records.
EXPORT TYPE Sealed
  ciphertext AS List OF Byte
  tag        AS List OF Byte
END TYPE

EXPORT TYPE KeyPair
  privateKey AS List OF Byte
  publicKey  AS List OF Byte
END TYPE

' The round-constant and initial-value tables are computed once at program
' start (module globals), not rebuilt per hash call — hashing is on the hot path
' of HMAC/HKDF/PBKDF2, where a per-call rebuild dominated the cost.
LET __CRYPTO_K256 AS List OF Integer = __crypto_sha256Ktable()
LET __CRYPTO_IV256 AS List OF Integer = __crypto_sha256Iv()
LET __CRYPTO_IV224 AS List OF Integer = __crypto_sha224Iv()
LET __CRYPTO_K512 AS List OF Integer = __crypto_sha512Ktable()
LET __CRYPTO_IV512 AS List OF Integer = __crypto_sha512Iv()
LET __CRYPTO_IV384 AS List OF Integer = __crypto_sha384Iv()
LET __CRYPTO_AES_SBOX AS List OF Byte = __crypto_aesSboxTable()

' --- shared 32-bit helpers -------------------------------------------------

' The 32-bit mask 2^32 - 1.
FUNC __crypto_m32() AS Integer
  RETURN 4294967295
END FUNC

' 32-bit modular addition. `a` and `b` must already be in 0..2^32-1.
FUNC __crypto_add32(a AS Integer, b AS Integer) AS Integer
  LET s AS Integer = a + b
  RETURN bits::band(s, 4294967295)
END FUNC

' 32-bit rotate-right by `n` (0..31).
FUNC __crypto_rotr32(x AS Integer, n AS Integer) AS Integer
  RETURN bits::rr32(x, n)
END FUNC

' 32-bit logical right shift.
FUNC __crypto_shr32(x AS Integer, n AS Integer) AS Integer
  RETURN bits::sr(x, n)
END FUNC

' 32-bit bitwise complement.
FUNC __crypto_not32(x AS Integer) AS Integer
  RETURN bits::band(bits::bnot(x), 4294967295)
END FUNC

' The big-endian 32-bit word at byte offset `o` of `data`.
FUNC __crypto_beWord(data AS List OF Byte, o AS Integer) AS Integer
  LET b0 AS Integer = toInt(collections::get(data, o))
  LET b1 AS Integer = toInt(collections::get(data, o + 1))
  LET b2 AS Integer = toInt(collections::get(data, o + 2))
  LET b3 AS Integer = toInt(collections::get(data, o + 3))
  LET w0 AS Integer = bits::sl(b0, 24)
  LET w1 AS Integer = bits::sl(b1, 16)
  LET w2 AS Integer = bits::sl(b2, 8)
  LET hi AS Integer = bits::bor(w0, w1)
  LET lo AS Integer = bits::bor(w2, b3)
  RETURN bits::bor(hi, lo)
END FUNC

' Append the 32-bit word `w` to `out` as four big-endian bytes.
FUNC __crypto_appendBeWord(out AS List OF Byte, w AS Integer) AS List OF Byte
  MUT result AS List OF Byte = out
  LET a AS Integer = bits::band(bits::sr(w, 24), 255)
  LET b AS Integer = bits::band(bits::sr(w, 16), 255)
  LET c AS Integer = bits::band(bits::sr(w, 8), 255)
  LET d AS Integer = bits::band(w, 255)
  result = collections::append(result, toByte(a))
  result = collections::append(result, toByte(b))
  result = collections::append(result, toByte(c))
  result = collections::append(result, toByte(d))
  RETURN result
END FUNC

' A fresh mutable copy of `data` (so appends don't disturb the caller's input).
FUNC __crypto_copyBytes(data AS List OF Byte) AS List OF Byte
  MUT out AS List OF Byte = []
  LET n AS Integer = len(data)
  MUT i AS Integer = 0
  WHILE i < n
    out = collections::append(out, collections::get(data, i))
    i = i + 1
  END WHILE
  RETURN out
END FUNC

' --- SHA-256 / SHA-224 -----------------------------------------------------

' The 64 SHA-256 round constants, decoded from their big-endian hex.
FUNC __crypto_sha256Ktable() AS List OF Integer
  LET hex AS String = "428a2f9871374491b5c0fbcfe9b5dba53956c25b59f111f1923f82a4ab1c5ed5d807aa9812835b01243185be550c7dc372be5d7480deb1fe9bdc06a7c19bf174e49b69c1efbe47860fc19dc6240ca1cc2de92c6f4a7484aa5cb0a9dc76f988da983e5152a831c66db00327c8bf597fc7c6e00bf3d5a7914706ca635114292967"
  LET hex2 AS String = "27b70a852e1b21384d2c6dfc53380d13650a7354766a0abb81c2c92e92722c85a2bfe8a1a81a664bc24b8b70c76c51a3d192e819d6990624f40e3585106aa07019a4c1161e376c082748774c34b0bcb5391c0cb34ed8aa4a5b9cca4f682e6ff3748f82ee78a5636f84c878148cc7020890befffaa4506cebbef9a3f7c67178f2"
  LET full AS String = hex & hex2
  LET raw AS List OF Byte = encoding::hexDecode(full)
  RETURN __crypto_beWords(raw)
END FUNC

' Split `data` (a multiple of 4 bytes) into big-endian 32-bit words.
FUNC __crypto_beWords(data AS List OF Byte) AS List OF Integer
  MUT out AS List OF Integer = []
  LET n AS Integer = len(data)
  MUT o AS Integer = 0
  WHILE o < n
    LET w AS Integer = __crypto_beWord(data, o)
    out = collections::append(out, w)
    o = o + 4
  END WHILE
  RETURN out
END FUNC

FUNC __crypto_sha256Iv() AS List OF Integer
  MUT iv AS List OF Integer = []
  iv = collections::append(iv, 1779033703)
  iv = collections::append(iv, 3144134277)
  iv = collections::append(iv, 1013904242)
  iv = collections::append(iv, 2773480762)
  iv = collections::append(iv, 1359893119)
  iv = collections::append(iv, 2600822924)
  iv = collections::append(iv, 528734635)
  iv = collections::append(iv, 1541459225)
  RETURN iv
END FUNC

FUNC __crypto_sha224Iv() AS List OF Integer
  MUT iv AS List OF Integer = []
  iv = collections::append(iv, 3238371032)
  iv = collections::append(iv, 914150663)
  iv = collections::append(iv, 812702999)
  iv = collections::append(iv, 4144912697)
  iv = collections::append(iv, 4290775857)
  iv = collections::append(iv, 1750603025)
  iv = collections::append(iv, 1694076839)
  iv = collections::append(iv, 3204075428)
  RETURN iv
END FUNC

FUNC __crypto_ch32(x AS Integer, y AS Integer, z AS Integer) AS Integer
  LET l AS Integer = bits::band(x, y)
  LET r AS Integer = bits::band(__crypto_not32(x), z)
  RETURN bits::bxor(l, r)
END FUNC

FUNC __crypto_maj32(x AS Integer, y AS Integer, z AS Integer) AS Integer
  LET a AS Integer = bits::band(x, y)
  LET b AS Integer = bits::band(x, z)
  LET c AS Integer = bits::band(y, z)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_bsig0(x AS Integer) AS Integer
  LET a AS Integer = __crypto_rotr32(x, 2)
  LET b AS Integer = __crypto_rotr32(x, 13)
  LET c AS Integer = __crypto_rotr32(x, 22)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_bsig1(x AS Integer) AS Integer
  LET a AS Integer = __crypto_rotr32(x, 6)
  LET b AS Integer = __crypto_rotr32(x, 11)
  LET c AS Integer = __crypto_rotr32(x, 25)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_ssig0(x AS Integer) AS Integer
  LET a AS Integer = __crypto_rotr32(x, 7)
  LET b AS Integer = __crypto_rotr32(x, 18)
  LET c AS Integer = __crypto_shr32(x, 3)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_ssig1(x AS Integer) AS Integer
  LET a AS Integer = __crypto_rotr32(x, 17)
  LET b AS Integer = __crypto_rotr32(x, 19)
  LET c AS Integer = __crypto_shr32(x, 10)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

' Pad `data` to the SHA-2/SHA-256 512-bit block boundary (RFC 6234 §4.1).
FUNC __crypto_pad512(data AS List OF Byte) AS List OF Byte
  MUT msg AS List OF Byte = __crypto_copyBytes(data)
  LET origLen AS Integer = len(data)
  LET bitLen AS Integer = origLen * 8
  msg = collections::append(msg, toByte(128))
  WHILE (len(msg) MOD 64) <> 56
    msg = collections::append(msg, toByte(0))
  END WHILE
  MUT pos AS Integer = 0
  WHILE pos < 8
    LET shift AS Integer = 56 - pos * 8
    LET b AS Integer = bits::band(bits::sr(bitLen, shift), 255)
    msg = collections::append(msg, toByte(b))
    pos = pos + 1
  END WHILE
  RETURN msg
END FUNC

' Build the 64-entry SHA-256 message schedule for the block at `base`.
FUNC __crypto_sha256Schedule(msg AS List OF Byte, base AS Integer) AS List OF Integer
  MUT w AS List OF Integer = []
  MUT t AS Integer = 0
  WHILE t < 16
    LET word AS Integer = __crypto_beWord(msg, base + t * 4)
    w = collections::append(w, word)
    t = t + 1
  END WHILE
  t = 16
  WHILE t < 64
    LET a AS Integer = __crypto_ssig1(collections::get(w, t - 2))
    LET b AS Integer = collections::get(w, t - 7)
    LET c AS Integer = __crypto_ssig0(collections::get(w, t - 15))
    LET d AS Integer = collections::get(w, t - 16)
    LET s1 AS Integer = __crypto_add32(a, b)
    LET s2 AS Integer = __crypto_add32(c, d)
    LET word AS Integer = __crypto_add32(s1, s2)
    w = collections::append(w, word)
    t = t + 1
  END WHILE
  RETURN w
END FUNC

' SHA-256 / SHA-224 core: process `data` from `iv`, emit `outBytes` digest bytes.
FUNC __crypto_sha2_32(data AS List OF Byte, iv AS List OF Integer, outBytes AS Integer) AS List OF Byte
  LET msg AS List OF Byte = __crypto_pad512(data)
  MUT h0 AS Integer = collections::get(iv, 0)
  MUT h1 AS Integer = collections::get(iv, 1)
  MUT h2 AS Integer = collections::get(iv, 2)
  MUT h3 AS Integer = collections::get(iv, 3)
  MUT h4 AS Integer = collections::get(iv, 4)
  MUT h5 AS Integer = collections::get(iv, 5)
  MUT h6 AS Integer = collections::get(iv, 6)
  MUT h7 AS Integer = collections::get(iv, 7)
  LET total AS Integer = len(msg)
  MUT base AS Integer = 0
  WHILE base < total
    LET w AS List OF Integer = __crypto_sha256Schedule(msg, base)
    MUT a AS Integer = h0
    MUT b AS Integer = h1
    MUT c AS Integer = h2
    MUT d AS Integer = h3
    MUT e AS Integer = h4
    MUT f AS Integer = h5
    MUT g AS Integer = h6
    MUT h AS Integer = h7
    MUT t AS Integer = 0
    WHILE t < 64
      LET t1a AS Integer = __crypto_add32(h, __crypto_bsig1(e))
      LET t1b AS Integer = __crypto_add32(__crypto_ch32(e, f, g), collections::get(__CRYPTO_K256, t))
      LET t1c AS Integer = __crypto_add32(t1b, collections::get(w, t))
      LET t1 AS Integer = __crypto_add32(t1a, t1c)
      LET t2 AS Integer = __crypto_add32(__crypto_bsig0(a), __crypto_maj32(a, b, c))
      h = g
      g = f
      f = e
      e = __crypto_add32(d, t1)
      d = c
      c = b
      b = a
      a = __crypto_add32(t1, t2)
      t = t + 1
    END WHILE
    h0 = __crypto_add32(h0, a)
    h1 = __crypto_add32(h1, b)
    h2 = __crypto_add32(h2, c)
    h3 = __crypto_add32(h3, d)
    h4 = __crypto_add32(h4, e)
    h5 = __crypto_add32(h5, f)
    h6 = __crypto_add32(h6, g)
    h7 = __crypto_add32(h7, h)
    base = base + 64
  END WHILE
  MUT digest AS List OF Byte = []
  digest = __crypto_appendBeWord(digest, h0)
  digest = __crypto_appendBeWord(digest, h1)
  digest = __crypto_appendBeWord(digest, h2)
  digest = __crypto_appendBeWord(digest, h3)
  digest = __crypto_appendBeWord(digest, h4)
  digest = __crypto_appendBeWord(digest, h5)
  digest = __crypto_appendBeWord(digest, h6)
  digest = __crypto_appendBeWord(digest, h7)
  RETURN __crypto_truncate(digest, outBytes)
END FUNC

' The first `n` bytes of `data`.
FUNC __crypto_truncate(data AS List OF Byte, n AS Integer) AS List OF Byte
  MUT out AS List OF Byte = []
  MUT i AS Integer = 0
  WHILE i < n
    out = collections::append(out, collections::get(data, i))
    i = i + 1
  END WHILE
  RETURN out
END FUNC

FUNC __crypto_sha256_bytes(data AS List OF Byte) AS List OF Byte
  RETURN __crypto_sha2_32(data, __CRYPTO_IV256, 32)
END FUNC

FUNC __crypto_sha256_text(data AS String) AS List OF Byte
  RETURN __crypto_sha2_32(strings::toBytes(data), __CRYPTO_IV256, 32)
END FUNC

FUNC __crypto_sha224_bytes(data AS List OF Byte) AS List OF Byte
  RETURN __crypto_sha2_32(data, __CRYPTO_IV224, 28)
END FUNC

FUNC __crypto_sha224_text(data AS String) AS List OF Byte
  RETURN __crypto_sha2_32(strings::toBytes(data), __CRYPTO_IV224, 28)
END FUNC

' --- 64-bit helpers (SHA-512, Poly1305) -----------------------------------

' 64-bit modular addition without tripping the trapping `+`: add the 32-bit
' halves, propagate the carry, and recombine as a raw 64-bit bit pattern.
FUNC __crypto_add64(a AS Integer, b AS Integer) AS Integer
  LET aLo AS Integer = bits::band(a, 4294967295)
  LET bLo AS Integer = bits::band(b, 4294967295)
  LET aHi AS Integer = bits::band(bits::sr(a, 32), 4294967295)
  LET bHi AS Integer = bits::band(bits::sr(b, 32), 4294967295)
  LET lo AS Integer = aLo + bLo
  LET carry AS Integer = bits::sr(lo, 32)
  LET loMasked AS Integer = bits::band(lo, 4294967295)
  LET hi AS Integer = aHi + bHi + carry
  LET hiMasked AS Integer = bits::band(hi, 4294967295)
  LET hiShifted AS Integer = bits::sl(hiMasked, 32)
  RETURN bits::bor(hiShifted, loMasked)
END FUNC

' The big-endian 64-bit word at byte offset `o` of `data`.
FUNC __crypto_beWord64(data AS List OF Byte, o AS Integer) AS Integer
  MUT w AS Integer = 0
  MUT i AS Integer = 0
  WHILE i < 8
    LET b AS Integer = toInt(collections::get(data, o + i))
    w = bits::bor(bits::sl(w, 8), b)
    i = i + 1
  END WHILE
  RETURN w
END FUNC

' Split `data` (a multiple of 8 bytes) into big-endian 64-bit words.
FUNC __crypto_beWords64(data AS List OF Byte) AS List OF Integer
  MUT out AS List OF Integer = []
  LET n AS Integer = len(data)
  MUT o AS Integer = 0
  WHILE o < n
    out = collections::append(out, __crypto_beWord64(data, o))
    o = o + 8
  END WHILE
  RETURN out
END FUNC

' Append the 64-bit word `w` to `out` as eight big-endian bytes.
FUNC __crypto_appendBeWord64(out AS List OF Byte, w AS Integer) AS List OF Byte
  MUT result AS List OF Byte = out
  MUT i AS Integer = 0
  WHILE i < 8
    LET shift AS Integer = 56 - i * 8
    LET b AS Integer = bits::band(bits::sr(w, shift), 255)
    result = collections::append(result, toByte(b))
    i = i + 1
  END WHILE
  RETURN result
END FUNC

FUNC __crypto_ch64(x AS Integer, y AS Integer, z AS Integer) AS Integer
  LET l AS Integer = bits::band(x, y)
  LET r AS Integer = bits::band(bits::bnot(x), z)
  RETURN bits::bxor(l, r)
END FUNC

FUNC __crypto_maj64(x AS Integer, y AS Integer, z AS Integer) AS Integer
  LET a AS Integer = bits::band(x, y)
  LET b AS Integer = bits::band(x, z)
  LET c AS Integer = bits::band(y, z)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_bsig0_64(x AS Integer) AS Integer
  LET a AS Integer = bits::rr64(x, 28)
  LET b AS Integer = bits::rr64(x, 34)
  LET c AS Integer = bits::rr64(x, 39)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_bsig1_64(x AS Integer) AS Integer
  LET a AS Integer = bits::rr64(x, 14)
  LET b AS Integer = bits::rr64(x, 18)
  LET c AS Integer = bits::rr64(x, 41)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_ssig0_64(x AS Integer) AS Integer
  LET a AS Integer = bits::rr64(x, 1)
  LET b AS Integer = bits::rr64(x, 8)
  LET c AS Integer = bits::sr(x, 7)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_ssig1_64(x AS Integer) AS Integer
  LET a AS Integer = bits::rr64(x, 19)
  LET b AS Integer = bits::rr64(x, 61)
  LET c AS Integer = bits::sr(x, 6)
  RETURN bits::bxor(bits::bxor(a, b), c)
END FUNC

FUNC __crypto_sha512Ktable() AS List OF Integer
  LET h1 AS String = "428a2f98d728ae227137449123ef65cdb5c0fbcfec4d3b2fe9b5dba58189dbbc3956c25bf348b53859f111f1b605d019923f82a4af194f9bab1c5ed5da6d8118d807aa98a303024212835b0145706fbe243185be4ee4b28c550c7dc3d5ffb4e272be5d74f27b896f80deb1fe3b1696b19bdc06a725c71235c19bf174cf692694"
  LET h2 AS String = "e49b69c19ef14ad2efbe4786384f25e30fc19dc68b8cd5b5240ca1cc77ac9c652de92c6f592b02754a7484aa6ea6e4835cb0a9dcbd41fbd476f988da831153b5983e5152ee66dfaba831c66d2db43210b00327c898fb213fbf597fc7beef0ee4c6e00bf33da88fc2d5a79147930aa72506ca6351e003826f142929670a0e6e70"
  LET h3 AS String = "27b70a8546d22ffc2e1b21385c26c9264d2c6dfc5ac42aed53380d139d95b3df650a73548baf63de766a0abb3c77b2a881c2c92e47edaee692722c851482353ba2bfe8a14cf10364a81a664bbc423001c24b8b70d0f89791c76c51a30654be30d192e819d6ef5218d69906245565a910f40e35855771202a106aa07032bbd1b8"
  LET h4 AS String = "19a4c116b8d2d0c81e376c085141ab532748774cdf8eeb9934b0bcb5e19b48a8391c0cb3c5c95a634ed8aa4ae3418acb5b9cca4f7763e373682e6ff3d6b2b8a3748f82ee5defb2fc78a5636f43172f6084c87814a1f0ab728cc702081a6439ec90befffa23631e28a4506cebde82bde9bef9a3f7b2c67915c67178f2e372532b"
  LET h5 AS String = "ca273eceea26619cd186b8c721c0c207eada7dd6cde0eb1ef57d4f7fee6ed17806f067aa72176fba0a637dc5a2c898a6113f9804bef90dae1b710b35131c471b28db77f523047d8432caab7b40c724933c9ebe0a15c9bebc431d67c49c100d4c4cc5d4becb3e42b6597f299cfc657e2a5fcb6fab3ad6faec6c44198c4a475817"
  LET full AS String = h1 & h2 & h3 & h4 & h5
  RETURN __crypto_beWords64(encoding::hexDecode(full))
END FUNC

FUNC __crypto_sha512Iv() AS List OF Integer
  LET hex AS String = "6a09e667f3bcc908bb67ae8584caa73b3c6ef372fe94f82ba54ff53a5f1d36f1510e527fade682d19b05688c2b3e6c1f1f83d9abfb41bd6b5be0cd19137e2179"
  RETURN __crypto_beWords64(encoding::hexDecode(hex))
END FUNC

FUNC __crypto_sha384Iv() AS List OF Integer
  LET hex AS String = "cbbb9d5dc1059ed8629a292a367cd5079159015a3070dd17152fecd8f70e593967332667ffc00b318eb44a8768581511db0c2e0d64f98fa747b5481dbefa4fa4"
  RETURN __crypto_beWords64(encoding::hexDecode(hex))
END FUNC

' Pad `data` to the SHA-512 1024-bit block boundary (RFC 6234 §4.2). Message
' lengths never approach 2^64 bits, so the high 64 length bits are always zero.
FUNC __crypto_pad1024(data AS List OF Byte) AS List OF Byte
  MUT msg AS List OF Byte = __crypto_copyBytes(data)
  LET bitLen AS Integer = len(data) * 8
  msg = collections::append(msg, toByte(128))
  WHILE (len(msg) MOD 128) <> 112
    msg = collections::append(msg, toByte(0))
  END WHILE
  MUT z AS Integer = 0
  WHILE z < 8
    msg = collections::append(msg, toByte(0))
    z = z + 1
  END WHILE
  msg = __crypto_appendBeWord64(msg, bitLen)
  RETURN msg
END FUNC

' Build the 80-entry SHA-512 message schedule for the block at `base`.
FUNC __crypto_sha512Schedule(msg AS List OF Byte, base AS Integer) AS List OF Integer
  MUT w AS List OF Integer = []
  MUT t AS Integer = 0
  WHILE t < 16
    w = collections::append(w, __crypto_beWord64(msg, base + t * 8))
    t = t + 1
  END WHILE
  t = 16
  WHILE t < 80
    LET a AS Integer = __crypto_ssig1_64(collections::get(w, t - 2))
    LET b AS Integer = collections::get(w, t - 7)
    LET c AS Integer = __crypto_ssig0_64(collections::get(w, t - 15))
    LET d AS Integer = collections::get(w, t - 16)
    LET s1 AS Integer = __crypto_add64(a, b)
    LET s2 AS Integer = __crypto_add64(c, d)
    w = collections::append(w, __crypto_add64(s1, s2))
    t = t + 1
  END WHILE
  RETURN w
END FUNC

' SHA-512 / SHA-384 core: process `data` from `iv`, emit `outBytes` digest bytes.
FUNC __crypto_sha2_64(data AS List OF Byte, iv AS List OF Integer, outBytes AS Integer) AS List OF Byte
  LET msg AS List OF Byte = __crypto_pad1024(data)
  MUT h0 AS Integer = collections::get(iv, 0)
  MUT h1 AS Integer = collections::get(iv, 1)
  MUT h2 AS Integer = collections::get(iv, 2)
  MUT h3 AS Integer = collections::get(iv, 3)
  MUT h4 AS Integer = collections::get(iv, 4)
  MUT h5 AS Integer = collections::get(iv, 5)
  MUT h6 AS Integer = collections::get(iv, 6)
  MUT h7 AS Integer = collections::get(iv, 7)
  LET total AS Integer = len(msg)
  MUT base AS Integer = 0
  WHILE base < total
    LET w AS List OF Integer = __crypto_sha512Schedule(msg, base)
    MUT a AS Integer = h0
    MUT b AS Integer = h1
    MUT c AS Integer = h2
    MUT d AS Integer = h3
    MUT e AS Integer = h4
    MUT f AS Integer = h5
    MUT g AS Integer = h6
    MUT h AS Integer = h7
    MUT t AS Integer = 0
    WHILE t < 80
      LET t1a AS Integer = __crypto_add64(h, __crypto_bsig1_64(e))
      LET t1b AS Integer = __crypto_add64(__crypto_ch64(e, f, g), collections::get(__CRYPTO_K512, t))
      LET t1c AS Integer = __crypto_add64(t1b, collections::get(w, t))
      LET t1 AS Integer = __crypto_add64(t1a, t1c)
      LET t2 AS Integer = __crypto_add64(__crypto_bsig0_64(a), __crypto_maj64(a, b, c))
      h = g
      g = f
      f = e
      e = __crypto_add64(d, t1)
      d = c
      c = b
      b = a
      a = __crypto_add64(t1, t2)
      t = t + 1
    END WHILE
    h0 = __crypto_add64(h0, a)
    h1 = __crypto_add64(h1, b)
    h2 = __crypto_add64(h2, c)
    h3 = __crypto_add64(h3, d)
    h4 = __crypto_add64(h4, e)
    h5 = __crypto_add64(h5, f)
    h6 = __crypto_add64(h6, g)
    h7 = __crypto_add64(h7, h)
    base = base + 128
  END WHILE
  MUT digest AS List OF Byte = []
  digest = __crypto_appendBeWord64(digest, h0)
  digest = __crypto_appendBeWord64(digest, h1)
  digest = __crypto_appendBeWord64(digest, h2)
  digest = __crypto_appendBeWord64(digest, h3)
  digest = __crypto_appendBeWord64(digest, h4)
  digest = __crypto_appendBeWord64(digest, h5)
  digest = __crypto_appendBeWord64(digest, h6)
  digest = __crypto_appendBeWord64(digest, h7)
  RETURN __crypto_truncate(digest, outBytes)
END FUNC

FUNC __crypto_sha512_bytes(data AS List OF Byte) AS List OF Byte
  RETURN __crypto_sha2_64(data, __CRYPTO_IV512, 64)
END FUNC

FUNC __crypto_sha512_text(data AS String) AS List OF Byte
  RETURN __crypto_sha2_64(strings::toBytes(data), __CRYPTO_IV512, 64)
END FUNC

FUNC __crypto_sha384_bytes(data AS List OF Byte) AS List OF Byte
  RETURN __crypto_sha2_64(data, __CRYPTO_IV384, 48)
END FUNC

FUNC __crypto_sha384_text(data AS String) AS List OF Byte
  RETURN __crypto_sha2_64(strings::toBytes(data), __CRYPTO_IV384, 48)
END FUNC

' --- HMAC (RFC 2104) -------------------------------------------------------

' XOR every byte of `data` with the constant `pad` (0x36 or 0x5c).
FUNC __crypto_xorPad(data AS List OF Byte, pad AS Integer) AS List OF Byte
  MUT out AS List OF Byte = []
  LET n AS Integer = len(data)
  MUT i AS Integer = 0
  WHILE i < n
    LET b AS Integer = toInt(collections::get(data, i))
    out = collections::append(out, toByte(bits::bxor(b, pad)))
    i = i + 1
  END WHILE
  RETURN out
END FUNC

' Right-pad `data` with zero bytes to `size` bytes.
FUNC __crypto_zeroPad(data AS List OF Byte, size AS Integer) AS List OF Byte
  MUT out AS List OF Byte = __crypto_copyBytes(data)
  WHILE len(out) < size
    out = collections::append(out, toByte(0))
  END WHILE
  RETURN out
END FUNC

' Concatenate two byte lists.
FUNC __crypto_concat(a AS List OF Byte, b AS List OF Byte) AS List OF Byte
  MUT out AS List OF Byte = __crypto_copyBytes(a)
  LET n AS Integer = len(b)
  MUT i AS Integer = 0
  WHILE i < n
    out = collections::append(out, collections::get(b, i))
    i = i + 1
  END WHILE
  RETURN out
END FUNC

' HMAC-SHA-256 over a `List OF Byte` message. Block size 64, digest 32.
FUNC __crypto_hmacSha256_bytes(key AS List OF Byte, data AS List OF Byte) AS List OF Byte
  MUT k AS List OF Byte = key
  IF len(k) > 64 THEN
    k = __crypto_sha256_bytes(k)
  END IF
  k = __crypto_zeroPad(k, 64)
  LET inner AS List OF Byte = __crypto_xorPad(k, 54)
  LET outer AS List OF Byte = __crypto_xorPad(k, 92)
  LET innerHash AS List OF Byte = __crypto_sha256_bytes(__crypto_concat(inner, data))
  RETURN __crypto_sha256_bytes(__crypto_concat(outer, innerHash))
END FUNC

FUNC __crypto_hmacSha256_text(key AS List OF Byte, data AS String) AS List OF Byte
  RETURN __crypto_hmacSha256_bytes(key, strings::toBytes(data))
END FUNC

' HMAC-SHA-512 over a `List OF Byte` message. Block size 128, digest 64.
FUNC __crypto_hmacSha512_bytes(key AS List OF Byte, data AS List OF Byte) AS List OF Byte
  MUT k AS List OF Byte = key
  IF len(k) > 128 THEN
    k = __crypto_sha512_bytes(k)
  END IF
  k = __crypto_zeroPad(k, 128)
  LET inner AS List OF Byte = __crypto_xorPad(k, 54)
  LET outer AS List OF Byte = __crypto_xorPad(k, 92)
  LET innerHash AS List OF Byte = __crypto_sha512_bytes(__crypto_concat(inner, data))
  RETURN __crypto_sha512_bytes(__crypto_concat(outer, innerHash))
END FUNC

FUNC __crypto_hmacSha512_text(key AS List OF Byte, data AS String) AS List OF Byte
  RETURN __crypto_hmacSha512_bytes(key, strings::toBytes(data))
END FUNC

' --- HKDF (RFC 5869) -------------------------------------------------------

' HKDF-Extract + Expand over HMAC-SHA-256 (hashLen 32).
FUNC __crypto_hkdfSha256(ikm AS List OF Byte, salt AS List OF Byte, info AS List OF Byte, length AS Integer) AS List OF Byte
  IF length < 1 OR length > 8160 THEN
    FAIL error(77050002, "hkdf length out of range")
  END IF
  MUT usedSalt AS List OF Byte = salt
  IF len(usedSalt) = 0 THEN
    usedSalt = __crypto_zeroPad([], 32)
  END IF
  LET prk AS List OF Byte = __crypto_hmacSha256_bytes(usedSalt, ikm)
  RETURN __crypto_hkdfExpand256(prk, info, length)
END FUNC

FUNC __crypto_hkdfExpand256(prk AS List OF Byte, info AS List OF Byte, length AS Integer) AS List OF Byte
  MUT okm AS List OF Byte = []
  MUT prev AS List OF Byte = []
  MUT counter AS Integer = 1
  WHILE len(okm) < length
    MUT block AS List OF Byte = __crypto_concat(prev, info)
    block = collections::append(block, toByte(counter))
    prev = __crypto_hmacSha256_bytes(prk, block)
    okm = __crypto_concat(okm, prev)
    counter = counter + 1
  END WHILE
  RETURN __crypto_truncate(okm, length)
END FUNC

' HKDF over HMAC-SHA-512 (hashLen 64).
FUNC __crypto_hkdfSha512(ikm AS List OF Byte, salt AS List OF Byte, info AS List OF Byte, length AS Integer) AS List OF Byte
  IF length < 1 OR length > 16320 THEN
    FAIL error(77050002, "hkdf length out of range")
  END IF
  MUT usedSalt AS List OF Byte = salt
  IF len(usedSalt) = 0 THEN
    usedSalt = __crypto_zeroPad([], 64)
  END IF
  LET prk AS List OF Byte = __crypto_hmacSha512_bytes(usedSalt, ikm)
  RETURN __crypto_hkdfExpand512(prk, info, length)
END FUNC

FUNC __crypto_hkdfExpand512(prk AS List OF Byte, info AS List OF Byte, length AS Integer) AS List OF Byte
  MUT okm AS List OF Byte = []
  MUT prev AS List OF Byte = []
  MUT counter AS Integer = 1
  WHILE len(okm) < length
    MUT block AS List OF Byte = __crypto_concat(prev, info)
    block = collections::append(block, toByte(counter))
    prev = __crypto_hmacSha512_bytes(prk, block)
    okm = __crypto_concat(okm, prev)
    counter = counter + 1
  END WHILE
  RETURN __crypto_truncate(okm, length)
END FUNC

' --- PBKDF2 (RFC 8018) -----------------------------------------------------

' The big-endian 4-byte block index appended to the salt in PBKDF2's F.
FUNC __crypto_be32(value AS Integer) AS List OF Byte
  MUT out AS List OF Byte = []
  out = collections::append(out, toByte(bits::band(bits::sr(value, 24), 255)))
  out = collections::append(out, toByte(bits::band(bits::sr(value, 16), 255)))
  out = collections::append(out, toByte(bits::band(bits::sr(value, 8), 255)))
  out = collections::append(out, toByte(bits::band(value, 255)))
  RETURN out
END FUNC

' XOR two equal-length byte lists.
FUNC __crypto_xorBytes(a AS List OF Byte, b AS List OF Byte) AS List OF Byte
  MUT out AS List OF Byte = []
  LET n AS Integer = len(a)
  MUT i AS Integer = 0
  WHILE i < n
    LET x AS Integer = toInt(collections::get(a, i))
    LET y AS Integer = toInt(collections::get(b, i))
    out = collections::append(out, toByte(bits::bxor(x, y)))
    i = i + 1
  END WHILE
  RETURN out
END FUNC

FUNC __crypto_pbkdf2Block256(password AS List OF Byte, salt AS List OF Byte, iterations AS Integer, index AS Integer) AS List OF Byte
  LET first AS List OF Byte = __crypto_concat(salt, __crypto_be32(index))
  MUT u AS List OF Byte = __crypto_hmacSha256_bytes(password, first)
  MUT result AS List OF Byte = u
  MUT j AS Integer = 1
  WHILE j < iterations
    u = __crypto_hmacSha256_bytes(password, u)
    result = __crypto_xorBytes(result, u)
    j = j + 1
  END WHILE
  RETURN result
END FUNC

FUNC __crypto_pbkdf2Sha256_bytes(password AS List OF Byte, salt AS List OF Byte, iterations AS Integer, length AS Integer) AS List OF Byte
  IF iterations < 1 OR length < 1 THEN
    FAIL error(77050002, "pbkdf2 iterations/length out of range")
  END IF
  MUT okm AS List OF Byte = []
  MUT index AS Integer = 1
  WHILE len(okm) < length
    okm = __crypto_concat(okm, __crypto_pbkdf2Block256(password, salt, iterations, index))
    index = index + 1
  END WHILE
  RETURN __crypto_truncate(okm, length)
END FUNC

FUNC __crypto_pbkdf2Sha256_text(password AS String, salt AS List OF Byte, iterations AS Integer, length AS Integer) AS List OF Byte
  RETURN __crypto_pbkdf2Sha256_bytes(strings::toBytes(password), salt, iterations, length)
END FUNC

FUNC __crypto_pbkdf2Block512(password AS List OF Byte, salt AS List OF Byte, iterations AS Integer, index AS Integer) AS List OF Byte
  LET first AS List OF Byte = __crypto_concat(salt, __crypto_be32(index))
  MUT u AS List OF Byte = __crypto_hmacSha512_bytes(password, first)
  MUT result AS List OF Byte = u
  MUT j AS Integer = 1
  WHILE j < iterations
    u = __crypto_hmacSha512_bytes(password, u)
    result = __crypto_xorBytes(result, u)
    j = j + 1
  END WHILE
  RETURN result
END FUNC

FUNC __crypto_pbkdf2Sha512_bytes(password AS List OF Byte, salt AS List OF Byte, iterations AS Integer, length AS Integer) AS List OF Byte
  IF iterations < 1 OR length < 1 THEN
    FAIL error(77050002, "pbkdf2 iterations/length out of range")
  END IF
  MUT okm AS List OF Byte = []
  MUT index AS Integer = 1
  WHILE len(okm) < length
    okm = __crypto_concat(okm, __crypto_pbkdf2Block512(password, salt, iterations, index))
    index = index + 1
  END WHILE
  RETURN __crypto_truncate(okm, length)
END FUNC

FUNC __crypto_pbkdf2Sha512_text(password AS String, salt AS List OF Byte, iterations AS Integer, length AS Integer) AS List OF Byte
  RETURN __crypto_pbkdf2Sha512_bytes(strings::toBytes(password), salt, iterations, length)
END FUNC

