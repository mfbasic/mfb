/target/
/cmake-build-*/
/tmp/
/temp/
*.ast
*.ir
!tests/**/golden/*.ast
!tests/**/golden/*.ir

# Build output. Every build emits into its project's `build/` directory
# (plan-46-D §4.1): `build/<name>.out`, `build/<name>.app`, and the `vendor/`
# copies an RPATH-bearing build points at. Unanchored, so it covers every
# project at any depth — that fixed directory name is the whole reason the
# output layout is `build/<name>.out` rather than `<name>/<name>.out`.
#
# A binding author's *source* `vendor/` blobs live at `<project>/vendor/`, not
# under `build/`, so they stay tracked.
build/

# Stale pre-plan-46-D artifacts sitting at project roots in existing worktrees.
*.out

# Compiled package artifacts. Rebuilt from source by `mfb build`.
bindings/**/*.mfp

# Packages installed into a consuming project by `mfb pkg install`.
examples/**/packages/

# Local editor and OS files
.DS_Store
*.swp
.claude/
