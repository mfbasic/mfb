{
  "name": "audio",
  "version": "0.1.0",
  "mfb": "1.0",
  "kind": "executable",
  "sources": [
    {
      "root": "src",
      "role": "main",
      "include": ["**/*.mfb"]
    }
  ],
  "resources": [
    { "src": "resources/*.ogg", "dst": "music/" }
  ],
  "entry": "main",
  "targets": ["native"]
}
