{
  "name": "mfbasic",
  "displayName": "MFBASIC",
  "description": "Syntax highlighting, outline, and folding for the MFBASIC language (.mfb).",
  "version": "0.2.0",
  "publisher": "mfbasic",
  "license": "SEE LICENSE IN ../../../LICENSE",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["mfbasic", "mfb", "basic"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:mfbasic"],
  "contributes": {
    "languages": [
      {
        "id": "mfbasic",
        "aliases": ["MFBASIC", "mfbasic"],
        "extensions": [".mfb"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mfbasic",
        "scopeName": "source.mfbasic",
        "path": "./syntaxes/mfbasic.tmLanguage.json"
      }
    ]
  }
}
